        <!-- Search Bar -->
       <form class="d-flex mx-auto" action="/products" method="GET" 
  style="width: 400px; position: relative;" id="searchForm">
  
  <input class="form-control rounded-pill px-4 py-2"
    type="text"
    name="search"
    id="searchInput"
    placeholder="Search cakes..."
    autocomplete="off"
    value="<%= typeof searchQuery !== 'undefined' ? searchQuery : (new URLSearchParams(typeof window !== 'undefined' ? window.location.search : '').get('search') || '') %>"
    style="color:#8B3A52; background-color: rgba(232,160,160,0.18); 
           border: 1.5px solid rgba(139,58,82,0.2); outline: none;
           padding-right: 80px;">

  <!-- Clear button -->
  <button type="button" id="clearBtn"
    style="display:none; position:absolute; right:44px; top:50%; 
           transform:translateY(-50%); background:none; border:none; 
           color:#8B3A52; font-size:1rem; cursor:pointer; padding:0 6px;">
    <i class="fas fa-times"></i>
  </button>

  <!-- Search submit -->
  <button type="submit"
    style="position:absolute; right:4px; top:50%; transform:translateY(-50%);
           background:none; border:none; padding:6px 12px; cursor:pointer;">
    <i class="fas fa-search" style="color:#8B3A52; font-size:1rem;"></i>
  </button>
</form>

<script>
(function () {
  const input    = document.getElementById('searchInput');
  const clearBtn = document.getElementById('clearBtn');
  const form     = document.getElementById('searchForm');

  // ── 1. Preserve search value from URL on page load ──
  const params      = new URLSearchParams(window.location.search);
  const urlSearch   = params.get('search') || '';
  if (urlSearch) {
    input.value          = urlSearch;
    clearBtn.style.display = 'block';
  }

  // ── 2. Show / hide clear button on typing ──
  input.addEventListener('input', () => {
    clearBtn.style.display = input.value.trim() ? 'block' : 'none';
  });

  // ── 3. Clear button ──
  clearBtn.addEventListener('click', () => {
    input.value            = '';
    clearBtn.style.display = 'none';
    input.focus();
    // Also redirect to /products without search param
    window.location.href = '/products';
  });

  // ── 4. Debounce — auto-submit after 500ms of no typing ──
  let debounceTimer;
  input.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    const val = input.value.trim();
    if (val.length === 0) return; // don't auto-submit empty
    debounceTimer = setTimeout(() => {
      form.submit();
    }, 500);
  });

})();
</script>

