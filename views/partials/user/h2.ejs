<!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Lato:wght@400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/cake.css">
<style>
  :root {
    --rose:     #8B4A5A;
    --rose-dk: #8c3535;
    --rose-lt: #f8ece8;
    --cream:   #f3d7d3;
    --ink:     #826e73;
  }

  .main-navbar {
    background: var(--cream);
    height: 72px;
    border-bottom: 1px solid rgba(175,84,84,.15);
    position: sticky;
    top: 0;
    z-index: 1050;
    box-shadow: 0 2px 16px rgba(175,84,84,.10);
  }
  .main-navbar .container-fluid { height: 100%; }

  .nav-brand {
    font-family: 'Playfair Display', serif;
    font-size: 1.55rem;
    font-weight: 900;
    color: var(--rose) !important;
    letter-spacing: -.5px;
    text-decoration: none;
    transition: opacity .2s;
  }
  .nav-brand:hover { opacity: .8; }

  .main-navbar .nav-link {
    font-family: 'Lato', sans-serif;
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--ink) !important;
    padding: 6px 10px !important;
    border-radius: 8px;
    transition: background .2s, color .2s;
  }
  .main-navbar .nav-link:hover {
    color: var(--rose) !important;
    background: rgba(175,84,84,.09);
  }

  /* ── ICON BUTTONS ── */
  .nav-icon-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px; height: 40px;
    border-radius: 50%;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--rose);
    transition: background .2s, transform .2s;
    text-decoration: none;
  }
  .nav-icon-btn:hover {
    background: rgba(175,84,84,.12);
    color: var(--rose-dk);
    transform: scale(1.1);
  }
  .nav-icon-btn svg {
    width: 20px; height: 20px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* ── BADGE ── */
  .nav-badge {
    position: absolute;
    top: 1px; right: 1px;
    min-width: 18px; height: 18px;
    background: var(--rose);
    color: #fff;
    font-family: 'Lato', sans-serif;
    font-size: .62rem;
    font-weight: 700;
    border-radius: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
    border: 2px solid var(--cream);
    pointer-events: none;
    transition: transform .2s;
  }
  /* Hide badge when count is 0 */
  .nav-badge[data-count="0"],
  .nav-badge:empty { display: none; }

  .nav-icon-btn:hover .nav-badge { transform: scale(1.12); }

  /* ── USER DROPDOWN ── */
  .user-toggle {
    font-family: 'Lato', sans-serif;
    font-size: .84rem;
    font-weight: 700;
    color: var(--rose) !important;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 6px 12px;
    border-radius: 20px;
    border: 1.5px solid rgba(175,84,84,.28);
    transition: background .2s;
  }
  .user-toggle:hover { background: rgba(175,84,84,.08); }

  .u-avatar {
    width: 28px; height: 28px;
    background: var(--rose);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: #fff;
    font-size: .75rem;
    font-weight: 900;
  }

  .u-menu {
    border: none !important;
    border-radius: 14px !important;
    box-shadow: 0 12px 40px rgba(175,84,84,.18) !important;
    padding: 8px !important;
    min-width: 165px;
    margin-top: 6px !important;
  }
  .u-menu .dropdown-item {
    border-radius: 9px;
    padding: 9px 14px;
    font-family: 'Lato', sans-serif;
    font-size: .84rem;
    font-weight: 600;
    color: var(--ink);
    display: flex; align-items: center; gap: 8px;
    transition: background .15s, color .15s;
  }
  .u-menu .dropdown-item:hover { background: var(--rose-lt); color: var(--rose); }
  .u-menu .dropdown-item svg { flex-shrink: 0; }
  .u-menu .dropdown-divider { border-color: rgba(175,84,84,.12); margin: 4px 8px; }

  .auth-link {
    font-family: 'Lato', sans-serif;
    font-size: .78rem;
    font-weight: 700;
    letter-spacing: .04em;
    color: var(--rose) !important;
    text-decoration: none;
    padding: 7px 14px;
    border-radius: 20px;
    transition: background .2s;
  }
  .auth-link:hover { background: rgba(175,84,84,.1); }
  .auth-link.signup { background: #8B4A5A; color: #fff !important; }
  .auth-link.signup:hover { background: var(--rose-dk); }
</style>

<nav class="main-navbar navbar navbar-expand-lg">
  <div class="container-fluid px-4 px-lg-5 d-flex justify-content-between align-items-center">

    <!-- Brand -->
    <a class="nav-brand" href="/">Cake O'Clock</a>

    <!-- Nav Links -->
    <ul class="nav gap-1 d-none d-lg-flex">
      <li><a class="nav-link" href="/">Home</a></li>
      <li><a class="nav-link" href="/products">Shop</a></li>
      <li><a class="nav-link" href="#">About Us</a></li>
      <li><a class="nav-link" href="#">Contact Us</a></li>
      <li><a class="nav-link" href="#">Support</a></li>
    </ul>

    <!-- Icons + User -->
    <div class="d-flex align-items-center gap-2">

      <!-- ❤ WISHLIST -->
      <a href="/wishlist" class="nav-icon-btn" title="My Wishlist" aria-label="Wishlist">
        <svg viewBox="0 0 24 24">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
        <%
          // Safely read wishlistCount — works whether it's set or not
          const _wc = locals.wishlistCount || 0;
        %>
        <span
          id="wishlist-count"
          class="nav-badge"
          data-count="<%= _wc %>"
          style="<%= _wc === 0 ? 'display:none' : '' %>"
        ><%= _wc > 0 ? _wc : '' %></span>
      </a>

      <!-- 🛒 CART -->
      <a href="/cart" class="nav-icon-btn" title="My Cart" aria-label="Cart">
        <svg viewBox="0 0 24 24">
          <circle cx="9" cy="21" r="1"/>
          <circle cx="20" cy="21" r="1"/>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
        </svg>
        <%
          const _cc = locals.cartCount || 0;
        %>
<span
  id="cart-count"
  class="nav-badge"
  data-count="<%= _cc %>"
  style="<%= _cc === 0 ? 'display:none' : '' %>"
>
  <%= _cc > 0 ? _cc : '' %>
</span>      </a>

      <!-- User / Auth -->
      <% if (locals.user) { %>
        <div class="dropdown">
          <a class="user-toggle dropdown-toggle" href="#"
             data-bs-toggle="dropdown" aria-expanded="false">
            <div class="u-avatar"><%= locals.user.name.charAt(0).toUpperCase() %></div>
            <%= locals.user.name.split(' ')[0] %>
          </a>
          <ul class="dropdown-menu dropdown-menu-end u-menu">
            <li><a class="dropdown-item" href="/profile">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              My Profile
            </a></li>
            <li><a class="dropdown-item" href="/wishlist">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              Wishlist
            </a></li>
            <li><a class="dropdown-item" href="/cart">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
              My Cart
            </a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="/logout" style="color:#c0392b">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
              Logout
            </a></li>
          </ul>
        </div>
      <% } else { %>
        <a href="/login"  class="auth-link">Log In</a>
        <a href="/signUp" class="auth-link signup">Sign Up</a>
      <% } %>

    </div>
  </div>
</nav>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
/* ════════════════════════════════════════
   LIVE BADGE UPDATER
   Call updateNavBadge('cart-count', 5) or
        updateNavBadge('wishlist-count', 2)
   from any page script after API responses.
════════════════════════════════════════ */
function updateNavBadge(id, count) {
  const badge = document.getElementById(id);
  if (!badge) return;
  const n = Number(count) || 0;
  badge.dataset.count = n;
  if (n > 0) {
    badge.textContent = n;
    badge.style.display = '';
  } else {
    badge.textContent = '';
    badge.style.display = 'none';
  }
}
</script>
