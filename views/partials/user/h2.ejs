<!-- Bootstrap CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Lato:wght@400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
  :root {
    --rose:    #8B4A5A;
    --rose-dk: #6e2f3a;
    --rose-lt: #f8ece8;
    --cream:   #F8CEDD;
    --ink:     #826e73;
  }

  .main-navbar {
    background: var(--cream);
    height: 76px;
    border-bottom: 1px solid rgba(175,84,84,.15);
    position: sticky;
    top: 0;
    z-index: 1050;
    box-shadow: 0 2px 16px rgba(175,84,84,.10);
  }
  .main-navbar .container-fluid { height: 100%; }

  /* ── BRAND ── */
  .nav-brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    transition: opacity .2s;
    flex-shrink: 0;
  }
  .nav-brand:hover { opacity: .85; }
  .nav-brand img {
    height: 58px;
    width: auto;
    object-fit: contain;
    mix-blend-mode: multiply;
  }

  /* ── NAV LINKS ── */
  .main-navbar .nav-link {
    font-family: 'Lato', sans-serif;
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--ink) !important;
    padding: 6px 12px !important;
    border-radius: 8px;
    transition: background .2s, color .2s;
    white-space: nowrap;
  }
  .main-navbar .nav-link:hover {
    color: var(--rose) !important;
    background: rgba(175,84,84,.09);
  }
  .main-navbar .nav-link.active-link {
    color: var(--rose) !important;
    background: rgba(175,84,84,.09);
  }

  /* ── ICON BUTTONS ── */
  .nav-icon-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px; height: 40px;
    border-radius: 50%;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--rose);
    transition: background .2s, transform .2s;
    text-decoration: none;
    flex-shrink: 0;
  }
  .nav-icon-btn:hover {
    background: rgba(175,84,84,.12);
    color: var(--rose-dk);
    transform: scale(1.1);
  }
  .nav-icon-btn svg {
    width: 21px; height: 21px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* Wishlist heart — solid fill look */
  .nav-icon-btn.wishlist-btn svg {
    fill: currentColor;
    stroke: none;
  }

  /* ── BADGE ── */
  .nav-badge {
    position: absolute;
    top: 1px; right: 1px;
    min-width: 17px; height: 17px;
    background: var(--rose-dk);
    color: #fff;
    font-family: 'Lato', sans-serif;
    font-size: .58rem;
    font-weight: 700;
    border-radius: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
    border: 2px solid var(--cream);
    pointer-events: none;
    transition: transform .2s;
  }
  .nav-badge[data-count="0"],
  .nav-badge:empty { display: none; }
  .nav-icon-btn:hover .nav-badge { transform: scale(1.12); }

  /* ── USER DROPDOWN TOGGLE ── */
.user-toggle {
    font-family: 'Lato', sans-serif;
    font-size: .95rem;
    font-weight: 700;
    color: var(--rose) !important;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 4px;
    transition: color .2s;
    white-space: nowrap;
  }
  .user-toggle:hover { color: var(--rose-dk) !important; }
  .user-toggle::after { display: none !important; }

  .u-avatar {
    width: 30px; height: 30px;
    background: linear-gradient(135deg, var(--rose) 0%, var(--rose-dk) 100%);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: #fff;
    font-family: 'Playfair Display', serif;
    font-size: .82rem;
    font-weight: 900;
    flex-shrink: 0;
  }

  .u-caret {
    font-size: .65rem;
    opacity: .6;
    margin-left: 2px;
  }

  /* ── DROPDOWN MENU ── */
.u-menu {
    display: none;
    position: absolute;
    right: 0;
  }
  .u-menu.show {
    display: block;
  }
  .u-menu {
    border: none !important;
    border-radius: 16px !important;
    box-shadow: 0 16px 48px rgba(139,74,90,.18) !important;
    padding: 8px !important;
    min-width: 172px;
    margin-top: 8px !important;
    background: var(--rose-lt) !important;
  }
  .u-menu .dropdown-item {
    border-radius: 10px;
    padding: 12px 16px;
    font-family: 'Lato', sans-serif;
    font-size: .92rem;
    font-weight: 700;
    color: var(--rose);
    transition: background .15s, color .15s;
  }
  .u-menu .dropdown-item:hover { background: #f3dde0; color: var(--rose-dk); }
  .u-menu .dropdown-divider {
    border-color: rgba(175,84,84,.15);
    margin: 4px 8px;
  }
  .u-menu .item-logout { color: var(--rose) !important; }
  .u-menu .item-logout:hover { background: #f3dde0 !important; color: var(--rose-dk) !important; }

  /* ── AUTH LINKS (guest) ── */
  .auth-link {
    font-family: 'Lato', sans-serif;
    font-size: .78rem;
    font-weight: 700;
    letter-spacing: .04em;
    color: var(--rose) !important;
    text-decoration: none !important;
    padding: 8px 16px;
    border-radius: 50px;
    transition: background .2s;
    white-space: nowrap;
  }
  .auth-link:hover { text-decoration: none !important; }
  .auth-link:hover { background: rgba(175,84,84,.1); }
  .auth-link.signup {
    background: var(--rose);
    color: #fff !important;
    box-shadow: 0 4px 14px rgba(139,74,90,.28);
  }
  .auth-link.signup:hover {
    background: var(--rose-dk);
    box-shadow: 0 6px 18px rgba(139,74,90,.36);
  }
</style>

<nav class="main-navbar navbar navbar-expand-lg">
  <div class="container-fluid px-4 px-lg-5 d-flex justify-content-between align-items-center gap-3">

    <!-- ── LOGO ── -->
    <a class="nav-brand" href="/">
      <img
        src="https://res.cloudinary.com/dtfzp8rwt/image/upload/v1780840131/WhatsApp_Image_2026-06-07_at_4.24.57_PM-removebg-preview_cmrltl.png"
        alt="Cake O'Clock">
    </a>

    <!-- ── NAV LINKS ── -->
    <ul class="nav gap-1 d-none d-lg-flex position-absolute start-50 translate-middle-x">
        <li><a class="nav-link" href="/">Home</a></li>
      <li><a class="nav-link" href="/products">Shop</a></li>
      <li><a class="nav-link" href="/about">About Us</a></li>
      <li><a class="nav-link" href="/contact-us">Contact Us</a></li>
      <li><a class="nav-link" href="/customer-support">Support</a></li>
    </ul>

    <!-- ── ICONS + USER ── -->
    <div class="d-flex align-items-center gap-2" style="flex-shrink:0;">

      <!-- WISHLIST -->
      <a href="/wishlist" class="nav-icon-btn wishlist-btn" title="My Wishlist" aria-label="Wishlist">
        <svg viewBox="0 0 24 24">
          <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
        </svg>
        <% const _wc = locals.wishlistCount || 0; %>
        <span id="wishlist-count" class="nav-badge"
          data-count="<%= _wc %>"
          style="<%= _wc === 0 ? 'display:none' : '' %>">
          <%= _wc > 0 ? _wc : '' %>
        </span>
      </a>

      <!-- CART -->
      <a href="/cart" class="nav-icon-btn" title="My Cart" aria-label="Cart">
        <svg viewBox="0 0 24 24">
          <circle cx="9" cy="21" r="1"/>
          <circle cx="20" cy="21" r="1"/>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
        </svg>
        <% const _cc = locals.cartCount || 0; %>
        <span id="cart-count" class="nav-badge"
          data-count="<%= _cc %>"
          style="<%= _cc === 0 ? 'display:none' : '' %>">
          <%= _cc > 0 ? _cc : '' %>
        </span>
      </a>

      <!-- ── USER / AUTH ── -->
      <% if (locals.user) { %>
        <div class="dropdown">
  <a class="user-toggle" href="#"
     data-bs-toggle="dropdown"
     aria-expanded="false">
    <%= locals.user.name %>
    <i class="fas fa-chevron-down u-caret"></i>
  </a>
          <ul class="dropdown-menu dropdown-menu-end u-menu">
  <li>
    <a class="dropdown-item" href="/profile">Profile</a>
  </li>
  <li><hr class="dropdown-divider"></li>
  <li>
    <a class="dropdown-item item-logout" href="/logout">Logout</a>
  </li>
</ul>
        </div>

      <% } else { %>
        <a href="/login"  class="auth-link">Log In</a>
        <a href="/signUp" class="auth-link signup">Sign Up</a>
      <% } %>

    </div>
  </div>
</nav>

<script>
(function () {
  document.querySelectorAll('.user-toggle[data-bs-toggle="dropdown"]').forEach(function (toggle) {
    var wrapper = toggle.closest('.dropdown');
    var menu = wrapper.querySelector('.dropdown-menu');
    if (!menu) return;

    toggle.removeAttribute('data-bs-toggle');

    toggle.addEventListener('click', function (e) {
      e.preventDefault();
      e.stopPropagation();
      var isOpen = menu.classList.contains('show');
      document.querySelectorAll('.u-menu.show').forEach(function (m) { m.classList.remove('show'); });
      if (!isOpen) menu.classList.add('show');
    });

    document.addEventListener('click', function (e) {
      if (!wrapper.contains(e.target)) menu.classList.remove('show');
    });
  });
})();
</script><script>
/* ── LIVE BADGE UPDATER ── */
function updateNavBadge(id, count) {
  const badge = document.getElementById(id);
  if (!badge) return;
  const n = Number(count) || 0;
  badge.dataset.count = n;
  if (n > 0) {
    badge.textContent = n;
    badge.style.display = '';
  } else {
    badge.textContent = '';
    badge.style.display = 'none';
  }
}

/* ── ACTIVE NAV LINK ── */
(function () {
  const links = document.querySelectorAll('.main-navbar .nav-link');
  const path  = window.location.pathname;
  links.forEach(link => {
    if (link.getAttribute('href') === path) {
      link.classList.add('active-link');
    }
  });
})();
</script>