<style>
  :root {
    --rose:    #8B4A5A;
    --rose-dk: #6e3547;
    --rose-lt: #fdf0f5;
    --blush:   #f3d7d3;
    --cream:   #fff8f9;
    --ink:     #4A3B32;
    --muted:   #a07085;
  }

  /* ── SIDEBAR SHELL ── */
  .sidebar-nav {
    background: linear-gradient(180deg, #fff5f7 0%, #ffeef3 100%);
    border-radius: 20px;
    padding: 20px 14px 28px;
    border: 1px solid #f0c4d4;
    box-shadow: 0 4px 24px rgba(139,74,90,.08);
    position: sticky;
    top: 100px;
  }

  /* ── BRAND ── */
  .sidebar-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 10px 20px;
    margin-bottom: 8px;
    border-bottom: 1.5px solid #f0c4d4;
    animation: sideDown .4s ease both;
  }

  .sidebar-brand-icon {
    width: 38px; height: 38px;
    background: linear-gradient(135deg, var(--rose) 0%, var(--rose-dk) 100%);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    color: #fff;
    font-size: .95rem;
    box-shadow: 0 4px 12px rgba(139,74,90,.28);
    flex-shrink: 0;
  }

  .sidebar-brand-text {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--rose);
    line-height: 1.2;
  }

  .sidebar-brand-sub {
    font-size: .68rem;
    color: var(--muted);
    font-family: 'Lato', sans-serif;
    font-weight: 600;
    letter-spacing: .04em;
  }

  /* ── SECTION LABEL ── */
  .sidebar-section-label {
    font-family: 'Lato', sans-serif;
    font-size: .62rem;
    font-weight: 800;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 14px 12px 6px;
    opacity: 0;
    animation: sideDown .4s ease .1s both;
  }

  /* ── MENU ITEM ── */
  .menu-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    margin-bottom: 4px;
    border-radius: 14px;
    color: var(--ink);
    text-decoration: none;
    font-family: 'Lato', sans-serif;
    font-size: .88rem;
    font-weight: 600;
    cursor: pointer;
    position: relative;
    transition: background .2s, color .2s, transform .2s, box-shadow .2s;
    opacity: 0;
    animation: sideItem .4s ease both;
  }

  .menu-item:nth-child(1)  { animation-delay: .12s; }
  .menu-item:nth-child(2)  { animation-delay: .18s; }
  .menu-item:nth-child(3)  { animation-delay: .24s; }
  .menu-item:nth-child(4)  { animation-delay: .30s; }
  .menu-item:nth-child(5)  { animation-delay: .36s; }
  .menu-item:nth-child(6)  { animation-delay: .42s; }

  @keyframes sideItem {
    from { opacity: 0; transform: translateX(-16px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  @keyframes sideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── ICON WRAP ── */
  .menu-icon {
    width: 36px; height: 36px;
    border-radius: 10px;
    background: transparent;
    display: flex; align-items: center; justify-content: center;
    font-size: .9rem;
    color: var(--muted);
    flex-shrink: 0;
    transition: background .2s, color .2s, transform .2s;
  }

  /* ── HOVER ── */
  .menu-item:hover {
    background: rgba(139,74,90,.07);
    color: var(--rose);
    transform: translateX(4px);
  }

  .menu-item:hover .menu-icon {
    background: var(--rose-lt);
    color: var(--rose);
    transform: scale(1.1);
  }

  /* ── ACTIVE ── */
  .menu-item.active {
    background: linear-gradient(135deg, var(--rose) 0%, var(--rose-dk) 100%);
    color: #fff !important;
    box-shadow: 0 6px 20px rgba(139,74,90,.28);
    transform: translateX(4px);
  }

  .menu-item.active .menu-icon {
    background: rgba(255,255,255,.2);
    color: #fff;
  }

  /* Active indicator dot */
  .menu-item.active::before {
    content: '';
    position: absolute;
    left: -14px;
    top: 50%; transform: translateY(-50%);
    width: 4px; height: 24px;
    background: var(--rose);
    border-radius: 0 4px 4px 0;
  }

  /* ── DIVIDER ── */
  .sidebar-divider {
    height: 1px;
    background: #f0c4d4;
    margin: 10px 8px;
    opacity: 0;
    animation: sideDown .4s ease .38s both;
  }

  /* ── LOGOUT ── */
  .menu-item.logout-item:hover {
    background: rgba(192,57,43,.08);
    color: #c0392b;
  }

  .menu-item.logout-item:hover .menu-icon {
    background: #fff0f0;
    color: #c0392b;
  }
</style>

<nav class="sidebar-nav">

  <!-- Brand -->
  <div class="sidebar-brand">
    <div class="sidebar-brand-icon">
      <i class="fas fa-cake-candles"></i>
    </div>
    <div>
      <div class="sidebar-brand-text">My Account</div>
      <div class="sidebar-brand-sub">Cake O'Clock</div>
    </div>
  </div>

  <!-- Section -->
  <div class="sidebar-section-label">Account</div>

  <a href="/profile" class="menu-item">
    <div class="menu-icon"><i class="fas fa-user"></i></div>
    Profile Information
  </a>

  <a href="/profile/address" class="menu-item">
    <div class="menu-icon"><i class="fas fa-location-dot"></i></div>
    Manage Address
  </a>

  <a href="/orders" class="menu-item">
    <div class="menu-icon"><i class="fas fa-bag-shopping"></i></div>
    My Orders
  </a>

  <a href="/wallet" class="menu-item">
    <div class="menu-icon"><i class="fas fa-wallet"></i></div>
    Wallet
  </a>

  <a href="/my-messages" class="menu-item">
  <div class="menu-icon"><i class="fas fa-envelope-open-text"></i></div>
  My Messages
</a>

  <div class="sidebar-divider"></div>

  <div class="sidebar-section-label">Settings</div>

  <a href="/changePassword" class="menu-item">
    <div class="menu-icon"><i class="fas fa-shield-halved"></i></div>
    Privacy Settings
  </a>

  <div class="sidebar-divider"></div>

  <a href="/logout" class="menu-item logout-item">
    <div class="menu-icon"><i class="fas fa-right-from-bracket"></i></div>
    Logout
  </a>

</nav>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const currentPath = window.location.pathname;
  const menuItems   = document.querySelectorAll('.menu-item');

  let bestMatch = null;
  let maxLen    = 0;

  menuItems.forEach(item => {
    const href = item.getAttribute('href');
    if (!href || href === '#') return;
    if (currentPath === href ||
       (currentPath.startsWith(href) && href !== '/')) {
      if (href.length > maxLen) {
        maxLen    = href.length;
        bestMatch = item;
      }
    }
  });

  if (bestMatch) {
    menuItems.forEach(i => i.classList.remove('active'));
    bestMatch.classList.add('active');
  }

  menuItems.forEach(item => {
    item.addEventListener('click', function () {
      menuItems.forEach(i => i.classList.remove('active'));
      this.classList.add('active');
    });
  });
});
</script>