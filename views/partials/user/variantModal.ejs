<!-- ══════════════════════════════════
     VARIANT MODAL — standalone partial
     Save as: views/partials/user/variantModal.ejs
════════════════════════════════════ -->

<style>
  .swal-custom-popup  { border-radius: 20px !important; padding: 32px 24px !important; }
  .swal-custom-btn    { border-radius: 12px !important; padding: 10px 36px !important; font-weight: 700 !important; font-size: .92rem !important; }
</style>

<div class="modal fade" id="variantModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" style="max-width:420px;">
    <div class="modal-content" style="border-radius:20px;border:none;overflow:hidden;">

      <!-- Header -->
      <div class="modal-header" style="background:#8b3a52;border:none;padding:18px 24px;">
        <div>
          <h5 class="modal-title"
              style="color:#fff;font-family:'Playfair Display',serif;font-size:1.1rem;margin:0;">
            Choose Variant
          </h5>
          <p id="vm-name-price"
             style="color:rgba(255,255,255,.75);font-size:.78rem;margin:3px 0 0;"></p>
        </div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>

      <!-- Body -->
      <div class="modal-body" style="padding:20px 24px;">
        <div id="vm-variants" style="display:flex;flex-direction:column;gap:8px;"></div>

        <!-- Price display -->
        <div style="margin-top:16px;padding-top:14px;border-top:1px solid #f0e8e8;
                    display:flex;justify-content:space-between;align-items:center;">
          <span style="font-size:.82rem;color:#9a7070;font-weight:600;">Total</span>
          <span id="vm-price-display"
                style="font-size:1.3rem;font-weight:800;color:#8b3a52;
                       font-family:'Playfair Display',serif;">₹0.00</span>
        </div>
      </div>

      <!-- Footer -->
      <div class="modal-footer" style="border:none;padding:0 24px 22px;gap:10px;">
        <button type="button" data-bs-dismiss="modal"
                style="flex:1;padding:11px;border:1.5px solid #ddd;border-radius:12px;
                       background:#fff;color:#8b3a52;font-weight:700;font-size:.85rem;cursor:pointer;">
          Cancel
        </button>
        <button type="button" id="vm-confirm-btn" onclick="confirmAddToCart()"
                style="flex:2;padding:11px;border:none;border-radius:12px;
                       background:linear-gradient(135deg,#8b3a52,#d97f9a);
                       color:#fff;font-weight:700;font-size:.85rem;cursor:pointer;
                       box-shadow:0 4px 14px rgba(175,84,84,.35);">
          🛒 Add to Cart
        </button>
      </div>

    </div>
  </div>
</div>
<script>
  // ─── State ───────────────────────────────────────────────────────────────────
  let _vmProduct = null;

  // ─── Swal title helper ────────────────────────────────────────────────────────
  // Wraps any title string in Dancing Script styling
  function swalTitle(text) {
    return `<span style="font-family:'Dancing Script',cursive;font-size:1.75rem;color:#3a1a1a;">${text}</span>`;
  }

  // ─── openVariantModal ────────────────────────────────────────────────────────
  function openVariantModal(product) {
    _vmProduct = product;

    document.getElementById('vm-name-price').textContent = product.name || '';

    const container = document.getElementById('vm-variants');
    container.innerHTML = '';

    const allOutOfStock    = product.variants.every(v => Number(v.stock) === 0);
    const firstAvailableIdx = product.variants.findIndex(v => Number(v.stock) > 0);

    product.variants.forEach((v, i) => {
      const outOfStock    = Number(v.stock) === 0;
      const isPreSelected = i === firstAvailableIdx;

      const label = document.createElement('label');
      label.style.cssText = `
        display:flex; align-items:center; justify-content:space-between;
        padding:10px 14px; border-radius:12px;
        cursor:${outOfStock ? 'not-allowed' : 'pointer'};
        border:1.5px solid ${isPreSelected ? '#8b3a52' : outOfStock ? '#f0e8e8' : '#e8d5d5'};
        background:${isPreSelected ? '#fdf5f7' : outOfStock ? '#fafafa' : '#fff'};
        opacity:${outOfStock ? '0.52' : '1'};
        transition:border-color .18s, background .18s;
        user-select:none;
      `;

      label.innerHTML = `
        <div style="display:flex;align-items:center;gap:10px;">
          <input
            type="radio"
            name="vm-variant"
            value="${v._id}"
            data-price="${v.price}"
            data-stock="${v.stock}"
            ${outOfStock ? 'disabled' : ''}
            ${isPreSelected ? 'checked' : ''}
            style="accent-color:#8b3a52;width:16px;height:16px;
                   cursor:${outOfStock ? 'not-allowed' : 'pointer'};"
            onchange="vmUpdatePrice(this)"
          >
          <div>
            <span style="font-size:.88rem;font-weight:600;
                         color:${outOfStock ? '#aaa' : '#3a1a1a'};">
              ${v.size || v.label || ('Variant ' + (i + 1))}
            </span>
            ${outOfStock
              ? `<span style="display:block;font-size:.72rem;color:#e07070;
                              font-weight:600;margin-top:2px;">Out of Stock</span>`
              : `<span style="display:block;font-size:.72rem;color:#5aaa60;
                              font-weight:500;margin-top:2px;">${v.stock} in stock</span>`
            }
          </div>
        </div>
        <span style="font-size:.9rem;font-weight:700;
                     color:${outOfStock ? '#bbb' : '#8b3a52'};">
          ₹${Number(v.price).toFixed(2)}
        </span>
      `;

      if (!outOfStock) {
        label.addEventListener('mouseenter', () => {
          label.style.borderColor = '#8b3a52';
          label.style.background  = '#fdf5f7';
        });
        label.addEventListener('mouseleave', () => {
          const inp = label.querySelector('input[type=radio]');
          label.style.borderColor = inp.checked ? '#8b3a52' : '#e8d5d5';
          label.style.background  = inp.checked ? '#fdf5f7' : '#fff';
        });
      }

      container.appendChild(label);
    });

    const firstChecked = container.querySelector('input[type=radio]:checked');
    document.getElementById('vm-price-display').textContent =
      firstChecked ? '₹' + Number(firstChecked.dataset.price).toFixed(2) : '₹0.00';

    bootstrap.Modal.getOrCreateInstance(document.getElementById('variantModal')).show();

    // All out of stock — fire Swal after modal opens
    if (allOutOfStock) {
      setTimeout(() => {
        Swal.fire({
          icon: 'error',
          iconColor: '#c97a4a',
          title: swalTitle('Out of Stock'),          
          html: '<p style="color:#6b4c4c;font-size:.92rem;margin:0;">All variants of this product are currently out of stock.</p>',
          confirmButtonText: 'OK',
          confirmButtonColor: '#8b3a52',
          customClass: { popup: 'swal-custom-popup', confirmButton: 'swal-custom-btn' }
        });
      }, 350);
    }
  }


  // ─── vmUpdatePrice ────────────────────────────────────────────────────────────
  function vmUpdatePrice(radio) {
    document.getElementById('vm-price-display').textContent =
      '₹' + Number(radio.dataset.price).toFixed(2);

    document.querySelectorAll('#vm-variants label').forEach(lbl => {
      const inp = lbl.querySelector('input[type=radio]');
      if (!inp.disabled) {
        lbl.style.borderColor = inp.checked ? '#8b3a52' : '#e8d5d5';
        lbl.style.background  = inp.checked ? '#fdf5f7' : '#fff';
      }
    });
  }


  // ─── confirmAddToCart ─────────────────────────────────────────────────────────
  function confirmAddToCart() {

    const selected = document.querySelector('#vm-variants input[type=radio]:checked');

    // Guard 1 — nothing selected
    if (!selected) {
      Swal.fire({
        icon: 'warning',
        iconColor: '#c97a4a',
        title: swalTitle('Select a Variant'),         // ← Dancing Script
        html: '<p style="color:#6b4c4c;font-size:.92rem;margin:0;">Please choose an available variant before adding to cart.</p>',
        confirmButtonText: 'OK',
        confirmButtonColor: '#8b3a52',
        customClass: { popup: 'swal-custom-popup', confirmButton: 'swal-custom-btn' }
      });
      return;
    }

    // Guard 2 — selected variant is out of stock
    if (Number(selected.dataset.stock) === 0) {
    Swal.fire({
  icon: 'error',
  iconColor: '#c97a4a',
  title: swalTitle('Item Unavailable'),   
  html: '<p style="color:#6b4c4c;font-size:.92rem;margin:0;">This variant is currently unavailable.</p>',  // ← change body here
  confirmButtonText: 'OK',
  confirmButtonColor: '#8b3a52',
  customClass: { popup: 'swal-custom-popup', confirmButton: 'swal-custom-btn' }
});
      return;
    }

    // ✅ All clear — proceed
    const variantId = selected.value;
    const price     = Number(selected.dataset.price);
    const productId = _vmProduct._id;

    bootstrap.Modal.getInstance(document.getElementById('variantModal'))?.hide();

    // TODO: replace with your real cart call
    // addToCart(productId, variantId);
    console.log('Cart →', { productId, variantId, price });

    Swal.fire({
      icon: 'success',
      title: swalTitle('Added to Cart!'),             // ← Dancing Script
      html: `<p style="color:#6b4c4c;font-size:.92rem;margin:0;">${_vmProduct.name} has been added to your cart.</p>`,
      timer: 2000,
      timerProgressBar: true,
      showConfirmButton: false,
      customClass: { popup: 'swal-custom-popup' }
    });
  }
</script>