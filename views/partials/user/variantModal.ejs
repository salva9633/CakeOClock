<style>
  .swal-custom-popup { border-radius: 20px !important; padding: 32px 24px !important; }
  .swal-custom-btn   { border-radius: 12px !important; padding: 10px 36px !important; font-weight: 700 !important; font-size: .92rem !important; }

  #variantModal .modal-content {
    border-radius: 22px;
    border: none;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(139,58,82,.22), 0 4px 16px rgba(0,0,0,.10);
    animation: vmSlideUp .28s cubic-bezier(.34,1.56,.64,1) both;
  }
  @keyframes vmSlideUp {
    from { opacity: 0; transform: translateY(32px) scale(.97); }
    to   { opacity: 1; transform: translateY(0)   scale(1);   }
  }

  .vm-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    border-radius: 14px;
    border: 1.5px solid #edd5dd;
    background: #fff;
    cursor: pointer;
    transition: border-color .18s, background .18s, transform .14s;
    user-select: none;
    gap: 10px;
  }
  .vm-row:hover:not(.vm-row-oos) {
    border-color: #8b3a52;
    background: #fdf5f7;
    transform: translateY(-1px);
  }
  .vm-row.vm-selected {
    border-color: #8b3a52;
    background: #fdf5f7;
  }
  .vm-row.vm-row-oos {
    opacity: .48;
    cursor: not-allowed;
    background: #fafafa;
    border-color: #f0e8e8;
  }

  .vm-radio {
    width: 18px; height: 18px;
    border-radius: 50%;
    border: 2px solid #d0b0bc;
    background: #fff;
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    transition: border-color .18s, background .18s;
  }
  .vm-radio.vm-radio-on {
    border-color: #8b3a52;
    background: #8b3a52;
  }
  .vm-radio.vm-radio-on::after {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #fff;
  }

  .vm-price-block {
    display: flex;
    flex-direction: row;
    align-items: baseline;
    gap: 6px;
    flex-shrink: 0;
  }
  .vm-price-old {
    font-size: .72rem;
    color: #bba0a8;
    text-decoration: line-through;
    white-space: nowrap;
  }
  .vm-price-now {
    font-size: .98rem;
    font-weight: 700;
    white-space: nowrap;
  }
  .vm-off-pill {
    font-size: .62rem;
    font-weight: 700;
    color: #fff;
    background: #5aaa60;
    border-radius: 20px;
    padding: 2px 7px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .vm-confirm-btn {
    flex: 2;
    padding: 12px;
    border: none;
    border-radius: 13px;
    background: #8b3a52;
    color: #fff;
    font-weight: 700;
    font-size: .88rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    transition: background .18s, transform .14s, box-shadow .18s;
    box-shadow: 0 4px 14px rgba(139,58,82,.30);
  }
  .vm-confirm-btn:hover {
    background: #a84465;
    transform: translateY(-1px);
    box-shadow: 0 8px 22px rgba(139,58,82,.38);
  }
  .vm-confirm-btn:active { transform: scale(.97); }
  .vm-confirm-btn:disabled { opacity: .6; cursor: not-allowed; transform: none; }

  .vm-cancel-btn {
    flex: 1;
    padding: 12px;
    border: 1.5px solid #e0ccd3;
    border-radius: 13px;
    background: #fff;
    color: #8b3a52;
    font-weight: 700;
    font-size: .88rem;
    cursor: pointer;
    transition: background .18s, border-color .18s;
  }
  .vm-cancel-btn:hover { background: #fdf5f7; border-color: #c9a0b0; }
</style>

<div class="modal fade" id="variantModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" style="max-width:430px;">
    <div class="modal-content">

      <!-- Header -->
      <div style="background:linear-gradient(135deg,#8b3a52 0%,#b85c78 100%);padding:20px 24px 18px;">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;">
          <div>
            <p style="color:rgba(255,255,255,.6);font-size:.62rem;letter-spacing:.14em;
                      text-transform:uppercase;margin:0 0 5px;">Choose Variant</p>
            <h5 id="vm-name-price"
                style="color:#fff;font-family:'Playfair Display',serif;
                       font-size:1.05rem;font-weight:700;margin:0;line-height:1.3;"></h5>
          </div>
          <button type="button" data-bs-dismiss="modal"
                  style="background:rgba(255,255,255,.15);border:none;color:#fff;
                         width:30px;height:30px;border-radius:50%;font-size:.85rem;
                         cursor:pointer;display:flex;align-items:center;justify-content:center;
                         flex-shrink:0;transition:background .18s;line-height:1;"
                  onmouseenter="this.style.background='rgba(255,255,255,.28)'"
                  onmouseleave="this.style.background='rgba(255,255,255,.15)'"><i class="fas fa-xmark"></i></button>
        </div>
      </div>

      <!-- Body -->
      <div style="padding:18px 20px 8px;">
        <div id="vm-variants" style="display:flex;flex-direction:column;gap:9px;"></div>
      </div>

      <!-- Footer -->
      <div style="padding:14px 20px 20px;display:flex;gap:10px;">
        <button type="button" data-bs-dismiss="modal" class="vm-cancel-btn">Cancel</button>
        <button type="button" id="vm-confirm-btn" class="vm-confirm-btn" onclick="confirmAddToCart()">
          <i class="fas fa-cart-shopping"></i> Add to Cart
        </button>
      </div>

    </div>
  </div>
</div>

<script>
  let _vmProduct = null;

  function swalTitle(text) {
    return `<span style="font-family:'Dancing Script',cursive;font-size:1.75rem;color:#3a1a1a;">${text}</span>`;
  }

  function formatWeight(w) {
    w = Number(w);
    if (w >= 1000) { const kg = w / 1000; return (kg % 1 === 0 ? kg : kg.toFixed(1)) + 'kg'; }
    return w + 'g';
  }

  function openVariantModal(product) {
    _vmProduct = product;
    document.getElementById('vm-name-price').textContent = product.name || '';

    const container = document.getElementById('vm-variants');
    container.innerHTML = '';

    const allOos       = product.variants.every(v => Number(v.stock) === 0);
    const firstIdx     = product.variants.findIndex(v => Number(v.stock) > 0);

    product.variants.forEach((v, i) => {
      const oos        = Number(v.stock) === 0;
      const preSelected = i === firstIdx && !oos;
      const hasDiscount = v.regularPrice && Number(v.regularPrice) > Number(v.price);
      const discPct     = hasDiscount
        ? Math.round(((Number(v.regularPrice) - Number(v.price)) / Number(v.regularPrice)) * 100)
        : 0;

      const row = document.createElement('div');
      row.className = 'vm-row' + (oos ? ' vm-row-oos' : '') + (preSelected ? ' vm-selected' : '');

      // LEFT — radio + label
      const left = document.createElement('div');
      left.style.cssText = 'display:flex;align-items:center;gap:11px;flex:1;min-width:0;';

      const radioDot = document.createElement('div');
      radioDot.className = 'vm-radio' + (preSelected ? ' vm-radio-on' : '');

      const info = document.createElement('div');
      info.innerHTML = `
        <span style="font-size:.88rem;font-weight:700;color:${oos ? '#aaa' : '#2b1515'};">
          ${v.weight ? formatWeight(v.weight) : v.size || v.label || ('Variant ' + (i + 1))}
        </span>
        ${oos
          ? `<span style="display:block;font-size:.7rem;color:#e07070;font-weight:600;margin-top:2px;">Out of Stock</span>`
          : `<span style="display:block;font-size:.7rem;color:#5aaa60;font-weight:500;margin-top:2px;">${v.stock} in stock</span>`
        }`;

      // Hidden radio
      const radio = document.createElement('input');
      radio.type = 'radio'; radio.name = 'vm-variant'; radio.value = v._id;
      radio.dataset.price = v.price; radio.dataset.stock = v.stock;
      radio.style.display = 'none';
      if (oos) radio.disabled = true;
      if (preSelected) radio.checked = true;

      left.appendChild(radioDot);
      left.appendChild(info);
      left.appendChild(radio);

      // RIGHT — price block (all on one line)
      const priceBlock = document.createElement('div');
      priceBlock.className = 'vm-price-block';

      if (hasDiscount) {
        priceBlock.innerHTML = `
          <span class="vm-price-old">₹${Number(v.regularPrice).toFixed(0)}</span>
          <span class="vm-price-now" style="color:${oos ? '#bbb' : '#8b3a52'};">₹${Number(v.price).toFixed(0)}</span>
          ${discPct > 0 ? `<span class="vm-off-pill">${discPct}% off</span>` : ''}
        `;
      } else {
        priceBlock.innerHTML = `
          <span class="vm-price-now" style="color:${oos ? '#bbb' : '#8b3a52'};">₹${Number(v.price).toFixed(0)}</span>
        `;
      }

      row.appendChild(left);
      row.appendChild(priceBlock);

      // Click to select
      if (!oos) {
        row.addEventListener('click', () => {
          // deselect all
          container.querySelectorAll('.vm-row').forEach(r => {
            r.classList.remove('vm-selected');
            const dot = r.querySelector('.vm-radio');
            if (dot) { dot.classList.remove('vm-radio-on'); }
            const inp = r.querySelector('input[type=radio]');
            if (inp) inp.checked = false;
          });
          // select this
          row.classList.add('vm-selected');
          radioDot.classList.add('vm-radio-on');
          radio.checked = true;
        });
      }

      container.appendChild(row);
    });

    bootstrap.Modal.getOrCreateInstance(document.getElementById('variantModal')).show();

    if (allOos) {
      setTimeout(() => {
        Swal.fire({
          icon: 'error', iconColor: '#c97a4a',
          title: swalTitle('Out of Stock'),
          html: '<p style="color:#6b4c4c;font-size:.92rem;margin:0;">All variants of this product are currently out of stock.</p>',
          confirmButtonText: 'OK', confirmButtonColor: '#8b3a52',
          customClass: { popup: 'swal-custom-popup', confirmButton: 'swal-custom-btn' }
        });
      }, 350);
    }
  }

  async function confirmAddToCart() {
    const selected = document.querySelector('#vm-variants input[type=radio]:checked');

    if (!selected) {
      Swal.fire({
        icon: 'warning', iconColor: '#c97a4a',
        title: swalTitle('Select a Variant'),
        html: '<p style="color:#6b4c4c;font-size:.92rem;margin:0;">Please choose an available variant before adding to cart.</p>',
        confirmButtonText: 'OK', confirmButtonColor: '#8b3a52',
        customClass: { popup: 'swal-custom-popup', confirmButton: 'swal-custom-btn' }
      });
      return;
    }

    const btn = document.getElementById('vm-confirm-btn');
    btn.disabled = true; btn.textContent = 'Adding…';

    bootstrap.Modal.getInstance(document.getElementById('variantModal'))?.hide();

    try {
      const res  = await fetch('/cart/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ productId: _vmProduct._id, variantId: selected.value, quantity: 1 })
      });
      const data = await res.json();

      if (data.success) {
        if (typeof data.cartCount !== 'undefined') updateNavBadge('cart-count', data.cartCount);
        Swal.fire({
          icon: 'success',
          title: swalTitle('Added to Cart!'),
          html: `<p style="color:#6b4c4c;font-size:.92rem;margin:0;">${_vmProduct.name} has been added to your cart.</p>`,
          timer: 2000, timerProgressBar: true, showConfirmButton: false,
          customClass: { popup: 'swal-custom-popup' }
        });
      } else {
        Swal.fire({
          icon: 'warning', title: swalTitle('Cannot Add'),
          html: `<p style="color:#6b4c4c;font-size:.92rem;margin:0;">${data.message || 'Something went wrong.'}</p>`,
          confirmButtonColor: '#8b3a52',
          customClass: { popup: 'swal-custom-popup', confirmButton: 'swal-custom-btn' }
        });
      }
    } catch {
      Swal.fire({
        icon: 'error', title: swalTitle('Network Error'),
        html: '<p style="color:#6b4c4c;font-size:.92rem;margin:0;">Please try again.</p>',
        confirmButtonColor: '#8b3a52',
        customClass: { popup: 'swal-custom-popup', confirmButton: 'swal-custom-btn' }
      });
   } finally {
      btn.disabled = false; btn.innerHTML = '<i class="fas fa-cart-shopping"></i> Add to Cart';
    }
  }
</script>
