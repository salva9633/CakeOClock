<style>
/* ── Keyframes ── */
@keyframes ftFadeUp {
  from { opacity: 0; transform: translateY(28px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes ftPulse {
  0%, 100% { opacity: 0.4; transform: scale(1); }
  50%       { opacity: 0.7; transform: scale(1.08); }
}
@keyframes ftFloat {
  0%, 100% { transform: translateY(0px); }
  50%       { transform: translateY(-8px); }
}
@keyframes ftShimmer {
  0%   { background-position: -200% center; }
  100% { background-position: 200% center; }
}
@keyframes ftSpin {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}

/* ── Column entrance ── */
.ft-col {
  opacity: 0;
  animation: ftFadeUp .7s cubic-bezier(.22,1,.36,1) both;
}
.ft-col:nth-child(1) { animation-delay: .1s; }
.ft-col:nth-child(2) { animation-delay: .22s; }
.ft-col:nth-child(3) { animation-delay: .34s; }
.ft-col:nth-child(4) { animation-delay: .46s; }

/* ── Brand title shimmer ── */
.ft-brand-title {
  background: linear-gradient(90deg, #fff 30%, #ffe0e8 50%, #fff 70%);
  background-size: 200% auto;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: ftShimmer 4s linear infinite;
  display: inline-block;
}
.ft-brand-em {
  background: linear-gradient(90deg, #ffd6e0 20%, #fff 50%, #ffd6e0 80%);
  background-size: 200% auto;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: ftShimmer 3s linear infinite reverse;
  font-style: italic;
}

/* ── Decorative blobs ── */
.ft-blob {
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
  filter: blur(60px);
  animation: ftPulse 6s ease-in-out infinite;
}

/* ── Social buttons ── */
.ft-soc-btn {
  width: 38px; height: 38px; border-radius: 50%;
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.22);
  display: flex; align-items: center; justify-content: center;
  color: #fff; text-decoration: none; font-size: .9rem;
  transition: background .25s, transform .25s, box-shadow .25s;
}
.ft-soc-btn:hover {
  background: rgba(255,255,255,0.28) !important;
  transform: translateY(-4px) scale(1.1) !important;
  box-shadow: 0 8px 20px rgba(0,0,0,0.15);
  color: #fff;
}

/* ── Nav links ── */
.ft-nav-link {
  font-size: .84rem;
  color: rgba(255,255,255,0.65);
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 6px;
  transition: color .2s, gap .2s, letter-spacing .2s;
}
.ft-nav-link:hover {
  color: #fff !important;
  gap: 10px !important;
  letter-spacing: .01em;
}
.ft-nav-link .ft-chevron {
  font-size: .5rem;
  color: rgba(255,220,228,0.55);
  transition: color .2s, transform .2s;
}
.ft-nav-link:hover .ft-chevron {
  color: rgba(255,220,228,0.9);
  transform: translateX(2px);
}

/* ── Contact icon box ── */
.ft-contact-icon {
  width: 34px; height: 34px; border-radius: 9px;
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.2);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  transition: background .25s, transform .25s;
}
.ft-contact-icon:hover {
  background: rgba(255,255,255,0.22);
  transform: scale(1.08);
}

/* ── Hours card ── */
.ft-hours-card {
  margin-top: 20px; padding: 14px;
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 12px;
  backdrop-filter: blur(6px);
  transition: background .3s, border-color .3s;
}
.ft-hours-card:hover {
  background: rgba(255,255,255,0.13);
  border-color: rgba(255,255,255,0.25);
}

/* ── Payment badges ── */
.ft-pay-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.18);
  border-radius: 7px; padding: 4px 11px;
  font-size: .68rem; font-weight: 700;
  color: rgba(255,255,255,0.7);
  letter-spacing: .07em;
  transition: background .2s, color .2s, transform .2s;
}
.ft-pay-badge i {
  transition: color .2s;
}
.ft-pay-badge:hover {
  background: rgba(255,255,255,0.22);
  color: #fff;
  transform: translateY(-2px);
}

/* ── Divider glow ── */
.ft-divider {
  max-width: 1100px; margin: 48px auto 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25) 30%, rgba(255,255,255,0.35) 50%, rgba(255,255,255,0.25) 70%, transparent);
}

/* ── Floating cake icon ── */
.ft-cake-float {
  position: absolute;
  font-size: 5rem;
  opacity: 0.06;
  pointer-events: none;
  animation: ftFloat 5s ease-in-out infinite;
}

/* ── Section heading ── */
.ft-section-head {
  font-size: .7rem; font-weight: 700; letter-spacing: .15em;
  text-transform: uppercase; color: rgba(255,220,228,0.9);
  margin-bottom: 20px; display: flex; align-items: center; gap: 8px;
}
.ft-section-head::after {
  content: '';
  flex: 1; height: 1px;
  background: linear-gradient(90deg, rgba(255,255,255,0.2), transparent);
}

/* ── Scroll-reveal via Intersection Observer ── */
.ft-reveal {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity .6s ease, transform .6s ease;
}
.ft-reveal.ft-visible {
  opacity: 1;
  transform: translateY(0);
}
</style>

