<style>
  :root {
    --rose:    #8B4A5A;
    --rose-dk: #6e3547;
    --rose-lt: #fdf0f5;
    --blush:   #f3d7d3;
    --cream:   #fff8f9;
    --ink:     #4A3B32;
    --muted:   #a07085;
    --border:  #f0c4d4;
    --text:    #2d1520;
    --font-display: 'Playfair Display', serif;
    --font-body: 'Lato', sans-serif;
  }

  * { box-sizing: border-box; }

  body {
    background: linear-gradient(135deg, #f9e8ef 0%, #fdf5f8 50%, #f3e8f5 100%);
    font-family: var(--font-body);
    min-height: 100vh;
  }

  /* ══════════════════════════════
     SHARED SHELL — sidebar + main
  ══════════════════════════════ */
  .page-wrap {
    max-width: 1180px;
    margin: 0 auto;
    padding: 32px 24px 60px;
    display: flex;
    gap: 28px;
    align-items: flex-start;
  }

  .dash-sidebar {
    width: 250px;
    min-width: 250px;
    flex-shrink: 0;
    position: sticky;
    top: 90px;
    align-self: flex-start;
    animation: slideLeft .5s ease both;
  }
  @keyframes slideLeft { from{opacity:0;transform:translateX(-24px)} to{opacity:1;transform:translateX(0)} }

  .dash-main {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 24px;
    animation: slideUp .55s ease .1s both;
  }
  @keyframes slideUp { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:translateY(0)} }

  /* ══════════════════════════════
     PAGE TOPBAR (address list)
  ══════════════════════════════ */
  .page-topbar { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; }
  .page-topbar h2, .card-title {
    font-family: var(--font-display); font-weight:700; color: var(--rose);
  }
  .page-topbar h2 { font-size:1.9rem; position:relative; }
  .page-topbar h2::after {
    content:''; position:absolute; bottom:-4px; left:0; height:3px; width:60px;
    background: linear-gradient(90deg,var(--rose),var(--rose-dk)); border-radius:2px;
  }

  .btn-add {
    display:inline-flex; align-items:center; gap:8px; padding:11px 22px;
    background: linear-gradient(135deg,var(--rose) 0%, var(--rose-dk) 100%);
    color:#fff; border:none; border-radius:50px; font-size:.85rem; font-weight:700;
    cursor:pointer; text-decoration:none; box-shadow:0 5px 18px rgba(139,74,90,.28);
    transition: transform .18s, box-shadow .18s;
  }
  .btn-add:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(139,74,90,.36); color:#fff; }

  /* ══════════════════════════════
     CARD SHELLS
  ══════════════════════════════ */
  .details-card, .form-card {
    background:#fff; border-radius:22px; padding:32px 36px;
    box-shadow:0 4px 20px rgba(139,74,90,.08); border:1px solid var(--border);
  }
  .card-title { font-size:1.2rem; margin-bottom:24px; padding-bottom:12px; border-bottom:2px solid var(--border); display:flex; align-items:center; gap:10px; }

  /* ══════════════════════════════
     ADDRESS LIST
  ══════════════════════════════ */
  .addr-list { display:flex; flex-direction:column; gap:16px; }
  .addr-card {
    background: var(--cream); border:1.5px solid var(--border); border-radius:18px;
    padding:22px 24px; display:flex; align-items:flex-start; justify-content:space-between; gap:16px;
    position:relative; overflow:hidden; transition: border-color .22s, box-shadow .22s, transform .22s;
  }
  .addr-card:hover { border-color:var(--rose); box-shadow:0 6px 22px rgba(139,74,90,.12); transform:translateX(4px); }
  .addr-card-left { display:flex; gap:16px; align-items:flex-start; }
  .addr-icon {
    width:46px; height:46px; background:var(--rose-lt); border-radius:12px;
    display:flex; align-items:center; justify-content:center; font-size:1.2rem; flex-shrink:0;
    transition: transform .25s cubic-bezier(.34,1.56,.64,1);
  }
  .addr-card:hover .addr-icon { transform: scale(1.12) rotate(-4deg); }
  .addr-type-badge {
    display:inline-block; font-size:.62rem; font-weight:800; letter-spacing:.08em; text-transform:uppercase;
    background: linear-gradient(135deg,var(--rose),var(--rose-dk)); color:#fff; border-radius:6px; padding:3px 9px; margin-bottom:6px;
  }
  .addr-name  { font-weight:700; font-size:.95rem; color: var(--text); }
  .addr-phone { font-size:.8rem; color:var(--muted); margin-top:2px; }
  .addr-line  { font-size:.84rem; color:var(--muted); margin-top:6px; line-height:1.5; }

  .menu-wrapper { position:relative; flex-shrink:0; }
  .menu-icon {
    width:36px; height:36px; background:#fff; border:1.5px solid var(--border); border-radius:10px;
    display:flex; align-items:center; justify-content:center; cursor:pointer; color:var(--muted);
    transition:border-color .2s,color .2s,transform .18s;
  }
  .menu-icon:hover { border-color:var(--rose); color:var(--rose); transform:rotate(90deg); }
  .menu-dropdown {
    display:none; position:absolute; top:calc(100% + 8px); right:0; background:#fff; border-radius:12px;
    box-shadow:0 8px 28px rgba(0,0,0,.12); min-width:130px; overflow:hidden; z-index:100; border:1px solid var(--border);
  }
  .menu-dropdown a {
    display:flex; align-items:center; gap:8px; padding:11px 16px; font-size:.84rem; font-weight:500;
    color:var(--text); text-decoration:none; transition:background .15s,padding-left .15s;
  }
  .menu-dropdown a:hover { background:var(--rose-lt); padding-left:20px; }
  .menu-dropdown .delete-link { color:#e05555; }
  .menu-dropdown .delete-link:hover { background:#fde8e8; }

  .empty-addr { text-align:center; padding:60px 20px; color:var(--muted); }
  .empty-addr .icon { font-size:3.5rem; margin-bottom:16px; display:block; }
  .empty-addr h3 { font-family: var(--font-display); font-size:1.4rem; color:var(--rose); margin-bottom:8px; }

  /* Modal */
  .modal-overlay { display:none; position:fixed; inset:0; background:rgba(74,59,50,.5); backdrop-filter:blur(4px); align-items:center; justify-content:center; z-index:200; }
  .modal-box { background:#fff; border-radius:18px; padding:36px 32px; width:340px; text-align:center; box-shadow:0 14px 44px rgba(139,74,90,.18); }
  .modal-icon { font-size:2.5rem; margin-bottom:14px; display:block; }
  .modal-box h3 { font-family: var(--font-display); font-size:1.4rem; color:var(--text); margin-bottom:8px; }
  .modal-box p { font-size:.88rem; color:var(--muted); margin-bottom:24px; }
  .modal-actions { display:flex; gap:12px; justify-content:center; }
  .btn-modal-cancel { padding:10px 22px; background:#f0ecec; color:var(--muted); border:none; border-radius:50px; font-weight:600; font-size:.85rem; cursor:pointer; transition: background .2s, transform .15s; }
  .btn-modal-cancel:hover { background:#e8e0e0; transform:translateY(-1px); }
  .btn-modal-delete { padding:10px 22px; background:#e05555; color:#fff; border:none; border-radius:50px; font-weight:600; font-size:.85rem; cursor:pointer; box-shadow:0 4px 14px rgba(224,85,85,.3); transition: background .2s, transform .15s; }
  .btn-modal-delete:hover { background:#c03a3a; transform:translateY(-1px); }
  .addr-card.removing { animation: cardRemove .4s ease forwards; }
  @keyframes cardRemove { to { opacity:0; transform:translateX(40px) scale(.96); max-height:0; padding:0; margin:0; } }

  /* ══════════════════════════════
     ADDRESS FORM (add / edit)
  ══════════════════════════════ */
  .form-header {
    background: linear-gradient(135deg,var(--rose) 0%, var(--rose-dk) 100%);
    padding:28px 36px; border-radius:22px; display:flex; align-items:center; gap:16px;
    position:relative; overflow:hidden; box-shadow:0 10px 30px rgba(139,74,90,.2);
  }
  .form-header-icon {
    width:52px; height:52px; background:rgba(255,255,255,.2); border-radius:14px;
    display:flex; align-items:center; justify-content:center; font-size:1.4rem; color:#fff; flex-shrink:0;
  }
  .form-header h1 { font-family: var(--font-display); font-size:1.6rem; font-weight:700; color:#fff; margin:0; }
  .form-header p  { font-size:.82rem; color:rgba(255,255,255,.8); margin:3px 0 0; }

  .form-grid { display:grid; grid-template-columns:1fr 1fr; gap:22px; }
  .full-col { grid-column: 1 / -1; }

  .field-group { display:flex; flex-direction:column; gap:7px; }
  .field-group label {
    font-size:.72rem; font-weight:700; letter-spacing:.10em; text-transform:uppercase; color:var(--muted); transition:color .2s;
  }
  .field-group:focus-within label { color: var(--rose); }

  .field-input {
    width:100%; background:var(--rose-lt); border:1.5px solid transparent; border-radius:10px;
    padding:13px 16px; font-family:var(--font-body); font-size:.92rem; color:var(--text); outline:none;
    transition: border-color .2s, background .2s, box-shadow .2s, transform .15s;
  }
  .field-input::placeholder { color:var(--muted); opacity:.7; }
  .field-input:focus { background:#fff; border-color:var(--rose); box-shadow:0 0 0 4px rgba(139,74,90,.09); transform:translateY(-1px); }
  .field-input.error { border-color:#e05555 !important; animation:shake .35s ease; }
  .field-input.success { border-color:#4caf50 !important; }
  @keyframes shake { 0%,100%{transform:translateX(0)} 20%{transform:translateX(-5px)} 40%{transform:translateX(5px)} 60%{transform:translateX(-4px)} 80%{transform:translateX(4px)} }
  textarea.field-input { resize:none; min-height:100px; }
  .error-text { font-size:.74rem; color:#e05555; }

  .type-label { font-size:.72rem; font-weight:700; letter-spacing:.10em; text-transform:uppercase; color:var(--muted); margin-bottom:12px; display:block; }
  .type-options { display:flex; gap:10px; flex-wrap:wrap; }
  .type-option input[type="radio"] { display:none; }
  .type-option label {
    display:flex; align-items:center; gap:7px; padding:9px 18px; border:1.5px solid var(--border);
    border-radius:50px; font-size:.83rem; font-weight:600; color:var(--muted); cursor:pointer;
    transition: all .22s cubic-bezier(.34,1.56,.64,1);
  }
  .type-option label:hover { border-color:var(--rose); color:var(--rose); transform:translateY(-2px) scale(1.04); }
  .type-option input:checked + label {
    border-color:var(--rose); background:var(--rose-lt); color:var(--rose);
    transform:translateY(-2px) scale(1.06); box-shadow:0 4px 18px rgba(139,74,90,.2);
  }

  .form-actions { display:flex; justify-content:flex-end; gap:12px; margin-top:32px; padding-top:24px; border-top:1px solid var(--border); }
  .btn-cancel {
    padding:12px 26px; background:#f5f0f0; color:var(--muted); border:none; border-radius:50px;
    font-family:var(--font-body); font-size:.88rem; font-weight:600; cursor:pointer; text-decoration:none;
    display:inline-flex; align-items:center; transition: background .2s, transform .18s;
  }
  .btn-cancel:hover { background:#ede8e8; transform:translateY(-2px); color:var(--muted); }
  .btn-save {
    padding:12px 32px; background: linear-gradient(135deg,var(--rose) 0%, var(--rose-dk) 100%);
    color:#fff; border:none; border-radius:50px; font-family:var(--font-body); font-size:.88rem; font-weight:700;
    cursor:pointer; transition: transform .18s, box-shadow .18s; box-shadow:0 6px 20px rgba(139,74,90,.28);
  }
  .btn-save:hover { transform:translateY(-2px); box-shadow:0 10px 28px rgba(139,74,90,.36); }
  .btn-save.saving { pointer-events:none; opacity:.75; }

  /* ══════════════════════════════
     PROFILE — hero / stats / details
  ══════════════════════════════ */
  .hero-card {
    background: linear-gradient(135deg, var(--rose) 0%, #c27090 50%, #d4889a 100%);
    border-radius:24px; padding:40px 48px; display:flex; align-items:center; gap:36px;
    box-shadow:0 16px 48px rgba(139,74,90,.22); position:relative; overflow:hidden;
  }
  .hero-card::before { content:''; position:absolute; top:-60px; right:-60px; width:220px; height:220px; border-radius:50%; background:rgba(255,255,255,.08); }
  .hero-card::after  { content:''; position:absolute; bottom:-40px; left:30%; width:160px; height:160px; border-radius:50%; background:rgba(255,255,255,.06); }
  .avatar-ring { width:110px; height:110px; border-radius:50%; padding:3px; background:rgba(255,255,255,.35); flex-shrink:0; box-shadow:0 8px 28px rgba(0,0,0,.18); position:relative; z-index:2; }
  .avatar-inner { width:100%; height:100%; border-radius:50%; overflow:hidden; background:var(--blush); border:3px solid rgba(255,255,255,.8); }
  .avatar-inner img { width:100%; height:100%; object-fit:cover; }
  .hero-info { position:relative; z-index:2; }
  .hero-name { font-family:var(--font-display); font-size:2rem; font-weight:700; color:#fff; line-height:1.1; margin-bottom:6px; }
  .hero-email { font-size:.88rem; color:rgba(255,255,255,.78); margin-bottom:14px; }
  .hero-badge { display:inline-flex; align-items:center; gap:6px; background:rgba(255,255,255,.18); border:1px solid rgba(255,255,255,.28); color:#fff; font-size:.72rem; font-weight:700; letter-spacing:.06em; padding:5px 14px; border-radius:50px; backdrop-filter:blur(6px); }

  .stats-row { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; }
  .stat-card { background:#fff; border-radius:18px; padding:22px 24px; display:flex; align-items:center; gap:16px; box-shadow:0 4px 20px rgba(139,74,90,.08); border:1px solid var(--border); transition:transform .25s, box-shadow .25s; }
  .stat-card:hover { transform:translateY(-4px); box-shadow:0 10px 32px rgba(139,74,90,.14); }
  .stat-icon { width:48px; height:48px; border-radius:14px; background:var(--rose-lt); display:flex; align-items:center; justify-content:center; color:var(--rose); font-size:1.2rem; flex-shrink:0; }
  .stat-label { font-size:.72rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:var(--muted); margin-bottom:4px; }
  .stat-value { font-family:var(--font-display); font-size:1rem; font-weight:700; color:var(--text); }

  .field-grid { display:grid; grid-template-columns:1fr 1fr; gap:18px; margin-bottom:24px; }
  .field-label { font-size:.7rem; font-weight:800; text-transform:uppercase; letter-spacing:.1em; color:var(--muted); }
  .field-value {
    background:var(--rose-lt); border:1.5px solid var(--border); border-radius:12px; padding:13px 18px;
    font-size:.93rem; font-weight:600; color:var(--text); font-family:var(--font-body);
  }
  .referral-row { display:flex; align-items:center; gap:12px; margin-bottom:28px; }
  .referral-box { flex:1; background: linear-gradient(135deg, var(--rose-lt) 0%, #fce8f0 100%); border:1.5px dashed var(--border); border-radius:12px; padding:13px 18px; font-size:.93rem; font-weight:700; color:var(--rose); letter-spacing:.06em; }
  .copy-btn { padding:13px 20px; background:var(--rose); color:#fff; border:none; border-radius:12px; font-size:.82rem; font-weight:700; cursor:pointer; display:flex; align-items:center; gap:6px; white-space:nowrap; transition: background .2s, transform .15s; }
  .copy-btn:hover { background:var(--rose-dk); transform:translateY(-1px); }
  .action-row { display:flex; gap:12px; }
  .btn-primary-rose { flex:1; background: linear-gradient(135deg,var(--rose) 0%, var(--rose-dk) 100%); color:#fff; border:none; border-radius:14px; padding:15px 24px; font-size:.92rem; font-weight:700; cursor:pointer; box-shadow:0 6px 20px rgba(139,74,90,.28); display:flex; align-items:center; justify-content:center; gap:8px; text-decoration:none; transition: transform .18s, box-shadow .18s; }
  .btn-primary-rose:hover { transform:translateY(-2px); box-shadow:0 10px 28px rgba(139,74,90,.36); color:#fff; }
  .btn-outline-rose { flex:1; background:transparent; color:var(--rose); border:1.5px solid var(--border); border-radius:14px; padding:15px 24px; font-size:.92rem; font-weight:700; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:8px; text-decoration:none; transition: all .18s; }
  .btn-outline-rose:hover { background:var(--rose-lt); border-color:var(--rose); color:var(--rose); transform:translateY(-2px); }
  .google-note { margin-top:16px; text-align:center; font-size:.82rem; color:var(--muted); background:var(--rose-lt); border-radius:10px; padding:10px 16px; }

  /* ══════════════════════════════
     RESPONSIVE
  ══════════════════════════════ */
  @media (max-width: 900px) {
    .page-wrap { flex-direction:column; padding:16px; }
    .dash-sidebar { width:100%; min-width:unset; position:static; }
    .stats-row { grid-template-columns:1fr 1fr; }
    .hero-card { flex-direction:column; text-align:center; padding:32px 24px; }
    .details-card, .form-card { padding:24px 20px; }
    .field-grid, .form-grid { grid-template-columns:1fr; }
  }
  @media (max-width: 540px) {
    .stats-row { grid-template-columns:1fr; }
    .action-row, .form-actions { flex-direction:column; }
  }
</style>
