<style>
  .admin-header {
    background-color:  #c76981f6;;
    color: #fff;
    height: 64px;
    padding: 0 30px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: 'Inter', sans-serif;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1100;
  }

  .logo {
    font-size: 22px;
    font-weight: 700;
    margin: 0;
  }

  .profile-dropdown { position: relative; }

  .profile-btn {
    background: transparent;
    border: none;
    color: #fff;
    font-size: 15px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .dropdown-menu {
    position: absolute;
    top: 55px;
    right: 0;
    background: #fff;
    border-radius: 6px;
    box-shadow: 0 8px 20px rgba(0,0,0,0.15);
    width: 160px;
    display: none;
    overflow: hidden;
    z-index: 2000;
  }

  .dropdown-menu a {
    display: block;
    padding: 12px 16px;
    color: #333;
    text-decoration: none;
    font-size: 14px;
  }

  .dropdown-menu a:hover { background-color: #f2f2f2; }

  .profile-dropdown.active .dropdown-menu { display: block; }
  .admin-header-brand { display: flex; align-items: center; gap: 12px; }
.admin-brand-logo { width: 44px; height: 44px; border-radius: 12px; overflow: hidden; flex-shrink: 0; }
.admin-brand-logo img { width: 100%; height: 100%; object-fit: cover; }
.admin-brand-name { font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 700; }
.admin-brand-sub { font-size: .64rem; letter-spacing: .06em; text-transform: uppercase; font-weight: 600; }
</style>

<header class="admin-header">
  <div class="admin-header-brand">
    <div class="admin-brand-logo">
      <img src="https://res.cloudinary.com/dtfzp8rwt/image/upload/v1780840131/WhatsApp_Image_2026-06-07_at_4.24.57_PM-removebg-preview_cmrltl.png"
           alt="Cake O Clock">
    </div>
    <div class="admin-brand-text">
      <div class="admin-brand-name">Cake O'Clock</div>
      <div class="admin-brand-sub">Admin Panel</div>
    </div>
  </div>

  <div class="header-right">
    <div class="profile-dropdown">
      <button class="profile-btn" type="button">
        <i class="fa-solid fa-user"></i>
        <span><%= admin?.name || "Admin" %></span>
        <i class="fa-solid fa-caret-down"></i>
      </button>
      <div class="dropdown-menu">
        <a href="/admin/logout">
          <i class="fa-solid fa-right-from-bracket"></i> Logout
        </a>
      </div>
    </div>
  </div>
</header>
<script>
  (function () {
    const profileBtn = document.querySelector(".profile-btn");
    const dropdown   = document.querySelector(".profile-dropdown");
    if (!profileBtn || !dropdown) return;

    profileBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      dropdown.classList.toggle("active");
    });

    document.addEventListener("click", (e) => {
      if (!dropdown.contains(e.target)) {
        dropdown.classList.remove("active");
      }
    });
  })();
</script>