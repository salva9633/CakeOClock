<style>
  :root {
    --bg-color: #FFF5F2;
    --sidebar-width: 260px;
    --header-height: 64px;
    --text-color: #4A3B32;
    --hover-color: #F4D0CB;
    --active-text: #FFFFFF;
    --btn-color:  #8B4A5A;;
  }

  *, *::before, *::after { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; width: 100%; overflow-x: hidden; }

  .sidebar {
    width: var(--sidebar-width);
    background-color: var(--bg-color);
    padding: 2rem 1.5rem;
    position: fixed;
    top: var(--header-height);
    left: 0;
    height: calc(100vh - var(--header-height));
    overflow-y: auto;
    z-index: 1000;
    border-right: 1px solid rgba(0, 0, 0, 0.05);
  }

  .menu-item {
    display: flex;
    align-items: center;
    padding: 12px 16px;
    margin-bottom: 8px;
    border-radius: 12px;
    color: var(--text-color);
    text-decoration: none;
    transition: 0.2s;
    font-weight: 500;
  }

  .menu-item i {
    width: 24px;
    margin-right: 12px;
  }

  .menu-item:hover { background-color: var(--hover-color); }

  .menu-item.active {
    background-color: var(--btn-color);
    color: var(--active-text);
  }

  /* ── MAIN CONTENT LAYOUT (global, defined once here) ── */
 .main-content {
  margin-left: var(--sidebar-width);
  margin-top: var(--header-height);
  margin-right: 0;
  margin-bottom: 0;
  width: calc(100% - var(--sidebar-width));
  min-height: calc(100vh - var(--header-height));
  padding: 30px;                    /* ← uniform padding, fixes orange shade */
  background: var(--bg-color);
  overflow-x: hidden;
  box-sizing: border-box;
}

  /* Mobile toggle */
  .mobile-toggle {
    display: none;
    position: fixed;
    top: 18px;
    right: 18px;
    z-index: 1100;
    font-size: 1.5rem;
    cursor: pointer;
  }

  .overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.3);
    z-index: 900;
  }

  @media (max-width: 992px) {
    .sidebar {
      transform: translateX(-100%);
      transition: 0.3s;
      top: 0;
      height: 100vh;
    }

    .sidebar.active {
      transform: translateX(0);
    }

    .mobile-toggle { display: block; }

    .overlay.active { display: block; }

    .main-content {
      margin-left: 0;
      width: 100%;
      max-width: 100%;
    }
  }

  @media (max-width: 600px) {
  .main-content { padding: 16px; }
}
</style>

<div class="mobile-toggle" onclick="toggleSidebar()">
  <i class="fas fa-bars"></i>
</div>

<div class="overlay" onclick="toggleSidebar()"></div>

<aside class="sidebar">
  <nav>
    <a href="/admin/dashboard"            class="menu-item"><i class="fas fa-th-large"></i>Dashboard</a>
    <a href="/admin/orders"     class="menu-item"><i class="fas fa-shopping-bag"></i>Order</a>
    <a href="/admin/products"   class="menu-item"><i class="fas fa-box"></i>Products</a>
    <a href="/admin/sales-report" class="menu-item"><i class="fas fa-chart-line"></i>Sales report</a>
    <a href="/admin/users"      class="menu-item"><i class="fas fa-users"></i>Customer</a>
    <a href="/admin/coupons"    class="menu-item"><i class="fas fa-tag"></i>Coupon</a>
    <a href="/admin/category"   class="menu-item"><i class="fas fa-layer-group"></i>Category</a>
  </nav>
</aside>

<script>
  function toggleSidebar() {
    document.querySelector('.sidebar')?.classList.toggle('active');
    document.querySelector('.overlay')?.classList.toggle('active');
  }

  document.addEventListener("DOMContentLoaded", () => {
    const currentPath = window.location.pathname;
    document.querySelectorAll(".menu-item").forEach(item => {
      const href = item.getAttribute("href");
      if (currentPath === href || (currentPath.startsWith(href) && href !== "/admin")) {
        item.classList.add("active");
      }
    });
  });
</script>