<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Admin | Cake O Clock</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Bootstrap -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />

  <!-- Font Awesome -->
  <link
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    rel="stylesheet"
  />

  <!-- Google Fonts -->
  <link
  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
  rel="stylesheet"
  />
  
  <!-- Cropper CSS -->
  <link
  href="https://cdn.jsdelivr.net/npm/cropperjs@1.6.1/dist/cropper.min.css"
  rel="stylesheet"
  />
  <style>
    /* ✅ FIX 1: Lock body background so it never changes */
html,
body {
  margin: 0;
  padding: 0;
  width: 100%;
  height: 100%;
  overflow-x: hidden;
  background: #f5e6e8;
  font-family: 'Inter', sans-serif;
}

body {
  display: flex;
  flex-direction: column;
}

body.modal-open {
  padding-right: 0 !important;
}

.main-content {
  margin-left: 260px;
  margin-top: 64px;

  width: calc(100% - 260px);
  min-height: calc(100vh - 64px);

  padding: 24px 30px;
  box-sizing: border-box;

  background: linear-gradient(135deg, #f5e6e8 0%, #f8d7da 100%);

  overflow-x: hidden;
}

@media (max-width: 992px) {
  .main-content {
    margin-left: 0;
    width: 100%;
    padding: 16px;
  }
}
  </style>
</head>

<body>

  <!-- HEADER -->
  <%- include("../partials/admin/header") %>

  <!-- SIDEBAR -->
  <%- include("../partials/admin/sidebar") %>

  <!-- MAIN CONTENT -->
  <main class="main-content">
    <%- body %>
  </main>


<!-- Cropper JS -->
<script
  src="https://cdn.jsdelivr.net/npm/cropperjs@1.6.1/dist/cropper.min.js">
</script>


  <!-- Bootstrap JS -->
  <script
    src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
  ></script>

</body>
</html>
