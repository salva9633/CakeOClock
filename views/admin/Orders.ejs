<%- include("../../views/partials/admin/sidebar") %>

<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --rose:#C97B8A;--rose-dk:#A85F6E;--rose-lt:#FAE8ED;
  --blush:#FDF0F3;--caramel:#D4A574;--brown:#5C3A3A;
  --muted:#B08A8A;--border:#F5D8E0;--mint:#E8F6F0;--white:#FFFFFF;
}

@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
@keyframes scaleIn{from{opacity:0;transform:scale(0.94)}to{opacity:1;transform:scale(1)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.5}}

.pg{padding:1.5rem 1rem}

.pg-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;animation:fadeUp .4s ease both}
.pg-header h1{font-size:20px;font-weight:500;color:var(--brown);display:flex;align-items:center;gap:8px}
.pg-header h1 i{color:var(--rose)}

.summary-grid{display:grid;grid-template-columns:repeat(8,minmax(0,1fr));gap:10px;margin-bottom:1.5rem}-grid{display:grid;grid-template-columns:repeat(8,minmax(0,1fr));gap:10px;margin-bottom:1.5rem}-grid{display:grid;grid-template-columns:repeat(7,minmax(0,1fr));gap:10px;margin-bottom:1.5rem}
.s-card{background:var(--white);border:0.5px solid var(--border);border-radius:12px;padding:.85rem 1rem;border-top:3px solid var(--rose);opacity:0;animation:fadeUp .5s ease forwards;transition:transform .2s}
.s-card:hover{transform:translateY(-2px)}
.s-card:nth-child(2){border-top-color:#F0A050;animation-delay:.05s}
.s-card:nth-child(3){border-top-color:#7BA8C9;animation-delay:.1s}
.s-card:nth-child(4){border-top-color:#7BB88A;animation-delay:.15s}
.s-card:nth-child(5){border-top-color:#9B7BB8;animation-delay:.2s}
.s-card:nth-child(6){border-top-color:var(--muted);animation-delay:.25s}
.s-card:nth-child(7){border-top-color:#C97B8A;animation-delay:.3s}
.s-label{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px}
.s-val{font-size:22px;font-weight:500;color:var(--brown);line-height:1}

.tabs{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:1rem;opacity:0;animation:fadeUp .5s ease .2s forwards}
.tab{font-size:12px;padding:5px 14px;border-radius:20px;border:0.5px solid var(--border);background:var(--white);color:var(--brown);cursor:pointer;transition:all .18s;text-decoration:none;display:inline-block}
.tab:hover{background:var(--rose-lt);border-color:var(--rose)}
.tab.active{background:var(--rose);color:var(--white);border-color:var(--rose)}

.toolbar{display:flex;gap:8px;align-items:center;flex-wrap:wrap;margin-bottom:.75rem;opacity:0;animation:fadeUp .5s ease .28s forwards}
.search-box{display:flex;align-items:center;gap:8px;flex:1;min-width:200px;max-width:360px;border:0.5px solid var(--border);border-radius:10px;padding:0 12px;background:var(--white);height:38px}
.search-box i{color:var(--muted);font-size:15px;flex-shrink:0}
.search-box input{border:none;outline:none;font-size:13px;width:100%;background:transparent;color:var(--brown)}
.filter-sel{height:38px;padding:0 12px;border-radius:10px;border:0.5px solid var(--border);background:var(--white);font-size:13px;color:var(--brown);outline:none;cursor:pointer}
.btn-clear{height:38px;padding:0 14px;border-radius:10px;border:0.5px solid var(--border);background:var(--white);color:var(--muted);font-size:13px;cursor:pointer;display:flex;align-items:center;gap:5px;transition:all .18s;text-decoration:none}
.btn-clear:hover{background:var(--rose-lt);color:var(--rose);border-color:var(--rose)}

.meta{font-size:12px;color:var(--muted);margin-bottom:.75rem}

.table-card{background:var(--white);border:0.5px solid var(--border);border-radius:12px;overflow:hidden;opacity:0;animation:scaleIn .5s ease .35s forwards}
.tbl-wrap{overflow-x:auto}
.tbl{width:100%;border-collapse:collapse;min-width:820px}
.tbl thead tr{background:linear-gradient(135deg,var(--rose) 0%,var(--rose-dk) 100%)}
.tbl thead th{padding:13px 14px;font-size:12px;font-weight:500;color:#fff;text-align:left;letter-spacing:.03em}
.tbl tbody td{padding:13px 14px;font-size:13px;border-bottom:0.5px solid var(--rose-lt);color:var(--brown);vertical-align:middle}
.tbl tbody tr:last-child td{border-bottom:none}
.tbl tbody tr{transition:background .15s}
.tbl tbody tr:hover td{background:var(--blush)}

.order-id{font-weight:500;color:var(--rose);font-size:12px}
.prod-name{font-weight:500;font-size:13px}
.prod-more{font-size:11px;color:var(--muted);margin-top:2px}
.cust-email{font-size:11px;color:var(--muted);margin-top:2px}

.status-badge{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:500}
.badge-pending{background:#FEF0E8;color:#C97A30}
.badge-processing{background:#E8F0FE;color:#3060C9}
.badge-shipped{background:#E8F6FF;color:#1A7AB8}
.badge-delivered{background:#E6F4EA;color:#2A7D3A}
.badge-cancelled{background:#FDECEA;color:#C03030}
.badge-returned{background:#F0E8FE;color:#7030C9}
.badge-return-req{background:#FFF3CD;color:#856404}

.status-sel{padding:5px 10px;border-radius:8px;border:0.5px solid var(--border);background:var(--white);font-size:12px;color:var(--brown);outline:none;cursor:pointer;transition:border-color .18s}
.status-sel:focus{border-color:var(--rose)}

.btn-view{display:inline-flex;align-items:center;gap:5px;padding:5px 12px;border-radius:8px;border:0.5px solid var(--border);background:var(--white);color:var(--brown);font-size:12px;cursor:pointer;transition:all .18s;text-decoration:none}
.btn-view:hover{background:var(--rose-lt);border-color:var(--rose);color:var(--rose)}

.pagi{display:flex;align-items:center;justify-content:space-between;padding:14px 16px;background:var(--blush);border-top:0.5px solid var(--border);flex-wrap:wrap;gap:8px}
.pagi-info{font-size:12px;color:var(--muted)}
.pagi-btns{display:flex;gap:5px}
.pager{min-width:32px;height:32px;display:flex;align-items:center;justify-content:center;border-radius:8px;border:0.5px solid var(--border);background:var(--white);color:var(--brown);font-size:12px;cursor:pointer;transition:all .18s;text-decoration:none}
.pager:hover{background:var(--rose-lt);border-color:var(--rose);color:var(--rose)}
.pager.active{background:var(--rose);color:var(--white);border-color:var(--rose)}
.pager.disabled{opacity:.4;pointer-events:none}

.empty-box{text-align:center;padding:60px 20px;color:var(--muted)}
.empty-box i{font-size:40px;display:block;margin-bottom:12px;color:var(--border)}
.empty-box p{font-size:15px}

.toast{position:fixed;right:24px;bottom:24px;padding:10px 18px;border-radius:10px;font-size:13px;color:#fff;opacity:0;transform:translateY(6px);transition:.3s;pointer-events:none;z-index:9999}
.toast.show{opacity:1;transform:translateY(0)}
.toast.success{background:#2e7d32}
.toast.error{background:#c0392b}

@media(max-width:992px){
  .summary-grid{grid-template-columns:repeat(4,1fr)}
  .pg{padding:1rem .75rem}
}
@media(max-width:600px){
  .summary-grid{grid-template-columns:repeat(2,1fr)}
}
.page-btn {
  min-width: 34px;
  height: 34px;
  border-radius: 8px;
  border: 0.5px solid var(--border);
  background: var(--white);
  color: var(--brown);
  font-size: 15px;}
</style>

<div class="pg">

  <div class="pg-header">
    <h1><i class="ti ti-shopping-bag" aria-hidden="true"></i> Orders</h1>
    <div style="display:flex;gap:8px;align-items:center">
      <a href="/admin/orders" class="btn-clear" style="height:34px;padding:0 14px;font-size:12px">
        <i class="ti ti-refresh" aria-hidden="true"></i> Refresh
      </a>
    </div>
  </div>

  <div class="summary-grid">
    <div class="s-card">
      <div class="s-label">All orders</div>
      <div class="s-val" data-target="<%= counts.All %>">0</div>
    </div>
    <div class="s-card">
      <div class="s-label">Pending</div>
      <div class="s-val" data-target="<%= counts.Pending %>">0</div>
    </div>
    <div class="s-card">
      <div class="s-label">Processing</div>
      <div class="s-val" data-target="<%= counts.Processing %>">0</div>
    </div>
    <div class="s-card">
      <div class="s-label">Shipped</div>
      <div class="s-val" data-target="<%= counts.Shipped %>">0</div>
    </div>
    <div class="s-card">
      <div class="s-label">Delivered</div>
      <div class="s-val" data-target="<%= counts.Delivered %>">0</div>
    </div>
    <div class="s-card">
      <div class="s-label">Cancelled</div>
      <div class="s-val" data-target="<%= counts.Cancelled %>">0</div>
    </div>
   <div class="s-card">
      <div class="s-label">Returned</div>
      <div class="s-val" data-target="<%= counts.Returned %>">0</div>
    </div>
    <div class="s-card" style="border-top-color:#856404;">
      <div class="s-label">Return Req.</div>
      <div class="s-val" data-target="<%= counts['Return Requested'] %>">0</div>
    </div>
  </div>

  <div class="tabs">
<% const tabStatuses = ["All","Pending","Processing","Shipped","Delivered","Return Requested","Returned","Cancelled"]; %>    <% tabStatuses.forEach(function(s){ %>
      <a href="/admin/orders?search=<%= encodeURIComponent(search) %>&status=<%= s==='All'?'':s %>&sort=<%= sort %>&page=1"
         class="tab <%= (s==='All'&&!status)||s===status?'active':'' %>">
        <%= s %>
      </a>
    <% }) %>
  </div>

  <div class="toolbar">
    <form method="GET" action="/admin/orders" style="display:contents" id="filter-form">
      <div class="search-box">
        <i class="ti ti-search" aria-hidden="true"></i>
        <input type="text" name="search"
               placeholder="Search order ID, name, product…"
               value="<%= search %>"
               oninput="debounceSubmit()">
        <input type="hidden" name="status" value="<%= status %>">
        <input type="hidden" name="page" value="1">
      </div>
      <select class="filter-sel" name="sort" onchange="document.getElementById('filter-form').submit()">
        <option value="date-desc"  <%= sort==='date-desc' ?'selected':'' %>>Newest first</option>
        <option value="date-asc"   <%= sort==='date-asc'  ?'selected':'' %>>Oldest first</option>
        <option value="total-desc" <%= sort==='total-desc'?'selected':'' %>>Amount: high → low</option>
        <option value="total-asc"  <%= sort==='total-asc' ?'selected':'' %>>Amount: low → high</option>
      </select>
    </form>
    <a href="/admin/orders" class="btn-clear">
      <i class="ti ti-x" aria-hidden="true"></i> Clear
    </a>
  </div>

  <p class="meta">
    Showing <%= orders.length ? ((currentPage-1)*10+1) : 0 %>–<%= Math.min(currentPage*10, total) %> of <%= total %> orders
  </p>

  <div class="table-card">
    <% if (orders.length === 0) { %>
      <div class="empty-box">
        <i class="ti ti-shopping-bag" aria-hidden="true"></i>
        <p>No orders found</p>
      </div>
    <% } else { %>

    <div class="tbl-wrap">
      <table class="tbl">
        <thead>
          <tr>
            <th>Product</th>
            <th>Order ID</th>
            <th>Date</th>
            <th>Customer</th>
            <th>Amount</th>
            <th>Status</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% orders.forEach(function(order) { %>
            <% const firstItem = order.items[0]; %>
            <% const extraCount = order.items.length - 1; %>
            <% const hasReturnRequest = order.items.some(function(i){ return i.status === 'Return Requested'; }); %>
            <tr>
              <td>
                <div class="prod-name"><%= firstItem ? firstItem.productName : '—' %></div>
                <% if (extraCount > 0) { %>
                  <div class="prod-more">+<%= extraCount %> more item<%= extraCount > 1 ? 's' : '' %></div>
                <% } %>
              </td>
              <td><span class="order-id"><%= order.orderId %></span></td>
              <td style="white-space:nowrap;font-size:12px;color:var(--muted)">
                <%= new Date(order.createdAt).toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }) %>
              </td>
              <td>
                <div style="font-size:13px"><%= order.address.name %></div>
                <% if (order.userId && order.userId.email) { %>
                  <div class="cust-email"><%= order.userId.email %></div>
                <% } %>
              </td>
              <td style="font-weight:500">₹<%= order.finalTotal.toLocaleString('en-IN') %></td>
           <td>
                <% if (hasReturnRequest) { %>
                  <span class="status-badge badge-return-req" style="margin-bottom:6px;display:inline-flex">
                    <i class="ti ti-arrow-back-up" style="font-size:11px" aria-hidden="true"></i>&nbsp;Return req.
                  </span><br>
                <% } %>
                <%
                  const sClass = {
                    Pending:'badge-pending', Processing:'badge-processing',
                    Shipped:'badge-shipped', Delivered:'badge-delivered',
                    Cancelled:'badge-cancelled', Returned:'badge-returned',
                    'Return Requested':'badge-return-req'
                  }[order.status] || 'badge-pending';
                %>
                <span class="status-badge <%= sClass %>"><%= order.status %></span>
              </td>
              <td>
                <a href="/admin/orders/<%= order._id %>" class="btn-view">
                  <i class="ti ti-eye" aria-hidden="true"></i> View
                </a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <% if (totalPages > 1) { %>
    <div class="pagi">
      <span class="pagi-info">
        Page <strong><%= currentPage %></strong> of <strong><%= totalPages %></strong>
        &nbsp;·&nbsp; <%= total %> total orders
      </span>
      <div class="pagi-btns">
        <a href="/admin/orders?search=<%= encodeURIComponent(search) %>&status=<%= status %>&sort=<%= sort %>&page=<%= currentPage-1 %>"
           class="pager <%= currentPage===1 ? 'disabled' : '' %>">
          <i class="ti ti-chevron-left" aria-hidden="true"></i>
        </a>

        <%
          const delta = 2;
          const range = [];
          for (let i = 1; i <= totalPages; i++) {
            if (i===1 || i===totalPages || (i>=currentPage-delta && i<=currentPage+delta)) range.push(i);
          }
          let prev = null;
          range.forEach(function(i) {
            if (prev !== null && i - prev > 1) {
        %>
          <span class="pager" style="pointer-events:none;border:none;background:none">…</span>
        <% } %>
          <a href="/admin/orders?search=<%= encodeURIComponent(search) %>&status=<%= status %>&sort=<%= sort %>&page=<%= i %>"
             class="pager <%= i===currentPage ? 'active' : '' %>"><%= i %></a>
        <% prev = i; }); %>

        <a href="/admin/orders?search=<%= encodeURIComponent(search) %>&status=<%= status %>&sort=<%= sort %>&page=<%= currentPage+1 %>"
           class="pager <%= currentPage===totalPages ? 'disabled' : '' %>">
          <i class="ti ti-chevron-right" aria-hidden="true"></i>
        </a>
      </div>
    </div>
    <% } %>

    <% } %>
  </div>

</div>

<div class="toast" id="toast"></div>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
<script>
  // Count-up animation for summary cards
  function animCount(el, target, dur) {
    var start = Date.now();
    function tick() {
      var p    = Math.min((Date.now() - start) / dur, 1);
      var ease = 1 - Math.pow(1 - p, 3);
      el.textContent = Math.round(target * ease);
      if (p < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  setTimeout(function() {
    document.querySelectorAll('.s-val[data-target]').forEach(function(el) {
      animCount(el, parseInt(el.dataset.target, 10) || 0, 700);
    });
  }, 100);

  // Status select — remember previous value
  document.querySelectorAll('.status-sel').forEach(function(sel) {
    sel.dataset.prev = sel.value;
  });

  // Debounced search
  var debounceTimer;
  function debounceSubmit() {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(function() {
      document.getElementById('filter-form').submit();
    }, 500);
  }

  // Toast helper
  function showToast(msg, type) {
    var t = document.getElementById('toast');
    t.textContent = msg;
    t.className = 'toast ' + type + ' show';
    setTimeout(function() { t.className = 'toast'; }, 3000);
  }

</script>
