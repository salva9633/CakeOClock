<style>
  .main-content {
    margin-left: 260px !important;
    margin-top: 64px !important;
    margin-right: 600px !important;
    margin-bottom: 0 !important;
    width: calc(100% - 260px) !important;
    min-height: calc(100vh - 64px);
    padding: 24px 30px;
    background: var(--bg-color);
    overflow-x: hidden;
    box-sizing: border-box;
    display: block;
  }

  /* ── Page Header (matches product list) ── */
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: 25px;
  }

  .page-title {
    font-size: 33px;
    font-weight: 750;
    color: #AF5454;
  }

  /* ── Summary Cards ── */
  .summary-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
    gap: 16px;
    margin-bottom: 28px;
  }

  .s-card {
    background: #fff;
    border-radius: 12px;
    padding: 18px 20px;
    box-shadow: 0 4px 20px rgba(0,0,0,.08);
    border-top: 3px solid #d97373;
  }

  .s-card-label {
    font-size: 12px;
    color: #a07060;
    text-transform: uppercase;
    letter-spacing: .5px;
    margin-bottom: 10px;
    font-weight: 600;
  }

  .s-card-val {
    font-size: 36px;
    font-weight: 700;
    color: #AF5454;
  }

  /* ── Status Tabs ── */
  .status-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 20px;
  }

  .status-tab {
    padding: 8px 20px;
    border-radius: 8px;
    border: 1.5px solid #e8c8c0;
    background: #fff;
    color: #4A3B32;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: .15s;
  }

  .status-tab:hover { background: #F4D0CB; }

  .status-tab.active {
    background: linear-gradient(135deg, #AF5454, #d97373);
    color: #fff;
    border-color: transparent;
    box-shadow: 0 2px 8px rgba(175,84,84,.3);
  }

  /* ── Toolbar ── */
  .toolbar {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }

  .search-wrap {
    position: relative;
    flex: 1;
    min-width: 220px;
    max-width: 380px;
  }

  .search-wrap i {
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    color: #a07060;
    font-size: 13px;
  }

  .search-wrap input {
    width: 100%;
    height: 42px;
    padding: 0 12px 0 36px;
    border-radius: 8px;
    border: 1px solid #e8c8c0;
    background: #fff;
    font-size: 14px;
    outline: none;
  }

  .search-wrap input:focus { border-color: #AF5454; }

  .filter-sel {
    height: 42px;
    padding: 0 14px;
    border-radius: 8px;
    border: 1px solid #e8c8c0;
    background: #fff;
    font-size: 14px;
    outline: none;
    color: #4A3B32;
  }

  .filter-sel:focus { border-color: #AF5454; }

  .btn-clear {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    height: 42px;
    padding: 0 18px;
    border-radius: 8px;
    border: 1.5px solid #e8c8c0;
    background: #fff;
    color: #AF5454;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: .15s;
  }

  .btn-clear:hover { background: #F4D0CB; }

  .meta-info {
    margin-bottom: 12px;
    color: #a07060;
    font-size: 13px;
  }

  /* ── Table Wrapper (identical to product list) ── */
  .table-wrapper {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,.1);
  }

  .table-scroll { overflow-x: auto; }

  table {
    width: 100%;
    border-collapse: collapse;
    min-width: 900px;
  }

  /* ── Thead gradient (same as product list) ── */
  thead {
    background: linear-gradient(135deg, #AF5454, #d97373);
  }

  thead th {
    padding: 16px;
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    text-align: left;
  }

  tbody td {
    padding: 16px;
    font-size: 14px;
    border-bottom: 1px solid #fff0ee;
    color: #4A3B32;
  }

  tbody tr:last-child td { border-bottom: none; }
  tbody tr:hover td { background: #fff8f6; }

  .product-name  { font-weight: 600; }
  .product-more  { font-size: 12px; color: #a07060; margin-top: 3px; }
  .order-id      { color: #AF5454; font-weight: 700; }
  .customer-email{ font-size: 12px; color: #a07060; margin-top: 3px; }

  /* ── Status select in table ── */
  .status-sel {
    padding: 6px 12px;
    border-radius: 8px;
    border: 1px solid #e8c8c0;
    background: #fff;
    font-size: 13px;
    outline: none;
    color: #4A3B32;
  }

  .status-sel:focus { border-color: #AF5454; }

  /* ── View button (same as product list Edit/View btn) ── */
  .btn-view {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 14px;
    border-radius: 6px;
    border: 1px solid #e8c8c0;
    background: #fff;
    color: #4A3B32;
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    transition: .15s;
  }

  .btn-view:hover {
    background: #F4D0CB;
    border-color: #AF5454;
    color: #AF5454;
  }

  /* ── Pagination ── */
  .pagination-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    padding: 16px 18px;
    background: #fdf8f7;
    border-top: 1px solid #fff0ee;
  }

  .page-info { font-size: 13px; color: #a07060; }

  .page-btns { display: flex; gap: 6px; flex-wrap: wrap; }

  .pager {
    min-width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    border: 1px solid #e8c8c0;
    background: #fff;
    color: #4A3B32;
    text-decoration: none;
    font-size: 13px;
    transition: .15s;
  }

  .pager:hover { background: #F4D0CB; }

  .pager.active {
    background: linear-gradient(135deg, #AF5454, #d97373);
    color: #fff;
    border-color: transparent;
  }

  .pager.disabled { opacity: .4; pointer-events: none; }

  /* ── Empty state ── */
  .empty-state {
    text-align: center;
    padding: 60px 20px;
    color: #a07060;
  }

  .empty-state i { font-size: 42px; margin-bottom: 14px; display: block; }
  .empty-state p { font-size: 16px; }

  /* ── Toast ── */
  .toast {
    position: fixed;
    right: 24px; bottom: 24px;
    background: #333; color: #fff;
    padding: 12px 20px;
    border-radius: 8px;
    font-size: 13px;
    opacity: 0; transform: translateY(8px);
    transition: .3s; z-index: 9999; pointer-events: none;
  }

  .toast.show    { opacity: 1; transform: translateY(0); }
  .toast.success { background: #2e7d32; }
  .toast.error   { background: #c0504d; }

  /* ── Responsive ── */
  @media (max-width: 992px) {
    .main-content { margin-left: 0 !important; width: 100% !important; padding: 16px; }
    .page-title   { font-size: 28px; }
    .summary-row  { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .summary-row { grid-template-columns: repeat(2, 1fr); }
  }
</style>



  <div class="page-header">
    <h1 class="page-title">Orders</h1>
  </div>

  <!-- Summary Cards -->
  <div class="summary-row">
    <div class="s-card">
      <div class="s-card-label">Total Orders</div>
      <div class="s-card-val"><%= counts.All %></div>
    </div>
    <div class="s-card">
      <div class="s-card-label">Pending</div>
      <div class="s-card-val"><%= counts.Pending %></div>
    </div>
    <div class="s-card">
      <div class="s-card-label">Processing</div>
      <div class="s-card-val"><%= counts.Processing %></div>
    </div>
    <div class="s-card">
      <div class="s-card-label">Shipped</div>
      <div class="s-card-val"><%= counts.Shipped %></div>
    </div>
    <div class="s-card">
      <div class="s-card-label">Delivered</div>
      <div class="s-card-val"><%= counts.Delivered %></div>
    </div>
    <div class="s-card">
      <div class="s-card-label">Cancelled</div>
      <div class="s-card-val"><%= counts.Cancelled %></div>
    </div>
    <div class="s-card">
      <div class="s-card-label">Returned</div>
      <div class="s-card-val"><%= counts.Returned %></div>
    </div>
  </div>

  <!-- Status Tabs -->
  <div class="status-tabs">
    <% const tabStatuses = ["All","Pending","Processing","Shipped","Delivered","Returned","Cancelled"]; %>
    <% tabStatuses.forEach(function(s) { %>
      <a href="/admin/orders?search=<%= encodeURIComponent(search) %>&status=<%= s === 'All' ? '' : s %>&sort=<%= sort %>&page=1"
         class="status-tab <%= (s === 'All' && !status) || s === status ? 'active' : '' %>">
        <%= s %>
      </a>
    <% }) %>
  </div>

  <!-- Toolbar -->
  <div class="toolbar">
    <form method="GET" action="/admin/orders" style="display:contents" id="filter-form">
      <div class="search-wrap">
        <i class="fas fa-search"></i>
        <input type="text" name="search" id="search-input"
               placeholder="Search order ID, name, product…"
               value="<%= search %>"
               oninput="debounceSubmit()">
      </div>
      <input type="hidden" name="status" value="<%= status %>">
      <select class="filter-sel" name="sort" onchange="document.getElementById('filter-form').submit()">
        <option value="date-desc"  <%= sort==='date-desc'  ? 'selected':'' %>>Date: newest first</option>
        <option value="date-asc"   <%= sort==='date-asc'   ? 'selected':'' %>>Date: oldest first</option>
        <option value="total-desc" <%= sort==='total-desc' ? 'selected':'' %>>Amount: high → low</option>
        <option value="total-asc"  <%= sort==='total-asc'  ? 'selected':'' %>>Amount: low → high</option>
      </select>
      <input type="hidden" name="page" value="1">
    </form>
    <a href="/admin/orders" class="btn-clear">
      <i class="fas fa-times"></i> Clear
    </a>
  </div>

  <p class="meta-info">
    Showing <%= orders.length ? ((currentPage-1)*10+1) : 0 %>–<%= Math.min(currentPage*10, total) %> of <%= total %> orders
  </p>

  <!-- Table -->
  <div class="table-wrapper">
    <% if (orders.length === 0) { %>
      <div class="empty-state">
        <i class="fas fa-shopping-bag"></i>
        <p>No orders found</p>
      </div>
    <% } else { %>

    <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <th>Product</th>
            <th>Order ID</th>
            <th>Date</th>
            <th>Customer</th>
            <th>Amount</th>
            <th>Status</th>
            <th>View</th>
          </tr>
        </thead>
        <tbody>
          <% orders.forEach(function(order) { %>
            <% const firstItem = order.items[0]; %>
            <% const extraCount = order.items.length - 1; %>
            <tr>
              <td>
                <div class="product-name"><%= firstItem ? firstItem.productName : '—' %></div>
                <% if (extraCount > 0) { %>
                  <div class="product-more">+ <%= extraCount %> more item<%= extraCount > 1 ? 's' : '' %></div>
                <% } %>
              </td>
              <td><span class="order-id"><%= order.orderId %></span></td>
              <td style="white-space:nowrap; color:#a07060; font-size:13px;">
                <%= new Date(order.createdAt).toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }) %>
              </td>
              <td>
                <div><%= order.address.name %></div>
                <% if (order.userId && order.userId.email) { %>
                  <div class="customer-email"><%= order.userId.email %></div>
                <% } %>
              </td>
              <td style="font-weight:700;">₹<%= order.finalTotal.toLocaleString('en-IN') %></td>
              <td>
                <select class="status-sel" data-id="<%= order._id %>" onchange="updateStatus(this)">
                  <% ["Pending","Processing","Shipped","Delivered","Cancelled","Returned"].forEach(function(s) { %>
                    <option value="<%= s %>" <%= order.status === s ? 'selected' : '' %>><%= s %></option>
                  <% }) %>
                </select>
              </td>
              <td>
                <a href="/admin/orders/<%= order._id %>" class="btn-view">
                  <i class="fas fa-eye"></i> View
                </a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <% if (totalPages > 1) { %>
    <div class="pagination-row">
      <span class="page-info">
        Page <strong><%= currentPage %></strong> of <strong><%= totalPages %></strong>
        &nbsp;·&nbsp; <%= total %> total orders
      </span>
      <div class="page-btns">
        <a href="/admin/orders?search=<%= encodeURIComponent(search) %>&status=<%= status %>&sort=<%= sort %>&page=<%= currentPage-1 %>"
           class="pager <%= currentPage===1 ? 'disabled':'' %>">‹ Prev</a>

        <%
          const delta = 2;
          const range = [];
          for (let i = 1; i <= totalPages; i++) {
            if (i===1 || i===totalPages || (i>=currentPage-delta && i<=currentPage+delta)) range.push(i);
          }
          let prev = null;
          range.forEach(function(i) {
            if (prev !== null && i - prev > 1) {
        %>
          <span class="pager" style="pointer-events:none;border:none;background:none;">…</span>
        <% } %>
          <a href="/admin/orders?search=<%= encodeURIComponent(search) %>&status=<%= status %>&sort=<%= sort %>&page=<%= i %>"
             class="pager <%= i===currentPage ? 'active':'' %>"><%= i %></a>
        <% prev = i; }); %>

        <a href="/admin/orders?search=<%= encodeURIComponent(search) %>&status=<%= status %>&sort=<%= sort %>&page=<%= currentPage+1 %>"
           class="pager <%= currentPage===totalPages ? 'disabled':'' %>">Next ›</a>
      </div>
    </div>
    <% } %>

    <% } %>
  </div>



<div class="toast" id="toast"></div>

<script>
let debounceTimer;
function debounceSubmit() {
  clearTimeout(debounceTimer);
  debounceTimer = setTimeout(() => document.getElementById('filter-form').submit(), 500);
}

function showToast(msg, type = 'success') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = `toast ${type} show`;
  setTimeout(() => { t.className = 'toast'; }, 3000);
}

async function updateStatus(sel) {
  const orderId = sel.dataset.id;
  const status  = sel.value;
  const prev    = sel.dataset.prev;
  try {
    const res = await fetch(`/admin/orders/${orderId}/status`, {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status }),
    });
    const data = await res.json();
    if (data.success) {
      showToast(`Status updated to "${status}"`, 'success');
      sel.dataset.prev = status;
    } else {
      showToast(data.message || 'Update failed', 'error');
      sel.value = prev;
    }
  } catch {
    showToast('Network error', 'error');
    sel.value = prev;
  }
}

document.querySelectorAll('.status-sel').forEach(sel => { sel.dataset.prev = sel.value; });
</script>
