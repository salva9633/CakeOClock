<%- include("../../views/partials/admin/sidebar") %>

<style>
:root {
  --rose: #C97B8A; --rose-dk: #A85F6E; --rose-lt: #FAE8ED;
  --blush: #FDF0F3; --caramel: #D4A574; --brown: #5C3A3A;
  --muted: #B08A8A; --border: #F5D8E0; --mint: #E8F6F0; --white: #FFFFFF;
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.94); }
  to   { opacity: 1; transform: scale(1); }
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.5; }
}

.cp { padding: 1.5rem 1rem; }

/* ── HEADER ── */
.cp-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 1.5rem; flex-wrap: wrap; gap: 12px;
  animation: fadeUp .4s ease both;
}
.cp-title { font-size: 20px; font-weight: 500; color: var(--brown); display: flex; align-items: center; gap: 8px; }
.cp-title i { color: var(--rose); font-size: 20px; }

.header-right { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }

/* ── SEARCH ── */
.search-wrap { position: relative; }
.search-wrap input {
  width: 260px; padding: 9px 36px 9px 36px;
  border: 0.5px solid var(--border); border-radius: 8px;
  font-size: 13px; color: var(--brown); background: var(--white);
  outline: none; transition: border-color .2s;
}
.search-wrap input:focus { border-color: var(--rose); }
.search-wrap input::placeholder { color: var(--muted); }
.search-icon, .clear-icon {
  position: absolute; top: 50%; transform: translateY(-50%);
  font-size: 14px; color: var(--muted); cursor: pointer;
}
.clear-icon {
  right: 11px;
  color: var(--rose-dk);
  font-size: 13px;
  font-weight: 600;
  line-height: 1;
  z-index: 10;
  padding: 2px 4px;
}
.search-icon { left: 11px; pointer-events: none; }
.clear-icon  { right: 11px; color: var(--rose-dk); }

/* ── ADD BUTTON ── */
.add-btn {
  background: linear-gradient(135deg, #A85F6E, #b24059);
  color: #fff; border: none; padding: 10px 18px; border-radius: 8px;
  font-weight: 600; font-size: 13px; cursor: pointer;
  display: flex; align-items: center; gap: 6px;
  box-shadow: 0 2px 8px rgba(175,84,84,.25); transition: opacity .2s; white-space: nowrap;
}
.add-btn:hover { opacity: .88; }

/* ── TABLE CARD ── */
.table-card {
  background: var(--white); border: 0.5px solid var(--border);
  border-radius: 12px; overflow: hidden;
  opacity: 0; animation: scaleIn .5s ease .2s forwards;
  margin-bottom: 1.25rem;
}
.table-card-header {
  padding: 1rem 1.25rem; display: flex; justify-content: space-between; align-items: center;
  border-bottom: 0.5px solid var(--border);
}
.table-card-title { font-size: 14px; font-weight: 500; color: var(--brown); display: flex; align-items: center; gap: 6px; }
.table-card-title i { color: var(--rose); font-size: 16px; }
.live-badge {
  font-size: 10px; padding: 3px 8px; border-radius: 20px;
  background: var(--rose-lt); color: var(--rose-dk);
  display: flex; align-items: center; gap: 4px;
}
.live-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--rose); animation: pulse 1.8s ease infinite; }

table { width: 100%; border-collapse: collapse; }
thead { background: linear-gradient(135deg, #A85F6E, #A85F6E); }
thead th {
  padding: 13px 16px; color: #fff; font-size: 12px;
  font-weight: 600; text-align: left; letter-spacing: .03em;
}
thead th:last-child { text-align: center; }
tbody td {
  padding: 14px 16px; font-size: 13px; color: var(--brown);
  border-bottom: 0.5px solid var(--rose-lt); vertical-align: middle;
}
tbody tr:last-child td { border-bottom: none; }
tbody tr { transition: background .15s; }
tbody tr:hover { background: var(--blush); }

/* ── CATEGORY CELL ── */
.cat-cell { display: flex; align-items: center; gap: 10px; }
.cat-thumb {
  width: 36px; height: 36px; border-radius: 8px; overflow: hidden;
  border: 0.5px solid var(--border); flex-shrink: 0; background: var(--rose-lt);
  display: flex; align-items: center; justify-content: center;
}
.cat-thumb img { width: 100%; height: 100%; object-fit: cover; }
.cat-name { font-weight: 500; font-size: 13px; }

.desc-cell {
  max-width: 280px; white-space: nowrap;
  overflow: hidden; text-overflow: ellipsis; color: var(--muted);
}

/* ── STATUS BADGE ── */
.status-badge {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; cursor: pointer;
  transition: opacity .2s;
}
.status-badge:hover { opacity: .8; }
.badge-active   { background: #E8F6EE; color: #1F7A47; }
.badge-inactive { background: #FDE8E8; color: #9B2222; }
.status-dot { width: 5px; height: 5px; border-radius: 50%; }
.badge-active .status-dot   { background: #28a745; }
.badge-inactive .status-dot { background: #dc3545; }

/* ── OFFER INPUT ── */
.offer-wrap { display: flex; align-items: center; gap: 6px; }
.offer-input {
  width: 64px; padding: 5px 8px; border: 0.5px solid var(--border);
  border-radius: 6px; font-size: 12px; color: var(--brown);
  outline: none; transition: border-color .2s;
}
.offer-input:focus { border-color: var(--rose); }
.offer-save-btn {
  padding: 5px 10px; border: none; border-radius: 6px;
  background: var(--rose-lt); color: var(--rose-dk);
  font-size: 12px; font-weight: 600; cursor: pointer; transition: all .2s;
}
.offer-save-btn:hover { background: var(--rose); color: #fff; }

/* ── ACTION BUTTONS ── */
.actions-cell { display: flex; align-items: center; justify-content: center; gap: 8px; flex-wrap: wrap; }
.edit-btn {
  border: 0.5px solid var(--caramel); color: var(--caramel); background: transparent;
  padding: 5px 12px; border-radius: 6px; font-size: 12px; font-weight: 500;
  cursor: pointer; display: inline-flex; align-items: center; gap: 5px; transition: all .2s;
}
.edit-btn:hover { background: var(--caramel); color: #fff; }

/* ── EMPTY STATE ── */
.empty-state { text-align: center; padding: 3rem 1rem; color: var(--muted); font-size: 13px; }
.empty-state i { font-size: 32px; margin-bottom: 8px; display: block; color: var(--border); }

/* ── PAGINATION ── */
.pagination-wrap {
  display: flex; align-items: center; justify-content: center; gap: 6px;
  opacity: 0; animation: fadeUp .4s ease .4s forwards;
}
.page-btn {
  min-width: 32px; height: 32px; padding: 0 8px; border-radius: 8px;
  display: inline-flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 500; text-decoration: none;
  color: var(--muted); border: 0.5px solid var(--border);
  background: var(--white); transition: all .2s;
}
.page-btn:hover:not(.disabled) { border-color: var(--rose); color: var(--rose-dk); background: var(--rose-lt); }
.page-btn.active    { background: var(--rose); color: #fff; border-color: var(--rose); }
.page-btn.disabled  { opacity: .4; pointer-events: none; }
.d-none { display: none !important; }
/* ── MODALS ── */
.modal-overlay {
  position: fixed; inset: 0; background: rgba(0,0,0,.4);
  display: none; align-items: center; justify-content: center;
  z-index: 3000; padding: 1rem;
}
.modal-overlay.open { display: flex; }
.modal-box {
  background: var(--white); width: 100%; max-width: 520px;
  border-radius: 14px; overflow: hidden;
  border: 0.5px solid var(--border);
  animation: scaleIn .25s ease;
}
.modal-hd {
  padding: 14px 18px; display: flex; justify-content: space-between; align-items: center;
  background: linear-gradient(135deg, #A85F6E, #b9576b);
}
.modal-hd h5 { font-size: 15px; font-weight: 600; color: #fff; margin: 0; display: flex; align-items: center; gap: 7px; }
.modal-close { background: none; border: none; color: #fff; font-size: 20px; cursor: pointer; line-height: 1; }
.modal-bd { padding: 1.25rem; display: flex; flex-direction: column; gap: 14px; }
.modal-ft { padding: 12px 18px; border-top: 0.5px solid var(--border); display: flex; justify-content: flex-end; gap: 8px; }

.form-label { font-size: 13px; color: var(--brown); font-weight: 500; margin-bottom: 4px; display: block; }
.form-input, .form-textarea, .form-select {
  width: 100%; padding: 9px 12px; border: 0.5px solid var(--border);
  border-radius: 8px; font-size: 13px; color: var(--brown);
  outline: none; transition: border-color .2s; background: var(--white);
}
.form-textarea { resize: vertical; min-height: 80px; }
.form-input:focus, .form-textarea:focus, .form-select:focus { border-color: var(--rose); }
.form-input.err, .form-textarea.err { border-color: #dc3545; }
small.err-msg { font-size: 11px; color: #dc3545; margin-top: 3px; display: block; }

.modal-row { display: flex; gap: 14px; }

/* image box */
.img-box {
  width: 120px; height: 100px; flex-shrink: 0;
  border: 1.5px dashed var(--border); border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; overflow: hidden; transition: border-color .2s; background: var(--blush);
  font-size: 12px; color: var(--muted); text-align: center; padding: 6px;
}
.img-box:hover { border-color: var(--rose); }
.img-box.err  { border-color: #dc3545; }
.img-box.ok   { border-color: #28a745; }
.img-box img  { width: 100%; height: 100%; object-fit: cover; }

.btn-save {
  background: linear-gradient(135deg, #A85F6E, #A85F6E); color: #fff;
  border: none; padding: 9px 22px; border-radius: 8px;
  font-size: 13px; font-weight: 600; cursor: pointer; transition: opacity .2s;
}
.btn-save:hover { opacity: .88; }

/* ── SWAL ABOVE MODAL ── */
.swal2-container { z-index: 9999 !important; }
</style>
<div class="cp">

  <!-- HEADER -->
  <div class="cp-header">
    <div class="cp-title">
      <i class="ti ti-category" aria-hidden="true"></i> Categories
    </div>
    <div class="header-right">
      <!-- SEARCH -->
      <form method="GET" action="/admin/category" id="searchForm">
        <div class="search-wrap">
          <i class="ti ti-search search-icon" aria-hidden="true"></i>
          <input
            type="text" name="search" id="searchInput"
            value="<%= search || '' %>"
            placeholder="Search categories…"
            autocomplete="off"
          >
<span class="clear-icon <%= (search && search.trim()) ? '' : 'd-none' %>" id="clearIcon">✕</span>        </div>
      </form>
      <button class="add-btn" onclick="openAddModal()">
        <i class="ti ti-plus" aria-hidden="true"></i> New category
      </button>
    </div>
  </div>

  <!-- TABLE -->
  <div class="table-card">
    <div class="table-card-header">
      <div class="table-card-title">
        <i class="ti ti-list-details" aria-hidden="true"></i>
        All categories
        <span style="font-size:11px;color:var(--muted);font-weight:400;margin-left:4px;">(<%= cat ? cat.length : 0 %> shown)</span>
      </div>
      <div class="live-badge"><span class="live-dot"></span> Live</div>
    </div>

    <% if (!cat || cat.length === 0) { %>
      <div class="empty-state">
        <i class="ti ti-inbox" aria-hidden="true"></i>
        No categories found<% if (search) { %> for "<%= search %>"<% } %>.
      </div>
    <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Category</th>
          <th>Description</th>
          <th>Created</th>
          <th>Offer</th>
          <th>Status</th>
          <th style="text-align:center;">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% cat.forEach(item => { %>
        <tr>
          <td>
            <div class="cat-cell">
              <div class="cat-thumb">
                <% if (item.image) { %>
                  <img src="<%= item.image %>" alt="<%= item.name %>">
                <% } else { %>
                  <i class="ti ti-cake" style="color:var(--rose);font-size:16px;"></i>
                <% } %>
              </div>
              <span class="cat-name"><%= item.name %></span>
            </div>
          </td>
          <td class="desc-cell"><%= item.description %></td>
          <td style="color:var(--muted);">
            <%= new Date(item.createdAt).toLocaleDateString("en-IN", { day:"2-digit", month:"short", year:"numeric" }) %>
          </td>
       <td>
            <div class="offer-wrap">
              <input
                type="number"
                class="offer-input"
                placeholder="0%"
                value="<%= item.categoryOffer || '' %>"
                min="0" max="100"
                id="offerInput_<%= item._id %>"
              >
              <button
                class="offer-save-btn"
                onclick="saveCategoryOffer('<%= item._id %>', '<%= item.name %>')">
                Save
              </button>
            </div>
          </td>
          <td>
            <span
              class="status-badge <%= item.isActive ? 'badge-active' : 'badge-inactive' %>"
              onclick="toggleStatus('<%= item._id %>')"
              title="Click to toggle"
            >
              <span class="status-dot"></span>
              <%= item.isActive ? 'Active' : 'Inactive' %>
            </span>
          </td>
          <td>
            <div class="actions-cell">
              <button
                class="edit-btn"
                onclick="openEditModal('<%= item._id %>','<%= item.name %>','<%= item.description %>','<%= item.image %>','<%= item.isActive %>')"
              >
                <i class="ti ti-edit" aria-hidden="true"></i> Edit
              </button>
            </div>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>

  <!-- PAGINATION -->
  <% if (totalPages > 1) { %>
  <div class="pagination-wrap">
    <a href="?page=<%= currentPage-1 %>&search=<%= search||'' %>"
       class="page-btn <%= currentPage===1 ? 'disabled' : '' %>">
      <i class="ti ti-chevron-left" style="font-size:13px;"></i>
    </a>
    <% for (let i = 1; i <= totalPages; i++) { %>
      <a href="?page=<%= i %>&search=<%= search||'' %>"
         class="page-btn <%= currentPage===i ? 'active' : '' %>"><%= i %></a>
    <% } %>
    <a href="?page=<%= currentPage+1 %>&search=<%= search||'' %>"
       class="page-btn <%= currentPage===totalPages ? 'disabled' : '' %>">
      <i class="ti ti-chevron-right" style="font-size:13px;"></i>
    </a>
  </div>
  <% } %>

</div>


<!-- ── ADD MODAL ── -->
<div class="modal-overlay" id="addModal">
  <div class="modal-box">
    <div class="modal-hd">
      <h5><i class="ti ti-plus"></i> Add category</h5>
      <button class="modal-close" onclick="closeAddModal()">×</button>
    </div>
    <div class="modal-bd">
      <div>
        <label class="form-label">Name</label>
        <input type="text" id="catName" class="form-input" placeholder="e.g. Birthday Cakes">
        <small id="nameError" class="err-msg"></small>
      </div>
      <div class="modal-row">
        <div>
          <label class="form-label">Image</label>
          <div id="imageBox" class="img-box" onclick="document.getElementById('catImage').click()">
            <img id="preview" style="display:none">
            <span id="imgText"><i class="ti ti-photo" style="display:block;font-size:20px;margin-bottom:4px;"></i>Add image</span>
          </div>
          <small id="imgError" class="err-msg"></small>
          <input type="file" id="catImage" hidden accept="image/*" onchange="previewImage(event)">
        </div>
        <div style="flex:1">
          <label class="form-label">Description</label>
          <textarea id="catDesc" class="form-textarea" placeholder="Short description…"></textarea>
          <small id="descError" class="err-msg"></small>
        </div>
      </div>
      <div>
        <label class="form-label">Status</label>
        <select id="catStatus" class="form-select">
          <option value="true">Active</option>
          <option value="false">Inactive</option>
        </select>
      </div>
    </div>
    <div class="modal-ft">
      <button class="btn btn-secondary btn-sm" onclick="closeAddModal()">Cancel</button>
      <button class="btn-save" onclick="submitCategory()">Add category</button>
    </div>
  </div>
</div>

<!-- ── EDIT MODAL ── -->
<div class="modal-overlay" id="editModal">
  <div class="modal-box">
    <div class="modal-hd">
      <h5><i class="ti ti-edit"></i> Edit category</h5>
      <button class="modal-close" onclick="closeEditModal()">×</button>
    </div>
    <div class="modal-bd">
      <input type="hidden" id="editId">
      <div>
        <label class="form-label">Name</label>
        <input type="text" id="editName" class="form-input">
        <small id="editNameError" class="err-msg"></small>
      </div>
      <div class="modal-row">
        <div>
          <label class="form-label">Thumbnail</label>
          <div id="editImageBox" class="img-box" onclick="document.getElementById('editImage').click()">
            <img id="editPreview" style="width:100%;height:100%;object-fit:cover;">
          </div>
          <small id="editImgError" class="err-msg"></small>
          <input type="file" id="editImage" hidden accept="image/*" onchange="previewEditImage(event)">
        </div>
        <div style="flex:1">
          <label class="form-label">Description</label>
          <textarea id="editDesc" class="form-textarea"></textarea>
          <small id="editDescError" class="err-msg"></small>
        </div>
      </div>
      <div>
        <label class="form-label">Status</label>
        <select id="editStatus" class="form-select">
          <option value="true">Active</option>
          <option value="false">Inactive</option>
        </select>
      </div>
    </div>
    <div class="modal-ft">
      <button class="btn btn-secondary btn-sm" onclick="closeEditModal()">Cancel</button>
      <button class="btn-save" onclick="updateCategory()">Update category</button>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
// ── MODAL OPEN/CLOSE ──
function openAddModal()  { document.getElementById("addModal").classList.add("open"); }
function closeAddModal() { document.getElementById("addModal").classList.remove("open"); }
function openEditModal(id, name, desc, image, status) {
  document.getElementById("editId").value     = id;
  document.getElementById("editName").value   = name;
  document.getElementById("editDesc").value   = desc;
  document.getElementById("editStatus").value = status;
  const ep = document.getElementById("editPreview");
  ep.src = image || "";
  ep.style.display = image ? "block" : "none";
  document.getElementById("editModal").classList.add("open");
}
function closeEditModal() { document.getElementById("editModal").classList.remove("open"); }

["addModal","editModal"].forEach(id => {
  document.getElementById(id).addEventListener("click", function(e) {
    if (e.target === this) this.classList.remove("open");
  });
});

// ── IMAGE PREVIEW ──
function previewImage(e) {
  const file = e.target.files[0]; if (!file) return;
  const prev = document.getElementById("preview");
  prev.src = URL.createObjectURL(file);
  prev.style.display = "block";
  document.getElementById("imgText").style.display = "none";
  document.getElementById("imgError").innerText = "";
  document.getElementById("imageBox").classList.remove("err");
}
function previewEditImage(e) {
  const file = e.target.files[0]; if (!file) return;
  const ep = document.getElementById("editPreview");
  ep.src = URL.createObjectURL(file);
  ep.style.display = "block";
  document.getElementById("editImgError").innerText = "";
  document.getElementById("editImageBox").classList.remove("err");
}

// ── VALIDATION HELPERS ──
function setErr(inputEl, errEl, msg) {
  if (inputEl) inputEl.classList.add("err");
  errEl.innerText = msg;
}
function clearErr(inputEl, errEl) {
  if (inputEl) inputEl.classList.remove("err");
  errEl.innerText = "";
}
function validateImage(file, boxEl, errEl) {
  if (!file) { setErr(null, errEl, "Image required"); boxEl.classList.add("err"); return false; }
  const valid = ["image/jpeg","image/png","image/jpg"];
  if (!valid.includes(file.type)) { setErr(null, errEl, "Only JPG/PNG allowed"); boxEl.classList.add("err"); return false; }
  if (file.size > 2*1024*1024)    { setErr(null, errEl, "Max size 2MB"); boxEl.classList.add("err"); return false; }
  boxEl.classList.remove("err"); boxEl.classList.add("ok"); return true;
}

// ── SUBMIT ADD ──
function submitCategory() {
  const name    = document.getElementById("catName");
  const desc    = document.getElementById("catDesc");
  const image   = document.getElementById("catImage").files[0];
  const nameErr = document.getElementById("nameError");
  const descErr = document.getElementById("descError");
  const imgErr  = document.getElementById("imgError");
  const imgBox  = document.getElementById("imageBox");

  clearErr(name, nameErr); clearErr(desc, descErr); imgErr.innerText = ""; imgBox.classList.remove("err","ok");

  let ok = true;
  if (!name.value.trim())                { setErr(name, nameErr, "Name required"); ok = false; }
  else if (name.value.trim().length < 3) { setErr(name, nameErr, "Min 3 characters"); ok = false; }
  if (!desc.value.trim())                { setErr(desc, descErr, "Description required"); ok = false; }
  if (!validateImage(image, imgBox, imgErr)) ok = false;
  if (!ok) return;

  const fd = new FormData();
  fd.append("name", name.value.trim());
  fd.append("description", desc.value.trim());
  fd.append("image", image);
  fd.append("isActive", document.getElementById("catStatus").value);

fetch("/admin/category/add", { method: "POST", body: fd })
    .then(r => r.json())
    .then(data => {
      closeAddModal();   // ← close modal first, then show Swal
      if (!data.success) {
        Swal.fire({ icon: "error", title: "Failed!", text: data.message || "Something went wrong", confirmButtonColor: "#A85F6E" });
        return;
      }
      Swal.fire({ icon: "success", title: "Category Added!", text: data.message, timer: 1500, showConfirmButton: false })
        .then(() => location.reload());
    })

    .catch(() => {
      Swal.fire({ icon: "error", title: "Network Error", text: "Could not connect. Please try again.", confirmButtonColor: "#A85F6E" });
    });
}

// ── SUBMIT EDIT ──
function updateCategory() {
  const name    = document.getElementById("editName");
  const desc    = document.getElementById("editDesc");
  const image   = document.getElementById("editImage").files[0];
  const nameErr = document.getElementById("editNameError");
  const descErr = document.getElementById("editDescError");
  const imgErr  = document.getElementById("editImgError");
  const imgBox  = document.getElementById("editImageBox");

  clearErr(name, nameErr); clearErr(desc, descErr); imgErr.innerText = ""; imgBox.classList.remove("err","ok");

  let ok = true;
  if (!name.value.trim())              { setErr(name, nameErr, "Name required"); ok = false; }
  else if (name.value.trim().length<3) { setErr(name, nameErr, "Min 3 characters"); ok = false; }
  if (!desc.value.trim())              { setErr(desc, descErr, "Description required"); ok = false; }
  if (image && !validateImage(image, imgBox, imgErr)) ok = false;
  if (!ok) return;

  const fd = new FormData();
  fd.append("name", name.value.trim());
  fd.append("description", desc.value.trim());
  fd.append("isActive", document.getElementById("editStatus").value);
  if (image) fd.append("image", image);

  fetch(`/admin/category/edit/${document.getElementById("editId").value}`, { method: "PATCH", body: fd })
    .then(r => r.json())
 .then(data => {
      closeEditModal();   // ← close modal first, then show Swal
      if (!data.success) {
        Swal.fire({ icon: "error", title: "Duplicate Category!", text: data.message, confirmButtonColor: "#A85F6E" });
        return;
      }
      Swal.fire({ icon: "success", title: "Updated!", timer: 1500, showConfirmButton: false })
        .then(() => location.reload());
    })
    .catch(() => {
      Swal.fire({ icon: "error", title: "Network Error", text: "Could not connect. Please try again.", confirmButtonColor: "#A85F6E" });
    });
}

// ── TOGGLE STATUS ──
function toggleStatus(id) {
  fetch(`/admin/category/status/${id}`, { method: "PATCH" }).then(() => location.reload());
}

// ── CATEGORY OFFER ──
async function saveCategoryOffer(categoryId, categoryName) {
  const input = document.getElementById('offerInput_' + categoryId);
  const value = input.value.trim();

  if (value === '' || isNaN(value)) {
    Swal.fire({ icon: 'warning', title: 'Invalid Value', text: 'Please enter a valid offer percentage.', confirmButtonColor: '#A85F6E' });
    return;
  }

  const percent = Number(value);
  if (percent < 0 || percent > 100) {
    Swal.fire({ icon: 'warning', title: 'Invalid Range', text: 'Offer must be between 0 and 100.', confirmButtonColor: '#A85F6E' });
    return;
  }

  const result = await Swal.fire({
    icon: 'question',
    title: percent === 0 ? 'Remove Offer?' : 'Apply Offer?',
    html: percent === 0
      ? `Remove category offer from <b>${categoryName}</b>?`
      : `Apply <b>${percent}% OFF</b> to all products in <b>${categoryName}</b>?`,
    showCancelButton: true,
    confirmButtonColor: '#A85F6E',
    cancelButtonColor:  '#B08A8A',
    confirmButtonText:  percent === 0 ? 'Remove' : 'Apply',
    cancelButtonText:   'Cancel'
  });

  if (!result.isConfirmed) return;

  try {
    const res  = await fetch('/admin/add-category-offer', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ categoryId, offerPercentage: percent })
    });
    const data = await res.json();
    if (data.success) {
      Swal.fire({ icon: 'success', title: 'Success', text: data.message, confirmButtonColor: '#A85F6E', timer: 2000, showConfirmButton: false })
        .then(() => location.reload());
    } else {
      Swal.fire({ icon: 'error', title: 'Failed', text: data.message || 'Something went wrong', confirmButtonColor: '#A85F6E' });
    }
  } catch (err) {
    Swal.fire({ icon: 'error', title: 'Error', text: 'Network error. Please try again.', confirmButtonColor: '#A85F6E' });
  }
}

// ── SEARCH ──
const searchInput = document.getElementById("searchInput");
const clearIcon   = document.getElementById("clearIcon");
const searchForm  = document.getElementById("searchForm");

searchInput.addEventListener("keydown", function (e) {
  if (e.key === "Enter") { e.preventDefault(); searchForm.submit(); }
});

clearIcon.addEventListener("click", function () {
  window.location.href = "/admin/category";
});

let searchTimer;
searchInput.addEventListener("input", function () {
  clearIcon.classList.toggle("d-none", !this.value.trim());
  clearTimeout(searchTimer);
  searchTimer = setTimeout(() => {
    const addOpen  = document.getElementById("addModal").classList.contains("open");
    const editOpen = document.getElementById("editModal").classList.contains("open");
    if (addOpen || editOpen) return;
    if (this.value.trim()) searchForm.submit();
    else window.location.href = "/admin/category";
  }, 500);
});
</script>