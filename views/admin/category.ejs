<!-- CATEGORY PAGE -->

<style>
  /* ===== PAGE HEADER ===== */
  .top-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }

  .top-bar h1 {
    font-size: 32px;
    font-weight: 700;
    color: #4a2b2b;
  }

  .add-btn {
    background: #c75c5c;
    color: #fff;
    border: none;
    padding: 10px 18px;
    border-radius: 10px;
    font-weight: 600;
    cursor: pointer;
  }

  /* ===== CONTROLS ===== */
  .controls {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 25px;
  }

  .search-box {
    display: flex;
    width: 320px;
    margin-bottom: 25px;
  }

  .search-box input {
    flex: 1;
    padding: 10px 14px;
    border-radius: 10px 0 0 10px;
    border: none;
    background: #ddb0b0;
  }

  .search-box button {
    border: none;
    padding: 10px 14px;
    background: #c75c5c;
    color: #fff;
    border-radius: 0 10px 10px 0;
    cursor: pointer;
  }

  /* ===== TABLE ===== */
  .table-wrapper {
    background: #fff;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  thead {
    background: #b85b5b;
    color: #fff;
  }

  th, td {
    padding: 16px;
    font-size: 14px;
    text-align: left;
  }

  tbody tr {
    border-bottom: 1px solid #f1f1f1;
  }

  .category-cell {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .icon {
    width: 38px;
    height: 38px;
    border-radius: 10px;
    overflow: hidden;
  }

  .icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .category-name {
    font-weight: 600;
  }

  .desc {
    max-width: 350px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: #7a5a5a;
  }

  .status {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #b85b5b;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    cursor: pointer;
  }

  .edit-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 18px;
  }

  /* ===== MODALS ===== */
  .modal {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 3000;
  }

  .modal-box {
    background: #fff;
    width: 560px;
    border-radius: 14px;
    overflow: hidden;
  }

  .modal-header {
    background: #b85b5b;
    color: #fff;
    padding: 14px 18px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .modal-body {
    padding: 18px;
  }

  .modal-footer {
    padding: 14px 18px;
    text-align: right;
  }

  .modal-body label {
    font-weight: 600;
    margin-top: 10px;
    display: block;
  }

  .modal-body input,
  .modal-body textarea,
  .modal-body select {
    width: 100%;
    padding: 10px;
    border-radius: 6px;
    border: 1px solid #ccc;
    margin-top: 6px;
  }

  .modal-row {
    display: flex;
    gap: 16px;
    margin-top: 10px;
  }

  .image-box {
    width: 140px;
    height: 120px;
    border: 2px dashed #ccc;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .image-box img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .error {
    color: red;
    font-size: 13px;
    margin-top: 8px;
  }

  .status-badge {
  padding: 6px 12px;
  border-radius: 12px;
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
}

.status-badge.active {
  background: #e6f4ea;
  color: #137333;
}

.status-badge.inactive {
  background: #fdecea;
  color: #b71c1c;
}
input.error-border, textarea.error-border {
  border: 1px solid red;
}

.error {
  color: red;
  font-size: 13px;
  display: block;
  margin-top: 4px;
}
.image-box.error-border {
  border: 2px solid red;
}

.image-box.success-border {
  border: 2px solid #28a745;
}

.error {
  color: #e53935;
  font-size: 13px;
  margin-top: 5px;
}
.image-box {
  transition: all 0.3s ease;
}
 .swal2-container {
    z-index: 9999 !important;
  }
  #clearBtn {
  display: none; /* hidden initially */
  margin-left: 8px;
}
</style>

<!-- ===== HEADER ===== -->
<div class="top-bar">
  <h1>Categories</h1>
  <button class="add-btn" onclick="openAddModal()">+ New</button>
</div>

<!-- ===== SEARCH ===== -->
<form method="GET" action="/admin/category" class="search-box">
  <input 
    type="text" 
    name="search" 
    id="searchInput"
    placeholder="Search category name..." 
    value="<%= search || '' %>"
  >

  <button type="submit">Search</button>

  <!-- 👇 Clear button (hidden initially) -->
  <button type="button" id="clearBtn" onclick="clearSearch()">Clear</button>
</form>

<!-- ===== TABLE ===== -->
<div class="table-wrapper">
  <table>
    <thead>
      <tr>
        <th>Category Info</th>
        <th>Description</th>
        <th>Created</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (cat && cat.length) { %>
        <% cat.forEach(item => { %>
          <tr>
          <td>
  <div class="category-cell">
    <div class="icon">
      <img src="<%= item.image ||'/images/default-category.png' %>">
    </div>
    <div class="category-name"><%= item.name %></div>
  </div>
</td>

            <td class="desc"><%= item.description %></td>
<td><%= new Date(item.createdAt).toLocaleDateString("en-IN", {
  day: "2-digit",
  month: "short",
  year: "numeric"
}) %></td>

            <td>
  <span
    class="status-badge <%= item.isActive ? 'active' : 'inactive' %>"
    onclick="toggleStatus('<%= item._id %>')"
  >
    <%= item.isActive ? 'Active' : 'Inactive' %>
  </span>
</td>



            <td>
              <button
                class="edit-btn"
                onclick="openEditModal(
                  '<%= item._id %>',
                  '<%= item.name %>',
                  '<%= item.description %>',
                  '<%= item.image %>',
                  '<%= item.isActive %>'
                )"
              >
                ✏️
              </button>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="5" style="text-align:center;padding:20px;">
            No categories found
          </td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>

<div class="d-flex justify-content-center mt-4">
  <ul class="pagination">

    <!-- PREVIOUS -->
    <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
      <a class="page-link" href="?page=<%= currentPage - 1 %>&search=<%= search || '' %>">Previous</a>
    </li>

    <!-- PAGE NUMBERS -->
    <% for (let i = 1; i <= totalPages; i++) { %>
      <li class="page-item <%= currentPage === i ? 'active' : '' %>">
        <a class="page-link" href="?page=<%= i %>&search=<%= search || '' %>">
          <%= i %>
        </a>
      </li>
    <% } %>

    <!-- NEXT -->
    <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
      <a class="page-link" href="?page=<%= currentPage + 1 %>&search=<%= search || '' %>">Next</a>
    </li>

  </ul>
</div>

<!-- ===== ADD MODAL ===== -->
<div class="modal" id="addModal">
  <div class="modal-box">
    <div class="modal-header">
      <h3>Add Category</h3>
      <span style="cursor:pointer" onclick="closeAddModal()">×</span>
    </div>

    <div class="modal-body">
      <label>Name</label>
      <input type="text" id="catName">
      <small id="nameError" class="error"></small>

      <div class="modal-row">
        <div>
          <label>Image</label>
<div id="imageBox" class="image-box" onclick="catImage.click()">   
           <span id="imgText">+ Add Image</span>
            <img id="preview" style="display:none">

          </div>
                        <small id="imgError" class="error"></small>

          <input type="file" id="catImage" hidden accept="image/*" onchange="previewImage(event)">
        </div>

        <div style="flex:1">
          <label>Description</label>
          <textarea id="catDesc"></textarea>
          <small id="descError" class="error"></small>
        </div>
      </div>

      <label>Status</label>
      <select id="catStatus">
        <option value="true">Active</option>
        <option value="false">Inactive</option>
      </select>
   </div>

    <div class="modal-footer">
      <button class="add-btn" onclick="submitCategory()">Add Category</button>
    </div>
  </div>
</div>

<!-- ===== EDIT MODAL ===== -->
<div class="modal" id="editModal">
  <div class="modal-box">
    <div class="modal-header">
      <h3>Update Category</h3>
      <span style="cursor:pointer" onclick="closeEditModal()">×</span>
    </div>

    <div class="modal-body">
      <input type="hidden" id="editId">

<label>Name</label>
<input type="text" id="editName">
<small id="editNameError" class="error"></small>

<div class="modal-row">
  <div>
    <label>Thumbnail</label>
    <div id="editImageBox" class="image-box" onclick="editImage.click()">
      <img id="editPreview">
    </div>
    <small id="editImgError" class="error"></small>
    <input type="file" id="editImage" hidden accept="image/*" onchange="previewEditImage(event)">
  </div>

  <div style="flex:1">
    <label>Description</label>
    <textarea id="editDesc"></textarea>
    <small id="editDescError" class="error"></small>
  </div>
</div>
      <label>Status</label>
      <select id="editStatus">
        <option value="true">Active</option>
        <option value="false">Inactive</option>
      </select>

      <p class="error" id="editError"></p>
    </div>

    <div class="modal-footer">
      <button class="add-btn" onclick="updateCategory()">Update Category</button>
    </div>
  </div>
</div>

<!-- ===== SCRIPTS ===== -->
 <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  const addModal = document.getElementById("addModal");
  const editModal = document.getElementById("editModal");

  function openAddModal() {
    addModal.style.display = "flex";
  
  }

  function closeAddModal() {
    addModal.style.display = "none";
  }



 function submitCategory() {

  const name = catName.value.trim();
  const desc = catDesc.value.trim();
  const image = catImage.files[0];

  let isValid = true;

  // RESET
  nameError.innerText = "";
  descError.innerText = "";
  imgError.innerText = "";

  catName.classList.remove("error-border");
  catDesc.classList.remove("error-border");

  // NAME
  if (!name) {
    nameError.innerText = "Category name required";
    catName.classList.add("error-border");
    isValid = false;
  } else if (name.length < 3) {
    nameError.innerText = "Minimum 3 characters";
    catName.classList.add("error-border");
    isValid = false;
  }

  // DESCRIPTION
  if (!desc) {
    descError.innerText = "Description required";
    catDesc.classList.add("error-border");
    isValid = false;
  }

// IMAGE VALIDATION
const imageBox = document.getElementById("imageBox");

// reset border
imageBox.classList.remove("error-border", "success-border");

if (!image) {
  imgError.innerText = "Image required";
  imageBox.classList.add("error-border");
  isValid = false;
} else {
  const validTypes = ["image/jpeg", "image/png", "image/jpg"];

  if (!validTypes.includes(image.type)) {
    imgError.innerText = "Only JPG/PNG allowed";
    imageBox.classList.add("error-border");
    isValid = false;
  } else if (image.size > 2 * 1024 * 1024) {
    imgError.innerText = "Max size 2MB";
    imageBox.classList.add("error-border");
    isValid = false;
  } else {
    // ✅ SUCCESS STYLE
    imageBox.classList.add("success-border");
    imgError.innerText = "";
  }
}
  if (!isValid) return;

  // SEND DATA
  const formData = new FormData();
  formData.append("name", name);
  formData.append("description", desc);
  formData.append("image", image);
  formData.append("isActive", catStatus.value);

  fetch("/admin/category/add", {
    method: "POST",
    body: formData
  })
  .then(res => res.json())
  .then(data => {

    if (!data.success) {
      Swal.fire({
        icon: "error",
        title: "Error",
        text: data.message
      });
      return;
    }

    Swal.fire({
      icon: "success",
      title: "Success",
      text: "Category added successfully",
      timer: 1500,
      showConfirmButton: false
    }).then(() => {
      location.reload();
    });

  });
}
  function softDeleteCategory(id) {
    if (!confirm("Delete this category?")) return;
    fetch(`/admin/category/delete/${id}`, { method: "DELETE" })
      .then(() => location.reload());
  }

  function openEditModal(id, name, desc, image, status) {
    editId.value = id;
    editName.value = name;
    editDesc.value = desc;
    editStatus.value = status;
    editPreview.src = image;
    editModal.style.display = "flex";
  }

  function closeEditModal() {
    editModal.style.display = "none";
    editError.innerText = "";
  }

  function previewEditImage(e) {
    editPreview.src = URL.createObjectURL(e.target.files[0]);
  }

  function updateCategory() {
  const name = editName.value.trim();
  const desc = editDesc.value.trim();
  const image = editImage.files[0];

  let isValid = true;

  // RESET
  document.getElementById("editNameError").innerText = "";
  document.getElementById("editDescError").innerText = "";
  document.getElementById("editImgError").innerText = "";
  editName.classList.remove("error-border");
  editDesc.classList.remove("error-border");
  document.getElementById("editImageBox").classList.remove("error-border", "success-border");

  // NAME
  if (!name) {
    document.getElementById("editNameError").innerText = "Category name required";
    editName.classList.add("error-border");
    isValid = false;
  } else if (name.length < 3) {
    document.getElementById("editNameError").innerText = "Minimum 3 characters";
    editName.classList.add("error-border");
    isValid = false;
  }

  // DESCRIPTION
  if (!desc) {
    document.getElementById("editDescError").innerText = "Description required";
    editDesc.classList.add("error-border");
    isValid = false;
  }

  // IMAGE — only validate if a new file is selected
  if (image) {
    const validTypes = ["image/jpeg", "image/png", "image/jpg"];
    if (!validTypes.includes(image.type)) {
      document.getElementById("editImgError").innerText = "Only JPG/PNG allowed";
      document.getElementById("editImageBox").classList.add("error-border");
      isValid = false;
    } else if (image.size > 2 * 1024 * 1024) {
      document.getElementById("editImgError").innerText = "Max size 2MB";
      document.getElementById("editImageBox").classList.add("error-border");
      isValid = false;
    } else {
      document.getElementById("editImageBox").classList.add("success-border");
    }
  }

  if (!isValid) return;

  const formData = new FormData();
  formData.append("name", name);
  formData.append("description", desc);
  formData.append("isActive", editStatus.value);
  if (image) formData.append("image", editImage.files[0]);

  fetch(`/admin/category/edit/${editId.value}`, {
    method: "PATCH",
    body: formData
  })
  .then(res => res.json())
  .then(data => {
    if (!data.success) {
      Swal.fire({ icon: "error", title: "Error", text: data.message });
      return;
    }
    Swal.fire({
      icon: "success",
      title: "Updated",
      text: "Category updated successfully",
      timer: 1500,
      showConfirmButton: false
    }).then(() => location.reload());
  });
}
function previewEditImage(e) {
  const file = e.target.files[0];
  if (!file) return;
  editPreview.src = URL.createObjectURL(file);
  document.getElementById("editImgError").innerText = "";
  document.getElementById("editImageBox").classList.remove("error-border");
}

  function toggleStatus(id) {
  fetch(`/admin/category/status/${id}`, { method: "PATCH" })
    .then(() => location.reload());
}

function previewImage(e) {
  const file = e.target.files[0];

  if (!file) return;

  preview.src = URL.createObjectURL(file);
  preview.style.display = "block";
  imgText.style.display = "none";

  // remove error UI
  imgError.innerText = "";
  document.getElementById("imageBox").classList.remove("error-border");
}
</script>
<script>
  // 👇 ADD THIS AT THE END

  document.querySelector(".search-box").addEventListener("submit", function(e) {
    const input = this.querySelector("input[name='search']");
    
    if (!input.value.trim()) {
      e.preventDefault(); // stop submit
      window.location.href = "/admin/category"; // reset page
    }
  });

</script>
<script>
// show/hide clear button
const searchInput = document.getElementById("searchInput");
const clearBtn = document.getElementById("clearBtn");

// when page loads
if (searchInput.value.trim() !== "") {
  clearBtn.style.display = "inline-block";
}

// when typing
searchInput.addEventListener("input", function () {
  if (this.value.trim() !== "") {
    clearBtn.style.display = "inline-block";
  } else {
    clearBtn.style.display = "none";
  }
});

// clear function
function clearSearch() {
  window.location.href = "/admin/category";
}
</script>