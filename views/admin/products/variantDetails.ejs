<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css">

<style>
:root {
  --rose: #C97B8A; --rose-dk: #A85F6E; --rose-lt: #FAE8ED;
  --blush: #FDF0F3; --caramel: #D4A574; --brown: #5C3A3A;
  --muted: #B08A8A; --border: #F5D8E0; --mint: #E8F6F0; --white: #FFFFFF;
  --green: #28a745; --red: #dc3545; --gray: #6c757d;
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.94); }
  to   { opacity: 1; transform: scale(1); }
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.5; }
}

.vd { padding: 1.5rem 1rem; }

/* ── HEADER ── */
.vd-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 1.5rem;
  animation: fadeUp .4s ease both;
  flex-wrap: wrap;
  gap: 12px;
}
.vd-title { font-size: 20px; font-weight: 500; color: var(--brown); display: flex; align-items: center; gap: 8px; }
.vd-title i { color: var(--rose); font-size: 20px; }
.vd-sub { font-size: 12px; color: var(--muted); margin-top: 5px; display: flex; gap: 12px; flex-wrap: wrap; }
.vd-sub span { display: flex; align-items: center; gap: 4px; }
.vd-sub i { font-size: 13px; color: var(--rose); }

.add-btn {
  display: flex;
  align-items: center;
  gap: 7px;
  background: var(--rose);
  color: var(--white);
  border: none;
  padding: 0 18px;
  height: 36px;
  border-radius: 24px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: background .2s, transform .15s;
  white-space: nowrap;
  box-shadow: 0 2px 8px rgba(175,84,84,.2);
}
.add-btn:hover { background: var(--rose-dk); transform: translateY(-1px); }
.add-btn i { font-size: 15px; }

/* ── METRIC CARDS ── */
.metrics {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12px;
  margin-bottom: 1.5rem;
}
.metric {
  background: var(--white);
  border: 0.5px solid var(--border);
  border-radius: 12px;
  padding: 1rem 1.25rem;
  border-top: 3px solid var(--rose);
  opacity: 0;
  animation: fadeUp .5s ease forwards;
  transition: transform .2s ease;
}
.metric:hover { transform: translateY(-3px); }
.metric.m2 { border-top-color: var(--caramel); animation-delay: .08s; }
.metric.m3 { border-top-color: #7BB88A;        animation-delay: .16s; }
.metric.m4 { border-top-color: var(--muted);   animation-delay: .24s; }

.metric-icon {
  width: 34px; height: 34px; border-radius: 8px;
  background: var(--rose-lt);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 10px; transition: transform .2s;
}
.metric:hover .metric-icon { transform: scale(1.1); }
.metric-icon i { font-size: 17px; color: var(--rose); }
.metric.m2 .metric-icon { background: #FEF0E8; }
.metric.m2 .metric-icon i { color: var(--caramel); }
.metric.m3 .metric-icon { background: var(--mint); }
.metric.m3 .metric-icon i { color: #5A9A6A; }
.metric.m4 .metric-icon { background: #F5F0F0; }
.metric.m4 .metric-icon i { color: var(--muted); }

.metric-label { font-size: 11px; color: var(--muted); letter-spacing: .05em; text-transform: uppercase; margin-bottom: 4px; }
.metric-value { font-size: 26px; font-weight: 500; color: var(--brown); line-height: 1; }
.metric-sub   { font-size: 11px; color: var(--muted); margin-top: 4px; }

/* ── TABLE CARD ── */
.table-card {
  background: var(--white);
  border: 0.5px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
  opacity: 0;
  animation: scaleIn .5s ease .3s forwards;
  margin-bottom: 1.25rem;
}
.table-card-header {
  padding: 1rem 1.25rem;
  display: flex; justify-content: space-between; align-items: center;
  border-bottom: 0.5px solid var(--border);
}
.table-card-title { font-size: 14px; font-weight: 500; color: var(--brown); display: flex; align-items: center; gap: 6px; }
.table-card-title i { color: var(--rose); font-size: 16px; }
.live-badge {
  font-size: 10px; padding: 3px 8px; border-radius: 20px;
  background: var(--rose-lt); color: var(--rose-dk);
  display: flex; align-items: center; gap: 4px;
}
.live-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--rose); animation: pulse 1.8s ease infinite; }

table { width: 100%; border-collapse: collapse; }
thead {
  background: var(--blush);
  border-bottom: 1px solid var(--border);
}
thead th {
  padding: 11px 16px; color: var(--muted); font-size: 11px;
  font-weight: 500; text-align: center; letter-spacing: .06em;
  text-transform: uppercase;
}
tbody td { padding: 14px 16px; font-size: 13px; color: var(--brown); text-align: center; vertical-align: middle; border-bottom: 0.5px solid var(--rose-lt); }
tbody tr:last-child td { border-bottom: none; }
tbody tr { transition: background .15s; }
tbody tr:hover { background: var(--blush); }

/* ── STATUS BADGES ── */
.status-badge {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; letter-spacing: .04em;
}
.badge-active    { background: #E8F6EE; color: #1F7A47; }
.badge-expired   { background: #FDE8E8; color: #9B2222; }
.badge-exhausted { background: #F0F0F0; color: #5C5C5C; }
.badge-dot { width: 5px; height: 5px; border-radius: 50%; }
.badge-active .badge-dot    { background: #28a745; }
.badge-expired .badge-dot   { background: #dc3545; }
.badge-exhausted .badge-dot { background: #6c757d; }

/* ── ACTION BUTTONS ── */
.edit-btn {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 11px;
  padding: 4px 12px;
  border-radius: 20px;
  border: 0.5px solid var(--border);
  background: var(--white);
  color: var(--muted);
  cursor: pointer;
  transition: all .2s;
}
.edit-btn:hover { border-color: var(--caramel); color: var(--caramel); background: #FEF0E8; }

/* ── BACK LINK ── */
.back-link {
  display: inline-flex; align-items: center; gap: 6px;
  font-size: 13px; color: var(--muted); text-decoration: none;
  padding: 8px 16px; border: 0.5px solid var(--border);
  border-radius: 20px; background: var(--white);
  transition: all .2s; opacity: 0;
  animation: fadeUp .4s ease .5s forwards;
}
.back-link:hover { color: var(--rose-dk); border-color: var(--rose); background: var(--rose-lt); }

/* ── EMPTY STATE ── */
.empty-state { text-align: center; padding: 3rem 1rem; color: var(--muted); font-size: 13px; }
.empty-state i { font-size: 32px; margin-bottom: 8px; display: block; color: var(--border); }

/* ── MODALS ── */
.modal-header { border-bottom: 0.5px solid var(--border); }
.modal-footer { border-top: 0.5px solid var(--border); }
.modal-title  { font-size: 15px; font-weight: 600; color: var(--brown); display: flex; align-items: center; gap: 6px; }
.modal-title i { color: var(--rose); }
.modal-content { border-radius: 12px; border: 0.5px solid var(--border); }
.form-label   { font-size: 12px; color: var(--muted); font-weight: 500; margin-bottom: 4px; text-transform: uppercase; letter-spacing: .05em; }
.form-control { font-size: 13px; border: 0.5px solid var(--border); border-radius: 8px; }
.form-control:focus { box-shadow: none; border-color: var(--rose); }
.form-control.is-invalid { background-image: none !important; border-color: #dc3545; }
small.text-danger { font-size: 11px; margin-top: 4px; display: block; }
.btn-save {
  background: var(--rose);
  color: #fff; border: none; padding: 7px 20px;
  border-radius: 20px; font-size: 13px; font-weight: 500; cursor: pointer;
  transition: background .2s, transform .15s;
}
.btn-save:hover { background: var(--rose-dk); transform: translateY(-1px); }

.btn-secondary {
  font-size: 13px;
  padding: 7px 18px;
  border-radius: 20px;
  border: 0.5px solid var(--border);
  background: var(--white);
  color: var(--muted);
  cursor: pointer;
  transition: all .2s;
}
.btn-secondary:hover { border-color: var(--rose); color: var(--rose); }

@media (max-width: 768px) {
  .metrics { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 480px) {
  .metrics { grid-template-columns: 1fr; }
}

/* ── MODAL POSITIONING FIX ── */
.modal { padding-top: 60px !important; }
.modal-dialog { margin: 80px auto 20px auto; }
</style>

<div class="vd">

  <!-- HEADER -->
  <div class="vd-header">
    <div>
      <div class="vd-title">
        <i class="ti ti-box" aria-hidden="true"></i>
        <%= variant.productId.productName %>
      </div>
      <div class="vd-sub">
        <span><i class="ti ti-weight" aria-hidden="true"></i>
          <%= variant.weight >= 1000 ? (variant.weight/1000) + ' kg' : variant.weight + ' g' %>
        </span>
        <span><i class="ti ti-currency-rupee" aria-hidden="true"></i> Cost ₹<%= variant.costPrice %></span>
        <span><i class="ti ti-tag" aria-hidden="true"></i> Regular ₹<%= variant.regularPrice %></span>
      </div>
    </div>
    <button class="add-btn" data-bs-toggle="modal" data-bs-target="#addBatchModal">
      <i class="ti ti-plus" aria-hidden="true"></i> Add Batch
    </button>
  </div>

  <!-- METRIC CARDS -->
  <%
    const totalBatches   = batches.length;
    const activeBatches  = batches.filter(b => b.status === 'active').length;
    const totalStock     = batches.reduce((s,b) => s + b.availableStock, 0);
    const expiredBatches = batches.filter(b => b.status === 'expired').length;
  %>
  <div class="metrics">
    <div class="metric m1">
      <div class="metric-icon"><i class="ti ti-packages" aria-hidden="true"></i></div>
      <div class="metric-label">Total batches</div>
      <div class="metric-value"><%= totalBatches %></div>
      <div class="metric-sub">All time</div>
    </div>
    <div class="metric m2">
      <div class="metric-icon"><i class="ti ti-circle-check" aria-hidden="true"></i></div>
      <div class="metric-label">Active batches</div>
      <div class="metric-value"><%= activeBatches %></div>
      <div class="metric-sub"><%= totalBatches > 0 ? Math.round(activeBatches/totalBatches*100) : 0 %>% of total</div>
    </div>
    <div class="metric m3">
      <div class="metric-icon"><i class="ti ti-stack" aria-hidden="true"></i></div>
      <div class="metric-label">Available stock</div>
      <div class="metric-value"><%= totalStock %></div>
      <div class="metric-sub">Units in hand</div>
    </div>
    <div class="metric m4">
      <div class="metric-icon"><i class="ti ti-clock-x" aria-hidden="true"></i></div>
      <div class="metric-label">Expired batches</div>
      <div class="metric-value"><%= expiredBatches %></div>
      <div class="metric-sub"><%= totalBatches > 0 ? Math.round(expiredBatches/totalBatches*100) : 0 %>% rate</div>
    </div>
  </div>

  <!-- BATCH TABLE -->
  <div class="table-card">
    <div class="table-card-header">
      <div class="table-card-title">
        <i class="ti ti-list-details" aria-hidden="true"></i> Batch inventory
      </div>
      <div class="live-badge">
        <span class="live-dot"></span> Live
      </div>
    </div>

    <% if (batches.length === 0) { %>
      <div class="empty-state">
        <i class="ti ti-inbox" aria-hidden="true"></i>
        No batches found. Add your first batch.
      </div>
    <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Manufactured</th>
          <th>Expiry</th>
          <th>Initial Stock</th>
          <th>Available</th>
          <th>Status</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% batches.forEach(batch => { %>
        <tr>
          <td><%= new Date(batch.manufacturedAt).toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }) %></td>
          <td><%= new Date(batch.expiryAt).toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }) %></td>
          <td><%= batch.initialStock %></td>
          <td>
            <span style="font-weight:600; color:<%= batch.availableStock > 0 ? '#1F7A47' : '#9B2222' %>">
              <%= batch.availableStock %>
            </span>
          </td>
          <td>
            <span class="status-badge badge-<%= batch.status %>">
              <span class="badge-dot"></span>
              <%= batch.status.charAt(0).toUpperCase() + batch.status.slice(1) %>
            </span>
          </td>
          <td>
            <button
              class="edit-btn edit-batch-btn"
              data-id="<%= batch._id %>"
              data-mfd="<%= new Date(batch.manufacturedAt).toLocaleDateString('en-CA') %>"
              data-stock="<%= batch.initialStock %>"
              data-expiry="<%= Math.round((new Date(batch.expiryAt) - new Date(batch.manufacturedAt)) / (1000*60*60*24)) %>"
            >
              <i class="ti ti-edit" aria-hidden="true"></i> Edit
            </button>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>

  <!-- BACK LINK -->
  <a href="/admin/products/<%= variant.productId._id %>" class="back-link">
    <i class="ti ti-arrow-left" aria-hidden="true"></i> Back to product
  </a>

</div>


<!-- ── ADD BATCH MODAL ── -->
<div class="modal fade" id="addBatchModal" tabindex="-1">
  <div class="modal-dialog">
    <form action="/admin/batches/add" method="post" class="modal-content" id="addBatchForm">
      <input type="hidden" name="variantId" value="<%= variant._id %>">
      <input type="hidden" name="productId" value="<%= variant.productId._id %>">

      <div class="modal-header">
        <h5 class="modal-title"><i class="ti ti-plus" aria-hidden="true"></i> Add batch</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body" style="display:flex;flex-direction:column;gap:14px;padding:1.25rem;">
        <div>
          <label class="form-label">Manufactured date</label>
          <input type="text" name="manufacturedAt" id="mfd" class="form-control" readonly>
        </div>
        <div>
          <label class="form-label">Expiry days</label>
          <input type="number" name="expiryDays" id="expiryDays" class="form-control" min="1" placeholder="e.g. 30">
          <small id="expiryError" class="text-danger d-none"></small>
        </div>
        <div>
          <label class="form-label">Initial stock</label>
          <input type="number" name="initialStock" id="stock" class="form-control" min="1" placeholder="e.g. 100">
          <small id="stockError" class="text-danger d-none"></small>
        </div>
      </div>

      <div class="modal-footer" style="gap:8px;">
        <button type="button" class="btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn-save">Save batch</button>
      </div>
    </form>
  </div>
</div>

<!-- ── EDIT BATCH MODAL ── -->
<div class="modal fade" id="editBatchModal" tabindex="-1">
  <div class="modal-dialog">
    <form id="editBatchForm" method="post" class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="ti ti-edit" aria-hidden="true"></i> Edit batch</h5>
        <button class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" style="display:flex;flex-direction:column;gap:14px;padding:1.25rem;">
        <div>
          <label class="form-label">Manufactured date</label>
          <input type="date" name="manufacturedAt" id="editManufactured" class="form-control" required>
        </div>
        <div>
          <label class="form-label">Expiry days</label>
          <input type="number" name="expiryDays" id="editExpiryDays" class="form-control" min="1" required>
          <small id="editExpiryError" class="text-danger d-none"></small>
        </div>
        <div>
          <label class="form-label">Initial stock</label>
          <input type="number" name="initialStock" id="editStock" class="form-control" min="1" required>
          <small id="editStockError" class="text-danger d-none"></small>
        </div>
      </div>
      <div class="modal-footer" style="gap:8px;">
        <button type="button" class="btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn-save">Update batch</button>
      </div>
    </form>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
  // SET TODAY'S DATE
  document.getElementById("mfd").value = new Date().toISOString().split("T")[0];

  // EDIT MODAL OPEN
  const editModal = new bootstrap.Modal(document.getElementById("editBatchModal"));
  document.querySelectorAll(".edit-batch-btn").forEach(btn => {
    btn.addEventListener("click", function () {
      document.getElementById("editManufactured").value  = this.dataset.mfd;
      document.getElementById("editStock").value         = this.dataset.stock;
      document.getElementById("editExpiryDays").value    = this.dataset.expiry;
      document.getElementById("editBatchForm").action    = `/admin/batches/edit/${this.dataset.id}`;
      editModal.show();
    });
  });

  // ADD FORM VALIDATION + SWAL
  let isSubmittingAdd = false;
  document.getElementById("addBatchForm").addEventListener("submit", function (e) {
    if (isSubmittingAdd) return;
    let valid = true;
    const expiry = document.getElementById("expiryDays");
    const stock  = document.getElementById("stock");
    const eErr   = document.getElementById("expiryError");
    const sErr   = document.getElementById("stockError");
    expiry.classList.remove("is-invalid"); eErr.classList.add("d-none");
    stock.classList.remove("is-invalid");  sErr.classList.add("d-none");
    if (!expiry.value || expiry.value <= 0) {
      expiry.classList.add("is-invalid"); eErr.innerText = "Enter valid expiry days"; eErr.classList.remove("d-none"); valid = false;
    }
    if (!stock.value || stock.value <= 0) {
      stock.classList.add("is-invalid"); sErr.innerText = "Enter valid stock"; sErr.classList.remove("d-none"); valid = false;
    }
    if (!valid) { e.preventDefault(); Swal.fire("Error", "Please fix the errors above.", "error"); return; }
    e.preventDefault();
    Swal.fire({ title: "Batch added!", text: "The batch has been saved.", icon: "success", confirmButtonColor: "#AF5454" })
      .then(() => { isSubmittingAdd = true; this.submit(); });
  });

  // EDIT FORM VALIDATION + SWAL
  let isSubmittingEdit = false;
  document.getElementById("editBatchForm").addEventListener("submit", function (e) {
    if (isSubmittingEdit) return;
    let valid = true;
    const expiry = document.getElementById("editExpiryDays");
    const stock  = document.getElementById("editStock");
    const eErr   = document.getElementById("editExpiryError");
    const sErr   = document.getElementById("editStockError");
    expiry.classList.remove("is-invalid"); eErr.classList.add("d-none");
    stock.classList.remove("is-invalid");  sErr.classList.add("d-none");
    if (!expiry.value || expiry.value <= 0) {
      expiry.classList.add("is-invalid"); eErr.innerText = "Enter valid expiry days"; eErr.classList.remove("d-none"); valid = false;
    }
    if (!stock.value || stock.value <= 0) {
      stock.classList.add("is-invalid"); sErr.innerText = "Enter valid stock"; sErr.classList.remove("d-none"); valid = false;
    }
    if (!valid) { e.preventDefault(); Swal.fire("Error", "Please fix the errors above.", "error"); return; }
    e.preventDefault();
    Swal.fire({ title: "Batch updated!", text: "Changes saved successfully.", icon: "success", confirmButtonColor: "#AF5454" })
      .then(() => { isSubmittingEdit = true; this.submit(); });
  });

  // LIVE VALIDATION – EDIT MODAL
  ["editExpiryDays","editStock"].forEach(id => {
    const el  = document.getElementById(id);
    const err = document.getElementById(id === "editExpiryDays" ? "editExpiryError" : "editStockError");
    el.addEventListener("input", function () {
      if (!this.value || this.value <= 0) {
        this.classList.add("is-invalid"); err.innerText = "Enter a valid value"; err.classList.remove("d-none");
      } else {
        this.classList.remove("is-invalid"); err.classList.add("d-none");
      }
    });
  });
</script>