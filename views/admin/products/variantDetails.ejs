<!-- VARIANT DETAILS PAGE -->

<style>
  /* REUSED PRODUCT PAGE THEME */
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 25px;
    flex-wrap: wrap;
    gap: 20px;
  }

  .page-title {
    font-size: 32px;
    font-weight: 700;
    color: #6d3939;
  }

  .variant-subtitle {
    font-size: 14px;
    color: #8b5a5a;
    margin-top: 4px;
  }

  .new-btn {
    background: linear-gradient(135deg, #AF5454, #d97373);
    color: #fff;
    border: none;
    padding: 12px 24px;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    box-shadow: 0 2px 8px rgba(175, 84, 84, .3);
  }

  .table-wrapper {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, .1);
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  thead {
    background: linear-gradient(135deg, #AF5454, #d97373);
  }

  thead th {
    padding: 16px;
    color: #fff;
    font-size: 14px;
    font-weight: 600;
  }

  tbody td {
    padding: 16px;
    font-size: 14px;
  }

  .badge-active {
    background: #28a745;
  }

  .badge-expired {
    background: #dc3545;
  }

  .badge-exhausted {
    background: #6c757d;
  }
  thead th,
tbody td{
text-align:center;
vertical-align:middle;
}

tbody tr:hover{
background:#f7f7f7;
}
.form-control.is-invalid {
  background-image: none !important;
}

small.text-danger {
  display: block;
  margin-top: 4px;
}
.form-control:focus {
  box-shadow: none;
  border-color: #AF5454;
}
.pagination {
  justify-content: center;
}
</style>

<!-- HEADER -->
<div class="page-header">
  <div>
    <h1 class="page-title">
      <%= variant.productId.productName %>
    </h1>
    <div class="variant-subtitle">
      Variant:
      <b>
        <%= variant.weight >= 1000
          ? variant.weight / 1000 + " kg"
          : variant.weight + " g" %>
      </b>
      • Cost ₹<%= variant.costPrice %>
      • Regular ₹<%= variant.regularPrice %>
      • Sale ₹<%= variant.salePrice %>
    </div>
  </div>

  <button
    class="new-btn"
    data-bs-toggle="modal"
    data-bs-target="#addBatchModal"
  >
    + Add Batch
  </button>
</div>

<!-- BATCH TABLE -->
<div class="table-wrapper">
  <table>
    <thead>
      <tr>
        <th>Manufactured</th>
        <th>Expiry</th>
        <th>Initial Stock</th>
        <th>Available Stock</th>
        <th>Status</th>
        <th>Action</th>
      </tr>
    </thead>

<tbody>
<% batches.forEach(batch => { %>

<tr>

<td><%= new Date(batch.manufacturedAt).toLocaleDateString() %></td>

<td><%= new Date(batch.expiryAt).toLocaleDateString() %></td>

<td><%= batch.initialStock %></td>

<td><%= batch.availableStock %></td>

<td>
<span class="badge
<%= batch.status === 'active' ? 'badge-active'
: batch.status === 'expired' ? 'badge-expired'
: 'badge-exhausted' %>">
<%= batch.status.toUpperCase() %>
</span>
</td>

<td>
<button
class="btn btn-sm btn-outline-warning edit-batch-btn"
data-id="<%= batch._id %>"
data-mfd="<%= new Date(batch.manufacturedAt).toLocaleDateString('en-CA') %>"data-stock="<%= batch.initialStock %>"
data-expiry="<%= Math.round((new Date(batch.expiryAt) - new Date(batch.manufacturedAt)) / (1000*60*60*24)) %>"
>
Edit
</button>
</td>

</tr>

<% }) %>
</tbody>
  </table>
</div>

<a href="/admin/products/<%= variant.productId._id %>" class="btn btn-secondary mt-4">
  ← Back to Variant
</a>





<!-- ADD BATCH MODAL -->
<div class="modal fade" id="addBatchModal" tabindex="-1">
  <div class="modal-dialog">
    <form action="/admin/batches/add" method="post" class="modal-content">

      <input type="hidden" name="variantId" value="<%= variant._id %>">
      <input type="hidden" name="productId" value="<%= variant.productId._id %>">

      <div class="modal-header">
        <h5 class="modal-title">Add Batch</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <!-- ✅ ADD THIS BODY -->
      <div class="modal-body">

        <!-- Manufactured -->
        <label>Manufactured Date</label>
        <input 
          type="text" 
          name="manufacturedAt" 
          id="mfd"
          class="form-control"
          readonly
        >

        <!-- Expiry -->
        <label class="mt-3">Expiry Days</label>
        <input type="number" name="expiryDays" id="expiryDays" class="form-control">
        <small id="expiryError" class="text-danger d-none"></small>

        <!-- Stock -->
        <label class="mt-3">Initial Stock</label>
        <input type="number" name="initialStock" id="stock" class="form-control">
        <small id="stockError" class="text-danger d-none"></small>

      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
          Cancel
        </button>
        <button class="btn btn-primary">
          Save Batch
        </button>
      </div>

    </form>
  </div>
</div>
<!-- EDIT BATCH MODAL -->

<div class="modal fade" id="editBatchModal" tabindex="-1">
<div class="modal-dialog">

<form id="editBatchForm" method="post" class="modal-content">

<div class="modal-header">
<h5 class="modal-title">Edit Batch</h5>
<button class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">

<label>Manufactured Date</label>
<input
type="date"
name="manufacturedAt"
id="editManufactured"
class="form-control"
required
>

<label class="mt-3">Expiry Days</label>
<input
type="number"
name="expiryDays"
id="editExpiryDays"
class="form-control"
min="1"
required
>
<small id="editExpiryError" class="text-danger d-none"></small>

<label class="mt-3">Initial Stock</label>
<input
type="number"
name="initialStock"
id="editStock"
class="form-control"
min="1"
required
>
<small id="editStockError" class="text-danger d-none"></small>

</div>

<div class="modal-footer">
<button class="btn btn-secondary" data-bs-dismiss="modal">
Cancel
</button>

<button type="submit" class="btn btn-primary">
Update Batch
</button>
</div>

</form>
</div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>

const editBatchModal = new bootstrap.Modal(
document.getElementById("editBatchModal")
);

const buttons = document.querySelectorAll(".edit-batch-btn");

if (buttons.length) {

buttons.forEach(btn => {

btn.addEventListener("click", function(){

const id = this.dataset.id;

document.getElementById("editManufactured").value =
this.dataset.mfd;

document.getElementById("editStock").value =
this.dataset.stock;

document.getElementById("editExpiryDays").value =
this.dataset.expiry;

document.getElementById("editBatchForm").action =
`/admin/batches/edit/${id}`;

editBatchModal.show();

});

});

}

// SET CURRENT DATE
const today = new Date().toISOString().split("T")[0];
document.getElementById("mfd").value = today;

</script>
<script>
  const addBatchForm = document.querySelector("#addBatchModal form");

let isSubmittingAdd = false;

addBatchForm.addEventListener("submit", function(e){

  if (isSubmittingAdd) return; // ✅ allow real submit

  let isValid = true;

  const expiry = document.getElementById("expiryDays");
  const stock = document.getElementById("stock");

  const expiryError = document.getElementById("expiryError");
  const stockError = document.getElementById("stockError");

  // RESET
  expiry.classList.remove("is-invalid");
  stock.classList.remove("is-invalid");
  expiryError.classList.add("d-none");
  stockError.classList.add("d-none");

  // VALIDATION
  if (!expiry.value || expiry.value <= 0) {
    expiry.classList.add("is-invalid");
    expiryError.innerText = "Enter valid expiry days";
    expiryError.classList.remove("d-none");
    isValid = false;
  }

  if (!stock.value || stock.value <= 0) {
    stock.classList.add("is-invalid");
    stockError.innerText = "Enter valid stock";
    stockError.classList.remove("d-none");
    isValid = false;
  }

  if (!isValid) {
    e.preventDefault();
    Swal.fire("Error", "Fix batch errors", "error");
    return;
  }

  // SUCCESS
  e.preventDefault();

  Swal.fire({
    title: "Success",
    text: "Batch added successfully",
    icon: "success"
  }).then(() => {
    isSubmittingAdd = true; // ✅ allow submit
    addBatchForm.submit();
  });

});
</script>
<script>
  // LIVE VALIDATION - EDIT BATCH

const editExpiry = document.getElementById("editExpiryDays");
const editStock = document.getElementById("editStock");

const editExpiryError = document.getElementById("editExpiryError");
const editStockError = document.getElementById("editStockError");

// EXPIRY LIVE
editExpiry.addEventListener("input", function(){

  if (!this.value || this.value <= 0) {
    this.classList.add("is-invalid");
    editExpiryError.innerText = "Enter valid expiry days";
    editExpiryError.classList.remove("d-none");
  } else {
    this.classList.remove("is-invalid");
    editExpiryError.classList.add("d-none");
  }

});

// STOCK LIVE
editStock.addEventListener("input", function(){

  if (!this.value || this.value <= 0) {
    this.classList.add("is-invalid");
    editStockError.innerText = "Enter valid stock";
    editStockError.classList.remove("d-none");
  } else {
    this.classList.remove("is-invalid");
    editStockError.classList.add("d-none");
  }

});
</script>
