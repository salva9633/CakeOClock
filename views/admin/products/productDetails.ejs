<!-- VARIANTS PAGE -->

<style>
  /* REUSED ADMIN PRODUCT THEME */
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 25px;
    flex-wrap: wrap;
    gap: 20px;
  }

  .page-title {
    font-size: 32px;
    font-weight: 700;
    color: #6d3939;
  }

  .page-subtitle {
    font-size: 14px;
    color: #8b5a5a;
  }

  .new-btn {
    background: linear-gradient(135deg, #AF5454, #d97373);
    color: #fff;
    border: none;
    padding: 12px 24px;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    box-shadow: 0 2px 8px rgba(175, 84, 84, .3);
  }

  .table-wrapper {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, .1);
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  thead {
    background: linear-gradient(135deg, #AF5454, #d97373);
  }

  thead th {
    padding: 16px;
    color: #fff;
    font-size: 14px;
    font-weight: 600;
  }

  tbody td {
    padding: 16px;
    font-size: 14px;
    vertical-align: middle;
  }

  .badge-available {
    background: #28a745;
  }

  .badge-out {
    background: #dc3545;
  }

  .price-small {
    font-size: 13px;
    color: #6c757d;
  }
</style>

<!-- HEADER -->
<div class="page-header">
  <div>
    <h1 class="page-title"><%= product.productName %></h1>
    <div class="page-subtitle"><%= product.description %></div>
  </div>

  <button
    class="new-btn"
    data-bs-toggle="modal"
    data-bs-target="#addVariantModal"
  >
    + Add Variant
  </button>
</div>

<!-- VARIANTS TABLE -->
<div class="table-wrapper">
  <table>
    <thead>
      <tr>
        <th>Weight</th>
        <th>Pricing</th>
        <th>Total Stock</th>
        <th>Status</th>
        <th>Action</th>
      </tr>
    </thead>

    <tbody>
      <% if (variants.length === 0) { %>
        <tr>
          <td colspan="5" class="text-center text-muted">
            No variants added yet
          </td>
        </tr>
      <% } else { %>

        <% variants.forEach(variant => { %>
          <tr>
            <td>
              <b>
                <%= variant.weight >= 1000
                  ? (variant.weight / 1000) + " kg"
                  : variant.weight + " g" %>
              </b>
            </td>

            <td>
              <div>Sale: ₹ <%= variant.salePrice %></div>
              <div class="price-small">Regular: ₹ <%= variant.regularPrice %></div>
              <div class="price-small">Cost: ₹ <%= variant.costPrice %></div>
            </td>

            <td><%= variant.totalStock %></td>

            <td>
              <span class="badge
                <%= variant.totalStock > 0 ? 'badge-available' : 'badge-out' %>
              ">
                <%= variant.totalStock > 0 ? "Available" : "Out of Stock" %>
              </span>
            </td>

            <td>
              <a
                href="/admin/variants/<%= variant._id %>"
                class="btn btn-sm btn-outline-primary"
              >
                Manage Batches
              </a>
            </td>
          </tr>
        <% }) %>

      <% } %>
    </tbody>
  </table>
</div>

<a href="/admin/products" class="btn btn-secondary mt-4">
  ← Back to Products
</a>

<!-- ADD VARIANT MODAL -->
<div class="modal fade" id="addVariantModal" tabindex="-1">
  <div class="modal-dialog">
    <form action="/admin/variants/add" method="post" class="modal-content custom-modal">

      <input type="hidden" name="productId" value="<%= product._id %>">

      <div class="modal-header">
        <h5 class="modal-title">Add Variant</h5>
        <button class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body">

        <label>Weight</label>
        <select name="weight" class="form-select" required>
  <option disabled selected>Select weight</option>

  <!-- Small sizes -->
  <option value="60">60 g</option>
  <option value="80">80 g</option>

  <!-- Medium sizes -->
  <option value="500">500 g</option>
  <option value="750">750 g</option>

  <!-- Large sizes -->
  <option value="1000">1 kg</option>
  <option value="2000">2 kg</option>
  <option value="3000">3 kg</option>
</select>

        <label class="mt-3">Cost Price (Production Cost)</label>
        <input type="number" name="costPrice" class="form-control" required min="1">

        <label class="mt-3">Regular Price</label>
        <input type="number" name="regularPrice" class="form-control" required>

        <label class="mt-3">Sale Price</label>
        <input type="number" name="salePrice" class="form-control" required>

      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
          Cancel
        </button>
        <button class="btn btn-primary">
          Save Variant
        </button>
      </div>

    </form>
  </div>
</div>
