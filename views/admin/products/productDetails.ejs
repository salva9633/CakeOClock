<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css">

<style>
:root {
  --rose: #C97B8A; --rose-dk: #A85F6E; --rose-lt: #FAE8ED;
  --blush: #FDF0F3; --caramel: #D4A574; --brown: #5C3A3A;
  --muted: #B08A8A; --border: #F5D8E0; --mint: #E8F6F0; --white: #FFFFFF;
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.94); }
  to   { opacity: 1; transform: scale(1); }
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50%       { opacity: 0.5; }
}

.vp { padding: 1.5rem 1rem; }

/* ── HEADER ── */
.vp-header {
  display: flex; justify-content: space-between; align-items: flex-start;
  margin-bottom: 1.5rem; flex-wrap: wrap; gap: 12px;
  animation: fadeUp .4s ease both;
}
.vp-title { font-size: 20px; font-weight: 500; color: var(--brown); display: flex; align-items: center; gap: 8px; }
.vp-title i { color: var(--rose); font-size: 20px; }
.vp-sub { font-size: 12px; color: var(--muted); margin-top: 5px; max-width: 480px; line-height: 1.5; }

.add-btn {
  display: flex;
  align-items: center;
  gap: 7px;
  background: var(--rose);
  color: var(--white);
  border: none;
  padding: 0 18px;
  height: 36px;
  border-radius: 24px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: background .2s, transform .15s;
  white-space: nowrap;
  box-shadow: 0 2px 8px rgba(175,84,84,.2);
}
.add-btn:hover { background: var(--rose-dk); transform: translateY(-1px); }
.add-btn i { font-size: 15px; }

/* ── METRIC CARDS ── */
.metrics {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12px; margin-bottom: 1.5rem;
}
.metric {
  background: var(--white); border: 0.5px solid var(--border);
  border-radius: 12px; padding: 1rem 1.25rem;
  border-top: 3px solid var(--rose);
  opacity: 0; animation: fadeUp .5s ease forwards;
  transition: transform .2s ease;
}
.metric:hover { transform: translateY(-3px); }
.metric.m2 { border-top-color: var(--caramel); animation-delay: .08s; }
.metric.m3 { border-top-color: #7BB88A;        animation-delay: .16s; }
.metric.m4 { border-top-color: var(--muted);   animation-delay: .24s; }

.metric-icon {
  width: 34px; height: 34px; border-radius: 8px;
  background: var(--rose-lt); display: flex; align-items: center;
  justify-content: center; margin-bottom: 10px; transition: transform .2s;
}
.metric:hover .metric-icon { transform: scale(1.1); }
.metric-icon i { font-size: 17px; color: var(--rose); }
.metric.m2 .metric-icon { background: #FEF0E8; }
.metric.m2 .metric-icon i { color: var(--caramel); }
.metric.m3 .metric-icon { background: var(--mint); }
.metric.m3 .metric-icon i { color: #5A9A6A; }
.metric.m4 .metric-icon { background: #F5F0F0; }
.metric.m4 .metric-icon i { color: var(--muted); }

.metric-label { font-size: 11px; color: var(--muted); letter-spacing: .05em; text-transform: uppercase; margin-bottom: 4px; }
.metric-value { font-size: 26px; font-weight: 500; color: var(--brown); line-height: 1; }
.metric-sub   { font-size: 11px; color: var(--muted); margin-top: 4px; }

/* ── TABLE CARD ── */
.table-card {
  background: var(--white); border: 0.5px solid var(--border);
  border-radius: 12px; overflow: hidden;
  opacity: 0; animation: scaleIn .5s ease .3s forwards;
  margin-bottom: 1.25rem;
}
.table-card-header {
  padding: 1rem 1.25rem; display: flex; justify-content: space-between; align-items: center;
  border-bottom: 0.5px solid var(--border);
}
.table-card-title { font-size: 14px; font-weight: 500; color: var(--brown); display: flex; align-items: center; gap: 6px; }
.table-card-title i { color: var(--rose); font-size: 16px; }
.live-badge {
  font-size: 10px; padding: 3px 8px; border-radius: 20px;
  background: var(--rose-lt); color: var(--rose-dk);
  display: flex; align-items: center; gap: 4px;
}
.live-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--rose); animation: pulse 1.8s ease infinite; }

table { width: 100%; border-collapse: collapse; table-layout: fixed; }
thead {
  background: var(--blush);
  border-bottom: 1px solid var(--border);
}
thead th {
  padding: 11px 16px; color: var(--muted); font-size: 11px;
  font-weight: 500; text-align: center; letter-spacing: .06em;
  text-transform: uppercase;
}
tbody td {
  padding: 16px; font-size: 13px; color: var(--brown);
  text-align: center; vertical-align: middle;
  border-bottom: 0.5px solid var(--rose-lt);
}
tbody tr:last-child td { border-bottom: none; }
tbody tr { transition: background .15s; }
tbody tr:hover { background: var(--blush); }

/* weight col wider */
th:nth-child(1), td:nth-child(1) { width: 14%; }
th:nth-child(2), td:nth-child(2) { width: 30%; }
th:nth-child(3), td:nth-child(3) { width: 14%; }
th:nth-child(4), td:nth-child(4) { width: 16%; }
th:nth-child(5), td:nth-child(5) { width: 13%; }
th:nth-child(6), td:nth-child(6) { width: 13%; }

/* ── WEIGHT CHIP ── */
.weight-chip {
  display: inline-block; background: var(--rose-lt); color: var(--rose-dk);
  padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600;
}

/* ── PRICE BOX ── */
.price-box { line-height: 1.7; }
.price-sale { font-size: 14px; font-weight: 600; color: var(--brown); }
.price-reg  { font-size: 12px; color: var(--muted); }
.price-cost { font-size: 11px; color: var(--muted); }

/* ── STOCK PILL ── */
.stock-val { font-size: 15px; font-weight: 600; }
.stock-val.in  { color: #1F7A47; }
.stock-val.out { color: #9B2222; }

/* ── STATUS BADGE ── */
.status-badge {
  display: inline-flex; align-items: center; gap: 5px;
  padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 600;
}
.badge-available { background: #E8F6EE; color: #1F7A47; }
.badge-out       { background: #FDE8E8; color: #9B2222; }
.badge-dot { width: 5px; height: 5px; border-radius: 50%; }
.badge-available .badge-dot { background: #28a745; }
.badge-out .badge-dot       { background: #dc3545; }

/* ── ACTION BUTTONS ── */
.batches-btn {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 11px;
  padding: 4px 12px;
  border-radius: 20px;
  border: 0.5px solid var(--border);
  background: var(--white);
  color: #3A7A4A;
  text-decoration: none;
  transition: all .2s;
}
.batches-btn:hover { border-color: #7BB88A; background: #EAF6EE; color: #2E6B3B; }

.edit-btn {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 11px;
  padding: 4px 12px;
  border-radius: 20px;
  border: 0.5px solid var(--border);
  background: var(--white);
  color: var(--muted);
  cursor: pointer;
  transition: all .2s;
}
.edit-btn:hover { border-color: var(--caramel); color: var(--caramel); background: #FEF0E8; }

/* ── EMPTY STATE ── */
.empty-state { text-align: center; padding: 3rem 1rem; color: var(--muted); font-size: 13px; }
.empty-state i { font-size: 32px; margin-bottom: 8px; display: block; color: var(--border); }

/* ── BACK LINK ── */
.back-link {
  display: inline-flex; align-items: center; gap: 6px;
  font-size: 13px; color: var(--muted); text-decoration: none;
  padding: 8px 16px; border: 0.5px solid var(--border);
  border-radius: 20px; background: var(--white); transition: all .2s;
  opacity: 0; animation: fadeUp .4s ease .5s forwards;
}
.back-link:hover { color: var(--rose-dk); border-color: var(--rose); background: var(--rose-lt); }

/* ── MODALS ── */
.modal-content  { border-radius: 12px; border: 0.5px solid var(--border); }
.modal-header   { border-bottom: 0.5px solid var(--border); }
.modal-footer   { border-top: 0.5px solid var(--border); gap: 8px; }
.modal-title    { font-size: 15px; font-weight: 600; color: var(--brown); display: flex; align-items: center; gap: 6px; }
.modal-title i  { color: var(--rose); }
.form-label     { font-size: 12px; color: var(--muted); font-weight: 500; margin-bottom: 4px; text-transform: uppercase; letter-spacing: .05em; }
.form-control, .form-select {
  font-size: 13px; border: 0.5px solid var(--border); border-radius: 8px;
}
.form-control:focus, .form-select:focus { box-shadow: none; border-color: var(--rose); }
.form-control.is-invalid, .form-select.is-invalid { background-image: none !important; border-color: #dc3545; }
small.text-danger { font-size: 11px; margin-top: 4px; display: block; }
.btn-save {
  background: var(--rose); color: #fff;
  border: none; padding: 7px 20px; border-radius: 20px; font-size: 13px;
  font-weight: 500; cursor: pointer; transition: background .2s, transform .15s;
}
.btn-save:hover { background: var(--rose-dk); transform: translateY(-1px); }

.btn-secondary {
  font-size: 13px;
  padding: 7px 18px;
  border-radius: 20px;
  border: 0.5px solid var(--border);
  background: var(--white);
  color: var(--muted);
  cursor: pointer;
  transition: all .2s;
}
.btn-secondary:hover { border-color: var(--rose); color: var(--rose); }

@media (max-width: 768px) {
  .metrics { grid-template-columns: repeat(2, 1fr); }
  th:nth-child(2), td:nth-child(2) { display: none; }
}
@media (max-width: 480px) {
  .metrics { grid-template-columns: 1fr; }
}

/* ── MODAL POSITIONING FIX ── */
.modal { padding-top: 60px !important; }
.modal-dialog { margin: 80px auto 20px auto; }
</style>

<div class="vp">

  <!-- HEADER -->
  <div class="vp-header">
    <div>
      <div class="vp-title">
        <i class="ti ti-cake" aria-hidden="true"></i>
        <%= product.productName %>
      </div>
      <div class="vp-sub"><%= product.description %></div>
    </div>
    <button class="add-btn" data-bs-toggle="modal" data-bs-target="#addVariantModal">
      <i class="ti ti-plus" aria-hidden="true"></i> Add Variant
    </button>
  </div>

  <!-- METRIC CARDS -->
  <%
    const totalVariants     = variants.length;
    const availableVariants = variants.filter(v => v.totalStock > 0).length;
    const totalStock        = variants.reduce((s, v) => s + (v.totalStock || 0), 0);
    const outOfStock        = variants.filter(v => v.totalStock === 0).length;
  %>
  <div class="metrics">
    <div class="metric m1">
      <div class="metric-icon"><i class="ti ti-layers" aria-hidden="true"></i></div>
      <div class="metric-label">Total variants</div>
      <div class="metric-value"><%= totalVariants %></div>
      <div class="metric-sub">Across all weights</div>
    </div>
    <div class="metric m2">
      <div class="metric-icon"><i class="ti ti-circle-check" aria-hidden="true"></i></div>
      <div class="metric-label">Available</div>
      <div class="metric-value"><%= availableVariants %></div>
      <div class="metric-sub"><%= totalVariants > 0 ? Math.round(availableVariants/totalVariants*100) : 0 %>% in stock</div>
    </div>
    <div class="metric m3">
      <div class="metric-icon"><i class="ti ti-stack" aria-hidden="true"></i></div>
      <div class="metric-label">Total stock</div>
      <div class="metric-value"><%= totalStock %></div>
      <div class="metric-sub">Units combined</div>
    </div>
    <div class="metric m4">
      <div class="metric-icon"><i class="ti ti-circle-x" aria-hidden="true"></i></div>
      <div class="metric-label">Out of stock</div>
      <div class="metric-value"><%= outOfStock %></div>
      <div class="metric-sub"><%= totalVariants > 0 ? Math.round(outOfStock/totalVariants*100) : 0 %>% rate</div>
    </div>
  </div>

  <!-- VARIANTS TABLE -->
  <div class="table-card">
    <div class="table-card-header">
      <div class="table-card-title">
        <i class="ti ti-list-details" aria-hidden="true"></i> Variant inventory
      </div>
      <div class="live-badge">
        <span class="live-dot"></span> Live
      </div>
    </div>

    <% if (variants.length === 0) { %>
      <div class="empty-state">
        <i class="ti ti-inbox" aria-hidden="true"></i>
        No variants yet. Add your first size.
      </div>
    <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Weight</th>
          <th>Pricing</th>
          <th>Stock</th>
          <th>Status</th>
          <th>Batches</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% variants.forEach(variant => { %>
        <tr>
          <td>
            <span class="weight-chip">
              <%= variant.weight >= 1000 ? (variant.weight/1000) + ' kg' : variant.weight + ' g' %>
            </span>
          </td>
          <td>
            <div class="price-box">
<div class="price-sale">₹<%= variant.regularPrice %></div>
              <div class="price-cost">Cost ₹<%= variant.costPrice %></div>
            </div>
          </td>
          <td>
            <span class="stock-val <%= variant.totalStock > 0 ? 'in' : 'out' %>">
              <%= variant.totalStock %>
            </span>
          </td>
          <td>
            <span class="status-badge <%= variant.totalStock > 0 ? 'badge-available' : 'badge-out' %>">
              <span class="badge-dot"></span>
              <%= variant.totalStock > 0 ? 'Available' : 'Out of Stock' %>
            </span>
          </td>
          <td>
            <a href="/admin/variants/<%= variant._id %>" class="batches-btn">
              <i class="ti ti-box" aria-hidden="true"></i> Batches
            </a>
          </td>
          <td>
            <button
              class="edit-btn edit-variant-btn"
              data-id="<%= variant._id %>"
              data-weight="<%= variant.weight %>"
              data-cost="<%= variant.costPrice %>"
              data-regular="<%= variant.regularPrice %>"
              data-sale="<%= variant.salePrice %>"
            >
              <i class="ti ti-edit" aria-hidden="true"></i> Edit
            </button>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <% } %>
  </div>

  <!-- BACK -->
  <a href="/admin/products" class="back-link">
    <i class="ti ti-arrow-left" aria-hidden="true"></i> Back to products
  </a>

</div>


<!-- ── ADD VARIANT MODAL ── -->
<div class="modal fade" id="addVariantModal" tabindex="-1">
  <div class="modal-dialog">
<form id="addVariantForm" class="modal-content">
        <input type="hidden" name="productId" value="<%= product._id %>">
      <div class="modal-header">
        <h5 class="modal-title"><i class="ti ti-plus" aria-hidden="true"></i> Add variant</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" style="display:flex;flex-direction:column;gap:14px;padding:1.25rem;">
        <div>
          <label class="form-label">Weight</label>
          <select name="weight" id="weight" class="form-select">
            <option disabled selected value="">Select weight</option>
            <option value="60">60 g</option>
            <option value="80">80 g</option>
            <option value="500">500 g</option>
            <option value="750">750 g</option>
            <option value="1000">1 kg</option>
            <option value="2000">2 kg</option>
            <option value="3000">3 kg</option>
          </select>
          <small id="weightError" class="text-danger d-none"></small>
        </div>
        <div>
          <label class="form-label">Cost price</label>
          <input type="number" name="costPrice" id="costPrice" class="form-control" min="1" placeholder="Production cost">
          <small id="costError" class="text-danger d-none"></small>
        </div>
        <div>
          <label class="form-label">Regular price</label>
          <input type="number" name="regularPrice" id="regularPrice" class="form-control" min="1" placeholder="MRP">
          <small id="regularError" class="text-danger d-none"></small>
        </div>
        
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn-save">Save variant</button>
      </div>
    </form>
  </div>
</div>

<!-- ── EDIT VARIANT MODAL ── -->
<div class="modal fade" id="editVariantModal" tabindex="-1">
  <div class="modal-dialog">
    <form id="editVariantForm" method="post" class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="ti ti-edit" aria-hidden="true"></i> Edit variant</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body" style="display:flex;flex-direction:column;gap:14px;padding:1.25rem;">
        <div>
          <label class="form-label">Weight</label>
          <select name="weight" id="editWeight" class="form-select">
            <option value="">Select weight</option>
            <option value="60">60 g</option>
            <option value="80">80 g</option>
            <option value="500">500 g</option>
            <option value="750">750 g</option>
            <option value="1000">1 kg</option>
            <option value="2000">2 kg</option>
            <option value="3000">3 kg</option>
          </select>
          <small id="editWeightError" class="text-danger d-none"></small>
        </div>
        <div>
          <label class="form-label">Cost price</label>
          <input type="number" name="costPrice" id="editCostPrice" class="form-control" min="1">
          <small id="editCostError" class="text-danger d-none"></small>
        </div>
        <div>
          <label class="form-label">Regular price</label>
          <input type="number" name="regularPrice" id="editRegularPrice" class="form-control" min="1">
          <small id="editRegularError" class="text-danger d-none"></small>
        </div>
        
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn-save">Update variant</button>
      </div>
    </form>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
function showError(el, errEl, msg) {
  el.classList.add("is-invalid");
  errEl.innerText = msg;
  errEl.classList.remove("d-none");
}
function clearError(el, errEl) {
  el.classList.remove("is-invalid");
  errEl.classList.add("d-none");
}

function validatePrices(cost, regular, sale, costErr, regularErr, saleErr) {
  let valid = true;
  if (!cost.value || cost.value <= 0)      { showError(cost, costErr, "Enter valid cost"); valid = false; }
  if (!regular.value || regular.value <= 0){ showError(regular, regularErr, "Enter valid regular price"); valid = false; }

  if (valid) {
    if (+regular.value <= +cost.value) { showError(regular, regularErr, "Regular must be > cost"); valid = false; }
    if (+sale.value <= +cost.value)    { showError(sale, saleErr, "Sale must be > cost"); valid = false; }
    if (+sale.value > +regular.value)  { showError(sale, saleErr, "Sale must be ≤ regular"); valid = false; }
  }
  return valid;
}

// EDIT MODAL POPULATE
const editModal = new bootstrap.Modal(document.getElementById("editVariantModal"));
document.querySelectorAll(".edit-variant-btn").forEach(btn => {
  btn.addEventListener("click", function () {
    document.getElementById("editWeight").value      = this.dataset.weight;
    document.getElementById("editCostPrice").value   = this.dataset.cost;
    document.getElementById("editRegularPrice").value= this.dataset.regular;
    document.getElementById("editVariantForm").action = `/admin/variants/edit/${this.dataset.id}`;
    editModal.show();
  });
});

// ADD FORM
document.getElementById("addVariantForm").addEventListener("submit", async function (e) {
  e.preventDefault();

const w  = document.getElementById("weight");
  const c  = document.getElementById("costPrice");
  const r  = document.getElementById("regularPrice");
  const wE = document.getElementById("weightError");
  const cE = document.getElementById("costError");
  const rE = document.getElementById("regularError");

  [w,c,r].forEach((el,i) => clearError(el, [wE,cE,rE][i]));

  let valid = true;
  if (!w.value) { showError(w, wE, "Weight required"); valid = false; }
  if (!c.value || c.value <= 0) { showError(c, cE, "Enter valid cost"); valid = false; }
  if (!r.value || r.value <= 0) { showError(r, rE, "Enter valid regular price"); valid = false; }
  if (valid && +r.value <= +c.value) { showError(r, rE, "Regular must be > cost"); valid = false; }
  if (!valid) { Swal.fire({ icon:"error", title:"Validation Error", text:"Please fix the errors above.", confirmButtonColor:"#AF5454" }); return; }

  const productId = document.querySelector('[name="productId"]').value;

  try {
    const res  = await fetch('/admin/variants/add', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        productId,
        weight:       w.value,
        costPrice:    c.value,
        regularPrice: r.value,
      })
    });
    const data = await res.json();

    if (!data.success) {
      Swal.fire({ icon: 'error', title: 'Failed!', text: data.message || 'Something went wrong.', confirmButtonColor: '#AF5454' });
      return;
    }

    Swal.fire({ icon: 'success', title: 'Variant Added!', timer: 1500, showConfirmButton: false })
      .then(() => window.location.href = `/admin/variants/${data.variantId}`);

  } catch (err) {
    Swal.fire({ icon: 'error', title: 'Network Error', text: 'Could not connect. Please try again.', confirmButtonColor: '#AF5454' });
  }
});

