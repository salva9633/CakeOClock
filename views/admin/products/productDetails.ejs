// EDIT FORM
document.getElementById("editVariantForm").addEventListener("submit", async function (e) {
  e.preventDefault();

  const w  = document.getElementById("editWeight");
  const c  = document.getElementById("editCostPrice");
  const r  = document.getElementById("editRegularPrice");
  const wE = document.getElementById("editWeightError");
  const cE = document.getElementById("editCostError");
  const rE = document.getElementById("editRegularError");

  [w,c,r].forEach((el,i) => clearError(el, [wE,cE,rE][i]));

  let valid = true;
  if (!w.value) { showError(w, wE, "Weight required"); valid = false; }
  if (!c.value || c.value <= 0) { showError(c, cE, "Enter valid cost"); valid = false; }
  if (!r.value || r.value <= 0) { showError(r, rE, "Enter valid regular price"); valid = false; }
  if (valid && +r.value <= +c.value) { showError(r, rE, "Regular must be > cost"); valid = false; }
  if (!valid) { Swal.fire({ icon:"error", title:"Validation Error", text:"Please fix the errors above.", confirmButtonColor:"#AF5454" }); return; }

  const variantId = this.action.split('/').pop();

  try {
    const res  = await fetch(`/admin/variants/edit/${variantId}`, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        weight:       w.value,
        costPrice:    c.value,
        regularPrice: r.value,
      })
    });
    const data = await res.json();

    if (!data.success) {
      Swal.fire({ icon:'error', title:'Failed!', text: data.message || 'Something went wrong.', confirmButtonColor:'#AF5454' });
      return;
    }

    Swal.fire({ icon:'success', title:'Updated!', timer:1500, showConfirmButton:false })
      .then(() => location.reload());

  } catch (err) {
    Swal.fire({ icon:'error', title:'Network Error', text:'Could not connect.', confirmButtonColor:'#AF5454' });
  }
});</script>