<%- include("../../views/partials/admin/sidebar") %>

<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --rose: #C97B8A; --rose-dk: #A85F6E; --rose-lt: #FAE8ED;
  --blush: #FDF0F3; --caramel: #D4A574; --brown: #5C3A3A;
  --muted: #B08A8A; --border: #F5D8E0; --mint: #E8F6F0; --white: #FFFFFF;
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.94); }
  to   { opacity: 1; transform: scale(1); }
}
@keyframes shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ─── Page shell ─── */
.pg { padding: 1.5rem 1rem; }

/* ─── Header ─── */
.pg-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 1.5rem;
  animation: fadeUp .45s ease both;
}
.pg-header h1 {
  font-size: 20px;
  font-weight: 500;
  color: var(--brown);
  display: flex;
  align-items: center;
  gap: 8px;
}
.pg-header h1 i { color: var(--rose); font-size: 20px; }

/* ─── Search ─── */
.search-wrap {
  display: flex;
  align-items: center;
  gap: 8px;
  background: var(--white);
  border: 0.5px solid var(--border);
  border-radius: 24px;
  padding: 0 14px;
  transition: border-color .2s;
  height: 36px;
}
.search-wrap:focus-within { border-color: var(--rose); }
.search-wrap i { color: var(--muted); font-size: 15px; flex-shrink: 0; }
.search-wrap input {
  border: none;
  outline: none;
  font-size: 13px;
  color: var(--brown);
  background: transparent;
  width: 200px;
}
.search-wrap input::placeholder { color: var(--muted); }
.search-clear {
  font-size: 11px;
  color: var(--muted);
  text-decoration: none;
  white-space: nowrap;
  transition: color .15s;
}
.search-clear:hover { color: var(--rose); }

/* ─── Add button ─── */
.add-btn {
  display: flex;
  align-items: center;
  gap: 7px;
  background: var(--rose);
  color: var(--white);
  border: none;
  padding: 0 18px;
  height: 36px;
  border-radius: 24px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: background .2s, transform .15s;
  white-space: nowrap;
}
.add-btn:hover { background: var(--rose-dk); transform: translateY(-1px); }
.add-btn i { font-size: 15px; }

/* ─── Stats row ─── */
.stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
  margin-bottom: 1.5rem;
}
.stat {
  background: var(--white);
  border: 0.5px solid var(--border);
  border-radius: 12px;
  padding: .9rem 1.1rem;
  border-top: 3px solid var(--rose);
  display: flex;
  align-items: center;
  gap: 12px;
  opacity: 0;
  animation: fadeUp .5s ease forwards;
  transition: transform .2s;
}
.stat:hover { transform: translateY(-2px); }
.stat.s2 { border-top-color: var(--caramel); animation-delay: .08s; }
.stat.s3 { border-top-color: #7BB88A;        animation-delay: .16s; }

.stat-icon {
  width: 34px; height: 34px;
  border-radius: 8px;
  background: var(--rose-lt);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.stat-icon i { font-size: 17px; color: var(--rose); }
.stat.s2 .stat-icon { background: #FEF0E8; }
.stat.s2 .stat-icon i { color: var(--caramel); }
.stat.s3 .stat-icon { background: var(--mint); }
.stat.s3 .stat-icon i { color: #5A9A6A; }

.stat-info {}
.stat-label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; }
.stat-value { font-size: 22px; font-weight: 500; color: var(--brown); line-height: 1.1; }

/* ─── Table card ─── */
.table-card {
  background: var(--white);
  border: 0.5px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
  opacity: 0;
  animation: scaleIn .5s ease .28s forwards;
  margin-bottom: 1.5rem;
}
.table-card table {
  width: 100%;
  border-collapse: collapse;
}
.table-card thead tr {
  background: var(--blush);
  border-bottom: 1px solid var(--border);
}
.table-card thead th {
  padding: 11px 16px;
  font-size: 11px;
  font-weight: 500;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: .06em;
  white-space: nowrap;
}
.table-card tbody tr {
  border-bottom: 0.5px solid var(--rose-lt);
  transition: background .15s;
}
.table-card tbody tr:last-child { border-bottom: none; }
.table-card tbody tr:hover { background: var(--blush); }
.table-card tbody td {
  padding: 12px 16px;
  font-size: 13px;
  color: var(--brown);
  vertical-align: middle;
}

/* ─── Product image cell ─── */
.prod-img-wrap {
  display: flex;
  align-items: center;
  gap: 10px;
}
.prod-thumb {
  width: 42px;
  height: 42px;
  border-radius: 10px;
  object-fit: cover;
  border: 1px solid var(--border);
  flex-shrink: 0;
}
.prod-name { font-size: 13px; color: var(--brown); font-weight: 500; }
.prod-desc { font-size: 11px; color: var(--muted); margin-top: 1px; }

/* ─── Category / Brand badges ─── */
.badge-cat {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 11px;
  padding: 3px 10px;
  border-radius: 20px;
  background: var(--rose-lt);
  color: var(--rose-dk);
  font-weight: 500;
}
.badge-brand {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 11px;
  padding: 3px 10px;
  border-radius: 20px;
  background: #FEF0E8;
  color: #A07040;
  font-weight: 500;
}

/* ─── Toggle ─── */
.form-switch .form-check-input {
  cursor: pointer;
  width: 36px;
  height: 20px;
}
.form-check-input:checked { background-color: var(--rose) !important; border-color: var(--rose) !important; }

/* ─── Action buttons ─── */
.btn-view {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 11px;
  padding: 4px 12px;
  border-radius: 20px;
  border: 0.5px solid var(--border);
  background: var(--white);
  color: var(--muted);
  text-decoration: none;
  transition: all .2s;
}
.btn-view:hover { border-color: var(--rose); color: var(--rose); background: var(--rose-lt); }

.btn-edit {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 11px;
  padding: 4px 12px;
  border-radius: 20px;
  border: 0.5px solid var(--border);
  background: var(--white);
  color: var(--muted);
  cursor: pointer;
  transition: all .2s;
}
.btn-edit:hover { border-color: var(--caramel); color: var(--caramel); background: #FEF0E8; }

/* ─── Empty state ─── */
.empty-row td {
  text-align: center;
  padding: 3rem 1rem !important;
  color: var(--muted);
  font-size: 13px;
}
.empty-icon { font-size: 36px; color: var(--border); margin-bottom: 8px; }

/* ─── Pagination ─── */
.pg-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 8px;
  animation: fadeUp .5s ease .4s both;
  opacity: 0;
}
.pg-info { font-size: 12px; color: var(--muted); }
.pager { display: flex; gap: 4px; }
.page-btn {
  min-width: 34px;
  height: 34px;
  border-radius: 8px;
  border: 0.5px solid var(--border);
  background: var(--white);
  color: var(--brown);
  font-size: 15px;
  display: flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  cursor: pointer;
  transition: all .2s;
  padding: 0 6px;
}
.page-btn:hover:not(.disabled):not(.active) { border-color: var(--rose); color: var(--rose); }
.page-btn.active { background: var(--rose); color: var(--white); border-color: var(--rose); }
.page-btn.disabled { opacity: .4; pointer-events: none; }

/* ─── Modals ─── */
.custom-modal {
  background: var(--blush);
  border-radius: 16px;
  border: 0.5px solid var(--border);
}
.modal-header {
  background: var(--white);
  border-bottom: 0.5px solid var(--border);
  padding: 1rem 1.25rem;
  border-radius: 16px 16px 0 0;
}
.modal-title {
  font-size: 15px;
  font-weight: 500;
  color: var(--brown);
  display: flex;
  align-items: center;
  gap: 8px;
}
.modal-title i { color: var(--rose); }
.modal-body { padding: 1.25rem; }
.modal-footer {
  background: var(--white);
  border-top: 0.5px solid var(--border);
  padding: .9rem 1.25rem;
  border-radius: 0 0 16px 16px;
}

.form-label { font-size: 12px; font-weight: 500; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; margin-bottom: 4px; }
.form-control, .form-select {
  border: 0.5px solid var(--border);
  border-radius: 8px;
  font-size: 13px;
  color: var(--brown);
  background: var(--white);
  padding: 8px 12px;
  transition: border-color .2s;
}
.form-control:focus, .form-select:focus {
  outline: none;
  border-color: var(--rose);
  box-shadow: 0 0 0 3px rgba(201,123,138,.12);
}
textarea.form-control { resize: vertical; min-height: 80px; }

.btn-cancel {
  font-size: 13px;
  padding: 7px 18px;
  border-radius: 20px;
  border: 0.5px solid var(--border);
  background: var(--white);
  color: var(--muted);
  cursor: pointer;
  transition: all .2s;
}
.btn-cancel:hover { border-color: var(--rose); color: var(--rose); }
.btn-save {
  font-size: 13px;
  padding: 7px 20px;
  border-radius: 20px;
  border: none;
  background: var(--rose);
  color: var(--white);
  cursor: pointer;
  font-weight: 500;
  transition: background .2s, transform .15s;
}
.btn-save:hover { background: var(--rose-dk); transform: translateY(-1px); }

/* ─── Image slots ─── */
.image-grid { display: flex; flex-wrap: wrap; gap: 10px; }
.image-slot {
  width: 90px;
  height: 90px;
  border: 1.5px dashed var(--border);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  position: relative;
  background: var(--white);
  transition: border-color .2s, transform .15s;
  overflow: hidden;
}
.image-slot:hover { border-color: var(--rose); transform: scale(1.04); }
.image-slot .slot-plus { font-size: 24px; color: var(--border); line-height: 1; }
.image-slot img { width: 100%; height: 100%; object-fit: cover; border-radius: 8px; }

/* ─── Crop modal ─── */
#cropModal .modal-dialog { max-width: 95vw; margin: 0 auto; }
#cropModal .modal-content { height: 95vh; background: #111; color: #fff; border-radius: 16px; }
#cropModal .modal-body { display: flex; align-items: center; justify-content: center; flex: 1; overflow: hidden; padding: 0; }
#cropModal .modal-header, #cropModal .modal-footer { background: #1a1a1a; border: none; }
#cropModal .btn-close { filter: invert(1); }
.cropper-container { max-height: 80vh !important; }
</style>

<div class="pg">

  <!-- Header -->
  <div class="pg-header">
    <h1><i class="ti ti-box" aria-hidden="true"></i> Products</h1>

    <form method="GET" action="/admin/products" class="search-wrap">
      <i class="ti ti-search" aria-hidden="true"></i>
      <input
        type="text"
        id="adminSearchInput"
        name="search"
        value="<%= search %>"
        placeholder="Search products…"
        autocomplete="off"
      >
      <% if (search) { %>
        <a href="/admin/products" class="search-clear">Clear</a>
      <% } %>
    </form>

    <button class="add-btn" data-bs-toggle="modal" data-bs-target="#addProductModal">
      <i class="ti ti-plus" aria-hidden="true"></i> Add Product
    </button>
  </div>

  <!-- Stats -->
  <div class="stats">
    <div class="stat s1">
      <div class="stat-icon"><i class="ti ti-box" aria-hidden="true"></i></div>
      <div class="stat-info">
        <div class="stat-label">Total products</div>
        <div class="stat-value"><%= typeof totalProducts !== 'undefined' ? totalProducts : products.length %></div>
      </div>
    </div>
    <div class="stat s2">
      <div class="stat-icon"><i class="ti ti-eye" aria-hidden="true"></i></div>
      <div class="stat-info">
        <div class="stat-label">Listed</div>
        <div class="stat-value"><%= products.filter(p => p.isListed).length %></div>
      </div>
    </div>
    <div class="stat s3">
      <div class="stat-icon"><i class="ti ti-eye-off" aria-hidden="true"></i></div>
      <div class="stat-info">
        <div class="stat-label">Unlisted</div>
        <div class="stat-value"><%= products.filter(p => !p.isListed).length %></div>
      </div>
    </div>
  </div>

  <!-- Table -->
  <div class="table-card">
    <table>
      <thead>
        <tr>
          <th>Product</th>
          <th>Category</th>
          <th>Brand</th>
          <th>Visibility</th>
          <th></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% if (products.length === 0) { %>
          <tr class="empty-row">
            <td colspan="6">
              <div class="empty-icon"><i class="ti ti-box-off" aria-hidden="true"></i></div>
              <div>No products found</div>
            </td>
          </tr>
        <% } %>
        <% products.forEach(product => { %>
          <tr>
            <td>
              <div class="prod-img-wrap">
                <img
                  src="<%= product.productImages?.[0] || '/placeholder.png' %>"
                  class="prod-thumb"
                  alt="<%= product.productName %>"
                >
                <div>
                  <div class="prod-name"><%= product.productName %></div>
                  <% if (product.description) { %>
                    <div class="prod-desc"><%= product.description.substring(0, 40) %><%= product.description.length > 40 ? '…' : '' %></div>
                  <% } %>
                </div>
              </div>
            </td>
            <td>
              <% if (product.categoryId) { %>
                <span class="badge-cat">
                  <i class="ti ti-tag" aria-hidden="true" style="font-size:10px;"></i>
                  <%= product.categoryId.name %>
                </span>
              <% } else { %>
                <span style="color:var(--muted); font-size:12px;">—</span>
              <% } %>
            </td>
            <td>
              <% if (product.brand) { %>
                <span class="badge-brand">
                  <i class="ti ti-rosette" aria-hidden="true" style="font-size:10px;"></i>
                  <%= product.brand %>
                </span>
              <% } else { %>
                <span style="color:var(--muted); font-size:12px;">—</span>
              <% } %>
            </td>
            <td>
              <div class="form-check form-switch" style="margin:0;">
                <input
                  class="form-check-input listing-toggle"
                  type="checkbox"
                  <%= product.isListed ? "checked" : "" %>
                  data-id="<%= product._id %>"
                  data-name="<%= product.productName %>"
                >
              </div>
            </td>
            <td>
              <a href="/admin/products/<%= product._id %>" class="btn-view">
                <i class="ti ti-eye" aria-hidden="true" style="font-size:12px;"></i> View
              </a>
            </td>
            <td>
        <button
                type="button"
                class="btn-edit edit-btn"
                data-id="<%= product._id %>"
                data-name="<%= product.productName %>"
                data-desc="<%= product.description %>"
                data-longdesc="<%= product.longDescription || '' %>"
                data-brand="<%= product.brand || '' %>"
                data-category="<%= product.categoryId ? product.categoryId._id : '' %>"
                data-offer="<%= product.productOffer || 0 %>"
                data-images='<%- JSON.stringify(product.productImages || []) %>'
              >
                <i class="ti ti-pencil" aria-hidden="true" style="font-size:12px;"></i> Edit
              </button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  <div class="pg-footer">
    <div class="pg-info">
      Page <%= currentPage %> of <%= totalPages %>
    </div>
    <div class="pager">
      <a
        class="page-btn <%= currentPage === 1 ? 'disabled' : '' %>"
        href="?page=<%= currentPage - 1 %>&search=<%= search %>"
        aria-label="Previous"
      >
        <i class="ti ti-chevron-left" aria-hidden="true"></i>
      </a>

      <% for (let i = 1; i <= totalPages; i++) { %>
        <a
          class="page-btn <%= currentPage === i ? 'active' : '' %>"
          href="?page=<%= i %>&search=<%= search %>"
        ><%= i %></a>
      <% } %>

      <a
        class="page-btn <%= currentPage === totalPages ? 'disabled' : '' %>"
        href="?page=<%= currentPage + 1 %>&search=<%= search %>"
        aria-label="Next"
      >
        <i class="ti ti-chevron-right" aria-hidden="true"></i>
      </a>
    </div>
  </div>

</div><!-- /pg -->


<!-- ─── ADD PRODUCT MODAL ─── -->
<div class="modal fade" id="addProductModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <form id="addProductForm" action="/admin/products/add" method="post" enctype="multipart/form-data" class="modal-content custom-modal">
      <div class="modal-header">
        <h5 class="modal-title"><i class="ti ti-plus" aria-hidden="true"></i> Add New Product</h5>
      </div>
      <div class="modal-body row g-3">
        <div class="col-12">
          <label class="form-label">Product Name</label>
          <input type="text" name="productName" id="productName" class="form-control" placeholder="Enter product name">
          <small id="nameError" class="text-danger"></small>
        </div>
        <div class="col-12">
          <label class="form-label">Short Description</label>
          <input type="text" name="description" id="description" class="form-control" placeholder="Brief description">
          <small id="descError" class="text-danger"></small>
        </div>
        <div class="col-12">
          <label class="form-label">Long Description</label>
          <textarea name="longDescription" id="longDescription" class="form-control" placeholder="Detailed description…"></textarea>
          <small id="longDescError" class="text-danger"></small>
        </div>
        <div class="col-md-6">
          <label class="form-label">Category</label>
          <select name="categoryId" id="categoryId" class="form-select">
            <% categories.forEach(cat => { %>
              <option value="<%= cat._id %>"><%= cat.name %></option>
            <% }) %>
          </select>
          <small id="categoryError" class="text-danger"></small>
        </div>
        <div class="col-md-6">
          <label class="form-label">Brand</label>
          <input type="text" name="brand" id="brand" class="form-control" placeholder="Brand name">
          <small id="brandError" class="text-danger"></small>
        </div>
        <div class="col-md-6">
          <label class="form-label">Product Offer (%)</label>
          <input type="number" name="productOffer" id="productOffer" 
            class="form-control" placeholder="e.g. 10" min="0" max="100" value="0">
        </div>
        <div class="col-12">
          <label class="form-label">Product Images <span style="color:var(--muted);font-weight:400;text-transform:none;">(max 5)</span></label>
          <div class="image-grid" id="imageSlots">
            <% for (let i = 0; i < 5; i++) { %>
              <div class="image-slot" data-index="<%= i %>">
                <span class="slot-plus">+</span>
                <img hidden>
              </div>
            <% } %>
          </div>
          <input type="file" id="imageInput" accept="image/*" hidden multiple>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-cancel" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn-save">Save Product</button>
      </div>
    </form>
  </div>
</div>

<!-- ─── CROP MODAL ─── -->
<div class="modal fade" id="cropModal" tabindex="-1">
  <div class="modal-dialog modal-fullscreen modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" style="color:#fff;">Crop Image</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body d-flex justify-content-center align-items-center p-0">
        <div style="width:100%; height:100%;">
          <img id="cropImage" style="max-width:100%; max-height:100vh; display:block; margin:auto;" />
        </div>
      </div>
      <div class="modal-footer justify-content-between">
        <small style="color:#999;">Drag to crop • Scroll to zoom</small>
        <button id="cropSaveBtn" class="btn-save">Crop & Use Image</button>
      </div>
    </div>
  </div>
</div>

<!-- ─── EDIT MODAL ─── -->
<div class="modal fade" id="editProductModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <form id="editProductForm" method="post" enctype="multipart/form-data" class="modal-content custom-modal">
      <div class="modal-header">
        <h5 class="modal-title"><i class="ti ti-pencil" aria-hidden="true"></i> Edit Product</h5>
      </div>
      <div class="modal-body row g-3">
        <div class="col-12">
          <label class="form-label">Product Name</label>
          <input id="editProductName" name="productName" class="form-control" required>
        </div>
        <div class="col-12">
          <label class="form-label">Short Description</label>
          <input id="editDescription" name="description" class="form-control" required>
        </div>
        <div class="col-12">
          <label class="form-label">Long Description</label>
          <textarea id="editLongDescription" name="longDescription" class="form-control"></textarea>
        </div>
        <div class="col-md-6">
          <label class="form-label">Category</label>
          <select id="editCategory" name="categoryId" class="form-select" required>
            <% categories.forEach(cat => { %>
              <option value="<%= cat._id %>"><%= cat.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label">Brand</label>
          <input id="editBrand" name="brand" class="form-control">
        </div>
        <div class="col-md-6">
          <label class="form-label">Product Offer (%)</label>
          <input type="number" id="editProductOffer" name="productOffer" 
            class="form-control" placeholder="e.g. 10" min="0" max="100" value="0">
        </div>
        <div class="col-12">
          <label class="form-label">Product Images <span style="color:var(--muted);font-weight:400;text-transform:none;">(max 5)</span></label>
          <div class="image-grid" id="editImageSlots">
            <% for (let i = 0; i < 5; i++) { %>
              <div class="image-slot edit-slot" data-index="<%= i %>">
                <span class="slot-plus">+</span>
                <img hidden>
              </div>
            <% } %>
          </div>
          <input type="file" id="editImageInput" accept="image/*" hidden multiple>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-cancel" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn-save">Update Product</button>
      </div>
    </form>
  </div>
</div>

<!-- ─── SCRIPTS ─── -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link href="https://cdn.jsdelivr.net/npm/cropperjs@1.6.1/dist/cropper.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
<script src="https://cdn.jsdelivr.net/npm/cropperjs@1.6.1/dist/cropper.min.js"></script>

<script>
document.addEventListener("DOMContentLoaded", function () {

  /* ── Toggle listing ── */
  let selectedProductId = null;
  let selectedCheckbox  = null;

  document.querySelectorAll(".listing-toggle").forEach(toggle => {
    toggle.addEventListener("change", function () {
      selectedProductId = this.dataset.id;
      selectedCheckbox  = this;
      const action = this.checked ? "list" : "unlist";

      document.querySelectorAll(".modal.show").forEach(m => {
        const inst = bootstrap.Modal.getInstance(m);
        if (inst) inst.hide();
      });

      Swal.fire({
        title: "Confirm Action",
        text: `${action === 'list' ? 'List' : 'Unlist'} "${this.dataset.name}"?`,
        icon: "question",
        showCancelButton: true,
        confirmButtonColor: "#C97B8A",
        cancelButtonColor: "#B08A8A",
        confirmButtonText: "Confirm",
        cancelButtonText: "Cancel"
      }).then(async result => {
        if (result.isConfirmed) {
          try {
            const res  = await fetch(`/admin/products/toggle/${selectedProductId}`, {
              method: "PATCH", credentials: "same-origin",
              headers: { "Content-Type": "application/json" }
            });
            const data = await res.json();
            if (!data.success) throw new Error();
            location.reload();
          } catch {
            Swal.fire("Error", "Toggle failed. Please try again.", "error");
            selectedCheckbox.checked = !selectedCheckbox.checked;
          }
        } else {
          selectedCheckbox.checked = !selectedCheckbox.checked;
        }
      });
    });
  });

  /* ── Cropper state ── */
  let cropper        = null;
  let currentMode    = null;
  let activeIndex    = null;
  let cropperReady   = false;

  const croppedImages     = [];
  const editCroppedImages = [];

  const imageInput     = document.getElementById("imageInput");
  const editImageInput = document.getElementById("editImageInput");
  const cropImage      = document.getElementById("cropImage");
  const cropModalEl    = document.getElementById("cropModal");
  const editModalEl    = document.getElementById("editProductModal");
  let   editModalInst  = null;
  let   cropModalInst  = null;

  /* ── Edit btn ── */
  document.querySelectorAll(".edit-btn").forEach(btn => {
    btn.addEventListener("click", function () {
      editCroppedImages.length = 0;
      document.getElementById("editProductName").value    = this.dataset.name;
      document.getElementById("editDescription").value    = this.dataset.desc;
      document.getElementById("editLongDescription").value = this.dataset.longdesc;
      document.getElementById("editBrand").value          = this.dataset.brand;
      document.getElementById("editProductOffer").value   = this.dataset.offer || 0;
      document.getElementById("editCategory").value       = this.dataset.category;
      document.getElementById("editProductForm").action   = `/admin/products/edit/${this.dataset.id}`;

      const images = JSON.parse(this.dataset.images || "[]");
      document.querySelectorAll(".edit-slot").forEach((slot, i) => {
        const img  = slot.querySelector("img");
        const plus = slot.querySelector(".slot-plus");
        img.hidden = true; img.src = ""; plus.style.display = "block";
        if (images[i]) { img.src = images[i]; img.hidden = false; plus.style.display = "none"; }
      });

      const modal = bootstrap.Modal.getOrCreateInstance(editModalEl);
      modal.show();
      editModalInst = modal;
    });
  });

  /* ── Slot clicks ── */
  document.querySelectorAll(".image-slot:not(.edit-slot)").forEach(slot => {
    slot.addEventListener("click", () => {
      currentMode = "add"; activeIndex = Number(slot.dataset.index);
      imageInput.value = ""; imageInput.click();
    });
  });
  document.querySelectorAll(".edit-slot").forEach(slot => {
    slot.addEventListener("click", () => {
      currentMode = "edit"; activeIndex = Number(slot.dataset.index);
      editImageInput.value = ""; editImageInput.click();
    });
  });

  imageInput.addEventListener("change",     e => { if (e.target.files[0]) handleImageSelect(e.target.files[0]); });
  editImageInput.addEventListener("change",  e => { if (e.target.files[0]) handleImageSelect(e.target.files[0]); });

  function handleImageSelect(file) {
    const reader = new FileReader();
    reader.onload = () => {
      cropImage.src = reader.result;
      cropperReady  = false;
      if (currentMode === "edit" && editModalInst) editModalInst.hide();
      cropModalInst = new bootstrap.Modal(cropModalEl);
      cropModalInst.show();
    };
    reader.readAsDataURL(file);
  }

  cropModalEl.addEventListener("shown.bs.modal", () => {
    if (cropperReady) return;
    if (cropper) { cropper.destroy(); cropper = null; }
    cropper = new Cropper(cropImage, {
      aspectRatio: 1, viewMode: 2, autoCropArea: 1,
      responsive: true, background: false, zoomable: true, movable: true
    });
    cropperReady = true;
  });

  cropModalEl.addEventListener("hidden.bs.modal", () => {
    if (cropper) { cropper.destroy(); cropper = null; }
    cropperReady = false;
    if (currentMode === "edit" && editModalInst) {
      setTimeout(() => editModalInst.show(), 200);
    }
    document.querySelectorAll(".modal-backdrop").forEach((b, i) => { if (i > 0) b.remove(); });
  });

  document.getElementById("cropSaveBtn").addEventListener("click", async () => {
    if (!cropper) return;
    const canvas = cropper.getCroppedCanvas({ width: 800, height: 800 });
    const blob   = await new Promise(res => canvas.toBlob(res, "image/jpeg", 0.9));

    const slotSelector = currentMode === "add"
      ? `.image-slot[data-index="${activeIndex}"]:not(.edit-slot)`
      : `.edit-slot[data-index="${activeIndex}"]`;

    const store = currentMode === "add" ? croppedImages : editCroppedImages;
    store[activeIndex] = blob;

    const slot = document.querySelector(slotSelector);
    const img  = slot.querySelector("img");
    img.src = URL.createObjectURL(blob);
    img.hidden = false;
    slot.querySelector(".slot-plus").style.display = "none";

    if (cropModalInst) cropModalInst.hide();
  });

  /* ── Add product form ── */
  const addForm       = document.getElementById("addProductForm");
  const nameInput     = document.getElementById("productName");
  const descInput     = document.getElementById("description");
  const longDescInput = document.getElementById("longDescription");
  const categoryInput = document.getElementById("categoryId");
  const brandInput    = document.getElementById("brand");

  addForm.addEventListener("submit", async e => {
    e.preventDefault();
    let isValid = true;

    const setErr = (el, errEl, msg) => {
      if (msg) { errEl.innerText = msg; el.classList.add("is-invalid"); isValid = false; }
      else      { errEl.innerText = ""; el.classList.remove("is-invalid"); }
    };

    const name     = nameInput.value.trim();
    const desc     = descInput.value.trim();
    const longDesc = longDescInput.value.trim();
    const category = categoryInput.value;
    const brand    = brandInput.value.trim();

    setErr(nameInput,     document.getElementById("nameError"),     name     === "" ? "Product name required" : "");
    setErr(descInput,     document.getElementById("descError"),     desc     === "" ? "Description required"  : "");
    setErr(longDescInput, document.getElementById("longDescError"), longDesc === "" ? "Long description required" : longDesc.length < 10 ? "Minimum 10 characters" : "");
    setErr(categoryInput, document.getElementById("categoryError"), !category ? "Select a category" : "");
    if (brand && brand.length < 2) { setErr(brandInput, document.getElementById("brandError"), "Min 2 characters"); }
    else { document.getElementById("brandError").innerText = ""; brandInput.classList.remove("is-invalid"); }

    if (!croppedImages.some(img => img)) {
      Swal.fire("No image", "Add at least one product image", "error");
      isValid = false;
    }

    if (!isValid) return;

    const fd = new FormData();
    fd.append("productName",    name);
    fd.append("description",    desc);
    fd.append("longDescription", addForm.longDescription.value);
    fd.append("categoryId",     category);
    fd.append("brand",          addForm.brand.value);
    fd.append("productOffer",   addForm.productOffer.value || 0);
    croppedImages.forEach((blob, i) => { if (blob) fd.append("images", blob, `image_${i}.jpg`); });

    try {
      const res  = await fetch(addForm.action, { method: "POST", body: fd });
      const data = await res.json();
      if (data.success) { window.location.href = data.redirectUrl; }
      else { Swal.fire({ icon: "error", title: "Error", text: data.message || "Product already exists" }); }
    } catch { alert("Something went wrong"); }
  });

  /* ── Edit product form ── */
  const editForm = document.getElementById("editProductForm");
  editForm.addEventListener("submit", async e => {
    e.preventDefault();
    let isValid = true;

    const name     = editForm.productName.value.trim();
    const desc     = editForm.description.value.trim();
    const longDesc = editForm.longDescription.value.trim();
    const category = editForm.categoryId.value;
    const brand    = editForm.brand.value.trim();

    if (!name)                           { Swal.fire("Error", "Product name required", "error"); isValid = false; }
    else if (!desc)                      { Swal.fire("Error", "Description required", "error"); isValid = false; }
    else if (longDesc.length < 10)       { Swal.fire("Error", "Long description min 10 chars", "error"); isValid = false; }
    else if (!category)                  { Swal.fire("Error", "Select a category", "error"); isValid = false; }
    else if (brand && brand.length < 2)  { Swal.fire("Error", "Brand must be at least 2 characters", "error"); isValid = false; }

    const hasNew      = editCroppedImages.some(img => img);
    const hasExisting = document.querySelectorAll("#editImageSlots img:not([hidden])").length > 0;
    if (!hasNew && !hasExisting) { Swal.fire("Error", "Add at least one image", "error"); isValid = false; }

    if (!isValid) return;

    const fd = new FormData();
    fd.append("productName",    name);
    fd.append("description",    desc);
    fd.append("longDescription", editForm.longDescription.value);
    fd.append("categoryId",     category);
    fd.append("brand",          brand);
    fd.append("productOffer",   editForm.productOffer.value || 0);
    editCroppedImages.forEach((blob, i) => {
      if (blob) { fd.append("images", blob, `image_${i}.jpg`); fd.append("imageIndexes[]", String(i)); }
    });

    try {
      const res  = await fetch(editForm.action, { method: "POST", body: fd });
      const data = await res.json();
      if (res.ok && data.success) {
        Swal.fire({ icon: "success", title: "Updated", text: "Product updated successfully" }).then(() => { window.location.href = "/admin/products"; });
      } else {
        Swal.fire({ icon: "error", title: "Error", text: data.message || "Update failed" });
      }
    } catch (err) { console.error(err); }
  });

  /* ── Debounced search ── */
  const searchForm  = document.querySelector('form[action="/admin/products"]');
  const searchInput = document.getElementById("adminSearchInput");
  let   searchTimer = null;

  searchInput.addEventListener("input", () => {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => searchForm.submit(), 500);
  });
  searchForm.addEventListener("submit", e => { e.preventDefault(); searchForm.submit(); });

});
</script>
