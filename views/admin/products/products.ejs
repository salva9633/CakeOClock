<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --rose: #C97B8A; --rose-dk: #A85F6E; --rose-lt: #FAE8ED;
  --blush: #FDF0F3; --caramel: #D4A574; --brown: #5C3A3A;
  --muted: #B08A8A; --border: #F5D8E0; --mint: #E8F6F0; --white: #FFFFFF;
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.94); }
  to   { opacity: 1; transform: scale(1); }
}
@keyframes shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.pg { padding: 1.5rem 1rem; }

.pg-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 1.5rem;
  animation: fadeUp .45s ease both;
}
.pg-header h1 {
  font-size: 20px;
  font-weight: 500;
  color: var(--brown);
  display: flex;
  align-items: center;
  gap: 8px;
}
.pg-header h1 i { color: var(--rose); font-size: 20px; }

.search-wrap {
  display: flex;
  align-items: center;
  gap: 8px;
  background: var(--white);
  border: 0.5px solid var(--border);
  border-radius: 24px;
  padding: 0 14px;
  transition: border-color .2s;
  height: 36px;
}
.search-wrap:focus-within { border-color: var(--rose); }
.search-wrap i { color: var(--muted); font-size: 15px; flex-shrink: 0; }
.search-wrap input {
  border: none;
  outline: none;
  font-size: 13px;
  color: var(--brown);
  background: transparent;
  width: 200px;
}
.search-wrap input::placeholder { color: var(--muted); }
.search-clear {
  font-size: 11px;
  color: var(--muted);
  text-decoration: none;
  white-space: nowrap;
  transition: color .15s;
}
.search-clear:hover { color: var(--rose); }

.add-btn {
  display: flex;
  align-items: center;
  gap: 7px;
  background: var(--rose);
  color: var(--white);
  border: none;
  padding: 0 18px;
  height: 36px;
  border-radius: 24px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: background .2s, transform .15s;
  white-space: nowrap;
}
.add-btn:hover { background: var(--rose-dk); transform: translateY(-1px); }
.add-btn i { font-size: 15px; }

.stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
  margin-bottom: 1.5rem;
}
.stat {
  background: var(--white);
  border: 0.5px solid var(--border);
  border-radius: 12px;
  padding: .9rem 1.1rem;
  border-top: 3px solid var(--rose);
  display: flex;
  align-items: center;
  gap: 12px;
  opacity: 0;
  animation: fadeUp .5s ease forwards;
  transition: transform .2s;
}
.stat:hover { transform: translateY(-2px); }
.stat.s2 { border-top-color: var(--caramel); animation-delay: .08s; }
.stat.s3 { border-top-color: #7BB88A;        animation-delay: .16s; }

.stat-icon {
  width: 34px; height: 34px;
  border-radius: 8px;
  background: var(--rose-lt);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.stat-icon i { font-size: 17px; color: var(--rose); }
.stat.s2 .stat-icon { background: #FEF0E8; }
.stat.s2 .stat-icon i { color: var(--caramel); }
.stat.s3 .stat-icon { background: var(--mint); }
.stat.s3 .stat-icon i { color: #5A9A6A; }

.stat-info {}
.stat-label { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; }
.stat-value { font-size: 22px; font-weight: 500; color: var(--brown); line-height: 1.1; }

.table-card {
  background: var(--white);
  border: 0.5px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
  opacity: 0;
  animation: scaleIn .5s ease .28s forwards;
  margin-bottom: 1.5rem;
}
.table-card table {
  width: 100%;
  border-collapse: collapse;
}
.table-card thead tr {
  background: var(--blush);
  border-bottom: 1px solid var(--border);
}
.table-card thead th {
  padding: 11px 16px;
  font-size: 11px;
  font-weight: 500;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: .06em;
  white-space: nowrap;
}
.table-card tbody tr {
  border-bottom: 0.5px solid var(--rose-lt);
  transition: background .15s;
}
.table-card tbody tr:last-child { border-bottom: none; }
.table-card tbody tr:hover { background: var(--blush); }
.table-card tbody td {
  padding: 12px 16px;
  font-size: 13px;
  color: var(--brown);
  vertical-align: middle;
}

.prod-img-wrap {
  display: flex;
  align-items: center;
  gap: 10px;
}
.prod-thumb {
  width: 42px;
  height: 42px;
  border-radius: 10px;
  object-fit: cover;
  border: 1px solid var(--border);
  flex-shrink: 0;
}
.prod-name { font-size: 13px; color: var(--brown); font-weight: 500; }
.prod-desc { font-size: 11px; color: var(--muted); margin-top: 1px; }

.badge-cat {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 11px;
  padding: 3px 10px;
  border-radius: 20px;
  background: var(--rose-lt);
  color: var(--rose-dk);
  font-weight: 500;
}
.badge-brand {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 11px;
  padding: 3px 10px;
  border-radius: 20px;
  background: #FEF0E8;
  color: #A07040;
  font-weight: 500;
}

.form-switch .form-check-input {
  cursor: pointer;
  width: 36px;
  height: 20px;
}
.form-check-input:checked { background-color: var(--rose) !important; border-color: var(--rose) !important; }

.btn-view {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 11px;
  padding: 4px 12px;
  border-radius: 20px;
  border: 0.5px solid var(--border);
  background: var(--white);
  color: var(--muted);
  text-decoration: none;
  transition: all .2s;
}
.btn-view:hover { border-color: var(--rose); color: var(--rose); background: var(--rose-lt); }

.btn-edit {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 11px;
  padding: 4px 12px;
  border-radius: 20px;
  border: 0.5px solid var(--border);
  background: var(--white);
  color: var(--muted);
  cursor: pointer;
  transition: all .2s;
}
.btn-edit:hover { border-color: var(--caramel); color: var(--caramel); background: #FEF0E8; }

.empty-row td {
  text-align: center;
  padding: 3rem 1rem !important;
  color: var(--muted);
  font-size: 13px;
}
.empty-icon { font-size: 36px; color: var(--border); margin-bottom: 8px; }

.pg-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 8px;
  animation: fadeUp .5s ease .4s both;
  opacity: 0;
}
.pg-info { font-size: 12px; color: var(--muted); }
.pager { display: flex; gap: 4px; }
.page-btn {
  min-width: 34px;
  height: 34px;
  border-radius: 8px;
  border: 0.5px solid var(--border);
  background: var(--white);
  color: var(--brown);
  font-size: 15px;
  display: flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  cursor: pointer;
  transition: all .2s;
  padding: 0 6px;
}
.page-btn:hover:not(.disabled):not(.active) { border-color: var(--rose); color: var(--rose); }
.page-btn.active { background: var(--rose); color: var(--white); border-color: var(--rose); }
.page-btn.disabled { opacity: .4; pointer-events: none; }

.modal { z-index: 10010; }
.modal-backdrop { z-index: 10005; }

.custom-modal {
  background: var(--blush);
  border-radius: 16px;
  border: 0.5px solid var(--border);
}
.modal-header {
  background: var(--white);
  border-bottom: 0.5px solid var(--border);
  padding: 1rem 1.25rem;
  border-radius: 16px 16px 0 0;
}
.modal-title {
  font-size: 15px;
  font-weight: 500;
  color: var(--brown);
  display: flex;
  align-items: center;
  gap: 8px;
}
.modal-title i { color: var(--rose); }
.modal-body { padding: 1.25rem; }
.modal-footer {
  background: var(--white);
  border-top: 0.5px solid var(--border);
  padding: .9rem 1.25rem;
  border-radius: 0 0 16px 16px;
}

.form-label { font-size: 12px; font-weight: 500; color: var(--muted); text-transform: uppercase; letter-spacing: .05em; margin-bottom: 4px; }
.form-control, .form-select {
  border: 0.5px solid var(--border);
  border-radius: 8px;
  font-size: 13px;
  color: var(--brown);
  background: var(--white);
  padding: 8px 12px;
  transition: border-color .2s;
}
.form-control:focus, .form-select:focus {
  outline: none;
  border-color: var(--rose);
  box-shadow: 0 0 0 3px rgba(201,123,138,.12);
}
.form-control.is-invalid, .form-select.is-invalid {
  border-color: #dc3545;
}
textarea.form-control { resize: vertical; min-height: 80px; }

.btn-cancel {
  font-size: 13px;
  padding: 7px 18px;
  border-radius: 20px;
  border: 0.5px solid var(--border);
  background: var(--white);
  color: var(--muted);
  cursor: pointer;
  transition: all .2s;
}
.btn-cancel:hover { border-color: var(--rose); color: var(--rose); }
.btn-save {
  font-size: 13px;
  padding: 7px 20px;
  border-radius: 20px;
  border: none;
  background: var(--rose);
  color: var(--white);
  cursor: pointer;
  font-weight: 500;
  transition: background .2s, transform .15s;
}
.btn-save:hover { background: var(--rose-dk); transform: translateY(-1px); }
.btn-save:disabled { opacity: .6; cursor: not-allowed; transform: none; }

.image-grid { display: flex; flex-wrap: wrap; gap: 10px; }
.image-slot {
  width: 90px;
  height: 90px;
  border: 1.5px dashed var(--border);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  position: relative;
  background: var(--white);
  transition: border-color .2s, transform .15s;
  overflow: hidden;
}
.image-slot:hover { border-color: var(--rose); transform: scale(1.04); }
.image-slot .slot-plus { font-size: 24px; color: var(--border); line-height: 1; }
.image-slot img { width: 100%; height: 100%; object-fit: cover; border-radius: 8px; }

#cropModal .modal-dialog { max-width: 95vw; margin: 0 auto; }
#cropModal .modal-content { height: 95vh; background: #111; color: #fff; border-radius: 16px; }
#cropModal .modal-body { display: flex; align-items: center; justify-content: center; flex: 1; overflow: hidden; padding: 0; }
#cropModal .modal-header, #cropModal .modal-footer { background: #1a1a1a; border: none; }
#cropModal .btn-close { filter: invert(1); }
.cropper-container { max-height: 80vh !important; }

/* Ensure SweetAlert2 always renders above Bootstrap modals/backdrops */
.swal2-container { z-index: 10020 !important; }

</style>

<div class="pg">

  <div class="pg-header">
    <h1><i class="ti ti-box" aria-hidden="true"></i> Products</h1>

    <form method="GET" action="/admin/products" class="search-wrap">
      <i class="ti ti-search" aria-hidden="true"></i>
      <input
        type="text"
        id="adminSearchInput"
        name="search"
        value="<%= search %>"
        placeholder="Search products…"
        autocomplete="off"
      >
      <% if (search) { %>
        <a href="/admin/products" class="search-clear">Clear</a>
      <% } %>
    </form>

    <button class="add-btn" data-bs-toggle="modal" data-bs-target="#addProductModal">
      <i class="ti ti-plus" aria-hidden="true"></i> Add Product
    </button>
  </div>

  <div class="table-card">
    <table>
      <thead>
        <tr>
          <th>Product</th>
          <th>Category</th>
          <th>Brand</th>
          <th>Visibility</th>
          <th></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% if (products.length === 0) { %>
          <tr class="empty-row">
            <td colspan="6">
              <div class="empty-icon"><i class="ti ti-box-off" aria-hidden="true"></i></div>
              <div>No products found</div>
            </td>
          </tr>
        <% } %>
        <% products.forEach(product => { %>
          <tr>
            <td>
              <div class="prod-img-wrap">
                <img
                  src="<%= product.productImages?.[0] || '/placeholder.png' %>"
                  class="prod-thumb"
                  alt="<%= product.productName %>"
                >
                <div>
                  <div class="prod-name"><%= product.productName %></div>
                  <% if (product.description) { %>
                    <div class="prod-desc"><%= product.description.substring(0, 40) %><%= product.description.length > 40 ? '…' : '' %></div>
                  <% } %>
                </div>
              </div>
            </td>
            <td>
              <% if (product.categoryId) { %>
                <span class="badge-cat">
                  <i class="ti ti-tag" aria-hidden="true" style="font-size:10px;"></i>
                  <%= product.categoryId.name %>
                </span>
              <% } else { %>
                <span style="color:var(--muted); font-size:12px;">—</span>
              <% } %>
            </td>
            <td>
              <% if (product.brand) { %>
                <span class="badge-brand">
                  <i class="ti ti-rosette" aria-hidden="true" style="font-size:10px;"></i>
                  <%= product.brand %>
                </span>
              <% } else { %>
                <span style="color:var(--muted); font-size:12px;">—</span>
              <% } %>
            </td>
            <td>
              <div class="form-check form-switch" style="margin:0;">
                <input
                  class="form-check-input listing-toggle"
                  type="checkbox"
                  <%= product.isListed ? "checked" : "" %>
                  data-id="<%= product._id %>"
                  data-name="<%= product.productName %>"
                >
              </div>
            </td>
            <td>
              <a href="/admin/products/<%= product._id %>" class="btn-view">
                <i class="ti ti-eye" aria-hidden="true" style="font-size:12px;"></i> View
              </a>
            </td>
            <td>
        <button
                type="button"
                class="btn-edit edit-btn"
                data-id="<%= product._id %>"
                data-name="<%= product.productName %>"
                data-desc="<%= product.description %>"
                data-longdesc="<%= product.longDescription || '' %>"
                data-brand="<%= product.brand || '' %>"
                data-category="<%= product.categoryId ? product.categoryId._id : '' %>"
                data-offer="<%= product.productOffer || 0 %>"
                data-images='<%- JSON.stringify(product.productImages || []) %>'
              >
                <i class="ti ti-pencil" aria-hidden="true" style="font-size:12px;"></i> Edit
              </button>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="pg-footer">
    <div class="pg-info">
      Page <%= currentPage %> of <%= totalPages %>
    </div>

<div class="pager">
      <a class="page-btn <%= currentPage === 1 ? 'disabled' : '' %>"
         href="?page=<%= currentPage - 1 %>&search=<%= search %>"
         aria-label="Previous">
        <i class="ti ti-chevron-left" aria-hidden="true"></i>
      </a>

      <% for (let i = 1; i <= totalPages; i++) { %>
        <a class="page-btn <%= currentPage === i ? 'active' : '' %>"
           href="?page=<%= i %>&search=<%= search %>"><%= i %></a>
      <% } %>

      <a class="page-btn <%= currentPage === totalPages ? 'disabled' : '' %>"
         href="?page=<%= currentPage + 1 %>&search=<%= search %>"
         aria-label="Next">
        <i class="ti ti-chevron-right" aria-hidden="true"></i>
      </a>
    </div>  
  </div>

</div><!-- /pg -->


<!-- ─── ADD PRODUCT MODAL ─── -->
<div class="modal fade" id="addProductModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <form id="addProductForm" action="/admin/products/add" method="post" enctype="multipart/form-data" class="modal-content custom-modal" novalidate>
      <div class="modal-header">
        <h5 class="modal-title"><i class="ti ti-plus" aria-hidden="true"></i> Add New Product</h5>
      </div>
      <div class="modal-body row g-3">
        <div class="col-12">
          <label class="form-label">Product Name</label>
          <input type="text" name="productName" id="productName" class="form-control" placeholder="Enter product name">
          <small id="nameError" class="text-danger"></small>
        </div>
        <div class="col-12">
          <label class="form-label">Short Description</label>
          <input type="text" name="description" id="description" class="form-control" placeholder="Brief description">
          <small id="descError" class="text-danger"></small>
        </div>
        <div class="col-12">
          <label class="form-label">Long Description</label>
          <textarea name="longDescription" id="longDescription" class="form-control" placeholder="Detailed description…"></textarea>
          <small id="longDescError" class="text-danger"></small>
        </div>
        <div class="col-md-6">
          <label class="form-label">Category</label>
          <select name="categoryId" id="categoryId" class="form-select">
            <option value="">Select category</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat._id %>"><%= cat.name %></option>
            <% }) %>
          </select>
          <small id="categoryError" class="text-danger"></small>
        </div>
        <div class="col-md-6">
          <label class="form-label">Brand</label>
          <input type="text" name="brand" id="brand" class="form-control" placeholder="Brand name">
          <small id="brandError" class="text-danger"></small>
        </div>
        <div class="col-md-6">
          <label class="form-label">Product Offer (%) <span style="color:var(--muted);font-weight:400;text-transform:none;">(optional)</span></label>
<input type="number" name="productOffer" id="productOffer" 
  class="form-control" placeholder="Leave blank for no offer" min="0" max="90">
          <small id="offerError" class="text-danger"></small>
        </div>
        <div class="col-12">
          <label class="form-label">Product Images <span style="color:var(--muted);font-weight:400;text-transform:none;">(max 5)</span></label>
          <div class="image-grid" id="imageSlots">
            <% for (let i = 0; i < 5; i++) { %>
              <div class="image-slot" data-index="<%= i %>">
                <span class="slot-plus">+</span>
                <img hidden>
              </div>
            <% } %>
          </div>
          <input type="file" id="imageInput" accept="image/*" hidden multiple>
          <small id="imageError" class="text-danger d-block mt-1"></small>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-cancel" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn-save">Save Product</button>
      </div>
    </form>
  </div>
</div>

<!-- ─── CROP MODAL ─── -->
<div class="modal fade" id="cropModal" tabindex="-1">
  <div class="modal-dialog modal-fullscreen modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" style="color:#fff;">Crop Image</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body d-flex justify-content-center align-items-center p-0">
        <div style="width:100%; height:100%;">
          <img id="cropImage" style="max-width:100%; max-height:100vh; display:block; margin:auto;" />
        </div>
      </div>
      <div class="modal-footer justify-content-between">
        <small style="color:#999;">Drag to crop • Scroll to zoom</small>
        <button id="cropSaveBtn" class="btn-save">Crop & Use Image</button>
      </div>
    </div>
  </div>
</div>

<!-- ─── EDIT MODAL ─── -->
<div class="modal fade" id="editProductModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <form id="editProductForm" method="post" enctype="multipart/form-data" class="modal-content custom-modal" novalidate>
      <div class="modal-header">
        <h5 class="modal-title"><i class="ti ti-pencil" aria-hidden="true"></i> Edit Product</h5>
      </div>
      <div class="modal-body row g-3">
        <div class="col-12">
          <label class="form-label">Product Name</label>
          <input id="editProductName" name="productName" class="form-control">
          <small id="editNameError" class="text-danger"></small>
        </div>
        <div class="col-12">
          <label class="form-label">Short Description</label>
          <input id="editDescription" name="description" class="form-control">
          <small id="editDescError" class="text-danger"></small>
        </div>
        <div class="col-12">
          <label class="form-label">Long Description</label>
          <textarea id="editLongDescription" name="longDescription" class="form-control"></textarea>
          <small id="editLongDescError" class="text-danger"></small>
        </div>
        <div class="col-md-6">
          <label class="form-label">Category</label>
          <select id="editCategory" name="categoryId" class="form-select">
            <option value="">Select category</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat._id %>"><%= cat.name %></option>
            <% }) %>
          </select>
          <small id="editCategoryError" class="text-danger"></small>
        </div>
        <div class="col-md-6">
          <label class="form-label">Brand</label>
          <input id="editBrand" name="brand" class="form-control">
          <small id="editBrandError" class="text-danger"></small>
        </div>
        <div class="col-md-6">
          <label class="form-label">Product Offer (%) <span style="color:var(--muted);font-weight:400;text-transform:none;">(optional)</span></label>
          <input type="number" name="productOffer" id="editProductOffer" 
            class="form-control" placeholder="Leave blank for no offer" min="0" max="90">
          <small id="editOfferError" class="text-danger"></small>
        </div>
        <div class="col-12">
          <label class="form-label">Product Images <span style="color:var(--muted);font-weight:400;text-transform:none;">(max 5)</span></label>
          <div class="image-grid" id="editImageSlots">
            <% for (let i = 0; i < 5; i++) { %>
              <div class="image-slot edit-slot" data-index="<%= i %>">
                <span class="slot-plus">+</span>
                <img hidden>
              </div>
            <% } %>
          </div>
          <input type="file" id="editImageInput" accept="image/*" hidden multiple>
          <small id="editImageError" class="text-danger d-block mt-1"></small>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn-cancel" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn-save">Update Product</button>
      </div>
    </form>
  </div>
</div>

<!-- ─── SCRIPTS ─── -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link href="https://cdn.jsdelivr.net/npm/cropperjs@1.6.1/dist/cropper.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
<script src="https://cdn.jsdelivr.net/npm/cropperjs@1.6.1/dist/cropper.min.js"></script>

<script>
(function () {

  /* =========================================================
     PROACTIVE CLEANUP — runs every time this script executes.
     Removes any stray backdrop / modal-open state left on <body>
     from a previously loaded page (important if the admin panel
     navigates via AJAX and swaps only inner content, since
     .modal-backdrop and body classes live outside that container).
  ========================================================= */
  document.querySelectorAll(".modal-backdrop").forEach(el => el.remove());
  if (!document.querySelector(".modal.show")) {
    document.body.classList.remove("modal-open");
    document.body.style.removeProperty("overflow");
    document.body.style.removeProperty("padding-right");
  }

  /* =========================================================
     INIT GUARD — prevents binding the same listeners twice if
     this script block gets executed more than once (e.g. AJAX
     navigation re-inserting this same page fragment/script).
  ========================================================= */
  if (window.__productsPageBound) return;
  window.__productsPageBound = true;

  /* ---------- SEARCH DEBOUNCE ---------- */
  (function () {
    const searchInput = document.getElementById("adminSearchInput");
    const searchForm = searchInput ? searchInput.closest("form") : null;
    if (!searchInput || !searchForm) return;

    let searchTimer;
    let lastSubmittedValue = searchInput.value.trim();

    searchInput.addEventListener("input", () => {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(() => {
        const value = searchInput.value.trim();
        if (value === lastSubmittedValue) return; // nothing changed, skip
        lastSubmittedValue = value;

        const url = "/admin/products" + (value ? `?search=${encodeURIComponent(value)}` : "");

        if (typeof window.adminNavigate === "function") {
          window.adminNavigate(url); // smooth AJAX nav, matches rest of admin panel
        } else {
          searchForm.submit(); // fallback if adminNav.js isn't loaded
        }
      }, 500);
    });
  })();

  let selectedProductId = null;

  let addImageFiles = new Array(5).fill(null);
  let editImageFiles = new Array(5).fill(null);
  let editExistingImages = new Array(5).fill(null); // URLs already saved, to know what stays
  let editChangedIndexes = new Set();
 let cropperInstance = null;
  let cropTargetContext = null; // { mode: 'add'|'edit', index: n }
  let activeParentModalId = null; // which modal ("addProductModal"/"editProductModal") to reopen after cropping  let cropTargetContext = null; // { mode: 'add'|'edit', index: n }

  /* ---------- helpers ---------- */
  function renderSlot(slotEl, src) {
    const img = slotEl.querySelector("img");
    const plus = slotEl.querySelector(".slot-plus");
    if (src) {
      img.src = src;
      img.hidden = false;
      plus.hidden = true;
    } else {
      img.src = "";
      img.hidden = true;
      plus.hidden = false;
    }
  }

  function setFieldError(fieldId, errorId, message) {
    const field = document.getElementById(fieldId);
    const errorEl = document.getElementById(errorId);
    if (!field || !errorEl) return;
    if (message) {
      field.classList.add("is-invalid");
      errorEl.textContent = message;
    } else {
      field.classList.remove("is-invalid");
      errorEl.textContent = "";
    }
  }

  function clearErrors(ids) {
    ids.forEach(({ fieldId, errorId }) => setFieldError(fieldId, errorId, ""));
  }

  /* ---------- shared validation ---------- */
  function validateProductFields({ name, desc, longDesc, categoryId, brand, offer }) {
    const errors = {};

    if (!name) {
      errors.name = "Product name is required";
    } else if (name.length < 3) {
      errors.name = "Must be at least 3 characters";
    } else if (name.length > 100) {
      errors.name = "Must be under 100 characters";
    }

    if (!desc) {
      errors.desc = "Short description is required";
    } else if (desc.length < 10) {
      errors.desc = "Must be at least 10 characters";
    } else if (desc.length > 200) {
      errors.desc = "Must be under 200 characters";
    }

    if (longDesc && longDesc.length > 3000) {
      errors.longDesc = "Must be under 3000 characters";
    }

    if (!categoryId) {
      errors.categoryId = "Please select a category";
    }

    if (brand && brand.length > 50) {
      errors.brand = "Must be under 50 characters";
    }

    // Offer is optional — only validate range if a value was actually entered
if (offer !== "" && offer !== null && offer !== undefined) {
  if (isNaN(offer)) {
    errors.offer = "Enter a valid number";
  } else if (Number(offer) < 0 || Number(offer) > 90) {
    errors.offer = "Must be between 0 and 90";
  }
}

    return errors;
  }

  /* =========================================================
     ADD MODAL: image slots — delegated (safe against re-render)
  ========================================================= */
document.addEventListener("click", (e) => {
    const addSlot = e.target.closest("#imageSlots .image-slot");
    if (addSlot) {
      cropTargetContext = { mode: "add", index: parseInt(addSlot.dataset.index) };
      activeParentModalId = "addProductModal";
      document.getElementById("imageInput").click();
      return;
    }
    const editSlot = e.target.closest("#editImageSlots .edit-slot");
    if (editSlot) {
      cropTargetContext = { mode: "edit", index: parseInt(editSlot.dataset.index) };
      activeParentModalId = "editProductModal";
      document.getElementById("editImageInput").click();
      return;
    }
  });

  document.getElementById("imageInput").addEventListener("change", (e) => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = () => openCropper(reader.result);
    reader.readAsDataURL(file);
    e.target.value = "";
  });

  document.getElementById("editImageInput").addEventListener("change", (e) => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = () => openCropper(reader.result);
    reader.readAsDataURL(file);
    e.target.value = "";
  });

  /* ---------- CROPPER ---------- */
function openCropper(dataUrl) {
    const cropImage = document.getElementById("cropImage");
    const cropModalEl = document.getElementById("cropModal");
    const parentModalEl = activeParentModalId ? document.getElementById(activeParentModalId) : null;

    const showCrop = () => {
      cropImage.src = dataUrl;
      const cropModal = bootstrap.Modal.getOrCreateInstance(cropModalEl);
      cropModal.show();

      cropModalEl.addEventListener("shown.bs.modal", function onShown() {
        if (cropperInstance) cropperInstance.destroy();
        cropperInstance = new Cropper(cropImage, {
          aspectRatio: 1,
          viewMode: 1,
          background: false
        });
        this.removeEventListener("shown.bs.modal", onShown);
      }, { once: true });
    };

    // Hide the parent modal (Add/Edit) before showing the crop modal so only
    // one Bootstrap modal is ever visible — avoids stacked-backdrop issues.
    if (parentModalEl && parentModalEl.classList.contains("show")) {
      parentModalEl.addEventListener("hidden.bs.modal", showCrop, { once: true });
      bootstrap.Modal.getOrCreateInstance(parentModalEl).hide();
    } else {
      showCrop();
    }
  }

document.getElementById("cropSaveBtn").addEventListener("click", () => {
    if (!cropperInstance || !cropTargetContext) return;

    const canvas = cropperInstance.getCroppedCanvas({ width: 600, height: 600 });
    canvas.toBlob((blob) => {
      const url = URL.createObjectURL(blob);
      const { mode, index } = cropTargetContext;

      if (mode === "add") {
        addImageFiles[index] = blob;
        renderSlot(document.querySelector(`#imageSlots .image-slot[data-index="${index}"]`), url);
        document.getElementById("imageError").textContent = "";
      } else {
        editImageFiles[index] = blob;
        editChangedIndexes.add(index);
        renderSlot(document.querySelector(`#editImageSlots .edit-slot[data-index="${index}"]`), url);
        document.getElementById("editImageError").textContent = "";
      }

      cropTargetContext = null;
      // hiding triggers the cropModal "hidden.bs.modal" handler below,
      // which destroys the cropper instance and reopens the parent modal
      bootstrap.Modal.getOrCreateInstance(document.getElementById("cropModal")).hide();
    }, "image/jpeg", 0.9);
  });

  /* =========================================================
     ADD PRODUCT
  ========================================================= */
  const addErrorFields = [
    { fieldId: "productName", errorId: "nameError" },
    { fieldId: "description", errorId: "descError" },
    { fieldId: "longDescription", errorId: "longDescError" },
    { fieldId: "categoryId", errorId: "categoryError" },
    { fieldId: "brand", errorId: "brandError" },
    { fieldId: "productOffer", errorId: "offerError" }
  ];

  addErrorFields.forEach(({ fieldId, errorId }) => {
    const el = document.getElementById(fieldId);
    if (el) el.addEventListener("input", () => setFieldError(fieldId, errorId, ""));
  });

  document.getElementById("addProductForm").addEventListener("submit", async (e) => {
    e.preventDefault();
    const form = e.target;

    clearErrors(addErrorFields);
    document.getElementById("imageError").textContent = "";

    const name = form.productName.value.trim();
    const desc = form.description.value.trim();
    const longDesc = form.longDescription.value.trim();
    const categoryId = form.categoryId.value;
    const brand = form.brand.value.trim();
const offer = form.productOffer.value.trim() === "" ? 0 : form.productOffer.value;

    const errors = validateProductFields({ name, desc, longDesc, categoryId, brand, offer });

    const hasAnyImage = addImageFiles.some(f => f !== null);
    let imageErrorMsg = "";
    if (!hasAnyImage) imageErrorMsg = "Please add at least one product image";

    if (Object.keys(errors).length > 0 || imageErrorMsg) {
      if (errors.name) setFieldError("productName", "nameError", errors.name);
      if (errors.desc) setFieldError("description", "descError", errors.desc);
      if (errors.longDesc) setFieldError("longDescription", "longDescError", errors.longDesc);
      if (errors.categoryId) setFieldError("categoryId", "categoryError", errors.categoryId);
      if (errors.brand) setFieldError("brand", "brandError", errors.brand);
      if (errors.offer) setFieldError("productOffer", "offerError", errors.offer);
      if (imageErrorMsg) document.getElementById("imageError").textContent = imageErrorMsg;
      return;
    }

    const formData = new FormData();
    formData.append("productName", name);
    formData.append("description", desc);
    formData.append("longDescription", longDesc);
    formData.append("categoryId", categoryId);
    formData.append("brand", brand);
    formData.append("productOffer", offer);

    addImageFiles.forEach((blob) => {
      if (blob) formData.append("images", blob, "image.jpg");
    });

    const saveBtn = form.querySelector(".btn-save");
    const originalText = saveBtn.textContent;
    saveBtn.disabled = true;
    saveBtn.textContent = "Saving...";

    try {
      const res = await fetch("/admin/products/add", { method: "POST", body: formData });
      const data = await res.json();

      if (data.success) {
        Swal.fire("Success", "Product added successfully", "success").then(() => {
          window.location.href = data.redirectUrl || "/admin/products";
        });
      } else {
        Swal.fire("Error", data.message || "Failed to add product", "error");
      }
    } catch (err) {
      console.error(err);
      Swal.fire("Error", "Something went wrong", "error");
    } finally {
      saveBtn.disabled = false;
      saveBtn.textContent = originalText;
    }
  });

  /* =========================================================
     EDIT PRODUCT
  ========================================================= */
  const editErrorFields = [
    { fieldId: "editProductName", errorId: "editNameError" },
    { fieldId: "editDescription", errorId: "editDescError" },
    { fieldId: "editLongDescription", errorId: "editLongDescError" },
    { fieldId: "editCategory", errorId: "editCategoryError" },
    { fieldId: "editBrand", errorId: "editBrandError" },
    { fieldId: "editProductOffer", errorId: "editOfferError" }
  ];

  editErrorFields.forEach(({ fieldId, errorId }) => {
    const el = document.getElementById(fieldId);
    if (el) el.addEventListener("input", () => setFieldError(fieldId, errorId, ""));
  });

  /* delegated click handler — works even if table rows are
     re-rendered via pagination/search without a full reload */
  document.addEventListener("click", (e) => {
    const btn = e.target.closest(".edit-btn");
    if (!btn) return;

    selectedProductId = btn.dataset.id;
    editChangedIndexes.clear();
    editImageFiles = new Array(5).fill(null);
    clearErrors(editErrorFields);
    document.getElementById("editImageError").textContent = "";

    document.getElementById("editProductName").value = btn.dataset.name || "";
    document.getElementById("editDescription").value = btn.dataset.desc || "";
    document.getElementById("editLongDescription").value = btn.dataset.longdesc || "";
    document.getElementById("editBrand").value = btn.dataset.brand || "";
    document.getElementById("editCategory").value = btn.dataset.category || "";
    document.getElementById("editProductOffer").value = btn.dataset.offer || 0;

    let images = [];
    try { images = JSON.parse(btn.dataset.images || "[]"); } catch { images = []; }
    editExistingImages = new Array(5).fill(null).map((_, i) => images[i] || null);

    document.querySelectorAll("#editImageSlots .edit-slot").forEach((slot, i) => {
      renderSlot(slot, images[i] || null);
    });

    document.getElementById("editProductForm").action = `/admin/products/edit/${selectedProductId}`;

    bootstrap.Modal.getOrCreateInstance(
      document.getElementById("editProductModal")
    ).show();
  });

  document.getElementById("editProductForm").addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!selectedProductId) return;

    const form = e.target;
    clearErrors(editErrorFields);
    document.getElementById("editImageError").textContent = "";

    const name = form.productName.value.trim();
    const desc = form.description.value.trim();
    const longDesc = form.longDescription.value.trim();
    const categoryId = form.categoryId.value;
const brand = form.brand.value.trim();
    const offer = form.productOffer.value.trim() === "" ? 0 : form.productOffer.value;

    const errors = validateProductFields({ name, desc, longDesc, categoryId, brand, offer });

    // at least one image must remain (existing, untouched) or be newly added
    // at least one image must remain (existing, untouched) or be newly added
    const hasExistingImage = editExistingImages.some((url, i) => url && !editChangedIndexes.has(i));
    const hasNewImage = [...editChangedIndexes].some(i => editImageFiles[i]);
    let imageErrorMsg = "";
    if (!hasExistingImage && !hasNewImage) {
      imageErrorMsg = "Please keep or add at least one product image";
    }

    if (Object.keys(errors).length > 0 || imageErrorMsg) {
      if (errors.name) setFieldError("editProductName", "editNameError", errors.name);
      if (errors.desc) setFieldError("editDescription", "editDescError", errors.desc);
      if (errors.longDesc) setFieldError("editLongDescription", "editLongDescError", errors.longDesc);
      if (errors.categoryId) setFieldError("editCategory", "editCategoryError", errors.categoryId);
      if (errors.brand) setFieldError("editBrand", "editBrandError", errors.brand);
      if (errors.offer) setFieldError("editProductOffer", "editOfferError", errors.offer);
      if (imageErrorMsg) document.getElementById("editImageError").textContent = imageErrorMsg;
      return;
    }

    const formData = new FormData();
    formData.append("productName", name);
    formData.append("description", desc);
    formData.append("longDescription", longDesc);
    formData.append("categoryId", categoryId);
    formData.append("brand", brand);
    formData.append("productOffer", offer);

    editChangedIndexes.forEach(index => {
      const blob = editImageFiles[index];
      if (blob) {
        formData.append("images", blob, "image.jpg");
        formData.append("imageIndexes[]", index);
      }
    });

    const saveBtn = form.querySelector(".btn-save");
    const originalText = saveBtn.textContent;
    saveBtn.disabled = true;
    saveBtn.textContent = "Saving...";

    try {
      const res = await fetch(`/admin/products/edit/${selectedProductId}`, {
        method: "POST",
        body: formData
      });
      const data = await res.json();

      if (data.success) {
        Swal.fire("Updated", "Product updated successfully", "success").then(() => {
          window.location.reload();
        });
      } else {
        Swal.fire("Error", data.message || "Failed to update product", "error");
      }
    } catch (err) {
      console.error(err);
      Swal.fire("Error", "Something went wrong", "error");
    } finally {
      saveBtn.disabled = false;
      saveBtn.textContent = originalText;
    }
  });

  /* =========================================================
     TOGGLE LISTING — delegated
  ========================================================= */
  document.addEventListener("change", async (e) => {
    const checkbox = e.target.closest(".listing-toggle");
    if (!checkbox) return;

    const id = checkbox.dataset.id;
    const name = checkbox.dataset.name;
    const wasChecked = checkbox.checked;

    // Revert the visual toggle immediately — we only flip it for real
    // after the user confirms and the API call succeeds.
    checkbox.checked = !wasChecked;

    const result = await Swal.fire({
      icon: "question",
      title: wasChecked ? "List this product?" : "Unlist this product?",
      html: wasChecked
        ? `Make <b>${name}</b> visible to customers?`
        : `Hide <b>${name}</b> from customers?`,
      showCancelButton: true,
      confirmButtonColor: "#A85F6E",
      cancelButtonColor: "#B08A8A",
      confirmButtonText: wasChecked ? "List it" : "Unlist it",
      cancelButtonText: "Cancel"
    });

    if (!result.isConfirmed) return; // checkbox already reverted, nothing else to do

    try {
      const res = await fetch(`/admin/products/toggle/${id}`, { method: "PATCH" });
      const data = await res.json();

      if (!data.success) {
        Swal.fire("Error", "Could not update listing status", "error");
        return;
      }

      checkbox.checked = data.isListed;
    } catch (err) {
      console.error(err);
      Swal.fire("Error", "Something went wrong", "error");
    }
  });

  /* =========================================================
     CLEAN UP ORPHANED BACKDROPS whenever any modal fully closes
  ========================================================= */
/* =========================================================
     CLEAN UP ORPHANED BACKDROPS whenever any modal fully closes
  ========================================================= */
/* =========================================================
     When the crop modal closes for ANY reason (Crop & Use, Cancel/X,
     or backdrop click), destroy the cropper and reopen whichever
     parent modal (Add/Edit) launched it.
  ========================================================= */
  document.getElementById("cropModal").addEventListener("hidden.bs.modal", () => {
    if (cropperInstance) {
      cropperInstance.destroy();
      cropperInstance = null;
    }
    if (activeParentModalId) {
      const parentEl = document.getElementById(activeParentModalId);
      if (parentEl) bootstrap.Modal.getOrCreateInstance(parentEl).show();
      activeParentModalId = null;
    }
  });

  /* =========================================================
     CLEAN UP ORPHANED BACKDROPS whenever any modal fully closes
  ========================================================= */
  document.addEventListener("hidden.bs.modal", () => {
    if (!document.querySelector(".modal.show")) {
      document.querySelectorAll(".modal-backdrop").forEach(el => el.remove());
      document.body.classList.remove("modal-open");
      document.body.style.removeProperty("overflow");
      document.body.style.removeProperty("padding-right");
    }
  });

})();


</script>