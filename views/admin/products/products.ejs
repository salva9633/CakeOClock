<!-- PRODUCTS PAGE CONTENT ONLY -->

<style>
  /* PAGE-SPECIFIC STYLES ONLY */
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 25px;
    flex-wrap: wrap;
    gap: 20px;
  }

  .page-title {
    font-size: 32px;
    font-weight: 700;
    color: #6d3939;
  }

  .new-btn {
    background: linear-gradient(135deg, #AF5454, #d97373);
    color: #fff;
    border: none;
    padding: 12px 24px;
    border-radius: 8px;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    box-shadow: 0 2px 8px rgba(175, 84, 84, .3);
  }

  .table-wrapper {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, .1);
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  thead {
    background: linear-gradient(135deg, #AF5454, #d97373);
  }

  thead th {
    padding: 16px;
    color: #fff;
    font-size: 14px;
    font-weight: 600;
  }

  tbody td {
    padding: 16px;
    font-size: 14px;
  }

  .product-image {
    width: 40px;
    height: 40px;
    border-radius: 6px;
    object-fit: cover;
    border: 1px solid #eee;
  }

  .custom-modal {
    background: #FDF2F2;
    border-radius: 16px;
  }

  .image-slot {
    width: 100px;
    height: 100px;
    border: 2px dashed #ccc;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    position: relative;
    background: #fff;
  }

  .image-slot span {
    font-size: 28px;
    color: #aaa;
  }

  .image-slot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 8px;
  }

  /* ===== Crop Modal Viewport Fix ===== */
#cropModal .modal-dialog {
  max-width: 90vw;
  max-height: 90vh;
}

#cropModal .modal-content {
  height: 90vh;
}

#cropModal .modal-body {
  display: flex;
  align-items: center;
  justify-content: center;
  max-height: calc(90vh - 120px); /* header + footer space */
  overflow: hidden;
}

  #cropModal .modal-content {
    background: #000;
    color: #fff;
  }

  #cropModal .modal-header,
  #cropModal .modal-footer {
    background: #111;
    border: none;
  }

  #cropModal .btn-close {
    filter: invert(1);
  }

  .cropper-container {
    max-height: 100vh !important;
  }



</style>

<div class="page-header">
  <h1 class="page-title">Products</h1>
  <button class="new-btn" data-bs-toggle="modal" data-bs-target="#addProductModal">
    + Add Product
  </button>
</div>

<div class="table-wrapper">
  <table>
  <thead>
    <tr>
      <th>Image</th>
      <th>Product Name</th>
      <th>Category</th>
      <th>Brand</th>
      <th>Visibility</th>
      <th>View</th>
      <th>Actions</th>
    </tr>
  </thead>

  <tbody>
    <% products.forEach(product => { %>
      <tr>

        <!-- Image -->
        <td>
          <img
            src="<%= product.productImages[0] %>"
            class="product-image"
            alt="<%= product.productName %>"
          >
        </td>

        <!-- Name -->
        <td><%= product.productName %></td>

        <!-- Category -->
        <td>
          <%= product.categoryId ? product.categoryId.name : "—" %>
        </td>

        <!-- Brand -->
        <td><%= product.brand || "N/A" %></td>

        <!-- Visibility Toggle -->
        <td>
          <div class="form-check form-switch">
            <input
              class="form-check-input listing-toggle"
              type="checkbox"
              <%= product.isListed ? "checked" : "" %>
              data-id="<%= product._id %>"
              data-name="<%= product.productName %>"
            >
          </div>
        </td>

        <!-- View -->
        <td>
          <a
            href="/admin/products/<%= product._id %>"
            class="btn btn-sm btn-outline-secondary">
            View
          </a>
        </td>

        <!-- Actions -->
        <td>
          <button
  type="button"
  class="btn btn-sm btn-outline-primary edit-btn"
  data-id="<%= product._id %>"
  data-name="<%= product.productName %>"
  data-desc="<%= product.description %>"
  data-longdesc="<%= product.longDescription || '' %>"
  data-brand="<%= product.brand || '' %>"
  data-category="<%= product.categoryId ? product.categoryId._id : '' %>"
  data-images='<%- JSON.stringify(product.productImages || []) %>'
>
  Edit
</button>

        </td>

      </tr>
    <% }) %>
  </tbody>
</table>

</div>

<!-- ADD PRODUCT MODAL -->
<div class="modal fade" id="addProductModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <form
      id="addProductForm"
      action="/admin/products/add"
      method="post"
      enctype="multipart/form-data"
      class="modal-content custom-modal"
    >

      <div class="modal-header">
        <h5 class="modal-title">Add New Product</h5>
      </div>

      <div class="modal-body row g-3">
        <div class="col-12">
          <label class="form-label">Product Name</label>
          <input type="text" name="productName" class="form-control" required>
        </div>

        <div class="col-12">
          <label class="form-label">Short Description</label>
          <input type="text" name="description" class="form-control" required>
        </div>

        <div class="col-12">
          <label class="form-label">Long Description</label>
          <textarea name="longDescription" class="form-control"></textarea>
        </div>

        <div class="col-md-6">
          <label class="form-label">Category</label>
          <select name="categoryId" class="form-select" required>
            <% categories.forEach(cat => { %>
              <option value="<%= cat._id %>"><%= cat.name %></option>
            <% }) %>
          </select>
        </div>

        <div class="col-md-6">
          <label class="form-label">Brand</label>
          <input
            type="text"
            name="brand"
            class="form-control"
            placeholder="Eg: Premium, Kids Special"
          >
        </div>

        <div class="col-12">
          <label class="form-label">Product Images (Max 5)</label>

          <div class="d-flex gap-3 flex-wrap" id="imageSlots">
            <% for (let i = 0; i < 5; i++) { %>
              <div class="image-slot" data-index="<%= i %>">
                <span>+</span>
                <img hidden>
              </div>
            <% } %>
          </div>

          <!-- Hidden file input -->
          <input type="file" id="imageInput" accept="image/*" hidden>
        </div>
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
          Cancel
        </button>
        <button class="btn btn-primary">
          Save Product
        </button>
      </div>

    </form>
  </div>
</div>

<!--Crop Modal -->
<div class="modal fade" id="cropModal" tabindex="-1">
  <div class="modal-dialog modal-fullscreen modal-dialog-centered">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">Crop Image</h5>
        <button
          type="button"
          class="btn-close"
          data-bs-dismiss="modal">
        </button>
      </div>

      <div class="modal-body d-flex justify-content-center align-items-center p-0">
        <div style="width:100%; height:100%;">
          <img
            id="cropImage"
            style="
              max-width:100%;
              max-height:100vh;
              display:block;
              margin:auto;
            "
          />
        </div>
      </div>

      <div class="modal-footer justify-content-between">
        <small class="text-muted">
          Drag to crop • Scroll to zoom
        </small>
        <button id="cropSaveBtn" class="btn btn-primary px-4">
          Crop & Use Image
        </button>
      </div>

    </div>
  </div>
</div>



<!-- Edit Modal -->
 <div class="modal fade" id="editProductModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <form
      id="editProductForm"
      method="post"
        enctype="multipart/form-data"
      class="modal-content custom-modal"
    >

      <div class="modal-header">
        <h5 class="modal-title">Edit Product</h5>
      </div>

      <div class="modal-body row g-3">

        <input type="hidden" name="productId" id="editProductId">

        <div class="col-12">
          <label class="form-label">Product Name</label>
          <input id="editProductName" name="productName" class="form-control" required>
        </div>

        <div class="col-12">
          <label class="form-label">Short Description</label>
          <input id="editDescription" name="description" class="form-control" required>
        </div>

        <div class="col-12">
          <label class="form-label">Long Description</label>
          <textarea id="editLongDescription" name="longDescription" class="form-control"></textarea>
        </div>

        <div class="col-md-6">
          <label class="form-label">Category</label>
          <select id="editCategory" name="categoryId" class="form-select" required>
            <% categories.forEach(cat => { %>
              <option value="<%= cat._id %>"><%= cat.name %></option>
            <% }) %>
          </select>
        </div>

        <div class="col-md-6">
          <label class="form-label">Brand</label>
          <input id="editBrand" name="brand" class="form-control">
        </div>

<div class="col-12">
  <label class="form-label">Product Images (Max 5)</label>

  <div class="d-flex gap-3 flex-wrap" id="editImageSlots">
    <% for (let i = 0; i < 5; i++) { %>
      <div class="image-slot edit-slot" data-index="<%= i %>">
        <span>+</span>
        <img hidden>
      </div>
    <% } %>
  </div>

  <!-- Hidden file input -->
  <input type="file" id="editImageInput" accept="image/*" hidden>
</div>
      </div>

      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button class="btn btn-primary">Update Product</button>
      </div>

    </form>
  </div>
</div>

<!-- Confirmation Modal -->

<div class="modal fade" id="confirmToggleModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">Confirm Action</h5>
      </div>

      <div class="modal-body">
        <p id="confirmText"></p>
      </div>

      <div class="modal-footer">
        <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button id="confirmToggleBtn" class="btn btn-danger">
          Confirm
        </button>
      </div>

    </div>
  </div>
</div>
<!-- Bootstrap JS (first) -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<!-- Cropper CSS -->
<link
  href="https://cdn.jsdelivr.net/npm/cropperjs@1.6.1/dist/cropper.min.css"
  rel="stylesheet"
/>
<script>
  let selectedProductId = null;
  let selectedCheckbox = null;

  document.querySelectorAll(".listing-toggle").forEach(toggle => {
    toggle.addEventListener("change", function () {
      selectedProductId = this.dataset.id;
      selectedCheckbox = this;

      const productName = this.dataset.name;
      const action = this.checked ? "list" : "unlist";

      document.getElementById("confirmText").innerText =
        `Are you sure you want to ${action} "${productName}"?`;

      const modal = new bootstrap.Modal(
        document.getElementById("confirmToggleModal")
      );

      modal.show();
    });
  });

  document.getElementById("confirmToggleBtn").addEventListener("click", async () => {
    try {
      await fetch(`/admin/products/toggle/${selectedProductId}`, {
        method: "PATCH"
      });
      location.reload();
    } catch (err) {
      alert("Something went wrong");
      selectedCheckbox.checked = !selectedCheckbox.checked;
    }
  });

  document
  .getElementById("confirmToggleModal")
  .addEventListener("hidden.bs.modal", () => {
    if (selectedCheckbox) {
      selectedCheckbox.checked = !selectedCheckbox.checked;
    }
    selectedCheckbox = null;
    selectedProductId = null;
  });

</script>
<script>
document.querySelectorAll(".edit-btn").forEach(btn => {
  btn.addEventListener("click", () => {

    editCroppedImages.length = 0; // 🔥 reset previous images

    document.getElementById("editProductName").value = btn.dataset.name;
    document.getElementById("editDescription").value = btn.dataset.desc;
    document.getElementById("editLongDescription").value = btn.dataset.longdesc;
    document.getElementById("editBrand").value = btn.dataset.brand;
    document.getElementById("editCategory").value = btn.dataset.category;

    const form = document.getElementById("editProductForm");
    form.action = `/admin/products/edit/${btn.dataset.id}`;

    const images = JSON.parse(btn.dataset.images || "[]");

    document.querySelectorAll(".edit-slot").forEach((slot, index) => {
      const img = slot.querySelector("img");
      const plus = slot.querySelector("span");

      if (images[index]) {
        img.src = images[index];
        img.hidden = false;
        plus.style.display = "none";
      } else {
        img.hidden = true;
        plus.style.display = "block";
      }
    });

    new bootstrap.Modal(
      document.getElementById("editProductModal")
    ).show();
  });
});

</script>


<script>
let cropper = null;
let currentMode = null; // "add" or "edit"
let activeIndex = null;

const croppedImages = [];
const editCroppedImages = [];

const imageInput = document.getElementById("imageInput");
const editImageInput = document.getElementById("editImageInput");
const cropImage = document.getElementById("cropImage");
const cropModalEl = document.getElementById("cropModal");

/* ---------- ADD IMAGE SLOT ---------- */
document.querySelectorAll(".image-slot:not(.edit-slot)").forEach(slot => {
  slot.addEventListener("click", () => {
    currentMode = "add";
    activeIndex = Number(slot.dataset.index);
    imageInput.value = "";
    imageInput.click();
  });
});

/* ---------- EDIT IMAGE SLOT ---------- */
document.querySelectorAll(".edit-slot").forEach(slot => {
  slot.addEventListener("click", () => {
    currentMode = "edit";
    activeIndex = Number(slot.dataset.index);
    editImageInput.value = "";
    editImageInput.click();
  });
});

/* ---------- ADD IMAGE SELECT ---------- */
imageInput.addEventListener("change", e => {
  handleImageSelect(e.target.files[0]);
});

/* ---------- EDIT IMAGE SELECT ---------- */
editImageInput.addEventListener("change", e => {
  handleImageSelect(e.target.files[0]);
});

/* ---------- HANDLE IMAGE ---------- */
function handleImageSelect(file) {
  if (!file) return;

  const reader = new FileReader();
  reader.onload = () => {
    cropImage.src = reader.result;

    const cropModal = new bootstrap.Modal(cropModalEl);
    cropModal.show();

    cropModalEl.addEventListener("shown.bs.modal", () => {
      if (cropper) cropper.destroy();

      cropper = new Cropper(cropImage, {
        aspectRatio: 1,
        viewMode: 2,
        autoCropArea: 1,
        responsive: true,
        background: false,
        zoomable: true,
        movable: true
      });
    }, { once: true });
  };

  reader.readAsDataURL(file);
}

/* ---------- SAVE CROPPED IMAGE ---------- */
document.getElementById("cropSaveBtn").addEventListener("click", async () => {
  if (!cropper) return;

  const canvas = cropper.getCroppedCanvas({
    width: 800,
    height: 800
  });

  const blob = await new Promise(resolve =>
    canvas.toBlob(resolve, "image/jpeg", 0.9)
  );

  if (currentMode === "add") {
    croppedImages[activeIndex] = blob;

    const slot = document.querySelector(
      `.image-slot[data-index="${activeIndex}"]:not(.edit-slot)`
    );

    const img = slot.querySelector("img");
    img.src = URL.createObjectURL(blob);
    img.hidden = false;
    slot.querySelector("span").style.display = "none";
  }

  if (currentMode === "edit") {
    editCroppedImages[activeIndex] = blob;

    const slot = document.querySelector(
      `.edit-slot[data-index="${activeIndex}"]`
    );

    const img = slot.querySelector("img");
    img.src = URL.createObjectURL(blob);
    img.hidden = false;
    slot.querySelector("span").style.display = "none";
  }

  cropper.destroy();
  cropper = null;

  bootstrap.Modal.getInstance(cropModalEl).hide();
});
</script>


<script>
const editForm = document.getElementById("editProductForm");

editForm.addEventListener("submit", async e => {
  e.preventDefault();

  const formData = new FormData(editForm);

editCroppedImages.forEach((img, index) => {
  if (img) {
    formData.append("images", img);
    formData.append("imageIndexes[]", index);
  }
});

  const res = await fetch(editForm.action, {
    method: "POST",
    body: formData
  });

  if (res.ok) {
    Swal.fire({
      icon: "success",
      title: "Product Updated",
      timer: 1500,
      showConfirmButton: false
    }).then(() => {
      location.reload();
    });
  } else {
    Swal.fire({
      icon: "error",
      title: "Update Failed"
    });
  }
});
</script>