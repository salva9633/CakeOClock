<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
@import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css');
* { box-sizing: border-box; }

:root {
  --bg:       #FDF1F3;
  --bg-2:     #FDF6F7;
  --white:    #FFFFFF;
  --primary:  #D89AA6;
  --primary-dk:#B97C8C;
  --primary-lt:#FDF2F4;
  --success:  #93C9AE;
  --warning:  #E3BE8E;
  --info:     #9FB8DE;
  --text:     #1F2937;
  --text-2:   #374151;
  --text-muted:#6B7280;
  --text-faint:#9CA3AF;
  --border:   #E5E7EB;
  --border-lt:#F3F4F6;
}

@keyframes fadeUp   { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:translateY(0)} }
@keyframes cardIn   { from{opacity:0;transform:translateY(20px) scale(.97)} to{opacity:1;transform:translateY(0) scale(1)} }
@keyframes rowIn    { from{opacity:0;transform:translateX(-8px)} to{opacity:1;transform:translateX(0)} }
@keyframes pulseDot { 0%{box-shadow:0 0 0 0 rgba(147,201,174,.5)} 70%{box-shadow:0 0 0 6px rgba(147,201,174,0)} 100%{box-shadow:0 0 0 0 rgba(147,201,174,0)} }
@keyframes iconFloat{ 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-3px); } }

/* PAGE SHELL */
.cm-page {
  font-family: 'Inter', system-ui, sans-serif;
  background: linear-gradient(180deg, var(--bg) 0%, var(--bg-2) 100%);
  min-height: 100vh;
  padding: 2rem 2rem 3rem;
  color: var(--text);
}

/* ── HEADER ── */
.cm-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20px;
  margin-bottom: 2rem;
  flex-wrap: wrap;
  animation: fadeUp .4s ease both;
}
.cm-header-left { display: flex; align-items: center; gap: 14px; }
.cm-hdr-title {
  font-size: 26px; font-weight: 700; color: #111827;
  letter-spacing: -.4px; line-height: 1.1;
  display: flex; align-items: center; gap: 10px;
}
.cm-hdr-icon {
  font-size: 22px;
  color: var(--primary-dk);
  animation: iconFloat 3.2s ease-in-out infinite;
}
.cm-hdr-sub   { font-size: 13px; color: var(--text-muted); margin-top: 4px; font-weight: 400; }
.cm-header-right { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }

.cm-search {
  display: flex; align-items: center; gap: 8px;
  background: var(--white); border: 1px solid var(--border);
  border-radius: 12px; padding: 0 16px; height: 42px; min-width: 260px;
  box-shadow: 0 2px 10px rgba(0,0,0,.03);
  transition: border-color .2s, box-shadow .2s;
}
.cm-search:focus-within { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(216,154,166,.12); }
.cm-search i   { font-size: 15px; color: var(--text-faint); flex-shrink: 0; }
.cm-search input {
  border: none; outline: none; font-size: 13px; color: var(--text);
  background: transparent; font-family: 'Inter', sans-serif; width: 100%;
}
.cm-search input::placeholder { color: var(--text-faint); }

.cm-sort-wrap {
  display: flex; align-items: center; gap: 6px;
  border: 1px solid var(--border); border-radius: 12px;
  padding: 0 12px; height: 42px;
  background: var(--white);
  transition: border-color .2s;
}
.cm-sort-wrap:focus-within { border-color: var(--primary); }
.cm-sort-wrap i { font-size: 15px; color: var(--text-faint); flex-shrink: 0; }
.cm-sort {
  height: 100%; border: none;
  font-size: 13px; color: var(--text-2);
  background: transparent; font-family: 'Inter', sans-serif;
  cursor: pointer; outline: none;
}

/* ── STATS ── */
.cm-stats {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14px;
  margin-bottom: 1.75rem;
}
.cm-stat {
  background: var(--white); border: 1px solid var(--border);
  border-radius: 16px; padding: 1.25rem 1.25rem 1.1rem;
  display: flex; flex-direction: column; gap: 14px;
  opacity: 0; animation: cardIn .5s ease forwards;
  transition: transform .25s, box-shadow .25s;
  position: relative; overflow: hidden;
}
.cm-stat::before {
  content: ''; position: absolute;
  top: 0; left: 0; right: 0; height: 3px;
}
.cm-stat.c-pink::before  { background: var(--primary); }
.cm-stat.c-amber::before { background: var(--warning); }
.cm-stat.c-blue::before  { background: var(--info); }
.cm-stat.c-green::before { background: var(--success); }
.cm-stat:nth-child(1) { animation-delay: .06s; }
.cm-stat:nth-child(2) { animation-delay: .12s; }
.cm-stat:nth-child(3) { animation-delay: .18s; }
.cm-stat:nth-child(4) { animation-delay: .24s; }
.cm-stat:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(0,0,0,.06); }

.cm-stat-head { display: flex; justify-content: space-between; align-items: center; }
.cm-stat-ico {
  width: 44px; height: 44px;
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.c-pink  .cm-stat-ico { background: var(--primary-lt); }
.c-amber .cm-stat-ico { background: #FBF1E0; }
.c-blue  .cm-stat-ico { background: #E8F0FB; }
.c-green .cm-stat-ico { background: #E7F5EE; }
.c-pink  .cm-stat-ico i { color: var(--primary-dk); }
.c-amber .cm-stat-ico i { color: var(--warning); }
.c-blue  .cm-stat-ico i { color: var(--info); }
.c-green .cm-stat-ico i { color: var(--success); }
.cm-stat-ico i { font-size: 20px; }

.cm-trend {
  font-size: 11px; font-weight: 600;
  padding: 3px 8px; border-radius: 20px;
  display: inline-flex; align-items: center; gap: 3px;
}
.trend-up  { background: #EAF6F0; color: #4E9974; }
.trend-neu { background: #F3F4F6; color: var(--text-muted); }

.cm-stat-num  { font-size: 36px; font-weight: 700; letter-spacing: -1px; line-height: 1; color: #111827; }
.cm-stat-lbl  { font-size: 14px; font-weight: 500; color: var(--text-2); margin-top: 2px; }
.cm-stat-hint { font-size: 12px; color: var(--text-faint); margin-top: 2px; }

/* ── FILTER PILLS ── */
.cm-filters {
  display: flex; gap: 8px; margin-bottom: 1.5rem;
  animation: fadeUp .5s ease .3s both; opacity: 0;
  flex-wrap: wrap;
}
.cm-pill {
  padding: 7px 16px; border-radius: 99px;
  font-size: 13px; font-weight: 500;
  cursor: pointer; border: 1.5px solid var(--border);
  background: var(--white); color: var(--text-muted);
  transition: all .2s; white-space: nowrap;
  font-family: 'Inter', sans-serif;
  text-decoration: none; display: inline-flex; align-items: center; gap: 6px;
}
.cm-pill i { font-size: 14px; }
.cm-pill:hover:not(.active) { border-color: var(--primary); color: var(--primary-dk); background: var(--primary-lt); transform: translateY(-1px); }
.cm-pill.active { background: var(--primary); color: #fff; border-color: var(--primary); box-shadow: 0 6px 16px rgba(216,154,166,.28); }
.cm-pill-count {
  font-size: 10px; font-weight: 700; min-width: 18px; height: 18px;
  border-radius: 99px; display: inline-flex; align-items: center;
  justify-content: center; padding: 0 4px;
}
.cm-pill.active .cm-pill-count  { background: rgba(255,255,255,.3); color: #fff; }
.cm-pill:not(.active) .cm-pill-count { background: var(--border-lt); color: var(--text-muted); }

/* ── TABLE CARD ── */
.cm-table-card {
  background: var(--white); border: 1px solid var(--border);
  border-radius: 16px; overflow: hidden;
  opacity: 0; animation: cardIn .5s ease .36s forwards;
  margin-bottom: 1.5rem;
  box-shadow: 0 4px 24px rgba(0,0,0,.03);
}

.cm-table-topbar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 22px; border-bottom: 1px solid var(--border-lt);
  flex-wrap: wrap; gap: 10px;
}
.cm-table-topbar-left { display: flex; align-items: center; gap: 8px; font-size: 14px; font-weight: 600; color: #111827; }
.cm-table-topbar-left i { color: var(--primary-dk); font-size: 16px; }
.cm-table-count { font-weight: 400; color: var(--text-faint); font-size: 13px; }
.cm-live-badge {
  display: inline-flex; align-items: center; gap: 6px;
  font-size: 12px; font-weight: 600; color: var(--primary-dk);
  background: var(--primary-lt); padding: 5px 12px; border-radius: 99px;
}
.cm-live-badge .live-dot {
  width: 7px; height: 7px; border-radius: 50%; background: var(--success);
  animation: pulseDot 1.8s infinite;
}

.cm-table-scroll { overflow-x: auto; }
.cm-table {
  width: 100%; border-collapse: collapse; min-width: 680px;
}
.cm-table thead tr {
  background: linear-gradient(90deg, var(--primary-dk), var(--primary));
}
.cm-table thead th {
  padding: 14px 18px; font-size: 12px; font-weight: 600;
  color: #fff; text-transform: uppercase;
  letter-spacing: .06em; white-space: nowrap; text-align: left;
}
.cm-table tbody tr {
  border-bottom: 1px solid var(--border-lt);
  transition: background .15s, transform .15s;
  cursor: pointer;
  opacity: 0;
  animation: rowIn .35s ease forwards;
}
.cm-table tbody tr:last-child { border-bottom: none; }
.cm-table tbody tr:hover { background: #FAFAFA; transform: translateX(2px); }
.cm-table tbody td {
  padding: 14px 18px; font-size: 14px;
  color: var(--text); vertical-align: middle;
}

/* Sender cell */
.cm-sender { display: flex; align-items: center; gap: 12px; }
.cm-av {
  width: 38px; height: 38px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 700; flex-shrink: 0; letter-spacing: .5px;
}
.av-0 { background: #FBE4EA; color: #B97C8C; }
.av-1 { background: #FBEFE3; color: #B5824A; }
.av-2 { background: #E7F5EE; color: #4E9974; }
.av-3 { background: #EFE9FA; color: #8362C9; }
.av-4 { background: #E8F0FB; color: #5E86C9; }
.cm-sname  { font-size: 14px; font-weight: 600; color: #111827; }
.cm-semail { font-size: 12px; color: var(--text-faint); margin-top: 1px; }

/* Subject */
.cm-subj      { font-size: 14px; font-weight: 500; color: #111827; }
.cm-subj.dim  { color: var(--text-muted); font-weight: 400; }
.cm-preview   {
  font-size: 12px; color: var(--text-faint); margin-top: 2px;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  max-width: 260px;
}

/* Badge */
.cm-badge {
  display: inline-flex; align-items: center; gap: 5px;
  font-size: 11px; font-weight: 600;
  padding: 4px 10px; border-radius: 99px;
  white-space: nowrap; border: 1px solid transparent;
}
.cm-badge i { font-size: 10px; }
.b-unread  { background: #FBF1E0; color: #B5824A; border-color: #F0DDB0; }
.b-read    { background: #E8F0FB; color: #5E86C9; border-color: #C9DAF3; }
.b-replied { background: #E7F5EE; color: #4E9974; border-color: #BEE5D2; }

.b-open        { background: #FBE4EA; color: #C0798A; border-color: #F0C8D2; }
.b-in_progress { background: #E8F0FB; color: #5E86C9; border-color: #C9DAF3; }
.b-resolved    { background: #FBF1E0; color: #B5824A; border-color: #F0DDB0; }
.b-closed      { background: #F3F4F6; color: #6B7280; border-color: #E5E7EB; }

/* Date */
.cm-date-main { font-size: 13px; color: var(--text-2); font-weight: 500; }
.cm-date-rel  { font-size: 11px; color: var(--text-faint); margin-top: 2px; }

/* View btn */
.cm-btn-view {
  display: inline-flex; align-items: center; gap: 6px;
  font-size: 12px; font-weight: 600;
  padding: 6px 14px; border-radius: 8px;
  border: 1.5px solid var(--border);
  background: var(--white); color: var(--text-muted);
  cursor: pointer; text-decoration: none;
  transition: all .2s; font-family: 'Inter', sans-serif;
}
.cm-btn-view:hover { background: var(--primary); color: #fff; border-color: var(--primary); transform: translateY(-1px); box-shadow: 0 6px 16px rgba(216,154,166,.28); }
.cm-btn-view i { font-size: 13px; }

/* Empty */
.cm-empty { text-align: center; padding: 4rem 1rem; animation: fadeUp .4s ease both; }
.cm-empty-ico { font-size: 52px; color: var(--border); margin-bottom: 16px; animation: iconFloat 3.2s ease-in-out infinite; }
.cm-empty h3  { font-size: 16px; font-weight: 600; color: var(--text-2); margin-bottom: 6px; }
.cm-empty p   { font-size: 13px; color: var(--text-faint); }

/* Footer / Pagination */
.cm-tbl-footer {
  display: flex; justify-content: space-between; align-items: center;
  padding: 14px 18px; border-top: 1px solid var(--border-lt);
  flex-wrap: wrap; gap: 10px;
}
.cm-pg-info { font-size: 13px; color: var(--text-muted); }
.cm-pager   { display: flex; gap: 4px; }
.cm-pb {
  min-width: 34px; height: 34px; border-radius: 9px;
  border: 1px solid var(--border); background: var(--white);
  color: var(--text-2); font-size: 13px; font-weight: 500;
  display: flex; align-items: center; justify-content: center;
  text-decoration: none; cursor: pointer;
  transition: all .2s; padding: 0 8px;
  font-family: 'Inter', sans-serif;
}
.cm-pb:hover:not(.dis):not(.on) { border-color: var(--primary); color: var(--primary-dk); transform: translateY(-1px); }
.cm-pb.on  { background: var(--primary); color: #fff; border-color: var(--primary); box-shadow: 0 6px 14px rgba(216,154,166,.32); }
.cm-pb.dis { opacity: .35; pointer-events: none; }

/* Responsive */
@media (max-width: 1024px) {
  .cm-stats { grid-template-columns: repeat(2, minmax(0, 1fr)); }
}
@media (max-width: 640px) {
  .cm-page { padding: 1rem; }
  .cm-stats { grid-template-columns: minmax(0, 1fr); }
  .cm-header { flex-direction: column; }
  .cm-search { min-width: 100%; }
}
</style>

<div class="page-wrapper">
  <div class="cm-page">

    <!-- ── HEADER ── -->
    <div class="cm-header">
    <div class="cm-header-left">
  <div>
    <div class="cm-hdr-title">
      <i class="ti ti-message-2 cm-hdr-icon" aria-hidden="true"></i>
      Contact Messages
    </div>
    <div class="cm-hdr-sub">Manage customer inquiries, review conversations, and respond efficiently.</div>
  </div>
</div>
      <div class="cm-header-right">
        <form method="GET" action="/admin/contact-messages" class="cm-search">
          <i class="ti ti-search" aria-hidden="true"></i>
          <input type="text" name="search" value="<%= search || '' %>"
                 placeholder="Search sender, email or subject…" autocomplete="off">
        </form>
        <div class="cm-sort-wrap">
          <i class="ti ti-arrows-sort" aria-hidden="true"></i>
          <select class="cm-sort" onchange="window.location='?sort='+this.value+'&status=<%= activeFilter %>'">
            <option value="newest" <%= (sort==='newest'||!sort)?'selected':'' %>>Newest first</option>
            <option value="oldest" <%= sort==='oldest'?'selected':'' %>>Oldest first</option>
          </select>
        </div>
      </div>
    </div>

    <!-- ── STATS ── -->
   <%
  const totalPct       = 100;
  const openPct        = totalCount > 0 ? Math.round(openCount       / totalCount * 100) : 0;
  const inProgressPct  = totalCount > 0 ? Math.round(inProgressCount / totalCount * 100) : 0;
  const resolvedPct    = totalCount > 0 ? Math.round(resolvedCount   / totalCount * 100) : 0;
  const closedPct      = totalCount > 0 ? Math.round(closedCount     / totalCount * 100) : 0;
%>
<div class="cm-stats">
  <div class="cm-stat c-pink">
    <div class="cm-stat-head">
      <div class="cm-stat-ico"><i class="ti ti-inbox" aria-hidden="true"></i></div>
    </div>
    <div>
      <div class="cm-stat-num"><%= totalCount %></div>
      <div class="cm-stat-lbl">Total tickets</div>
      <div class="cm-stat-hint">All time received</div>
    </div>
  </div>
  <div class="cm-stat c-amber">
    <div class="cm-stat-head">
      <div class="cm-stat-ico"><i class="ti ti-bell" aria-hidden="true"></i></div>
      <span class="cm-trend trend-neu">New</span>
    </div>
    <div>
      <div class="cm-stat-num"><%= openCount %></div>
      <div class="cm-stat-lbl">Open</div>
      <div class="cm-stat-hint">Needs first reply</div>
    </div>
  </div>
  <div class="cm-stat c-blue">
    <div class="cm-stat-head">
      <div class="cm-stat-ico"><i class="ti ti-messages" aria-hidden="true"></i></div>
      <span class="cm-trend trend-neu">Active</span>
    </div>
    <div>
      <div class="cm-stat-num"><%= inProgressCount %></div>
      <div class="cm-stat-lbl">In Progress</div>
      <div class="cm-stat-hint">Ongoing conversation</div>
    </div>
  </div>
  <div class="cm-stat c-green">
    <div class="cm-stat-head">
      <div class="cm-stat-ico"><i class="ti ti-circle-check" aria-hidden="true"></i></div>
    </div>
    <div>
      <div class="cm-stat-num"><%= resolvedCount %></div>
      <div class="cm-stat-lbl">Resolved</div>
      <div class="cm-stat-hint">Awaiting customer</div>
    </div>
  </div>
</div>

<!-- ── FILTER PILLS ── -->
<div class="cm-filters">
  <%
    const filters = [
      { key: 'all',         label: 'All',         count: totalCount,      icon: 'ti-layout-grid'   },
      { key: 'open',        label: 'Open',        count: openCount,       icon: 'ti-alert-circle'  },
      { key: 'in_progress', label: 'In Progress', count: inProgressCount, icon: 'ti-messages'      },
      { key: 'resolved',    label: 'Resolved',    count: resolvedCount,   icon: 'ti-circle-check'  },
      { key: 'closed',      label: 'Closed',      count: closedCount,     icon: 'ti-lock'          },
    ];
  %>
  <% filters.forEach(f => { %>
    <a href="/admin/contact-messages<%= f.key !== 'all' ? '?status='+f.key : '' %>"
       class="cm-pill <%= activeFilter === f.key ? 'active' : '' %>">
      <i class="ti <%= f.icon %>" aria-hidden="true"></i>
      <%= f.label %>
      <span class="cm-pill-count"><%= f.count %></span>
    </a>
  <% }) %>
</div>

    <!-- ── TABLE ── -->
    <div class="cm-table-card">

      <div class="cm-table-topbar">
        <div class="cm-table-topbar-left">
          <i class="ti ti-layout-list" aria-hidden="true"></i>
          <span>All Messages</span>
          <span class="cm-table-count">(<%= messages.length %> shown)</span>
        </div>
        <span class="cm-live-badge"><span class="live-dot"></span> Live</span>
      </div>

      <% if (messages.length === 0) { %>
        <div class="cm-empty">
          <div class="cm-empty-ico"><i class="ti ti-mail-off" aria-hidden="true"></i></div>
          <h3>No Messages Found</h3>
          <p>Customer messages will appear here once they reach out.</p>
        </div>
     <% } else { %>
      <%
  const avClasses = ['av-0','av-1','av-2','av-3','av-4'];
  const badgeMap  = {
    open:        { cls: 'b-open',        icon: 'ti-alert-circle', label: 'Open'        },
    in_progress: { cls: 'b-in_progress', icon: 'ti-messages',     label: 'In Progress' },
    resolved:    { cls: 'b-resolved',    icon: 'ti-check',        label: 'Resolved'    },
    closed:      { cls: 'b-closed',      icon: 'ti-lock',         label: 'Closed'      },
  };
  function timeAgo(date) {
    const diff = Math.floor((Date.now() - new Date(date)) / 1000);
    if (diff < 3600)   return Math.floor(diff/60) + ' min ago';
    if (diff < 86400)  return Math.floor(diff/3600) + ' hours ago';
    if (diff < 172800) return 'Yesterday';
    return Math.floor(diff/86400) + ' days ago';
  }
%>
<div class="cm-table-scroll">
  <table class="cm-table">
    <thead>
      <tr>
        <th style="width:20%">Sender</th>
        <th style="width:26%">Ticket</th>
        <th style="width:13%">Status</th>
        <th style="width:18%">Last Activity</th>
        <th style="width:17%;text-align:center">Action</th>
      </tr>
    </thead>
    <tbody>
      <% messages.forEach((msg, i) => {
        const initials = msg.name.split(' ').map(n => n[0]).join('').substring(0,2).toUpperCase();
        const avCls    = avClasses[i % avClasses.length];
        const b        = badgeMap[msg.status] || badgeMap.open;
        const dateStr  = new Date(msg.lastActivityAt || msg.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'});
        const relTime  = timeAgo(msg.lastActivityAt || msg.createdAt);
        const firstMsg = msg.messages && msg.messages.length ? msg.messages[0].text : '';
      %>
      <tr onclick="window.location='/admin/contact-messages/<%= msg._id %>'" style="animation-delay: <%= (i * 0.045).toFixed(2) %>s">
        <td>
          <div class="cm-sender">
            <div class="cm-av <%= avCls %>"><%= initials %></div>
            <div>
              <div style="display:flex; align-items:center; gap:8px;">
  <div class="cm-sname"><%= msg.name %></div>
  <% if (msg.unreadAdminCount > 0) { %>
  <span style="
    background:#C97B8A;
    color:#fff;
    font-size:10px;
    font-weight:800;
    min-width:20px;
    height:20px;
    border-radius:99px;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    padding:0 5px;
    line-height:1;
    flex-shrink:0;
    box-shadow:0 2px 6px rgba(201,123,138,.4);
  "><%= msg.unreadAdminCount %></span>
  <% } %>
</div>
<div class="cm-semail"><%= msg.email %></div>
            </div>
          </div>
        </td>
        <td>
          <div class="cm-subj">
            <span style="color:var(--primary-dk);font-weight:700;">#<%= msg.ticketNumber %></span>
            &nbsp;<%= msg.subject.length > 40 ? msg.subject.substring(0,40)+'…' : msg.subject %>
          </div>
          <% if (firstMsg) { %>
            <div class="cm-preview"><%= firstMsg.substring(0, 60) %>…</div>
          <% } %>
        </td>
        <td>
          <span class="cm-badge <%= b.cls %>">
            <i class="ti <%= b.icon %>" aria-hidden="true"></i>
            <%= b.label %>
          </span>
        </td>
        <td>
          <div class="cm-date-main"><%= dateStr %></div>
          <div class="cm-date-rel"><%= relTime %></div>
        </td>
        <td style="text-align:center;" onclick="event.stopPropagation()">
          <a href="/admin/contact-messages/<%= msg._id %>" class="cm-btn-view">
            <i class="ti ti-eye" aria-hidden="true"></i> View
          </a>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

      <!-- PAGINATION -->
      <div class="cm-tbl-footer">
        <div class="cm-pg-info">
          Showing <%= (currentPage - 1) * perPage + 1 %>–<%= Math.min(currentPage * perPage, totalCount) %>
          of <%= totalCount %> messages
        </div>
        <div class="cm-pager">
          <a class="cm-pb <%= currentPage === 1 ? 'dis' : '' %>"
             href="?page=<%= currentPage-1 %>&status=<%= activeFilter %>" aria-label="Previous">
            <i class="ti ti-chevron-left" aria-hidden="true"></i>
          </a>
          <% for (let p = 1; p <= totalPages; p++) { %>
            <% if (totalPages > 7 && p > 3 && p < totalPages - 1 && Math.abs(p - currentPage) > 1) { %>
              <% if (p === 4 || p === totalPages - 2) { %>
                <span class="cm-pb dis">…</span>
              <% } %>
            <% } else { %>
              <a class="cm-pb <%= currentPage === p ? 'on' : '' %>"
                 href="?page=<%= p %>&status=<%= activeFilter %>"><%= p %></a>
            <% } %>
          <% } %>
          <a class="cm-pb <%= currentPage === totalPages ? 'dis' : '' %>"
             href="?page=<%= currentPage+1 %>&status=<%= activeFilter %>" aria-label="Next">
            <i class="ti ti-chevron-right" aria-hidden="true"></i>
          </a>
        </div>
      </div>
      <% } %>
    

  </div>
</div>

<script>
(function(){
  const searchForm  = document.querySelector('form.cm-search');
  const searchInput = searchForm ? searchForm.querySelector('input') : null;
  let   timer       = null;
  if (searchInput) {
    searchInput.addEventListener('input', () => {
      clearTimeout(timer);
      timer = setTimeout(() => searchForm.submit(), 450);
    });
    searchForm.addEventListener('submit', e => { e.preventDefault(); searchForm.submit(); });
  }
})();
</script>