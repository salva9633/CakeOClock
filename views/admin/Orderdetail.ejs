<%- include("../../views/partials/admin/sidebar") %>

<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --rose:#C97B8A;--rose-dk:#A85F6E;--rose-lt:#FAE8ED;
  --blush:#FDF0F3;--caramel:#D4A574;--brown:#5C3A3A;
  --muted:#B08A8A;--border:#F5D8E0;--mint:#E8F6F0;--white:#FFFFFF;
}

@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
@keyframes scaleIn{from{opacity:0;transform:scale(0.96)}to{opacity:1;transform:scale(1)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.5}}

.pg{padding:1.5rem 1rem}

.pg-header{display:flex;align-items:center;gap:12px;margin-bottom:1.5rem;flex-wrap:wrap;animation:fadeUp .4s ease both}
.back-btn{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:10px;border:0.5px solid var(--border);background:var(--white);color:var(--brown);font-size:13px;text-decoration:none;transition:all .18s;flex-shrink:0}
.back-btn:hover{background:var(--rose-lt);border-color:var(--rose);color:var(--rose)}
.pg-title{font-size:20px;font-weight:500;color:var(--brown)}
.order-tag{font-size:12px;font-weight:500;color:var(--rose);background:var(--rose-lt);padding:4px 12px;border-radius:20px;border:0.5px solid var(--border)}
.live-badge{font-size:10px;padding:3px 8px;border-radius:20px;background:var(--rose-lt);color:var(--rose-dk);display:flex;align-items:center;gap:4px;margin-left:auto}
.live-dot{width:6px;height:6px;border-radius:50%;background:var(--rose);animation:pulse 1.8s ease infinite}

.detail-grid{display:grid;grid-template-columns:1fr 300px;gap:14px;align-items:start}

.card{background:var(--white);border:0.5px solid var(--border);border-radius:12px;padding:1.25rem;margin-bottom:14px;opacity:0;animation:scaleIn .5s ease forwards}
.card:nth-child(1){animation-delay:.05s}
.card:nth-child(2){animation-delay:.12s}
.card:nth-child(3){animation-delay:.18s}
.right-col .card:nth-child(1){animation-delay:.08s}
.right-col .card:nth-child(2){animation-delay:.14s}
.right-col .card:nth-child(3){animation-delay:.2s}
.card:last-child{margin-bottom:0}

.card-head{display:flex;align-items:center;gap:8px;padding-bottom:12px;margin-bottom:14px;border-bottom:0.5px solid var(--rose-lt)}
.card-head-title{font-size:13px;font-weight:500;color:var(--brown);display:flex;align-items:center;gap:6px}
.card-head-title i{color:var(--rose);font-size:15px}
.card-head-sub{font-size:11px;color:var(--muted);margin-left:auto}

.info-row{display:flex;justify-content:space-between;align-items:flex-start;font-size:13px;padding:8px 0;border-bottom:0.5px solid var(--rose-lt);gap:12px}
.info-row:last-child{border-bottom:none}
.info-label{color:var(--muted);font-size:12px;min-width:110px;flex-shrink:0}
.info-val{font-weight:500;color:var(--brown);text-align:right;word-break:break-word;font-size:13px}

/* ── INVOICE CARD ── */
.invoice-card{background:var(--white);border:0.5px solid var(--border);border-radius:12px;margin-bottom:14px;overflow:hidden;opacity:0;animation:scaleIn .5s ease .05s forwards}

.inv-header{background:linear-gradient(135deg,var(--rose) 0%,var(--rose-dk) 100%);padding:1.25rem 1.5rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px}
.inv-brand{display:flex;align-items:center;gap:10px}
.inv-brand-icon{width:38px;height:38px;background:rgba(255,255,255,0.18);border-radius:9px;display:flex;align-items:center;justify-content:center}
.inv-brand-icon i{font-size:19px;color:#fff}
.inv-brand-text h2{font-size:16px;font-weight:500;color:#fff;letter-spacing:-0.2px}
.inv-brand-text p{font-size:10px;color:rgba(255,255,255,0.72);margin-top:1px}
.inv-id-badge{background:rgba(255,255,255,0.16);border:0.5px solid rgba(255,255,255,0.28);border-radius:8px;padding:6px 12px;text-align:right}
.inv-id-badge p:first-child{font-size:9px;color:rgba(255,255,255,0.65);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:3px}
.inv-id-badge p:last-child{font-size:13px;font-weight:500;color:#fff}

.inv-meta{display:grid;grid-template-columns:1fr 1fr;gap:10px;padding:1.25rem 1.5rem;border-bottom:0.5px solid var(--rose-lt)}
.inv-meta-box{background:var(--blush);border-radius:9px;padding:.85rem 1rem}
.inv-meta-box h3{font-size:9px;text-transform:uppercase;letter-spacing:0.09em;color:var(--muted);margin-bottom:8px;display:flex;align-items:center;gap:4px}
.inv-meta-box h3 i{font-size:12px;color:var(--rose)}
.meta-field{margin-bottom:5px}
.meta-field:last-child{margin-bottom:0}
.meta-field span:first-child{font-size:10px;color:var(--muted);display:block}
.meta-field span:last-child{font-size:12px;font-weight:500;color:var(--brown)}
.paid-pill{display:inline-flex;align-items:center;gap:4px;font-size:10px;font-weight:500;padding:2px 8px;border-radius:20px;background:#E6F4EA;color:#2A7D3A}
.paid-dot{width:5px;height:5px;border-radius:50%;background:#2A7D3A}

.inv-items{padding:1.25rem 1.5rem;border-bottom:0.5px solid var(--rose-lt)}
.inv-section-label{font-size:9px;text-transform:uppercase;letter-spacing:0.09em;color:var(--muted);margin-bottom:10px;display:flex;align-items:center;gap:6px}
.inv-section-label::after{content:'';flex:1;height:0.5px;background:var(--rose-lt)}
.inv-section-label i{font-size:12px;color:var(--rose)}

.inv-tbl{width:100%;border-collapse:collapse;font-size:12px}
.inv-tbl thead tr{border-bottom:0.5px solid var(--rose-lt)}
.inv-tbl thead th{font-size:9px;text-transform:uppercase;letter-spacing:0.07em;color:var(--muted);font-weight:500;padding:0 0 8px;text-align:left}
.inv-tbl thead th:not(:first-child){text-align:center}
.inv-tbl thead th:last-child{text-align:right}
.inv-tbl tbody td{padding:11px 0;border-bottom:0.5px solid var(--rose-lt);vertical-align:middle}
.inv-tbl tbody tr:last-child td{border-bottom:none}
.inv-tbl tbody tr:hover td{background:var(--blush)}
.item-thumb{width:34px;height:34px;border-radius:8px;background:var(--rose-lt);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.item-thumb img{width:34px;height:34px;object-fit:cover;border-radius:8px}
.item-thumb i{font-size:16px;color:var(--rose)}
.item-cell{display:flex;align-items:center;gap:9px}
.item-name{font-size:12px;font-weight:500;color:var(--brown)}
.item-sub{font-size:10px;color:var(--muted);margin-top:1px}
.item-cancel-reason{font-size:10px;color:#C03030;margin-top:1px}
.item-return-reason{font-size:10px;color:#7030C9;margin-top:1px}
.inv-tbl .qty-cell{text-align:center;color:var(--brown);font-weight:500}
.inv-tbl .price-cell{text-align:center;color:var(--muted)}
.inv-tbl .total-cell{text-align:right;font-weight:500;color:var(--brown)}
.inv-tbl .status-cell{text-align:center}
.inv-tbl .action-cell{text-align:right}

.badge{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:20px;font-size:10px;font-weight:500;white-space:nowrap}
.b-Pending{background:#FEF0E8;color:#C97A30}
.b-Processing{background:#E8F0FE;color:#3060C9}
.b-Shipped{background:#E8F6FF;color:#1A7AB8}
.b-Delivered{background:#E6F4EA;color:#2A7D3A}
.b-Cancelled{background:#FDECEA;color:#C03030}
.b-Returned{background:#F0E8FE;color:#7030C9}
.b-Return-Requested{background:#FFF3CD;color:#856404}
.b-Return-Rejected{background:#FDECEA;color:#C03030}
.b-Paid{background:#E6F4EA;color:#2A7D3A}
.b-Failed{background:#FDECEA;color:#C03030}
.b-COD{background:#FEF0E8;color:#C97A30}
.b-Online{background:#E8F0FE;color:#3060C9}
.b-Razorpay{background:#E8F0FE;color:#3060C9}
.b-Wallet{background:var(--rose-lt);color:var(--rose-dk)}

.inv-totals{padding:1.25rem 1.5rem;border-bottom:0.5px solid var(--rose-lt)}
.totals-inner{background:var(--blush);border-radius:10px;padding:1rem 1.25rem}
.t-row{display:flex;justify-content:space-between;align-items:center;font-size:12px;padding:5px 0}
.t-row .t-lbl{color:var(--muted)}
.t-row .t-val{font-weight:500;color:var(--brown)}
.t-row .t-green{font-weight:500;color:#2A7D3A}
.t-divider{height:0.5px;background:var(--border);margin:8px 0}
.t-grand-row{display:flex;justify-content:space-between;align-items:center;padding:8px 0 0}
.t-grand-lbl{font-size:14px;font-weight:500;color:var(--brown)}
.t-grand-val{font-size:18px;font-weight:500;color:var(--rose)}
.coupon-chip{display:inline-flex;align-items:center;gap:3px;font-size:10px;padding:1px 7px;border-radius:20px;background:var(--rose-lt);color:var(--rose-dk);border:0.5px dashed var(--rose);margin-left:5px}
.coupon-chip i{font-size:10px}

.inv-footer{padding:1rem 1.5rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px}
.inv-footer-note{font-size:11px;color:var(--muted);display:flex;align-items:center;gap:5px}
.inv-footer-note i{color:var(--rose);font-size:13px}
.inv-footer-links{display:flex;gap:14px}
.inv-footer-link{font-size:10px;color:var(--muted);display:flex;align-items:center;gap:3px}
.inv-footer-link i{font-size:12px}

/* ── OTHER CARDS ── */
.tbl{width:100%;border-collapse:collapse;font-size:13px}
.tbl thead tr{background:linear-gradient(135deg,var(--rose) 0%,var(--rose-dk) 100%)}
.tbl thead th{padding:10px 12px;font-size:11px;font-weight:500;color:#fff;text-align:left;letter-spacing:.03em}
.tbl tbody td{padding:11px 12px;border-bottom:0.5px solid var(--rose-lt);color:var(--brown);vertical-align:middle}
.tbl tbody tr:last-child td{border-bottom:none}
.tbl tbody tr{transition:background .15s}
.tbl tbody tr:hover td{background:var(--blush)}

.item-img{width:40px;height:40px;object-fit:cover;border-radius:8px;border:0.5px solid var(--border);flex-shrink:0}
.item-placeholder{width:40px;height:40px;border-radius:8px;background:var(--rose-lt);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.item-placeholder i{font-size:16px;color:var(--rose)}

.status-sel-lg{width:100%;padding:9px 12px;border:0.5px solid var(--border);border-radius:10px;background:var(--white);font-size:13px;color:var(--brown);outline:none;cursor:pointer;margin-bottom:10px;transition:border-color .18s}
.status-sel-lg:focus{border-color:var(--rose)}
.btn-update{width:100%;padding:10px;border-radius:10px;font-size:13px;font-weight:500;cursor:pointer;border:none;background:linear-gradient(135deg,var(--rose),var(--rose-dk));color:#fff;transition:opacity .18s;display:flex;align-items:center;justify-content:center;gap:6px}
.btn-update:hover{opacity:.9}
.btn-update:disabled{opacity:.5;cursor:not-allowed}

.timeline{list-style:none;padding:0;position:relative}
.timeline::before{content:'';position:absolute;left:9px;top:0;bottom:0;width:1.5px;background:var(--rose-lt)}
.timeline li{position:relative;padding-left:28px;margin-bottom:16px}
.timeline li:last-child{margin-bottom:0}
.tl-dot{position:absolute;left:3px;top:3px;width:14px;height:14px;border-radius:50%;background:var(--rose);border:2px solid var(--white);box-shadow:0 0 0 2px var(--rose)}
.tl-dot.inactive{background:var(--border);box-shadow:0 0 0 2px var(--border)}
.tl-status{font-size:13px;font-weight:500;color:var(--brown)}
.tl-status.inactive{color:var(--muted);font-weight:400}
.tl-date{font-size:11px;color:var(--muted);margin-top:2px}

.btn-approve{background:var(--mint);color:#2A7D3A;border:none;border-radius:7px;padding:5px 11px;font-size:11px;font-weight:500;cursor:pointer;transition:opacity .18s}
.btn-approve:hover{opacity:.85}
.btn-reject{background:#FDECEA;color:#C03030;border:none;border-radius:7px;padding:5px 11px;font-size:11px;font-weight:500;cursor:pointer;transition:opacity .18s}
.btn-reject:hover{opacity:.85}

.toast{position:fixed;right:24px;bottom:24px;padding:10px 18px;border-radius:10px;font-size:13px;color:#fff;opacity:0;transform:translateY(6px);transition:.3s;pointer-events:none;z-index:9999}
.toast.show{opacity:1;transform:translateY(0)}
.toast.success{background:#2e7d32}
.toast.error{background:#c0392b}

@media(max-width:1100px){.detail-grid{grid-template-columns:1fr}}
@media(max-width:600px){.inv-meta{grid-template-columns:1fr}}
</style>

<div class="pg">

  <div class="pg-header">
    <a href="/admin/orders" class="back-btn">
      <i class="ti ti-arrow-left" aria-hidden="true"></i> Back
    </a>
    <span class="pg-title">Order detail</span>
    <span class="order-tag"><%= order.orderId %></span>
    <div class="live-badge">
      <span class="live-dot"></span> Live
    </div>
  </div>

  <div class="detail-grid">

    <!-- ── LEFT COLUMN ── -->
    <div class="left-col">

      <!-- ── INVOICE CARD ── -->
      <div class="invoice-card">

        <!-- Header -->
        <div class="inv-header">
          <div class="inv-brand">
            <div class="inv-brand-icon">
              <i class="ti ti-cake" aria-hidden="true"></i>
            </div>
            <div class="inv-brand-text">
              <h2>Cake O'Clock</h2>
              <p>Fresh baked, delivered with love</p>
            </div>
          </div>
          <div class="inv-id-badge">
            <p>Tax Invoice</p>
            <p><%= order.orderId %></p>
          </div>
        </div>

        <!-- Meta: invoice details + customer -->
        <div class="inv-meta">
          <div class="inv-meta-box">
            <h3><i class="ti ti-calendar" aria-hidden="true"></i> Invoice details</h3>
            <div class="meta-field">
              <span>Invoice date</span>
              <span><%= new Date(order.createdAt).toLocaleDateString('en-IN', {day:'2-digit', month:'short', year:'numeric'}) %></span>
            </div>
            <div class="meta-field">
              <span>Payment method</span>
              <span><%= order.paymentMethod %></span>
            </div>
            <div class="meta-field">
              <span>Status</span>
              <span>
                <span class="paid-pill">
                  <span class="paid-dot"></span>
                  <%= order.paymentStatus %>
                </span>
              </span>
            </div>
          </div>
          <div class="inv-meta-box">
            <h3><i class="ti ti-user" aria-hidden="true"></i> Customer</h3>
            <div class="meta-field">
              <span>Name</span>
              <span><%= order.address.name %></span>
            </div>
            <div class="meta-field">
              <span>Phone</span>
              <span><%= order.address.phone %></span>
            </div>
            <div class="meta-field">
              <span>Address</span>
              <span><%= order.address.city %>, <%= order.address.state %> – <%= order.address.pincode %></span>
            </div>
          </div>
        </div>

        <!-- Items table -->
        <div class="inv-items">
          <div class="inv-section-label">
            <i class="ti ti-box" aria-hidden="true"></i>
            Order items &nbsp;<%= order.items.length %> item<%= order.items.length > 1 ? 's' : '' %>
          </div>
          <div style="overflow-x:auto">
            <table class="inv-tbl">
              <thead>
                <tr>
                  <th style="width:46%">Product</th>
                  <th style="width:10%">Qty</th>
                  <th style="width:16%">Price</th>
                  <th style="width:16%">Subtotal</th>
                  <th style="width:12%">Status</th>
                  <% if (order.items.some(function(i){ return i.status === 'Return Requested'; })) { %>
                  <th style="width:14%">Action</th>
                  <% } %>
                </tr>
              </thead>
              <tbody>
                <% order.items.forEach(function(item) { %>
                <tr>
                  <td>
                    <div class="item-cell">
                      <% if (item.productImage) { %>
                        <div class="item-thumb"><img src="<%= item.productImage %>" alt=""></div>
                      <% } else { %>
                        <div class="item-thumb"><i class="ti ti-cake" aria-hidden="true"></i></div>
                      <% } %>
                      <div>
                        <div class="item-name"><%= item.productName %></div>
                        <% if (item.weight) { %>
                          <div class="item-sub"><%= item.weight %>g</div>
                        <% } %>
                        <% if (item.cancelReason) { %>
                          <div class="item-cancel-reason">Reason: <%= item.cancelReason %></div>
                        <% } %>
                        <% if (item.returnReason) { %>
                          <div class="item-return-reason">Reason: <%= item.returnReason %></div>
                        <% } %>
                      </div>
                    </div>
                  </td>
                  <td class="qty-cell"><%= item.quantity %></td>
                  <td class="price-cell">₹<%= item.price.toLocaleString('en-IN') %></td>
                  <td class="total-cell">₹<%= (item.price * item.quantity).toLocaleString('en-IN') %></td>
                  <td class="status-cell">
                    <span class="badge b-<%= item.status.replace(' ','-') %> item-status-badge">
                      <%= item.status %>
                    </span>
                  </td>
                  <% if (order.items.some(function(i){ return i.status === 'Return Requested'; })) { %>
                  <td class="action-cell">
                    <% if (item.status === 'Return Requested') { %>
                      <div style="display:flex;gap:5px;justify-content:flex-end;flex-wrap:wrap">
                        <button class="btn-approve"
                          onclick="handleReturn('<%= order._id %>', '<%= item._id %>', 'approve')">
                          <i class="ti ti-check" style="font-size:10px" aria-hidden="true"></i> Approve
                        </button>
                        <button class="btn-reject"
                          onclick="handleReturn('<%= order._id %>', '<%= item._id %>', 'reject')">
                          <i class="ti ti-x" style="font-size:10px" aria-hidden="true"></i> Reject
                        </button>
                      </div>
                    <% } else { %>
                      <span style="font-size:10px;color:var(--muted)">—</span>
                    <% } %>
                  </td>
                  <% } %>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Payment summary / totals -->
        <div class="inv-totals">
          <div class="inv-section-label">
            <i class="ti ti-receipt" aria-hidden="true"></i>
            Payment summary
          </div>
          <div class="totals-inner">
            <div class="t-row">
              <span class="t-lbl">Item total</span>
              <span class="t-val">₹<%= order.itemTotal.toLocaleString('en-IN') %></span>
            </div>
            <% if (order.discount > 0) { %>
            <div class="t-row">
              <span class="t-lbl">Discount</span>
              <span class="t-green">−₹<%= order.discount.toLocaleString('en-IN') %></span>
            </div>
            <% } %>
            <% if (order.couponCode) { %>
            <div class="t-row">
              <span class="t-lbl">
                Coupon
                <span class="coupon-chip">
                  <i class="ti ti-tag" aria-hidden="true"></i><%= order.couponCode %>
                </span>
              </span>
              <span class="t-green">Applied</span>
            </div>
            <% } %>
            <% if (order.tax > 0) { %>
            <div class="t-row">
              <span class="t-lbl">Tax</span>
              <span class="t-val">₹<%= order.tax.toLocaleString('en-IN') %></span>
            </div>
            <% } %>
            <div class="t-row">
              <span class="t-lbl">Shipping</span>
              <% if (order.shippingCharge > 0) { %>
                <span class="t-val">₹<%= order.shippingCharge.toLocaleString('en-IN') %></span>
              <% } else { %>
                <span class="t-green">Free</span>
              <% } %>
            </div>
            <div class="t-divider"></div>
            <div class="t-grand-row">
              <span class="t-grand-lbl">Grand total</span>
              <span class="t-grand-val">₹<%= order.finalTotal.toLocaleString('en-IN') %></span>
            </div>
          </div>
        </div>

        <!-- Footer -->
        <div class="inv-footer">
          <div class="inv-footer-note">
            <i class="ti ti-heart" aria-hidden="true"></i>
            Thank you for choosing Cake O'Clock!
          </div>
          <div class="inv-footer-links">
            <span class="inv-footer-link"><i class="ti ti-mail" aria-hidden="true"></i>support@cakeoclock.com</span>
            <span class="inv-footer-link"><i class="ti ti-world" aria-hidden="true"></i>cakeoclock.com</span>
          </div>
        </div>

      </div><!-- /invoice-card -->

      <!-- Delivery address -->
      <div class="card">
        <div class="card-head">
          <div class="card-head-title">
            <i class="ti ti-map-pin" aria-hidden="true"></i> Delivery address
          </div>
        </div>
        <div class="info-row"><span class="info-label">Name</span><span class="info-val"><%= order.address.name %></span></div>
        <div class="info-row"><span class="info-label">Phone</span><span class="info-val"><%= order.address.phone %></span></div>
        <div class="info-row"><span class="info-label">Street</span><span class="info-val"><%= order.address.street %></span></div>
        <% if (order.address.address) { %>
        <div class="info-row"><span class="info-label">Address</span><span class="info-val"><%= order.address.address %></span></div>
        <% } %>
        <% if (order.address.landmark) { %>
        <div class="info-row"><span class="info-label">Landmark</span><span class="info-val"><%= order.address.landmark %></span></div>
        <% } %>
        <div class="info-row"><span class="info-label">City</span><span class="info-val"><%= order.address.city %></span></div>
        <div class="info-row"><span class="info-label">State</span><span class="info-val"><%= order.address.state %></span></div>
        <div class="info-row"><span class="info-label">Pincode</span><span class="info-val"><%= order.address.pincode %></span></div>
        <% if (order.address.type) { %>
        <div class="info-row"><span class="info-label">Type</span><span class="info-val"><%= order.address.type %></span></div>
        <% } %>
      </div>

    </div>

    <!-- ── RIGHT COLUMN ── -->
    <div class="right-col">

      <!-- Order summary + status update -->
      <div class="card">
        <div class="card-head">
          <div class="card-head-title">
            <i class="ti ti-info-circle" aria-hidden="true"></i> Order summary
          </div>
        </div>

        <div class="info-row">
          <span class="info-label">Order ID</span>
          <span class="info-val" style="color:var(--rose)"><%= order.orderId %></span>
        </div>
        <div class="info-row">
          <span class="info-label">Date</span>
          <span class="info-val">
            <%= new Date(order.createdAt).toLocaleDateString('en-IN', {day:'2-digit', month:'short', year:'numeric'}) %>
          </span>
        </div>
        <div class="info-row">
          <span class="info-label">Payment</span>
          <span class="info-val">
            <span class="badge b-<%= order.paymentMethod %>"><%= order.paymentMethod %></span>
          </span>
        </div>
        <div class="info-row">
          <span class="info-label">Pay status</span>
          <span class="info-val">
            <span class="badge b-<%= order.paymentStatus %>"><%= order.paymentStatus %></span>
          </span>
        </div>
        <div class="info-row">
          <span class="info-label">Order status</span>
          <span class="info-val">
<span class="badge b-<%= order.status.replace(/ /g,'-') %>" id="current-badge"><%= order.status %></span>          </span>
        </div>
        <% if (order.cancelReason) { %>
        <div class="info-row">
          <span class="info-label">Cancel reason</span>
          <span class="info-val" style="color:#C03030;font-size:12px"><%= order.cancelReason %></span>
        </div>
        <% } %>
        <% if (order.returnReason) { %>
        <div class="info-row">
          <span class="info-label">Return reason</span>
          <span class="info-val" style="color:#7030C9;font-size:12px"><%= order.returnReason %></span>
        </div>
        <% } %>

        <div style="margin-top:16px">
          <div style="font-size:11px;color:var(--muted);margin-bottom:6px">Update order status</div>
<%
            const STATUS_ORDER = ["Pending","Processing","Shipped","Delivered","Cancelled","Returned"];
            const currentIdx   = STATUS_ORDER.indexOf(order.status);
            const LOCKED       = ['Cancelled','Returned'];
          %>
          <select class="status-sel-lg" id="status-select">
            <% STATUS_ORDER.forEach(function(s, i) { %>
              <% if (s !== 'Returned' && s !== 'Cancelled') { %>
                <option value="<%= s %>"
                  <%= order.status === s ? 'selected' : '' %>
                  <%= (i < currentIdx || LOCKED.includes(order.status)) ? 'disabled' : '' %>
                ><%= s %></option>
              <% } %>
              <% if (s === 'Cancelled') { %>
                <option value="Cancelled"
                  <%= order.status === 'Cancelled' ? 'selected' : '' %>
                  <%= (['Delivered','Cancelled','Returned'].includes(order.status)) ? 'disabled' : '' %>
                >Cancelled</option>
              <% } %>
            <% }) %>
          </select>
                    <button class="btn-update" id="update-btn" onclick="submitStatusUpdate()">
            <i class="ti ti-check" aria-hidden="true"></i> Update status
          </button>
        </div>
      </div>

      <!-- Customer -->
      <div class="card">
        <div class="card-head">
          <div class="card-head-title">
            <i class="ti ti-user" aria-hidden="true"></i> Customer
          </div>
        </div>
        <% if (order.userId) { %>
        <div class="info-row">
          <span class="info-label">Name</span>
          <span class="info-val"><%= order.userId.name || order.address.name %></span>
        </div>
        <div class="info-row">
          <span class="info-label">Email</span>
          <span class="info-val" style="font-size:12px"><%= order.userId.email || '—' %></span>
        </div>
        <% } else { %>
        <div class="info-row">
          <span class="info-label">Name</span>
          <span class="info-val"><%= order.address.name %></span>
        </div>
        <% } %>
        <div class="info-row">
          <span class="info-label">Phone</span>
          <span class="info-val"><%= order.address.phone %></span>
        </div>
      </div>

      <!-- Timeline -->
      <div class="card">
        <div class="card-head">
          <div class="card-head-title">
            <i class="ti ti-timeline" aria-hidden="true"></i> Status timeline
          </div>
        </div>
        <%
          const allStatuses = ["Pending","Processing","Shipped","Delivered"];
          const timelineIdx = allStatuses.indexOf(order.status);
        %>
        <ul class="timeline">
          <% allStatuses.forEach(function(s, i) { %>
            <li>
              <div class="tl-dot <%= i <= timelineIdx ? '' : 'inactive' %>"></div>
              <div class="tl-status <%= i <= timelineIdx ? '' : 'inactive' %>"><%= s %></div>
              <% if (i <= timelineIdx) { %>
                <div class="tl-date">
                  <%= new Date(order.updatedAt).toLocaleDateString('en-IN', {day:'2-digit', month:'short', year:'numeric'}) %>
                </div>
              <% } else { %>
                <div class="tl-date">Upcoming</div>
              <% } %>
            </li>
          <% }) %>
          <% if (order.status === 'Cancelled') { %>
            <li>
              <div class="tl-dot" style="background:#C03030;box-shadow:0 0 0 2px #C03030"></div>
              <div class="tl-status" style="color:#C03030">Cancelled</div>
              <div class="tl-date"><%= new Date(order.updatedAt).toLocaleDateString('en-IN', {day:'2-digit', month:'short', year:'numeric'}) %></div>
            </li>
          <% } %>
          <% if (order.status === 'Returned' || order.status === 'Return Requested') { %>
            <li>
              <div class="tl-dot" style="background:#7030C9;box-shadow:0 0 0 2px #7030C9"></div>
              <div class="tl-status" style="color:#7030C9"><%= order.status %></div>
              <div class="tl-date"><%= new Date(order.updatedAt).toLocaleDateString('en-IN', {day:'2-digit', month:'short', year:'numeric'}) %></div>
            </li>
          <% } %>
        </ul>
      </div>

    </div>
  </div>
</div>

<div class="toast" id="toast"></div>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<style>
  .swal-slim        { border-radius: 16px !important; padding: 1.4rem !important; width: 300px !important; }
  .swal-slim-title  { font-size: 15px !important; font-weight: 600 !important; color: #5C3A3A !important; padding: 0 !important; }
  .swal-slim-text   { font-size: 12px !important; color: #B08A8A !important; margin-top: 4px !important; }
</style>

<script>
  window.addEventListener('pageshow', function (event) {
  if (event.persisted) {
    // Page was restored from bfcache — force a fresh load with current data
    window.location.reload();
  }
});
const ORDER_ID        = '<%= order._id %>';
const STATUS_ORDER    = ['Pending','Processing','Shipped','Delivered','Cancelled','Returned'];
const LOCKED = ['Cancelled','Returned'];
let   lastKnownStatus = '<%= order.status %>';

function getOrderIdFromUrl() {
  const parts = window.location.pathname.split('/').filter(Boolean);
  return parts[parts.length - 1];
}

function showToast(msg, type) {
  var t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast ' + (type || 'success') + ' show';
  setTimeout(function() { t.className = 'toast'; }, 3000);
}

async function submitStatusUpdate() {
  var sel    = document.getElementById('status-select');
  var btn    = document.getElementById('update-btn');
  var status = sel.value;
  btn.disabled = true;
  btn.innerHTML = '<i class="ti ti-loader" aria-hidden="true"></i> Updating…';
  try {
    var res  = await fetch('/admin/orders/' + getOrderIdFromUrl() + '/status', {
        method: 'PATCH', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ status: status })
    });
    var data = await res.json();
    if (data.success) {
      lastKnownStatus = status;
      updateDetailUI(status);
      showToast('Status updated to "' + status + '"', 'success'); // ✅ toast ONLY here (manual update)
    } else {
      showToast(data.message || 'Update failed', 'error');
    }
  } catch (e) {
    showToast('Network error', 'error');
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<i class="ti ti-check" aria-hidden="true"></i> Update status';
  }
}

async function handleReturn(orderId, itemId, action) {
  const isApprove = action === 'approve';
  const confirm = await Swal.fire({
    title: isApprove ? '✅ Approve Return?' : '✕ Reject Return?',
    text: isApprove ? 'Refund goes to wallet.' : 'Request will be declined.',
    icon: isApprove ? 'success' : 'error',
    background: isApprove ? '#f0faf2' : '#fff5f5',
    showCancelButton: true,
    confirmButtonColor: isApprove ? '#2A7D3A' : '#C03030',
    cancelButtonColor: '#B08A8A',
    confirmButtonText: isApprove ? 'Approve' : 'Reject',
    cancelButtonText: 'Back',
    customClass: {
      popup: 'swal-slim',
      title: 'swal-slim-title',
      htmlContainer: 'swal-slim-text'
    }
  });
  if (!confirm.isConfirmed) return;

  var url = isApprove ? '/admin/approve-return' : '/admin/reject-return';
  try {
    var res  = await fetch(url, {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ orderId: orderId, itemId: itemId })
    });
    var data = await res.json();
    if (data.success) {
      showToast(data.message, 'success');
      setTimeout(function() { location.reload(); }, 1200);
    } else {
      showToast(data.message || 'Failed', 'error');
    }
  } catch (e) {
    showToast('Network error', 'error');
  }
}

async function pollStatus() {
  try {
    var res  = await fetch('/admin/orders/' + getOrderIdFromUrl() + '/poll-status');
    var data = await res.json();
    if (data.success && data.status !== lastKnownStatus) {
      lastKnownStatus = data.status;
      updateDetailUI(data.status);
      // 🔕 No toast here — polling should update UI silently.
      // Toast only fires from submitStatusUpdate() (manual admin action).
    }
  } catch (e) { /* silent */ }
}
var pollIntervalId = setInterval(pollStatus, 8000);

function updateDetailUI(newStatus) {
  var badge = document.getElementById('current-badge');
  if (badge) { badge.textContent = newStatus; badge.className = 'badge b-' + newStatus; }

  document.querySelectorAll('.item-status-badge').forEach(function(el) {
    var cur = el.textContent.trim();
    if (!['Cancelled','Returned'].includes(cur)) {
      el.textContent = newStatus;
      el.className   = 'badge b-' + newStatus.replace(' ','-') + ' item-status-badge';
    }
  });

  var sel = document.getElementById('status-select');
  if (sel) {
    sel.value = newStatus;
    var curIdx   = STATUS_ORDER.indexOf(newStatus);
    var isLocked = LOCKED.includes(newStatus);
    Array.from(sel.options).forEach(function(opt) {
      opt.disabled = isLocked || STATUS_ORDER.indexOf(opt.value) < curIdx;
    });
    if (isLocked) {
      sel.style.opacity       = '0.6';
      sel.style.pointerEvents = 'none';
      document.getElementById('update-btn').disabled = true;
    }
  }
}

window.addEventListener('pageshow', function (event) {
  if (event.persisted) {
    clearInterval(pollIntervalId);
    window.location.reload();
  }
});
</script>
