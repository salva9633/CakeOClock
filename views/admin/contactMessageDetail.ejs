<%- include('../partials/admin/header') %>

<div class="page-wrapper">
  <%- include('../partials/admin/sidebar') %>

  <div class="main-content msg-detail-page">

    <!-- Back -->
    <a href="/admin/contact-messages" class="back-link">
      <i class="ti ti-arrow-left" aria-hidden="true"></i> Back to messages
    </a>

    <!-- Page Header -->
    <div class="page-header">
      <div>
        <h1 class="page-title">Message details</h1>
        <p class="page-subtitle">View customer inquiries and manage responses.</p>
      </div>
      <%
        const badges = {
          unread:  { cls:'badge-unread',  icon:'ti-mail',         label:'Unread'  },
          read:    { cls:'badge-read',    icon:'ti-eye',          label:'Read'    },
          replied: { cls:'badge-replied', icon:'ti-circle-check', label:'Replied' }
        };
        const b = badges[msg.status] || badges.read;
      %>
      <span class="status-badge <%= b.cls %>">
        <i class="ti <%= b.icon %>" aria-hidden="true"></i> <%= b.label %>
      </span>
    </div>

    <!-- Customer Information Card -->
    <div class="card anim-card" style="animation-delay:.05s">
      <div class="card-body">
        <div class="section-label">
          <i class="ti ti-user" aria-hidden="true"></i> Customer information
        </div>
        <div class="customer-grid">
          <div class="avatar" aria-hidden="true">
            <%= msg.name.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2) %>
          </div>
          <div>
            <div class="customer-name"><%= msg.name %></div>
            <div class="customer-subject"><%= msg.subject %></div>
            <div class="meta-row">
              <span class="meta-item">
                <i class="ti ti-mail" aria-hidden="true"></i>
                <a href="mailto:<%= msg.email %>"><%= msg.email %></a>
              </span>
              <span class="meta-item">
                <i class="ti ti-calendar" aria-hidden="true"></i>
                <%= new Date(msg.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %>
              </span>
              <span class="meta-item">
                <i class="ti ti-clock" aria-hidden="true"></i>
                <%= new Date(msg.createdAt).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}) %>
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Customer Message Card -->
    <div class="card anim-card" style="animation-delay:.1s">
      <div class="card-body">
        <div class="section-label">
          <i class="ti ti-message" aria-hidden="true"></i> Customer message
        </div>
        <div class="msg-bubble">
          <p class="msg-text"><%= msg.message %></p>
          <div class="msg-time">
            <i class="ti ti-clock" aria-hidden="true"></i>
            <%= new Date(msg.createdAt).toLocaleString('en-IN',{
              day:'numeric', month:'short', year:'numeric',
              hour:'2-digit', minute:'2-digit'
            }) %>
          </div>
        </div>
      </div>
    </div>

    <!-- Previous Reply Card -->
    <% if (msg.adminReply && msg.adminReply.text) { %>
    <div class="card anim-card" style="animation-delay:.15s">
      <div class="card-body">
        <div class="section-label">
          <i class="ti ti-corner-down-right" aria-hidden="true"></i> Your reply
        </div>
        <div class="reply-row">
          <div class="avatar avatar-sm" aria-hidden="true">A</div>
          <div style="flex:1;min-width:0;">
            <div class="reply-meta">
              <span class="reply-label">
                <i class="ti ti-check" aria-hidden="true"></i> Sent by admin
              </span>
              <span class="reply-time-tag">
                <i class="ti ti-clock" aria-hidden="true"></i>
                <%= new Date(msg.adminReply.repliedAt).toLocaleString('en-IN',{
                  day:'numeric', month:'short', year:'numeric',
                  hour:'2-digit', minute:'2-digit'
                }) %>
              </span>
            </div>
            <div class="reply-bubble">
              <p class="reply-text"><%= msg.adminReply.text %></p>
            </div>
          </div>
        </div>
      </div>
    </div>
    <% } %>

    <!-- Activity Timeline Card -->
    <div class="card anim-card" style="animation-delay:.2s">
      <div class="card-body">
        <div class="section-label">
          <i class="ti ti-timeline" aria-hidden="true"></i> Activity timeline
        </div>
        <div class="timeline">
          <div class="tl-item">
            <div class="tl-dot-wrap">
              <div class="tl-dot tl-dot-accent"></div>
              <div class="tl-line"></div>
            </div>
            <div class="tl-content">
              <div class="tl-title">Message received</div>
              <div class="tl-time">
                <%= new Date(msg.createdAt).toLocaleString('en-IN',{
                  day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit'
                }) %>
              </div>
            </div>
          </div>

          <% if (msg.status !== 'unread') { %>
          <div class="tl-item">
            <div class="tl-dot-wrap">
              <div class="tl-dot tl-dot-blue"></div>
              <% if (msg.adminReply && msg.adminReply.text) { %><div class="tl-line"></div><% } %>
            </div>
            <div class="tl-content">
              <div class="tl-title">Marked as read</div>
              <div class="tl-time">
                <%= new Date(msg.createdAt).toLocaleString('en-IN',{
                  day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit'
                }) %>
              </div>
            </div>
          </div>
          <% } %>

          <% if (msg.adminReply && msg.adminReply.text) { %>
          <div class="tl-item">
            <div class="tl-dot-wrap">
              <div class="tl-dot tl-dot-success"></div>
            </div>
            <div class="tl-content">
              <div class="tl-title">Reply sent</div>
              <div class="tl-time">
                <%= new Date(msg.adminReply.repliedAt).toLocaleString('en-IN',{
                  day:'numeric', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit'
                }) %>
              </div>
            </div>
          </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="actions-row">
      <button class="btn btn-danger" onclick="deleteMessage('<%= msg._id %>')">
        <i class="ti ti-trash" aria-hidden="true"></i> Delete
      </button>
      <button class="btn btn-primary" onclick="openReplyModal()">
        <i class="ti ti-send" aria-hidden="true"></i>
        <%= msg.adminReply && msg.adminReply.text ? 'Reply again' : 'Reply to customer' %>
      </button>
    </div>
  </div>
</div>

<!-- ═══ REPLY MODAL ═══ -->
<div id="replyModal" class="coc-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-heading">
  <div class="coc-modal">
    <div class="modal-hd">
      <div>
        <div class="modal-title" id="modal-heading">
          <i class="ti ti-mail-forward" aria-hidden="true"></i>
          Reply to <%= msg.name %>
        </div>
        <div class="modal-sub"><%= msg.email %></div>
      </div>
      <button class="modal-close" onclick="closeReplyModal()" aria-label="Close modal">
        <i class="ti ti-x" aria-hidden="true"></i>
      </button>
    </div>

    <div class="modal-quote">
      <p class="modal-quote-label">Replying to</p>
      <p class="modal-quote-text"><%= msg.message %></p>
    </div>

    <div class="modal-body">
      <textarea id="replyText" class="reply-input" rows="6"
        placeholder="Type your reply here…"
        aria-label="Reply message"></textarea>
      <div id="replyFeedback" class="feedback" role="alert" aria-live="polite"></div>
      <div class="modal-footer">
        <button class="btn btn-ghost" onclick="closeReplyModal()">Cancel</button>
        <button id="sendReplyBtn" class="btn btn-primary" onclick="sendReply('<%= msg._id %>')">
          <i class="ti ti-send" aria-hidden="true"></i> Send reply
        </button>
      </div>
    </div>
  </div>
</div>

<style>
/* ── Page layout ── */
.msg-detail-page {
  padding: 32px;
  max-width: 840px;
  margin-left: 0;
  width: 100%;
  animation: mdFadeIn .35s ease both;
}
@keyframes mdFadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ── Back link ── */
.back-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  color: #9ca3af;
  text-decoration: none;
  padding: 6px 14px;
  border: 1px solid var(--border);
  border-radius: 9px;
  background: #fff;
  transition: all .18s;
  margin-bottom: 20px;
}
.back-link:hover { border-color: var(--rose); color: var(--rose); }

/* ── Page header ── */
.page-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  flex-wrap: wrap;
  margin-bottom: 24px;
}
.page-title { font-size: 22px; font-weight: 700; color: var(--brown); line-height: 1.2; }
.page-subtitle { font-size: 13px; color: #9ca3af; margin-top: 4px; }

/* ── Status badge ── */
.status-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 12px;
  font-weight: 600;
  padding: 5px 13px;
  border-radius: 20px;
  white-space: nowrap;
  margin-top: 4px;
}
.badge-unread  { background: #fce8ed; color: #c0394f; border: 1px solid #f5c6cb; }
.badge-read    { background: #e8f0fe; color: #3367d6; border: 1px solid #c5d4f8; }
.badge-replied { background: #e6f4ea; color: #2e7d32; border: 1px solid #b7dfbf; }

/* ── Cards ── */
.card {
  background: #fff;
  border: 1px solid #f0e8ea;
  border-radius: 16px;
  margin-bottom: 16px;
  transition: box-shadow .2s;
  overflow: hidden;
}
.card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.06); }
.card-body { padding: 24px; }
.anim-card { animation: mdFadeIn .4s ease both; }

/* ── Section label ── */
.section-label {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .08em;
  color: #b0aab0;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 6px;
}

/* ── Customer grid ── */
.customer-grid { display: grid; grid-template-columns: auto 1fr; gap: 16px; align-items: start; }
.avatar {
  width: 48px; height: 48px; border-radius: 50%;
  background: #fce8ed;
  display: flex; align-items: center; justify-content: center;
  font-size: 16px; font-weight: 700; color: var(--rose-dk, #A85F6E);
  flex-shrink: 0;
}
.avatar-sm { width: 32px; height: 32px; font-size: 12px; background: #e6f4ea; color: #2e7d32; }
.customer-name  { font-size: 16px; font-weight: 700; color: var(--brown); margin-bottom: 2px; }
.customer-subject { font-size: 14px; color: #6b7280; margin-bottom: 10px; }
.meta-row { display: flex; flex-wrap: wrap; gap: 14px; }
.meta-item { display: flex; align-items: center; gap: 5px; font-size: 13px; color: #9ca3af; }
.meta-item i { font-size: 14px; }
.meta-item a { color: var(--rose-dk, #A85F6E); text-decoration: none; }
.meta-item a:hover { text-decoration: underline; }

/* ── Message bubble ── */
.msg-bubble {
  background: #f9f5f6;
  border: 1px solid #f0e8ea;
  border-radius: 12px;
  padding: 18px 20px;
}
.msg-text  { font-size: 15px; color: #374151; line-height: 1.8; white-space: pre-wrap; }
.msg-time  { font-size: 12px; color: #9ca3af; margin-top: 10px; display: flex; align-items: center; gap: 4px; }

/* ── Reply section ── */
.reply-row { display: flex; align-items: flex-start; gap: 12px; }
.reply-meta { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px; margin-bottom: 10px; }
.reply-label { font-size: 12px; font-weight: 600; color: #2e7d32; display: flex; align-items: center; gap: 5px; }
.reply-time-tag { font-size: 12px; color: #9ca3af; display: flex; align-items: center; gap: 4px; }
.reply-bubble { background: #eef8f0; border: 1px solid #b7dfbf; border-radius: 12px; padding: 16px 18px; }
.reply-text { font-size: 15px; color: #1f2937; line-height: 1.8; white-space: pre-wrap; }

/* ── Timeline ── */
.timeline { display: flex; flex-direction: column; }
.tl-item { display: flex; align-items: flex-start; gap: 14px; padding-bottom: 20px; }
.tl-item:last-child { padding-bottom: 0; }
.tl-dot-wrap { display: flex; flex-direction: column; align-items: center; width: 24px; flex-shrink: 0; }
.tl-dot { width: 10px; height: 10px; border-radius: 50%; border: 2px solid; flex-shrink: 0; margin-top: 4px; }
.tl-dot-accent  { background: #fce8ed; border-color: var(--rose, #C86A7A); }
.tl-dot-blue    { background: #e8f0fe; border-color: #3367d6; }
.tl-dot-success { background: #e6f4ea; border-color: #2e7d32; }
.tl-line { width: 1.5px; background: #f0e8ea; flex: 1; min-height: 22px; margin-top: 5px; }
.tl-title { font-size: 13px; font-weight: 600; color: var(--brown); }
.tl-time  { font-size: 12px; color: #9ca3af; margin-top: 2px; }

/* ── Action buttons ── */
.actions-row { display: flex; align-items: center; justify-content: flex-end; gap: 10px; flex-wrap: wrap; margin-top: 4px; }
.btn {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 9px 20px; border-radius: 10px;
  font-size: 14px; font-weight: 600; cursor: pointer;
  font-family: inherit; transition: all .18s; border: none;
}
.btn:disabled { opacity: .5; cursor: not-allowed; }
.btn-primary { background: #C86A7A; color: #fff; }
.btn-primary:hover:not(:disabled) { background: #b35868; }
.btn-primary:active:not(:disabled) { transform: scale(.98); }
.btn-danger { background: #fff; color: #c0394f; border: 1.5px solid #f5c6cb; }
.btn-danger:hover:not(:disabled) { background: #fce8ed; }
.btn-ghost  { background: #f7f0f2; color: #9ca3af; border: 1px solid #e8d0d6; }
.btn-ghost:hover  { background: #f0e8ea; color: #555; }

/* ── Reply Modal ── */
.coc-overlay {
  display: none;
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.4);
  z-index: 99999;
  align-items: center;
  justify-content: center;
  padding: 20px;
}
.coc-overlay.open { display: flex !important; }
.coc-modal {
  background: #fff;
  border-radius: 18px;
  width: 100%; max-width: 560px;
  overflow: hidden;
  animation: modalSlide .25s ease;
  position: relative;
  z-index: 1;
}
@keyframes modalSlide {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}
.modal-hd {
  padding: 20px 24px;
  border-bottom: 1px solid #f0e8ea;
  display: flex; align-items: center; justify-content: space-between; gap: 12px;
}
.modal-title { font-size: 15px; font-weight: 700; color: var(--brown); }
.modal-title i { margin-right: 6px; color: #C86A7A; }
.modal-sub   { font-size: 13px; color: #9ca3af; margin-top: 3px; }
.modal-close {
  width: 32px; height: 32px; border-radius: 50%;
  border: 1px solid #e8d0d6; background: #f7f0f2;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  color: #9ca3af; font-size: 15px; transition: all .15s;
}
.modal-close:hover { border-color: var(--rose); color: var(--rose); }
.modal-quote       { padding: 12px 24px; background: #fdf6f8; border-bottom: 1px solid #f0e8ea; }
.modal-quote-label { font-size: 11px; color: #bbb; text-transform: uppercase; letter-spacing: .07em; margin-bottom: 4px; }
.modal-quote-text  {
  font-size: 13px; color: #9ca3af; line-height: 1.6;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
.modal-body { padding: 20px 24px; }
.reply-input {
  width: 100%; box-sizing: border-box;
  border: 1px solid #e8d0d6; border-radius: 10px;
  padding: 12px 14px; font-size: 14px; font-family: inherit;
  color: #333; background: #fdf9fa;
  resize: vertical; outline: none; line-height: 1.7; transition: border-color .15s;
}
.reply-input:focus { border-color: var(--rose, #C86A7A); background: #fff; }
.feedback      { margin-top: 10px; font-size: 13px; display: none; align-items: center; gap: 5px; }
.feedback.show { display: flex; }
.feedback.err  { color: #c0394f; }
.feedback.ok   { color: #2e7d32; }
.modal-footer  { display: flex; justify-content: flex-end; gap: 10px; margin-top: 14px; }

/* ── Responsive ── */
@media (max-width: 640px) {
  .msg-detail-page { padding: 20px 16px; }
  .customer-grid { grid-template-columns: 1fr; }
  .avatar { display: none; }
  .modal { border-radius: 14px; }
}
</style>

<script>
function openReplyModal() {
  document.getElementById('replyModal').classList.add('open');
  setTimeout(() => document.getElementById('replyText').focus(), 120);
}

function closeReplyModal() {
  document.getElementById('replyModal').classList.remove('open');
  document.getElementById('replyText').value = '';
  const fb = document.getElementById('replyFeedback');
  fb.className = 'feedback';
  fb.innerHTML = '';
}

async function sendReply(msgId) {
  const replyText = document.getElementById('replyText').value.trim();
  const fb  = document.getElementById('replyFeedback');
  const btn = document.getElementById('sendReplyBtn');

  if (!replyText) {
    fb.className = 'feedback show err';
    fb.innerHTML = '<i class="ti ti-alert-circle"></i> Reply cannot be empty.';
    return;
  }

  btn.disabled  = true;
  btn.innerHTML = '<i class="ti ti-loader-2"></i> Sending…';
  fb.className  = 'feedback';

  try {
    const res  = await fetch(`/admin/contact-messages/${msgId}/reply`, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ replyText })
    });
    const data = await res.json();

    if (data.success) {
      fb.className = 'feedback show ok';
      fb.innerHTML = '<i class="ti ti-circle-check"></i> Reply sent! Reloading…';
      setTimeout(() => window.location.reload(), 1500);
    } else {
      throw new Error(data.message || 'Something went wrong.');
    }
  } catch (err) {
    fb.className  = 'feedback show err';
    fb.innerHTML  = `<i class="ti ti-alert-circle"></i> ${err.message}`;
    btn.disabled  = false;
    btn.innerHTML = '<i class="ti ti-send"></i> Send reply';
  }
}

async function deleteMessage(msgId) {
  if (!confirm('Delete this message permanently?')) return;
  try {
    const res  = await fetch(`/admin/contact-messages/${msgId}`, { method: 'DELETE' });
    const data = await res.json();
    if (data.success) window.location.href = '/admin/contact-messages';
    else alert(data.message || 'Could not delete.');
  } catch {
    alert('Something went wrong. Please try again.');
  }
}

document.getElementById('replyModal').addEventListener('click', function(e) {
  if (e.target === this) closeReplyModal();
});
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeReplyModal(); });
</script>
