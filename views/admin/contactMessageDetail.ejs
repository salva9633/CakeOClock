<%- include('../partials/admin/header') %>

<div class="page-wrapper">
  <%- include('../partials/admin/sidebar') %>

  <div class="main-content msg-detail-page">

    <a href="/admin/contact-messages" class="back-link">
      <i class="ti ti-arrow-left" aria-hidden="true"></i> Back to messages
    </a>

    <div class="page-header">
      <div>
        <h1 class="page-title">Ticket #<%= msg.ticketNumber %></h1>
        <p class="page-subtitle"><%= msg.subject %></p>
      </div>
      <%
        const badges = {
          open:        { cls:'badge-open',        icon:'ti-alert-circle', label:'Open'         },
          in_progress: { cls:'badge-in_progress', icon:'ti-messages',     label:'In Progress'  },
          resolved:    { cls:'badge-resolved',    icon:'ti-circle-check', label:'Resolved'     },
          closed:      { cls:'badge-closed',      icon:'ti-lock',         label:'Closed'       }
        };
        const b = badges[msg.status] || badges.open;
      %>
      <span class="status-badge <%= b.cls %>">
        <i class="ti <%= b.icon %>" aria-hidden="true"></i> <%= b.label %>
      </span>
    </div>

    <!-- Customer Information Card -->
    <div class="card anim-card" style="animation-delay:.05s">
      <div class="card-body">
        <div class="section-label">
          <i class="ti ti-user" aria-hidden="true"></i> Customer information
        </div>
        <div class="customer-grid">
          <div class="avatar" aria-hidden="true">
            <%= msg.name.split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2) %>
          </div>
          <div>
            <div class="customer-name"><%= msg.name %></div>
            <div class="customer-subject"><%= msg.subject %></div>
            <div class="meta-row">
              <span class="meta-item">
                <i class="ti ti-mail" aria-hidden="true"></i>
                <a href="mailto:<%= msg.email %>"><%= msg.email %></a>
              </span>
              <span class="meta-item">
                <i class="ti ti-calendar" aria-hidden="true"></i>
                Opened <%= new Date(msg.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %>
              </span>
              <% if (msg.status === 'resolved' && msg.resolvedAt) { %>
                <span class="meta-item">
                  <i class="ti ti-clock" aria-hidden="true"></i>
                  Resolved <%= new Date(msg.resolvedAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %>
                  — auto-closes if no reply in 3 days
                </span>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Conversation Thread Card -->
    <div class="card anim-card" style="animation-delay:.1s">
      <div class="card-body">
        <div class="section-label">
          <i class="ti ti-message" aria-hidden="true"></i> Conversation
        </div>
        <div class="thread" id="threadList">
          <% (msg.messages || []).forEach(m => { %>
            <div class="thread-row <%= m.sender === 'admin' ? 'from-admin' : 'from-user' %>">
              <div class="avatar avatar-sm" aria-hidden="true"><%= m.sender === 'admin' ? 'A' : msg.name[0].toUpperCase() %></div>
              <div style="flex:1;min-width:0;">
                <div class="thread-meta">
                  <span class="thread-label"><%= m.sender === 'admin' ? 'You (Admin)' : msg.name %></span>
                  <span class="thread-time">
                    <%= new Date(m.createdAt).toLocaleString('en-IN',{day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
                  </span>
                </div>
                <div class="thread-bubble <%= m.sender === 'admin' ? 'bubble-admin' : 'bubble-user' %>">
                  <p><%= m.text %></p>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>

    <!-- Action Buttons -->
    <div class="actions-row">
      <button class="btn btn-danger" onclick="deleteMessage('<%= msg._id %>')">
        <i class="ti ti-trash" aria-hidden="true"></i> Delete
      </button>
      <% if (msg.status !== 'closed') { %>
        <% if (msg.status !== 'resolved') { %>
          <button class="btn btn-ghost" onclick="resolveTicket('<%= msg._id %>')">
            <i class="ti ti-circle-check" aria-hidden="true"></i> Mark Resolved
          </button>
        <% } %>
        <button class="btn btn-primary" onclick="openReplyModal()">
          <i class="ti ti-send" aria-hidden="true"></i> Reply
        </button>
      <% } %>
    </div>

  </div>
</div>

<!-- ═══ REPLY MODAL ═══ -->
<div id="replyModal" class="coc-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-heading">
  <div class="coc-modal">
    <div class="modal-hd">
      <div>
        <div class="modal-title" id="modal-heading">
          <i class="ti ti-mail-forward" aria-hidden="true"></i>
          Reply to <%= msg.name %>
        </div>
        <div class="modal-sub"><%= msg.email %> · Ticket #<%= msg.ticketNumber %></div>
      </div>
      <button class="modal-close" onclick="closeReplyModal()" aria-label="Close modal">
        <i class="ti ti-x" aria-hidden="true"></i>
      </button>
    </div>

    <div class="modal-body">
      <textarea id="replyText" class="reply-input" rows="6"
        placeholder="Type your reply here…"
        aria-label="Reply message"></textarea>
      <div id="replyFeedback" class="feedback" role="alert" aria-live="polite"></div>
      <div class="modal-footer">
        <button class="btn btn-ghost" onclick="closeReplyModal()">Cancel</button>
        <button id="sendReplyBtn" class="btn btn-primary" onclick="sendReply('<%= msg._id %>')">
          <i class="ti ti-send" aria-hidden="true"></i> Send reply
        </button>
      </div>
    </div>
  </div>
</div>

<style>
.msg-detail-page {
  padding: 32px;
  max-width: 840px;
  margin-left: 0;
  width: 100%;
  animation: mdFadeIn .35s ease both;
}
@keyframes mdFadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to   { opacity: 1; transform: translateY(0); }
}

.back-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  color: #9ca3af;
  text-decoration: none;
  padding: 6px 14px;
  border: 1px solid var(--border);
  border-radius: 9px;
  background: #fff;
  transition: all .18s;
  margin-bottom: 20px;
}
.back-link:hover { border-color: var(--rose); color: var(--rose); }

.page-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
  flex-wrap: wrap;
  margin-bottom: 24px;
}
.page-title { font-size: 22px; font-weight: 700; color: var(--brown); line-height: 1.2; }
.page-subtitle { font-size: 13px; color: #9ca3af; margin-top: 4px; }

.status-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 12px;
  font-weight: 600;
  padding: 5px 13px;
  border-radius: 20px;
  white-space: nowrap;
  margin-top: 4px;
}
.badge-open        { background: #fce8ed; color: #c0394f; border: 1px solid #f5c6cb; }
.badge-in_progress { background: #e8f0fe; color: #3367d6; border: 1px solid #c5d4f8; }
.badge-resolved    { background: #fff8e1; color: #b9840a; border: 1px solid #f0dca0; }
.badge-closed      { background: #eee; color: #777; border: 1px solid #ddd; }

.card {
  background: #fff;
  border: 1px solid #f0e8ea;
  border-radius: 16px;
  margin-bottom: 16px;
  transition: box-shadow .2s;
  overflow: hidden;
}
.card:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.06); }
.card-body { padding: 24px; }
.anim-card { animation: mdFadeIn .4s ease both; }

.section-label {
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .08em;
  color: #b0aab0;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 6px;
}

.customer-grid { display: grid; grid-template-columns: auto 1fr; gap: 16px; align-items: start; }
.avatar {
  width: 48px; height: 48px; border-radius: 50%;
  background: #fce8ed;
  display: flex; align-items: center; justify-content: center;
  font-size: 16px; font-weight: 700; color: var(--rose-dk, #A85F6E);
  flex-shrink: 0;
}
.avatar-sm { width: 32px; height: 32px; font-size: 12px; }
.customer-name  { font-size: 16px; font-weight: 700; color: var(--brown); margin-bottom: 2px; }
.customer-subject { font-size: 14px; color: #6b7280; margin-bottom: 10px; }
.meta-row { display: flex; flex-wrap: wrap; gap: 14px; }
.meta-item { display: flex; align-items: center; gap: 5px; font-size: 13px; color: #9ca3af; }
.meta-item i { font-size: 14px; }
.meta-item a { color: var(--rose-dk, #A85F6E); text-decoration: none; }
.meta-item a:hover { text-decoration: underline; }

/* ── THREAD ── */
.thread { display: flex; flex-direction: column; gap: 18px; max-height: 520px; overflow-y: auto; padding-right: 4px; }
.thread-row { display: flex; align-items: flex-start; gap: 12px; }
.thread-row.from-admin .avatar-sm { background: #fce8ed; color: #A85F6E; }
.thread-row.from-user  .avatar-sm { background: #e6f4ea; color: #2e7d32; }
.thread-meta { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 8px; margin-bottom: 8px; }
.thread-label { font-size: 12px; font-weight: 600; color: #374151; }
.thread-time { font-size: 12px; color: #9ca3af; }
.thread-bubble { border-radius: 12px; padding: 14px 16px; }
.thread-bubble p { font-size: 14px; color: #1f2937; line-height: 1.8; white-space: pre-wrap; }
.bubble-user  { background: #f9f5f6; border: 1px solid #f0e8ea; }
.bubble-admin { background: #eef8f0; border: 1px solid #b7dfbf; }

.actions-row { display: flex; align-items: center; justify-content: flex-end; gap: 10px; flex-wrap: wrap; margin-top: 4px; }
.btn {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 9px 20px; border-radius: 10px;
  font-size: 14px; font-weight: 600; cursor: pointer;
  font-family: inherit; transition: all .18s; border: none;
}
.btn:disabled { opacity: .5; cursor: not-allowed; }
.btn-primary { background: #C86A7A; color: #fff; }
.btn-primary:hover:not(:disabled) { background: #b35868; }
.btn-primary:active:not(:disabled) { transform: scale(.98); }
.btn-danger { background: #fff; color: #c0394f; border: 1.5px solid #f5c6cb; }
.btn-danger:hover:not(:disabled) { background: #fce8ed; }
.btn-ghost  { background: #f7f0f2; color: #9ca3af; border: 1px solid #e8d0d6; }
.btn-ghost:hover  { background: #f0e8ea; color: #555; }

.coc-overlay {
  display: none;
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.4);
  z-index: 99999;
  align-items: center;
  justify-content: center;
  padding: 20px;
}
.coc-overlay.open { display: flex !important; }
.coc-modal {
  background: #fff;
  border-radius: 18px;
  width: 100%; max-width: 560px;
  overflow: hidden;
  animation: modalSlide .25s ease;
  position: relative;
  z-index: 1;
}
@keyframes modalSlide {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}
.modal-hd {
  padding: 20px 24px;
  border-bottom: 1px solid #f0e8ea;
  display: flex; align-items: center; justify-content: space-between; gap: 12px;
}
.modal-title { font-size: 15px; font-weight: 700; color: var(--brown); }
.modal-title i { margin-right: 6px; color: #C86A7A; }
.modal-sub   { font-size: 13px; color: #9ca3af; margin-top: 3px; }
.modal-close {
  width: 32px; height: 32px; border-radius: 50%;
  border: 1px solid #e8d0d6; background: #f7f0f2;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  color: #9ca3af; font-size: 15px; transition: all .15s;
}
.modal-close:hover { border-color: var(--rose); color: var(--rose); }
.modal-body { padding: 20px 24px; }
.reply-input {
  width: 100%; box-sizing: border-box;
  border: 1px solid #e8d0d6; border-radius: 10px;
  padding: 12px 14px; font-size: 14px; font-family: inherit;
  color: #333; background: #fdf9fa;
  resize: vertical; outline: none; line-height: 1.7; transition: border-color .15s;
}
.reply-input:focus { border-color: var(--rose, #C86A7A); background: #fff; }
.feedback      { margin-top: 10px; font-size: 13px; display: none; align-items: center; gap: 5px; }
.feedback.show { display: flex; }
.feedback.err  { color: #c0394f; }
.feedback.ok   { color: #2e7d32; }
.modal-footer  { display: flex; justify-content: flex-end; gap: 10px; margin-top: 14px; }

@media (max-width: 640px) {
  .msg-detail-page { padding: 20px 16px; }
  .customer-grid { grid-template-columns: 1fr; }
  .avatar { display: none; }
}
</style>

<script>
function openReplyModal() {
  document.getElementById('replyModal').classList.add('open');
  setTimeout(() => document.getElementById('replyText').focus(), 120);
}

function closeReplyModal() {
  document.getElementById('replyModal').classList.remove('open');
  document.getElementById('replyText').value = '';
  const fb = document.getElementById('replyFeedback');
  fb.className = 'feedback';
  fb.innerHTML = '';
}

async function sendReply(msgId) {
  const replyText = document.getElementById('replyText').value.trim();
  const fb  = document.getElementById('replyFeedback');
  const btn = document.getElementById('sendReplyBtn');

  if (!replyText) {
    fb.className = 'feedback show err';
    fb.innerHTML = '<i class="ti ti-alert-circle"></i> Reply cannot be empty.';
    return;
  }

  btn.disabled  = true;
  btn.innerHTML = '<i class="ti ti-loader-2"></i> Sending…';
  fb.className  = 'feedback';

  try {
    const res  = await fetch(`/admin/contact-messages/${msgId}/reply`, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ replyText })
    });
    const data = await res.json();

    if (data.success) {
      fb.className = 'feedback show ok';
      fb.innerHTML = '<i class="ti ti-circle-check"></i> Reply sent! Reloading…';
      setTimeout(() => window.location.reload(), 1200);
    } else {
      throw new Error(data.message || 'Something went wrong.');
    }
  } catch (err) {
    fb.className  = 'feedback show err';
    fb.innerHTML  = `<i class="ti ti-alert-circle"></i> ${err.message}`;
    btn.disabled  = false;
    btn.innerHTML = '<i class="ti ti-send"></i> Send reply';
  }
}

async function resolveTicket(msgId) {
  if (!confirm('Mark this ticket as resolved? Customer will have 3 days to reply before it auto-closes.')) return;
  try {
    const res = await fetch(`/admin/contact-messages/${msgId}/resolve`, { method: 'PATCH' });
    const data = await res.json();
    if (data.success) window.location.reload();
    else alert(data.message || 'Could not resolve.');
  } catch {
    alert('Something went wrong. Please try again.');
  }
}

async function deleteMessage(msgId) {
  if (!confirm('Delete this ticket permanently?')) return;
  try {
    const res  = await fetch(`/admin/contact-messages/${msgId}`, { method: 'DELETE' });
    const data = await res.json();
    if (data.success) window.location.href = '/admin/contact-messages';
    else alert(data.message || 'Could not delete.');
  } catch {
    alert('Something went wrong. Please try again.');
  }
}

document.getElementById('replyModal').addEventListener('click', function(e) {
  if (e.target === this) closeReplyModal();
});
document.addEventListener('keydown', e => { if (e.key === 'Escape') closeReplyModal(); });
</script>