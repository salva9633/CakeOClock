<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>My Cart – Cake O'Clock</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,900;1,700&family=Lato:wght@300;400;700&family=Dancing+Script:wght@700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <style>
    :root {
      --rose:      #C2607A;
      --rose-dk:   #8B3A52;
      --rose-lt:   #fdf0f3;
      --rose-pale: #fce8ed;
      --cream:     #f9e4ea;
      --muted:     #9a6b75;
      --border:    #f0d4db;
      --white:     #fff;
      --bg:        #fce8ed;
      --text:      #2d1a20;
      --shadow-sm: 0 2px 12px rgba(194,96,122,.10);
      --shadow-md: 0 8px 32px rgba(194,96,122,.16);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Lato', sans-serif; background: var(--bg); color: var(--text); }
    a    { text-decoration: none; color: inherit; }

    /* ── BREADCRUMB ── */
    .breadcrumb-strip {
      background: #fff8f9;
      border-bottom: 1px solid var(--border);
      padding: 11px 36px;
      display: flex; align-items: center; gap: 6px;
      font-size: .76rem; letter-spacing: .04em; color: var(--muted);
    }
    .breadcrumb-strip a { color: var(--muted); transition: color .2s; }
    .breadcrumb-strip a:hover { color: var(--rose); }
    .bc-sep    { color: var(--border); font-size: .9rem; }
    .bc-active { color: var(--rose); font-weight: 700; }

    /* ── LAYOUT ── */
    .cart-wrap {
      max-width: 1140px;
      margin: 32px auto;
      padding: 0 20px;
      display: grid;
      grid-template-columns: 1fr 340px;
      gap: 24px;
      align-items: start;
    }
    @media (max-width: 860px) {
      .cart-wrap { grid-template-columns: 1fr; }
    }

    /* ── SECTION CARD ── */
    .section-card {
      background: #fff;
      border-radius: 18px;
      border: 1px solid var(--border);
      box-shadow: var(--shadow-sm);
      overflow: hidden;
    }
    .section-head {
      padding: 18px 22px;
      border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between;
    }
    .section-head h2 {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem; font-weight: 700;
      color: var(--rose-dk);
    }
    .section-head .item-count {
      font-size: .78rem; color: var(--muted);
      background: var(--rose-pale);
      padding: 3px 10px; border-radius: 20px;
    }

    /* ── OUT OF STOCK BANNER ── */
    .oos-banner {
      margin: 16px 22px 0;
      padding: 12px 16px;
      background: #fff5f0;
      border: 1.5px solid #f5c0a0;
      border-radius: 12px;
      display: flex; align-items: center; gap: 10px;
      font-size: .83rem; color: #7a3800;
    }
    .oos-banner i { color: #e07040; font-size: 1rem; }

    /* ── CART ITEM ── */
    .cart-item {
      display: flex;
      gap: 16px;
      padding: 18px 22px;
      border-bottom: 1px solid #faf0f2;
      transition: background .2s;
      position: relative;
    }
    .cart-item:last-child { border-bottom: none; }
    .cart-item:hover { background: #fffbfc; }

    /* Blocked item overlay */
    .cart-item.item-blocked { background: #fdf8f8; }
    .cart-item.item-blocked .item-img img { filter: grayscale(.5) brightness(.95); }

    .item-img {
      width: 82px; height: 82px;
      border-radius: 12px; overflow: hidden;
      flex-shrink: 0; border: 1px solid var(--border);
      position: relative;
    }
    .item-img img { width: 100%; height: 100%; object-fit: cover; }

    /* OOS stamp on image */
    .oos-stamp {
      position: absolute; inset: 0;
      background: rgba(255,255,255,.7);
      display: flex; align-items: center; justify-content: center;
      border-radius: 12px;
    }
    .oos-stamp span {
      font-size: .58rem; font-weight: 800;
      letter-spacing: .08em; text-transform: uppercase;
      color: var(--rose-dk);
      background: rgba(255,255,255,.92);
      padding: 3px 8px; border-radius: 20px;
      border: 1px solid var(--border);
    }

    .item-details { flex: 1; min-width: 0; }
    .item-name {
      font-family: 'Playfair Display', serif;
      font-size: .95rem; font-weight: 600;
      color: var(--text); line-height: 1.3;
      margin-bottom: 3px;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .item-variant {
      font-size: .74rem; color: var(--muted);
      margin-bottom: 6px;
    }

    /* OOS / exceeds-stock tag */
    .stock-tag {
      display: inline-flex; align-items: center; gap: 4px;
      font-size: .7rem; font-weight: 700;
      padding: 2px 9px; border-radius: 20px;
      margin-bottom: 8px;
    }
    .stock-tag.oos        { background: #fde8e8; color: #b03030; }
    .stock-tag.exceeds    { background: #fff3d6; color: #7a5000; }
    .stock-tag.unavailable{ background: #f0e8ff; color: #5a00a0; }

    /* PRICING */
    .item-pricing {
      display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
    }
    .item-price-now {
      font-family: 'Playfair Display', serif;
      font-size: 1rem; font-weight: 800; color: var(--rose);
    }
    .item-price-old {
      font-size: .76rem; color: #c0a0a8;
      text-decoration: line-through;
    }
    .item-disc-pill {
      font-size: .62rem; font-weight: 700;
      padding: 2px 7px; border-radius: 20px;
      background: #e6fdf0; color: #196638;
    }

    /* QTY CONTROLS */
    .item-footer {
      display: flex; align-items: center;
      justify-content: space-between;
      margin-top: 10px;
    }
    .qty-box {
      display: flex; align-items: center; gap: 0;
      border: 1.5px solid var(--border);
      border-radius: 10px; overflow: hidden;
    }
    .qty-btn {
      width: 32px; height: 32px;
      background: var(--rose-pale);
      border: none; cursor: pointer;
      font-size: .9rem; color: var(--rose-dk);
      display: flex; align-items: center; justify-content: center;
      transition: background .2s;
    }
    .qty-btn:hover:not(:disabled) { background: var(--rose); color: #fff; }
    .qty-btn:disabled { opacity: .4; cursor: not-allowed; }
    .qty-val {
      width: 36px; text-align: center;
      font-size: .88rem; font-weight: 700;
      color: var(--text); border: none; outline: none;
      background: #fff; pointer-events: none;
    }

    /* Blocked qty box */
    .qty-box.qty-disabled .qty-btn { pointer-events: none; opacity: .35; }
    .qty-box.qty-disabled .qty-val  { color: #bbb; }

    .remove-btn {
      background: none; border: none;
      color: #c0a0a8; font-size: .8rem;
      cursor: pointer; padding: 4px 8px;
      border-radius: 8px; transition: color .2s, background .2s;
    }
    .remove-btn:hover { color: #e05050; background: #fde8e8; }

    /* ── EMPTY STATE ── */
    .empty-cart {
      padding: 70px 20px; text-align: center; color: var(--muted);
    }
    .empty-cart .ec-icon { font-size: 3.5rem; margin-bottom: 16px; }
    .empty-cart h3 {
      font-family: 'Playfair Display', serif;
      font-size: 1.5rem; color: var(--rose); margin-bottom: 8px;
    }
    .empty-cart a {
  display: inline-block; margin-top: 18px;
  padding: 11px 28px; border-radius: 12px;
  background: var(--rose-dk); color: #fff;
  font-weight: 700; font-size: .88rem;
  transition: background .2s;
  text-decoration: none !important;
}
    .empty-cart a:hover { background: var(--rose); }

    /* ── ORDER SUMMARY ── */
    .summary-body { padding: 20px 22px; }
    .summary-row {
      display: flex; justify-content: space-between; align-items: center;
      font-size: .86rem; color: #6b4c4c;
      padding: 6px 0;
      border-bottom: 1px dashed #f5e0e5;
    }
    .summary-row:last-of-type { border-bottom: none; }
    .summary-row.savings { color: #196638; font-weight: 700; }
    .summary-total {
      display: flex; justify-content: space-between; align-items: center;
      margin-top: 14px; padding-top: 14px;
      border-top: 2px solid var(--border);
    }
    .summary-total span:first-child {
      font-weight: 700; font-size: .92rem; color: var(--text);
    }
    .summary-total .total-price {
      font-family: 'Playfair Display', serif;
      font-size: 1.4rem; font-weight: 900; color: var(--rose-dk);
    }

    /* CHECKOUT BUTTON */
    .checkout-btn {
      display: block; width: 100%;
      margin-top: 18px; padding: 13px;
      background: linear-gradient(135deg, #8b3a52, #d97f9a);
      color: #fff; border: none; border-radius: 14px;
      font-family: 'Lato', sans-serif;
      font-size: .92rem; font-weight: 700;
      letter-spacing: .05em; cursor: pointer;
      box-shadow: 0 4px 14px rgba(175,84,84,.3);
      transition: opacity .2s, transform .15s;
      text-align: center;
      text-decoration: none;
    }
    .checkout-btn:hover:not(:disabled) { opacity: .9; transform: translateY(-1px); }
    .checkout-btn:disabled {
      background: #ddd; color: #aaa;
      box-shadow: none; cursor: not-allowed;
      transform: none;
    }

    /* Checkout blocked notice */
    .checkout-blocked {
      margin-top: 12px; padding: 10px 14px;
      background: #fff5f0; border: 1.5px solid #f5c0a0;
      border-radius: 10px;
      font-size: .79rem; color: #7a3800;
      display: flex; align-items: center; gap: 8px;
    }

    .continue-link {
      display: block; text-align: center;
      margin-top: 14px; font-size: .82rem;
      color: var(--muted); transition: color .2s;
    }
    .continue-link:hover { color: var(--rose); }

    /* Savings pill */
    #savings-pill {
      margin-top: 10px; padding: 8px 12px;
      background: #e6fdf0; border-radius: 10px;
      font-size: .78rem; color: #196638; font-weight: 700;
      text-align: center;
    }

    /* TOAST */
    #toast-rack {
      position: fixed; bottom: 24px; right: 24px;
      z-index: 9999; display: flex; flex-direction: column; gap: 8px;
      pointer-events: none;
    }
    .toast-pill {
      background: var(--rose-dk); color: #fff;
      padding: 12px 20px; border-radius: 50px;
      font-size: .83rem; font-weight: 600;
      box-shadow: 0 16px 48px rgba(194,96,122,.22);
      animation: popIn .32s cubic-bezier(.34,1.56,.64,1) both,
                 fadeAway .32s ease 2.4s both;
      white-space: nowrap;
    }
    @keyframes popIn {
      from { transform: translateY(18px) scale(.88); opacity: 0; }
      to   { transform: translateY(0) scale(1); opacity: 1; }
    }
    @keyframes fadeAway {
      to { transform: translateY(8px) scale(.92); opacity: 0; }
    }

    .swal-custom-popup { border-radius: 20px !important; padding: 32px 24px !important; }
    .swal-custom-btn   { border-radius: 12px !important; padding: 10px 36px !important; font-weight: 700 !important; }
  </style>
</head>

<body>
<%- include("../../views/partials/user/h2") %>

<!-- BREADCRUMB -->
<div class="breadcrumb-strip">
  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
    <polyline points="9 22 9 12 15 12 15 22"/>
  </svg>
  <a href="/">Home</a>
  <span class="bc-sep">›</span>
  <a href="/products">Shop</a>
  <span class="bc-sep">›</span>
  <span class="bc-active">My Cart</span>
</div>

<div class="cart-wrap">

  <!-- ════ LEFT — CART ITEMS ════ -->
  <div>
    <div class="section-card">
      <div class="section-head">
<h2><i class="fas fa-cart-shopping" style="color:var(--rose-dk);margin-right:6px;"></i> My Cart</h2>
        <span class="item-count" id="item-count-label"><%= items.length %> item<%= items.length !== 1 ? 's' : '' %></span>
      </div>

      <!-- Out-of-stock warning banner -->
      <% if (hasOutOfStock) { %>
        <div class="oos-banner" id="oos-banner">
          <i class="fas fa-exclamation-circle"></i>
          <span>Some items are <strong>out of stock</strong> or unavailable. Remove them to proceed to checkout.</span>
        </div>
      <% } else { %>
        <div class="oos-banner" id="oos-banner" style="display:none;">
          <i class="fas fa-exclamation-circle"></i>
          <span>Some items are <strong>out of stock</strong> or unavailable. Remove them to proceed to checkout.</span>
        </div>
      <% } %>

      <% if (!items || items.length === 0) { %>
        <div class="empty-cart">
<div class="ec-icon"><i class="fas fa-cake-candles" style="color:var(--rose);"></i></div>          <h3>Your cart is empty</h3>
          <p>Looks like you haven't added anything yet.</p>
          <a href="/products">Browse Cakes</a>
        </div>
      <% } else { %>
        <% items.forEach(item => { %>
          <%
            const name       = item.productId?.productName || 'Product';
            const img        = item.productId?.productImages?.[0] || 'https://placehold.co/160x160/fde2d9/C2607A?text=';
            const variant    = item.variantId?.weight || item.variantId?.size || '';
            const price      = item.effectivePrice || item.price;
            const regular    = item.regularPrice || price;
            const disc       = item.discountPercent || 0;
            const blocked    = item.isBlocked;
            const unlisted   = !item.productId?.isListed;
            const varUnavail = item.variantUnavailable || item.variantId?.isAvailable === false;
            const oos        = item.outOfStock;
            const exceeds    = item.exceedsStock;
            /* stamp label & tag label per reason */
            const stampLabel = unlisted   ? 'Unavailable'
                             : varUnavail ? 'Unavailable'
                             : oos        ? 'Out of Stock'
                             : null;
          %>
          <div class="cart-item <%= blocked ? 'item-blocked' : '' %>"
               id="cart-item-<%= item._id %>">

            <!-- Image -->
            <div class="item-img">
              <img src="<%= img %>" alt="<%= name %>">
              <% if (stampLabel) { %>
                <div class="oos-stamp"><span><%= stampLabel %></span></div>
              <% } %>
            </div>

            <!-- Details -->
            <div class="item-details">
              <div class="item-name"><%= name %></div>
              <% if (variant) { %>
                <div class="item-variant"><i class="fas fa-weight-scale" style="font-size:.6rem;margin-right:3px;"></i><%= variant %></div>
              <% } %>

              <!-- Stock / availability tag -->
              <% if (unlisted) { %>
                <span class="stock-tag oos"><i class="fas fa-ban"></i> Product Unavailable</span>
              <% } else if (varUnavail) { %>
                <span class="stock-tag oos"><i class="fas fa-ban"></i> Option Unavailable</span>
              <% } else if (oos) { %>
                <span class="stock-tag oos"><i class="fas fa-ban"></i> Out of Stock</span>
              <% } else if (exceeds) { %>
                <span class="stock-tag exceeds"><i class="fas fa-exclamation-triangle"></i> Only <%= item.totalStock %> left — reduce quantity</span>
              <% } %>

              <!-- Pricing -->
              <div class="item-pricing">
                <span class="item-price-now">₹<%= price.toLocaleString('en-IN') %></span>
                <% if (regular > price) { %>
                  <span class="item-price-old">₹<%= regular.toLocaleString('en-IN') %></span>
                <% } %>
              </div>

              <!-- Qty + Remove -->
              <div class="item-footer">
                <div class="qty-box <%= blocked ? 'qty-disabled' : '' %>">
                  <button class="qty-btn"
                          onclick="changeQty('<%= item._id %>', -1)"
                          <%= blocked ? 'disabled' : '' %>>
                    <i class="fas fa-minus" style="font-size:.65rem;"></i>
                  </button>
                  <span class="qty-val" id="qty-<%= item._id %>"><%= item.quantity %></span>
                  <button class="qty-btn"
                          onclick="changeQty('<%= item._id %>', 1)"
                          <%= blocked ? 'disabled' : '' %>>
                    <i class="fas fa-plus" style="font-size:.65rem;"></i>
                  </button>
                </div>
                <button class="remove-btn" onclick="removeItem('<%= item._id %>')">
                  <i class="fas fa-trash-alt"></i> Remove
                </button>
              </div>

            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>

  <!-- ════ RIGHT — ORDER SUMMARY ════ -->
  <div>
    <div class="section-card">
      <div class="section-head">
        <h2>Order Summary</h2>
      </div>
      <div class="summary-body">

        <%
          const validItems    = items.filter(i => !i.isBlocked);
          const subtotal      = validItems.reduce((s, i) => s + (i.regularPrice || i.price) * i.quantity, 0);
          const discountTotal = validItems.reduce((s, i) => s + ((i.regularPrice || i.price) - (i.effectivePrice || i.price)) * i.quantity, 0);
        %>

        <div class="summary-row" id="subtotal-row">
          <span>Subtotal (<span id="valid-item-count"><%= validItems.length %></span> item<span id="valid-item-suffix"><%= validItems.length !== 1 ? 's' : '' %></span>)</span>
          <span id="subtotal-val">₹<%= subtotal.toLocaleString('en-IN') %></span>
        </div>

        <!-- FIX 1: savings row is always in DOM, shown/hidden dynamically -->
        <div class="summary-row savings" id="savings-row" style="<%= discountTotal > 0 ? '' : 'display:none;' %>">
          <span><i class="fas fa-tag" style="margin-right:4px;"></i> Offer Savings</span>
          <span id="savings-val">−₹<%= discountTotal.toLocaleString('en-IN') %></span>
        </div>

        <div class="summary-row">
          <span>Delivery</span>
          <span style="color:#196638;font-weight:700;">FREE</span>
        </div>

        <div class="summary-total">
          <span>Total</span>
          <span class="total-price" id="total-price-val">₹<%= total.toLocaleString('en-IN') %></span>
        </div>

      <div id="savings-pill" style="<%= savings > 0 ? '' : 'display:none;' %>">
  <i class="fas fa-party-horn" style="margin-right:5px;"></i> You save <span id="savings-pill-val">₹<%= savings.toLocaleString('en-IN') %></span> on this order!
</div>

        <!-- Checkout button: always a button, JS validates cart on click before navigating -->
        <button
          class="checkout-btn"
          id="checkout-btn"
          onclick="handleCheckout()"
          <%= items.length === 0 ? 'disabled' : '' %>
        >
<i class="fas fa-lock" style="margin-right:6px;"></i> Proceed to Checkout        </button>

        <!-- Shown when server-side render already knows items are blocked -->
        <div class="checkout-blocked" id="checkout-blocked-msg"
             style="<%= hasOutOfStock ? '' : 'display:none;' %>">
          <i class="fas fa-lock"></i>
          Remove out-of-stock or unavailable items to unlock checkout.
        </div>

        <a href="/products" class="continue-link">
          ← Continue Shopping
        </a>

      </div>
    </div>
  </div>

</div>

<!-- TOAST -->
<div id="toast-rack"></div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
  function swalTitle(text) {
    return `<span style="font-family:'Dancing Script',cursive;font-size:1.75rem;color:#3a1a1a;">${text}</span>`;
  }

 function toast(msg) {
  const rack = document.getElementById('toast-rack');
  const el   = document.createElement('div');
  el.className  = 'toast-pill';
  el.innerHTML  = msg;
  rack.appendChild(el);
  setTimeout(() => el.remove(), 2800);
}

  function formatINR(amount) {
    return '₹' + Number(amount).toLocaleString('en-IN');
  }

  function updateNavBadge(id, count) {
    const el = document.getElementById(id);
    if (!el) return;
    el.textContent   = count;
    el.style.display = count > 0 ? 'inline-flex' : 'none';
  }

  /* ── FIX 1 + FIX 2: Update summary panel after any cart change ── */
  function updateSummaryUI(data) {
    // Total
    const totalEl = document.getElementById('total-price-val');
    if (totalEl && typeof data.total !== 'undefined') {
      totalEl.textContent = formatINR(data.total);
    }

    // Subtotal
    const subtotalEl = document.getElementById('subtotal-val');
    if (subtotalEl && typeof data.subtotal !== 'undefined') {
      subtotalEl.textContent = formatINR(data.subtotal);
    }

    // Savings row
    const savingsRowEl  = document.getElementById('savings-row');
    const savingsValEl  = document.getElementById('savings-val');
    const savingsPillEl = document.getElementById('savings-pill');
    const savingsPillValEl = document.getElementById('savings-pill-val');

    if (savingsRowEl && savingsValEl && typeof data.savings !== 'undefined') {
      if (data.savings > 0) {
        savingsValEl.textContent = '−' + formatINR(data.savings);
        savingsRowEl.style.display = '';
      } else {
        savingsRowEl.style.display = 'none';
      }
    }
    if (savingsPillEl && savingsPillValEl && typeof data.savings !== 'undefined') {
      if (data.savings > 0) {
        savingsPillValEl.textContent = formatINR(data.savings);
        savingsPillEl.style.display  = '';
      } else {
        savingsPillEl.style.display = 'none';
      }
    }

    // Cart count badge
    if (typeof data.cartCount !== 'undefined') {
      updateNavBadge('cart-count', data.cartCount);
    }

    // Update checkout button + blocked message based on hasBlocked flag
    if (typeof data.hasBlocked !== 'undefined') {
      const checkoutBtn = document.getElementById('checkout-btn');
      const blockedMsg  = document.getElementById('checkout-blocked-msg');
      const oosBanner   = document.getElementById('oos-banner');

      if (data.hasBlocked) {
        if (checkoutBtn) checkoutBtn.disabled = true;
        if (blockedMsg)  blockedMsg.style.display = '';
        if (oosBanner)   oosBanner.style.display  = '';
      } else {
        if (checkoutBtn) checkoutBtn.disabled = false;
        if (blockedMsg)  blockedMsg.style.display = 'none';
        if (oosBanner)   oosBanner.style.display  = 'none';
      }
    }
  }

  /* ── HANDLE CHECKOUT CLICK — validate cart with server first ─────────────── */
  async function handleCheckout() {
    const btn = document.getElementById('checkout-btn');
    const originalHTML = btn.innerHTML;

    // Show loading state
    btn.disabled  = true;
    btn.innerHTML = '<i class="fas fa-spinner fa-spin" style="margin-right:6px;"></i> Checking...';

    try {
      const res  = await fetch('/cart/validate', { method: 'GET' });
      const data = await res.json();

      if (data.success) {
        // All items valid — navigate to checkout
        window.location.href = '/checkout';
        return;
      }

      // Restore button
      btn.disabled  = false;
      btn.innerHTML = originalHTML;

      if (data.redirectUrl) {
        window.location.href = data.redirectUrl;
        return;
      }

      // Show blocked items alert
      Swal.fire({
        icon:             'warning',
        iconColor:        '#e07040',
        title:            swalTitle('Cart Has Unavailable Items'),
        html:             `<p style="color:#6b4c4c;font-size:.9rem;margin:0;">${data.message || 'Please remove unavailable items before checkout.'}</p>`,
        confirmButtonText: 'OK, I\'ll review my cart',
        confirmButtonColor: '#8b3a52',
        customClass: { popup: 'swal-custom-popup', confirmButton: 'swal-custom-btn' }
      });

      // Show the blocked message banner and OOS banner
      const blockedMsg = document.getElementById('checkout-blocked-msg');
      const oosBanner  = document.getElementById('oos-banner');
      if (blockedMsg) blockedMsg.style.display = '';
      if (oosBanner)  oosBanner.style.display  = '';

    } catch {
      btn.disabled  = false;
      btn.innerHTML = originalHTML;
      toast('⚠️ Network error. Please try again.');
    }
  }

  /* ── CHANGE QTY ─────────────────────────────────────────────────────────── */
  async function changeQty(itemId, delta) {
    const qtyEl  = document.getElementById('qty-' + itemId);
    const newQty = Number(qtyEl.textContent) + delta;

    if (newQty < 1) { removeItem(itemId); return; }

    try {
      const res  = await fetch('/cart/update', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ itemId, quantity: newQty })
      });
      const data = await res.json();

      if (!data.success) {
        Swal.fire({
          icon:  'warning',
          iconColor: '#c97a4a',
          title: swalTitle('Cannot Update'),
          html:  `<p style="color:#6b4c4c;font-size:.92rem;margin:0;">${data.message || 'Could not update quantity.'}</p>`,
          confirmButtonText:  'OK',
          confirmButtonColor: '#8b3a52',
          customClass: { popup: 'swal-custom-popup', confirmButton: 'swal-custom-btn' }
        });
        return;
      }

      // Update qty display
      qtyEl.textContent = newQty;

      // FIX 1 + FIX 2: update all summary figures and checkout state
      updateSummaryUI(data);

toast('<i class="fas fa-check-circle"></i> Quantity updated');
    } catch {
      toast('⚠️ Network error. Please try again.');
    }
  }

  /* ── REMOVE ITEM ────────────────────────────────────────────────────────── */
  async function removeItem(itemId) {
    const confirmed = await Swal.fire({
      icon:  'warning',
      iconColor: '#c97a4a',
      title: swalTitle('Remove Item?'),
      html:  '<p style="color:#6b4c4c;font-size:.92rem;margin:0;">Are you sure you want to remove this item from your cart?</p>',
      showCancelButton:   true,
      confirmButtonText:  'Yes, Remove',
      cancelButtonText:   'Keep it',
      confirmButtonColor: '#8b3a52',
      cancelButtonColor:  '#d6c0bc',
      customClass: { popup: 'swal-custom-popup', confirmButton: 'swal-custom-btn' }
    });

    if (!confirmed.isConfirmed) return;

    try {
      const res  = await fetch('/cart/remove', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ itemId })
      });
      const data = await res.json();

      if (!data.success) {toast('<i class="fas fa-triangle-exclamation"></i> Could not remove item.'); return; }

      // Remove row from DOM
      const row = document.getElementById('cart-item-' + itemId);
      if (row) {
        row.style.transition = 'opacity .3s, transform .3s';
        row.style.opacity    = '0';
        row.style.transform  = 'translateX(20px)';
        setTimeout(() => {
          row.remove();
          // FIX 1 + FIX 2: update summary after DOM removal
          updateSummaryUI(data);
        }, 320);
      } else {
        updateSummaryUI(data);
      }

toast('<i class="fas fa-trash-alt"></i> Item removed from cart');
    } catch {
toast('<i class="fas fa-triangle-exclamation"></i> Network error. Please try again.');    }
  }
</script>

</body>
</html>
