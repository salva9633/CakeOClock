<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>My Cart – Cake O'Clock</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
  <style>
    :root{
      --rose:#AF5454;--rose-dk:#8c3535;--rose-lt:#f8ece8;
      --cream:#fdf8f5;--border:#edd8d0;--ink:#2b1515;
      --muted:#9a7070;--white:#fff;--r:16px;
      --sh:0 4px 24px rgba(175,84,84,.10);
      --sh-h:0 12px 36px rgba(175,84,84,.18);
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Lato',sans-serif;background:var(--cream);color:var(--ink)}
    a{text-decoration:none;color:inherit}

    .bc{background:var(--white);border-bottom:1px solid var(--border);padding:13px 40px;
      font-size:.78rem;color:var(--muted);display:flex;align-items:center;gap:6px}
    .bc a{color:var(--muted);transition:color .2s}.bc a:hover{color:var(--rose)}
    .bc .sep{color:var(--border)}.bc .cur{color:var(--rose);font-weight:700}

    .cart-page{max-width:1200px;margin:40px auto 80px;padding:0 24px;
      display:grid;grid-template-columns:1fr 330px;gap:28px;align-items:start}

    .page-title{font-family:'Playfair Display',serif;font-size:2rem;font-weight:900;
      color:var(--rose);margin-bottom:24px;grid-column:1/-1}

    .items-col{display:flex;flex-direction:column;gap:16px}

    .ci{background:var(--white);border-radius:var(--r);box-shadow:var(--sh);
      display:flex;align-items:center;gap:16px;padding:16px;
      transition:box-shadow .3s,transform .2s;
      animation:slideIn .4s ease both}
    .ci:hover{box-shadow:var(--sh-h);transform:translateX(3px)}
    @keyframes slideIn{from{opacity:0;transform:translateX(-18px)}to{opacity:1;transform:translateX(0)}}
    .ci:nth-child(2){animation-delay:.07s}.ci:nth-child(3){animation-delay:.14s}

    .ci-img{width:90px;height:90px;border-radius:12px;object-fit:cover;flex-shrink:0;background:var(--rose-lt)}

    .ci-info{flex:1;min-width:0}
    .ci-name{font-family:'Playfair Display',serif;font-size:.97rem;font-weight:700;
      color:var(--ink);margin-bottom:3px;
      display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
    .ci-name a:hover{color:var(--rose)}
    .ci-variant{font-size:.74rem;color:var(--muted);margin-bottom:5px}
    .ci-unit{font-size:.8rem;color:var(--muted)}
    .ci-unit strong{color:var(--rose)}

    .qty-row{display:flex;align-items:center;margin-top:10px;
      border:1.5px solid var(--border);border-radius:10px;overflow:hidden;width:fit-content}
    .qty-btn{width:32px;height:32px;background:var(--rose-lt);border:none;cursor:pointer;
      font-size:1rem;font-weight:700;color:var(--rose);
      display:flex;align-items:center;justify-content:center;transition:background .2s,color .2s}
    .qty-btn:hover{background:var(--rose);color:#fff}
    .qty-val{width:40px;height:32px;border:none;
      border-left:1.5px solid var(--border);border-right:1.5px solid var(--border);
      background:var(--white);text-align:center;font-family:'Lato',sans-serif;
      font-size:.88rem;font-weight:700;color:var(--ink);outline:none}

    .ci-sub{font-family:'Playfair Display',serif;font-size:1.05rem;font-weight:900;
      color:var(--rose);white-space:nowrap;flex-shrink:0}

    .rm-ci{background:none;border:none;cursor:pointer;color:var(--muted);
      padding:4px;border-radius:8px;transition:color .2s,background .2s;flex-shrink:0}
    .rm-ci:hover{color:var(--rose-dk);background:var(--rose-lt)}
    .rm-ci svg{width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:2;
      stroke-linecap:round;stroke-linejoin:round}

    .cshop{display:inline-flex;align-items:center;gap:7px;margin-top:8px;
      padding:10px 20px;border:2px solid var(--rose);border-radius:30px;
      font-family:'Lato',sans-serif;font-size:.83rem;font-weight:700;
      color:var(--rose);transition:background .2s}
    .cshop:hover{background:rgba(175,84,84,.07);color:var(--rose)}

    .summary{background:var(--white);border-radius:var(--r);
      box-shadow:var(--sh);padding:28px 24px;position:sticky;top:90px}
    .sum-title{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:900;
      color:var(--ink);margin-bottom:18px;padding-bottom:14px;
      border-bottom:1px solid var(--border)}
    .sum-row{display:flex;justify-content:space-between;align-items:center;
      padding:8px 0;font-size:.87rem;color:var(--muted)}
    .sum-row.total{font-size:1rem;font-weight:700;color:var(--ink);
      border-top:1.5px solid var(--border);margin-top:8px;padding-top:14px}
    .sum-row.total .sv{font-family:'Playfair Display',serif;font-size:1.2rem;
      font-weight:900;color:var(--rose)}
    .savings-tag{background:rgba(175,84,84,.08);border-radius:10px;padding:10px 14px;
      margin:14px 0;font-size:.78rem;color:var(--rose);font-weight:600;
      display:flex;align-items:center;gap:8px}

    .checkout-btn{width:100%;padding:14px;background:var(--rose);color:#fff;
      border:none;border-radius:13px;font-family:'Lato',sans-serif;
      font-size:.9rem;font-weight:700;letter-spacing:.06em;cursor:pointer;
      margin-top:18px;display:flex;align-items:center;justify-content:center;gap:9px;
      transition:background .2s,transform .15s,box-shadow .2s;
      box-shadow:0 6px 20px rgba(175,84,84,.32)}
    .checkout-btn:hover{background:var(--rose-dk);transform:translateY(-2px);
      box-shadow:0 10px 28px rgba(175,84,84,.38)}

    .empty-wrap{text-align:center;padding:100px 20px;grid-column:1/-1}
    .empty-wrap .ei{font-size:4rem;display:block;margin-bottom:18px;
      animation:pulse 2s ease-in-out infinite}
    @keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.12)}}
    .empty-wrap h2{font-family:'Playfair Display',serif;font-size:1.8rem;color:var(--rose);margin-bottom:10px}
    .empty-wrap p{font-size:.9rem;color:var(--muted);margin-bottom:28px}
    .sbtn{display:inline-flex;align-items:center;gap:8px;padding:13px 28px;
      background:var(--rose);color:#fff;border:none;border-radius:30px;
      font-family:'Lato',sans-serif;font-size:.88rem;font-weight:700;
      cursor:pointer;box-shadow:0 6px 20px rgba(175,84,84,.3);
      transition:background .2s,transform .15s}
    .sbtn:hover{background:var(--rose-dk);transform:translateY(-1px);color:#fff}

    #trk{position:fixed;bottom:24px;right:24px;z-index:9999;
      display:flex;flex-direction:column;gap:8px;pointer-events:none}
    .tpill{background:var(--rose-dk);color:#fff;padding:12px 20px;border-radius:50px;
      font-size:.83rem;font-weight:600;box-shadow:0 8px 24px rgba(175,84,84,.28);
      animation:popIn .3s cubic-bezier(.34,1.56,.64,1) both,fadeOut .35s ease 2.3s both}
    @keyframes popIn{from{transform:translateY(16px) scale(.85);opacity:0}to{transform:translateY(0) scale(1);opacity:1}}
    @keyframes fadeOut{to{transform:translateY(10px) scale(.9);opacity:0}}

    @media(max-width:860px){
      .cart-page{grid-template-columns:1fr}
      .summary{position:static}.bc{padding:11px 16px}
      .cart-page{padding:0 12px 40px}
    }
  </style>
</head>
<body>

<%- include("../partials/user/h2") %>

<div class="bc">
  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
  <a href="/">Home</a><span class="sep">›</span>
  <span class="cur">My Cart</span>
</div>

<%
  let subtotal = 0;
  let savings  = 0;
  if (items && items.length > 0) {
    items.forEach(item => {
      subtotal += item.price * item.quantity;
      if (item.variantId && item.variantId.regularPrice) {
        savings += (item.variantId.regularPrice - item.price) * item.quantity;
      }
    });
  }
%>

<div class="cart-page">

  <h1 class="page-title">My Cart</h1>

  <% if (!items || items.length === 0) { %>

    <div class="empty-wrap">
      <span class="ei">🛒</span>
      <h2>Your cart is empty</h2>
      <p>Looks like you haven't added any cakes yet!</p>
      <a href="/products" class="sbtn">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        Shop Now
      </a>
    </div>

  <% } else { %>

    <!-- ── ITEMS ── -->
    <div class="items-col">
      <% items.forEach(item => {
           const product = item.productId;
           const variant = item.variantId;
           const img     = product?.productImages?.[0];
      %>
        <div class="ci" id="ci-<%= item._id %>">
          <img class="ci-img"
            src="<%= img || 'https://placehold.co/90x90/fde2d9/AF5454?text=🎂' %>"
            alt="<%= product?.productName %>">

          <div class="ci-info">
            <div class="ci-name">
              <a href="/product/<%= product?._id %>"><%= product?.productName %></a>
            </div>
            <% if (variant && variant.weight) { %>
              <div class="ci-variant">Weight: <%= variant.weight %></div>
            <% } %>
            <div class="ci-unit">Unit price: <strong>₹<%= item.price %></strong></div>
            <% if (item.outOfStock) { %>
              <div style="font-size:.75rem;color:#e05555;font-weight:600;margin-top:4px">
                ⚠️ Out of stock — please remove this item
              </div>
            <% } else if (item.exceedsStock) { %>
              <div style="font-size:.75rem;color:#e05555;font-weight:600;margin-top:4px">
                ⚠️ Only <%= item.totalStock %> left in stock
              </div>
            <% } %>
            <div class="qty-row">
              <button class="qty-btn" onclick="changeQty('<%= item._id %>', -1)">−</button>
              <input class="qty-val" id="qty-<%= item._id %>" type="text" value="<%= item.quantity %>" readonly>
              <button class="qty-btn" onclick="changeQty('<%= item._id %>', 1)">+</button>
            </div>
          </div>

          <div class="ci-sub" id="sub-<%= item._id %>">₹<%= item.price * item.quantity %></div>

          <button class="rm-ci" onclick="removeItem('<%= item._id %>','<%= product?.productName %>')" title="Remove">
            <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
          </button>
        </div>
      <% }) %>

      <a href="/products" class="cshop">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><polyline points="15 18 9 12 15 6"/></svg>
        Continue Shopping
      </a>
    </div>

    <!-- ── SUMMARY ── -->
    <div class="summary">
      <div class="sum-title">Cart Summary</div>
      <div class="sum-row">
        <span>Subtotal (<%= items.length %> item<%= items.length!==1?'s':'' %>)</span>
        <span>₹<%= subtotal %></span>
      </div>
      <div class="sum-row">
        <span>Delivery</span>
        <span style="color:#27ae60;font-weight:700">FREE</span>
      </div>
      <% if (savings > 0) { %>
        <div class="savings-tag">🎉 You're saving ₹<%= savings %> on this order!</div>
      <% } %>
      <div class="sum-row total">
        <span>Total</span>
        <span class="sv" id="grand-total">₹<%= subtotal %></span>
      </div>

      <% if (hasOutOfStock) { %>
        <button class="checkout-btn" disabled
          style="background:#ccc;cursor:not-allowed;box-shadow:none;transform:none"
          title="Remove out-of-stock items to proceed">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          Proceed to Checkout
        </button>
        <p style="text-align:center;font-size:.75rem;color:#e05555;margin-top:8px;font-weight:600">
          ⚠️ Remove out-of-stock items to proceed
        </p>
      <% } else { %>
        <button class="checkout-btn" onclick="window.location.href='/checkout'">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          Proceed to Checkout
        </button>
      <% } %>
      <p style="text-align:center;font-size:.72rem;color:var(--muted);margin-top:13px">
        🔒 Secure checkout · Free delivery
      </p>
    </div>

  <% } %>
</div>

<div id="trk"></div>

<!-- ── SCRIPTS: Bootstrap → SweetAlert2 → your code ── -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
  const MAX_QTY = 5; // must match cartController.js MAX_QTY = 5

  // unit prices map for subtotal recalculation
  const unitPrices = {
    <% if (items && items.length > 0) { items.forEach((item, i) => { %>
      '<%= item._id %>': <%= item.price %><%= i < items.length - 1 ? ',' : '' %>
    <% }) } %>
  };

  /* ════════════════════════════
     CHANGE QUANTITY
  ════════════════════════════ */
  function changeQty(itemId, delta) {
    const inp     = document.getElementById('qty-' + itemId);
    const current = parseInt(inp.value);
    const newQ    = current + delta;

    // Minimum limit — show Swal, do NOT go below 1
    if (newQ < 1) {
      Swal.fire({
        icon: 'info',
        title: 'Minimum Quantity',
        text: 'Minimum 1 item is required. Use the delete button to remove the item.',
        confirmButtonColor: '#AF5454'
      });
      return;
    }

    // Maximum limit — show Swal, do NOT go above MAX_QTY
    if (newQ > MAX_QTY) {
      Swal.fire({
        icon: 'warning',
        title: 'Maximum Quantity Reached',
        text: 'You can only add a maximum of ' + MAX_QTY + ' of each item.',
        confirmButtonColor: '#AF5454'
      });
      return;
    }

    // Send update to server
    fetch('/cart/update', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ itemId, quantity: newQ })
    })
    .then(r => r.json())
    .then(d => {
      if (!d.success) {
        // Server-side error e.g. stock exceeded
        Swal.fire({
          icon: 'warning',
          title: 'Cannot Update',
          text: d.message,
          confirmButtonColor: '#AF5454'
        });
        return;
      }
      // Update UI
      inp.value = newQ;
      const sub  = document.getElementById('sub-' + itemId);
      const unit = unitPrices[itemId] || 0;
      if (sub) sub.textContent = '₹' + (unit * newQ);
      recalcTotal();
    })
    .catch(() => {
      Swal.fire({
        icon: 'error',
        title: 'Network Error',
        text: 'Could not update quantity. Please try again.',
        confirmButtonColor: '#AF5454'
      });
    });
  }

  /* ════════════════════════════
     RECALCULATE TOTAL
  ════════════════════════════ */
  function recalcTotal() {
    let t = 0;
    document.querySelectorAll('[id^="sub-"]').forEach(el => {
      t += parseInt(el.textContent.replace('₹', '')) || 0;
    });
    const gt = document.getElementById('grand-total');
    if (gt) gt.textContent = '₹' + t;
  }

  /* ════════════════════════════
     REMOVE ITEM
  ════════════════════════════ */
  function removeItem(itemId, name) {
    Swal.fire({
      title: 'Remove Item?',
      text: 'Remove "' + name + '" from your cart?',
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#AF5454',
      cancelButtonColor: '#9a7070',
      confirmButtonText: 'Yes, remove it',
      cancelButtonText: 'Keep it'
    }).then((result) => {
      if (!result.isConfirmed) return;

      fetch('/cart/remove', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ itemId })
      })
      .then(r => r.json())
      .then(d => {
        if (!d.success) return;
        const el = document.getElementById('ci-' + itemId);
        if (el) {
          el.style.transition = 'all .35s ease';
          el.style.transform  = 'translateX(-24px)';
          el.style.opacity    = '0';
          setTimeout(() => { el.remove(); recalcTotal(); }, 370);
        }
        toast('🗑️ "' + name + '" removed');
      })
      .catch(() => {
        Swal.fire({
          icon: 'error',
          title: 'Network Error',
          text: 'Could not remove item. Please try again.',
          confirmButtonColor: '#AF5454'
        });
      });
    });
  }

  /* ════════════════════════════
     TOAST
  ════════════════════════════ */
  function toast(msg) {
    const r  = document.getElementById('trk');
    const el = document.createElement('div');
    el.className   = 'tpill';
    el.textContent = msg;
    r.appendChild(el);
    setTimeout(() => el.remove(), 2800);
  }
</script>
</body>
</html>
