<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>My Wishlist – Cake O'Clock</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,900;1,700&family=Lato:wght@300;400;700&family=Dancing+Script:wght@600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <style>
    :root {
      --rose:      #C2607A;
      --rose-dk:   #8B3A52;
      --rose-lt:   #fdf0f3;
      --rose-pale: #fce8ed;
      --cream:     #fdf6f8;
      --border:    #f0d4db;
      --ink:       #2d1a20;
      --muted:     #9a7070;
      --white:     #fff;
      --sh:        0 4px 24px rgba(194,96,122,.10);
      --sh-h:      0 16px 48px rgba(194,96,122,.22);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Lato', sans-serif;
      background: var(--cream);
      color: var(--ink);
      overflow-x: hidden;
    }
    a { text-decoration: none; color: inherit; }

    /* ── ANIMATED BG BLOBS ── */
    .bg-blobs {
      position: fixed; inset: 0; z-index: 0; pointer-events: none; overflow: hidden;
    }
    .blob {
      position: absolute; border-radius: 50%;
      filter: blur(80px); opacity: .13;
      animation: blobFloat 12s ease-in-out infinite;
    }
    .blob-1 { width: 500px; height: 500px; background: var(--rose); top: -120px; left: -100px; animation-delay: 0s; }
    .blob-2 { width: 350px; height: 350px; background: #d97f9a; bottom: 100px; right: -80px; animation-delay: 4s; }
    .blob-3 { width: 280px; height: 280px; background: #e8a0b0; top: 40%; left: 55%; animation-delay: 8s; }
    @keyframes blobFloat {
      0%, 100% { transform: translate(0, 0) scale(1); }
      33%       { transform: translate(30px, -40px) scale(1.05); }
      66%       { transform: translate(-20px, 20px) scale(.96); }
    }

    /* ── BREADCRUMB ── */
    .bc {
      position: relative; z-index: 1;
      background: rgba(255,255,255,.88);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--border);
      padding: 12px 40px;
      display: flex; align-items: center; gap: 6px;
      font-size: .76rem; color: var(--muted);
    }
    .bc a { color: var(--muted); transition: color .2s; }
    .bc a:hover { color: var(--rose); }
    .bc .sep { color: var(--border); }
    .bc .cur { color: var(--rose); font-weight: 700; }

    /* ── PAGE ── */
    .page { position: relative; z-index: 1; max-width: 1200px; margin: 0 auto 80px; padding: 0 24px; }

    /* ── PAGE HERO HEADER ── */
    .page-hero {
      text-align: center;
      padding: 52px 20px 40px;
      position: relative;
    }
    .hero-eyebrow {
      font-family: 'Dancing Script', cursive;
      font-size: 1.15rem;
      color: var(--rose);
      margin-bottom: 6px;
      opacity: 0;
      animation: fadeSlideDown .6s ease .1s forwards;
    }
    .hero-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 5vw, 3rem);
      font-weight: 900;
      color: var(--rose-dk);
      line-height: 1.1;
      opacity: 0;
      animation: fadeSlideDown .6s ease .2s forwards;
    }
    .hero-title span {
      color: var(--rose);
      font-style: italic;
    }
    .hero-sub {
      margin-top: 10px;
      font-size: .88rem;
      color: var(--muted);
      opacity: 0;
      animation: fadeSlideDown .6s ease .3s forwards;
    }
    .hero-divider {
      display: flex; align-items: center; justify-content: center; gap: 14px;
      margin-top: 22px;
      opacity: 0;
      animation: fadeSlideDown .5s ease .4s forwards;
    }
    .hero-divider::before,
    .hero-divider::after {
      content: '';
      height: 1px; width: 80px;
      background: linear-gradient(to right, transparent, var(--border));
    }
    .hero-divider::after { background: linear-gradient(to left, transparent, var(--border)); }
    .hero-divider .diamond {
      width: 7px; height: 7px;
      background: var(--rose);
      transform: rotate(45deg);
      border-radius: 1px;
    }

    @keyframes fadeSlideDown {
      from { opacity: 0; transform: translateY(-14px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── ITEM COUNT CHIP ── */
    .count-chip {
      display: inline-flex; align-items: center; gap: 6px;
      background: var(--rose-pale);
      border: 1px solid var(--border);
      border-radius: 30px;
      padding: 5px 14px;
      font-size: .78rem; font-weight: 700;
      color: var(--rose-dk);
      margin-top: 14px;
      opacity: 0;
      animation: fadeSlideDown .5s ease .5s forwards;
    }
    .count-chip i { font-size: .7rem; }

    /* ── GRID ── */
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 24px;
    }

    /* ── WISHLIST CARD ── */
    .wc {
      background: var(--white);
      border-radius: 20px;
      box-shadow: var(--sh);
      border: 1px solid rgba(240,212,219,.5);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      transition: box-shadow .35s, transform .35s;
      opacity: 0;
      transform: translateY(28px);
      animation: cardRise .55s cubic-bezier(.22,1,.36,1) forwards;
    }
    .wc:hover {
      box-shadow: var(--sh-h);
      transform: translateY(-6px);
    }

    @keyframes cardRise {
      to { opacity: 1; transform: translateY(0); }
    }
    /* stagger delays */
    .wc:nth-child(1)  { animation-delay: .05s; }
    .wc:nth-child(2)  { animation-delay: .10s; }
    .wc:nth-child(3)  { animation-delay: .15s; }
    .wc:nth-child(4)  { animation-delay: .20s; }
    .wc:nth-child(5)  { animation-delay: .25s; }
    .wc:nth-child(6)  { animation-delay: .30s; }
    .wc:nth-child(7)  { animation-delay: .35s; }
    .wc:nth-child(8)  { animation-delay: .40s; }
    .wc:nth-child(9)  { animation-delay: .45s; }
    .wc:nth-child(10) { animation-delay: .50s; }
    .wc:nth-child(11) { animation-delay: .55s; }
    .wc:nth-child(12) { animation-delay: .60s; }

    /* IMAGE ZONE */
    .wimg {
      position: relative;
      height: 215px;
      background: var(--rose-pale);
      overflow: hidden;
    }
    .wimg img {
      width: 100%; height: 100%;
      object-fit: cover;
      transition: transform .55s cubic-bezier(.22,1,.36,1);
    }
    .wc:hover .wimg img { transform: scale(1.08); }

    /* Gradient overlay on image bottom */
    .wimg::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 60px;
      background: linear-gradient(to top, rgba(43,10,20,.25), transparent);
      pointer-events: none;
    }

    /* OOS dimming */
    .wc.is-oos .wimg img {
      filter: grayscale(.4) brightness(.92);
    }
    .oos-overlay {
      position: absolute; inset: 0;
      background: rgba(255,248,250,.6);
      display: flex; align-items: center; justify-content: center;
      z-index: 2;
    }
    .oos-badge-img {
      background: rgba(255,255,255,.94);
      border: 1.5px solid var(--border);
      color: var(--rose-dk);
      font-size: .6rem; font-weight: 800;
      letter-spacing: .1em; text-transform: uppercase;
      padding: 4px 12px; border-radius: 20px;
    }

    /* REMOVE BUTTON */
    .rm-btn {
      position: absolute;
      top: 10px; left: 10px;
      width: 34px; height: 34px;
      background: rgba(255,255,255,.92);
      border: none; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer;
      box-shadow: 0 2px 10px rgba(0,0,0,.12);
      z-index: 3;
      transition: background .2s, transform .2s;
      color: var(--rose);
      font-size: .82rem;
    }
    .rm-btn:hover {
      background: var(--rose);
      color: #fff;
      transform: scale(1.14);
    }
    /* Heartbeat animation on hover */
    .rm-btn:hover i {
      animation: heartBeat .45s ease;
    }
    @keyframes heartBeat {
      0%   { transform: scale(1); }
      30%  { transform: scale(1.4); }
      60%  { transform: scale(.9); }
      100% { transform: scale(1); }
    }

    /* CARD BODY */
    .wbody {
      padding: 14px 16px 18px;
      display: flex; flex-direction: column; flex: 1;
    }

    .wname {
      font-family: 'Playfair Display', serif;
      font-size: .97rem; font-weight: 700;
      color: var(--ink); line-height: 1.3;
      margin-bottom: 4px;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      transition: color .2s;
    }
    .wc:hover .wname { color: var(--rose); }

    .wdesc {
      font-size: .76rem; color: var(--muted);
      line-height: 1.5; margin-bottom: 11px; flex: 1;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    /* PRICING */
    .wpr {
      display: flex; align-items: baseline; gap: 8px;
      margin-bottom: 13px;
    }
    .wpnow {
      font-family: 'Playfair Display', serif;
      font-size: 1.1rem; font-weight: 900;
      color: var(--rose);
    }
    .wpold {
      font-size: .77rem; color: #c0a0a8;
      text-decoration: line-through;
    }
    .wdisc {
      font-size: .6rem; font-weight: 800;
      background: #e6fdf0; color: #196638;
      padding: 2px 7px; border-radius: 20px;
    }

    /* ADD TO CART BUTTON */
    .atcb {
      width: 100%;
      padding: 10px 14px;
      background: linear-gradient(135deg, var(--rose-dk), #d97f9a);
      color: #fff;
      border: none; border-radius: 12px;
      font-family: 'Lato', sans-serif;
      font-size: .82rem; font-weight: 700;
      letter-spacing: .05em; cursor: pointer;
      display: flex; align-items: center; justify-content: center; gap: 7px;
      transition: opacity .2s, transform .15s, box-shadow .2s;
      box-shadow: 0 4px 14px rgba(139,58,82,.28);
      position: relative;
      overflow: hidden;
    }
    .atcb::before {
      content: '';
      position: absolute; inset: 0;
      background: rgba(255,255,255,.15);
      transform: translateX(-100%) skewX(-15deg);
      transition: transform .4s ease;
    }
    .atcb:hover::before { transform: translateX(120%) skewX(-15deg); }
    .atcb:hover:not(:disabled) {
      opacity: .92;
      transform: translateY(-2px);
      box-shadow: 0 8px 22px rgba(139,58,82,.35);
    }
    .atcb:active:not(:disabled) { transform: translateY(0) scale(.97); }

    .atcb.oos {
      background: #ede0e4;
      color: #b09090;
      cursor: not-allowed;
      box-shadow: none;
    }
    .atcb.oos::before { display: none; }
    .atcb.unavailable {
      background: #f5e8ea;
      color: #c09090;
      cursor: not-allowed;
      box-shadow: none;
    }

    /* ── EMPTY STATE ── */
    .empty {
      text-align: center;
      padding: 90px 20px;
    }
    .empty-heart {
      width: 90px; height: 90px;
      background: var(--rose-pale);
      border-radius: 50%;
      display: inline-flex; align-items: center; justify-content: center;
      margin-bottom: 24px;
      animation: emptyPulse 2.4s ease-in-out infinite;
    }
    .empty-heart i { font-size: 2.2rem; color: var(--rose); }
    @keyframes emptyPulse {
      0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(194,96,122,.2); }
      50%       { transform: scale(1.06); box-shadow: 0 0 0 14px rgba(194,96,122,0); }
    }
    .empty h2 {
      font-family: 'Playfair Display', serif;
      font-size: 1.9rem; color: var(--rose-dk); margin-bottom: 10px;
    }
    .empty p { font-size: .9rem; color: var(--muted); margin-bottom: 28px; }

    .obtn {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 12px 28px; border-radius: 30px;
      font-family: 'Lato', sans-serif;
      font-size: .87rem; font-weight: 700;
      letter-spacing: .05em; cursor: pointer;
      transition: background .2s, transform .15s;
    }
    .obtn.solid {
      background: linear-gradient(135deg, var(--rose-dk), var(--rose));
      color: #fff;
      box-shadow: 0 6px 20px rgba(194,96,122,.3);
      border: none;
    }
    .obtn.solid:hover { opacity: .9; transform: translateY(-2px); color: #fff; }
    .obtn.outline {
      background: transparent;
      color: var(--rose);
      border: 2px solid var(--rose);
    }
    .obtn.outline:hover { background: rgba(194,96,122,.06); }

    /* ── CONTINUE STRIP ── */
    .continue-strip {
      margin-top: 44px;
      text-align: center;
      opacity: 0;
      animation: fadeSlideDown .5s ease .8s forwards;
    }

    /* ── TOAST ── */
    #trk {
      position: fixed; bottom: 24px; right: 24px;
      z-index: 9999;
      display: flex; flex-direction: column; gap: 8px;
      pointer-events: none;
    }
    .tpill {
      background: var(--rose-dk); color: #fff;
      padding: 12px 20px; border-radius: 50px;
      font-size: .83rem; font-weight: 600;
      box-shadow: 0 8px 28px rgba(139,58,82,.3);
      animation: popIn .32s cubic-bezier(.34,1.56,.64,1) both,
                 fadeAway .32s ease 2.4s both;
      white-space: nowrap;
    }
    @keyframes popIn {
      from { transform: translateY(18px) scale(.88); opacity: 0; }
      to   { transform: translateY(0) scale(1); opacity: 1; }
    }
    @keyframes fadeAway {
      to { transform: translateY(8px) scale(.92); opacity: 0; }
    }

    /* ── SWAL CUSTOM ── */
    .swal-custom-popup { border-radius: 20px !important; padding: 32px 24px !important; }
    .swal-custom-btn   { border-radius: 12px !important; padding: 10px 36px !important; font-weight: 700 !important; }

    @media (max-width: 600px) {
      .bc { padding: 12px 16px; }
      .page { padding: 0 14px; }
      .hero-title { font-size: 1.8rem; }
    }
  </style>
</head>
<body>

<!-- Animated background blobs -->
<div class="bg-blobs">
  <div class="blob blob-1"></div>
  <div class="blob blob-2"></div>
  <div class="blob blob-3"></div>
</div>

<%- include("../partials/user/h2") %>

<!-- BREADCRUMB -->
<div class="bc">
  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2">
    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
    <polyline points="9 22 9 12 15 12 15 22"/>
  </svg>
  <a href="/">Home</a>
  <span class="sep">›</span>
  <span class="cur">My Wishlist</span>
</div>

<div class="page">

  <!-- HERO HEADER -->
  <div class="page-hero">
    <div class="hero-eyebrow">Your saved favourites</div>
    <h1 class="hero-title">My <span>Wishlist</span></h1>
    <p class="hero-sub">Every cake you've fallen for — all in one place.</p>
    <div class="hero-divider"><div class="diamond"></div></div>
    <% if (products && products.length > 0) { %>
      <div>
        <span class="count-chip">
          <i class="fas fa-heart"></i>
          <%= products.length %> item<%= products.length !== 1 ? 's' : '' %> saved
        </span>
      </div>
    <% } %>
  </div>

  <!-- EMPTY STATE -->
  <% if (!products || products.length === 0) { %>
    <div class="empty">
      <div class="empty-heart">
        <i class="far fa-heart"></i>
      </div>
      <h2>Nothing saved yet</h2>
      <p>Browse our collection and tap the heart on any cake you love.</p>
      <a href="/products" class="obtn solid">
        <i class="fas fa-store" style="font-size:.8rem;"></i>
        Browse Cakes
      </a>
    </div>

  <!-- PRODUCT GRID -->
  <% } else { %>
    <div class="grid">
      <% products.forEach(product => {
           const hasStock = !!product.startingPrice;
           const isBlocked = product.isBlocked;
           const oos = !hasStock || isBlocked;
      %>
        <div class="wc <%= oos ? 'is-oos' : '' %>" id="wc-<%= product._id %>">

          <!-- IMAGE -->
          <div class="wimg">

            <!-- Remove / heart button -->
            <button
              class="rm-btn"
              onclick="removeWish(this, '<%= product._id %>', '<%= product.variantId %>', '<%= product.productName %>')"
              title="Remove from Wishlist">
              <i class="fas fa-heart"></i>
            </button>

            <% if (oos) { %>
              <div class="oos-overlay">
                <span class="oos-badge-img">Out of Stock</span>
              </div>
            <% } %>

            <a href="/product/<%= product._id %>">
              <% if (product.productImages && product.productImages[0]) { %>
                <img src="<%= product.productImages[0] %>" alt="<%= product.productName %>" loading="lazy">
              <% } else { %>
                <img src="https://placehold.co/400x280/fde2d9/C2607A?text=🎂" alt="No image">
              <% } %>
            </a>

          </div><!-- /wimg -->

          <!-- BODY -->
          <div class="wbody">
            <a href="/product/<%= product._id %>">
              <div class="wname"><%= product.productName %></div>
            </a>
            <div class="wdesc"><%= product.description %></div>

            <!-- Pricing -->
            <div class="wpr">
              <% if (product.startingPrice) { %>
                <span class="wpnow">₹<%= product.startingPrice %></span>
                <% if (product.regularPrice > product.startingPrice) { %>
                  <span class="wpold">₹<%= product.regularPrice %></span>
                  <%
                    const discPct = Math.round(
                      (product.regularPrice - product.startingPrice) / product.regularPrice * 100
                    );
                  %>
                  <% if (discPct > 0) { %>
                    <span class="wdisc"><%= discPct %>% OFF</span>
                  <% } %>
                <% } %>
              <% } else { %>
                <span style="font-size:.78rem;color:#b09090;">Currently unavailable</span>
              <% } %>
            </div>

            <!-- CTA button -->
            <% if (isBlocked) { %>
              <button class="atcb unavailable" disabled>
                <i class="fas fa-ban" style="font-size:.75rem;"></i> Unavailable
              </button>
            <% } else if (!hasStock) { %>
              <button class="atcb oos" disabled>
                <i class="fas fa-clock" style="font-size:.75rem;"></i> Out of Stock
              </button>
            <% } else { %>
              <button
                class="atcb"
                data-id="<%= product._id %>"
                data-variant-id="<%= product.variantId %>"
                data-name="<%= product.productName %>"
                onclick="addToCart(this)">
                <i class="fas fa-shopping-bag" style="font-size:.75rem;"></i>
                Add to Cart
              </button>
            <% } %>
          </div><!-- /wbody -->

        </div><!-- /wc -->
      <% }) %>
    </div><!-- /grid -->

    <div class="continue-strip">
      <a href="/products" class="obtn outline">
        <i class="fas fa-arrow-left" style="font-size:.75rem;"></i> Continue Shopping
      </a>
    </div>
  <% } %>

</div><!-- /page -->

<div id="trk"></div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
  /* ── Swal title helper ── */
  function swalTitle(text) {
    return `<span style="font-family:'Dancing Script',cursive;font-size:1.75rem;color:#3a1a1a;">${text}</span>`;
  }

  /* ── Toast ── */
  function toast(msg) {
    const wrap = document.getElementById('trk');
    const el   = document.createElement('div');
    el.className   = 'tpill';
    el.textContent = msg;
    wrap.appendChild(el);
    setTimeout(() => el.remove(), 2800);
  }

  /* ── Remove from wishlist ── */
  function removeWish(btn, productId, variantId, name) {
    fetch('/wishlist/toggle', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ productId, variantId })
    })
    .then(r => r.json())
    .then(() => {
      const card = document.getElementById('wc-' + productId);
      if (card) {
        card.style.transition = 'all .38s cubic-bezier(.4,0,.2,1)';
        card.style.transform  = 'scale(.82) translateY(-10px)';
        card.style.opacity    = '0';
        setTimeout(() => {
          card.remove();
          if (document.querySelectorAll('.wc').length === 0) location.reload();
        }, 400);
      }
      toast('🤍 "' + name + '" removed from wishlist');
    })
    .catch(() => toast('🤍 Removed from wishlist'));
  }

  /* ── Add to cart ── */
  function addToCart(btn) {
    const productId = btn.dataset.id;
    const variantId = btn.dataset.variantId;
    const name      = btn.dataset.name;

    // Button loading state
    const original = btn.innerHTML;
    btn.disabled   = true;
    btn.innerHTML  = '<i class="fas fa-spinner fa-spin" style="font-size:.75rem;"></i> Adding…';

    fetch('/cart/add', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ productId, variantId, quantity: 1 })
    })
    .then(r => r.json())
    .then(data => {
      if (data.redirectUrl) { window.location.href = data.redirectUrl; return; }

      if (!data.success) {
        btn.disabled  = false;
        btn.innerHTML = original;
        Swal.fire({
          icon:  'error',
          iconColor: '#c97a4a',
          title: swalTitle('Cannot Add to Cart'),
          html:  `<p style="color:#6b4c4c;font-size:.92rem;margin:0;">${data.message || 'Something went wrong.'}</p>`,
          confirmButtonText:  'OK',
          confirmButtonColor: '#8B3A52',
          customClass: { popup: 'swal-custom-popup', confirmButton: 'swal-custom-btn' }
        });
        return;
      }

      toast('🛒 "' + name + '" added to cart!');

      // Animate card out after successful add
      const card = document.getElementById('wc-' + productId);
      if (card) {
        card.style.transition = 'all .38s cubic-bezier(.4,0,.2,1)';
        card.style.transform  = 'scale(.82) translateY(-10px)';
        card.style.opacity    = '0';
        setTimeout(() => {
          card.remove();
          if (document.querySelectorAll('.wc').length === 0) location.reload();
        }, 400);
      }
    })
    .catch(() => {
      btn.disabled  = false;
      btn.innerHTML = original;
      toast('⚠️ Network error. Please try again.');
    });
  }
</script>

</body>
</html>