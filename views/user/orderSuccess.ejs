<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Order Placed – Cake O'Clock</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Lato:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    :root { --rose:#AF5454; --cream:#fdf6f0; }
    body { font-family:'Lato',sans-serif; background:var(--cream); min-height:100vh; display:flex; flex-direction:column; }
    .success-wrap { flex:1; display:flex; align-items:center; justify-content:center; padding:40px 16px; }
    .card-success { background:#fff; border-radius:24px; padding:48px 40px; text-align:center; max-width:480px; width:100%; box-shadow:0 4px 30px rgba(0,0,0,.08); animation:fadeUp .5s ease both; }
    @keyframes fadeUp { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:none} }
    .tick-circle { width:90px; height:90px; background:#fff5f5; border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 24px; animation:pop .4s .2s ease both; }
    @keyframes pop { from{transform:scale(.5);opacity:0} to{transform:scale(1);opacity:1} }
    h2 { font-family:'Playfair Display',serif; font-size:1.8rem; color:#2d1f1f; margin-bottom:8px; }
    .sub { color:#7a6060; font-size:.95rem; margin-bottom:4px; }
    .order-id { font-weight:700; color:var(--rose); font-size:1.05rem; }
    .btn-primary-rose { background:var(--rose); color:#fff; border:none; border-radius:12px; padding:13px 28px; font-weight:700; font-size:.95rem; text-decoration:none; display:inline-block; transition:.2s; }
    .btn-primary-rose:hover { background:#8c3a3a; color:#fff; }
    .btn-outline-rose { border:2px solid var(--rose); color:var(--rose); border-radius:12px; padding:11px 28px; font-weight:700; font-size:.95rem; text-decoration:none; display:inline-block; background:transparent; transition:.2s; }
    .btn-outline-rose:hover { background:var(--rose); color:#fff; }
    .divider { border:none; border-top:1px solid #f0e8e8; margin:24px 0; }
    .info-row { display:flex; justify-content:space-between; font-size:.88rem; margin-bottom:6px; }
    .info-label { color:#7a6060; }
    .info-val { font-weight:600; }
  </style>
</head>
<body>

<%- include("../partials/user/h2") %>

<div class="success-wrap">
  <div class="card-success">
    <div class="tick-circle">
      <svg viewBox="0 0 48 48" width="90" height="90" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="24" cy="24" r="22" stroke="#AF5454" stroke-width="3" fill="#fff5f5"/>
        <path d="M14 25l7 7 13-14" stroke="#AF5454" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>

    <h2>Order Placed! 🎉</h2>
    <p class="sub">Thank you for your order.</p>
    <p class="sub">We're baking your happiness with love.</p>
    <div class="order-id mt-3"><%= order.orderId %></div>

    <hr class="divider">

    <div class="info-row">
      <span class="info-label">Payment</span>
      <span class="info-val"><%= order.paymentMethod === 'COD' ? 'Cash on Delivery' : order.paymentMethod %></span>
    </div>
    <div class="info-row">
      <span class="info-label">Total</span>
      <span class="info-val" style="color:var(--rose)">₹<%= order.finalTotal.toLocaleString('en-IN') %></span>
    </div>
    <div class="info-row">
      <span class="info-label">Date</span>
      <span class="info-val"><%= new Date(order.createdAt).toLocaleDateString('en-IN', {day:'numeric',month:'long',year:'numeric'}) %></span>
    </div>

    <hr class="divider">

    <div class="d-flex gap-3 justify-content-center flex-wrap">
      <a href="/orders/<%= order._id %>" class="btn-primary-rose">View Order Details</a>
      <a href="/products" class="btn-outline-rose">Continue Shopping</a>
    </div>
  </div>
</div>

<%- include("../partials/user/footer") %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
