<%- include('../partials/user/header') %>
<%- include('../partials/user/navbar') %>

<!-- ============================================================
     CAKE O'CLOCK — CONTACT US
     Same token system / motion language as the About page.
============================================================= -->

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
  :root{
    --blush:#FDF1F4;
    --cream:#FFF9F7;
    --rosegold:#C97B84;
    --choco:#3B1F29;
    --beige:#F6E8E3;
    --gold:#D9A857;
  }

  .coc-contact{ background:var(--cream); color:var(--choco); overflow:hidden; }
  .coc-contact *{ box-sizing:border-box; }
  .coc-contact h1,.coc-contact h2,.coc-contact h3{ font-family:'Playfair Display',serif; font-weight:600; letter-spacing:-0.01em; }
  .coc-contact, .coc-contact p, .coc-contact span, .coc-contact a, .coc-contact button, .coc-contact input, .coc-contact textarea, .coc-contact label{
    font-family:'Poppins',sans-serif;
  }
  .coc-wrap{ max-width:1080px; margin:0 auto; padding:0 28px; }

  .coc-reveal{ opacity:0; transform:translateY(28px); transition:opacity .9s cubic-bezier(.2,.7,.2,1), transform .9s cubic-bezier(.2,.7,.2,1); }
  .coc-reveal.is-in{ opacity:1; transform:translateY(0); }
  @media (prefers-reduced-motion: reduce){ .coc-reveal{ transition:none; opacity:1; transform:none; } .coc-float-icon{ animation:none !important; } }

  .coc-scallop{ display:block; width:100%; height:34px; margin-top:-1px; }

  /* ---------- hero ---------- */
  .coc-c-hero{
    position:relative; padding:110px 0 80px; text-align:center; overflow:hidden;
    background:
      radial-gradient(55% 50% at 85% 10%, rgba(201,123,132,.16), transparent 60%),
      radial-gradient(45% 40% at 8% 90%, rgba(217,168,87,.14), transparent 60%),
      var(--blush);
  }
  .coc-eyebrow{
    display:inline-flex; align-items:center; gap:8px; font-size:.74rem; letter-spacing:.22em;
    font-weight:600; color:var(--rosegold); text-transform:uppercase; margin-bottom:18px; justify-content:center;
  }
  .coc-eyebrow svg{ width:14px; height:14px; }
  .coc-c-hero h1{ font-size:clamp(2.2rem,4.4vw,3.2rem); color:var(--choco); margin:0 0 16px; }
  .coc-c-hero h1 em{ font-style:italic; color:var(--rosegold); }
  .coc-c-hero p.sub{ color:#7a5a62; font-size:1rem; max-width:460px; margin:0 auto; line-height:1.8; }

  .coc-c-float{ position:absolute; font-size:1.7rem; filter:drop-shadow(0 6px 10px rgba(0,0,0,.1)); animation:coc-float 6s ease-in-out infinite; }
  .coc-c-float.f1{ top:18%; left:8%; }
  .coc-c-float.f2{ top:22%; right:10%; animation-delay:1s; font-size:1.4rem; }
  .coc-c-float.f3{ bottom:14%; left:16%; animation-delay:2s; font-size:1.3rem; }
  @keyframes coc-float{ 0%,100%{ transform:translateY(0);} 50%{ transform:translateY(-12px);} }

  /* ---------- success banner ---------- */
  .coc-success{
    display:flex; align-items:center; gap:12px; justify-content:center;
    background:#fff; border:1px solid rgba(201,123,132,.25); color:var(--choco);
    padding:16px 22px; border-radius:16px; margin:0 0 36px; box-shadow:0 14px 34px rgba(59,31,41,.1);
    font-size:.92rem; animation:coc-slide-in .6s cubic-bezier(.2,.7,.2,1);
  }
  .coc-success .ic{
    width:30px; height:30px; flex:0 0 30px; border-radius:50%; background:var(--rosegold); color:#fff;
    display:flex; align-items:center; justify-content:center;
  }
  @keyframes coc-slide-in{ from{ opacity:0; transform:translateY(-14px); } to{ opacity:1; transform:translateY(0); } }

  /* ---------- body grid ---------- */
  .coc-c-body{ padding:0 0 110px; }
  .coc-c-grid{ display:grid; grid-template-columns:.85fr 1.15fr; gap:30px; align-items:start; }

  .coc-info-card{
    background:rgba(255,255,255,.6); backdrop-filter:blur(14px); border:1px solid rgba(255,255,255,.7);
    border-radius:20px; padding:26px; margin-bottom:18px; box-shadow:0 14px 34px rgba(59,31,41,.07);
    transition:transform .4s cubic-bezier(.2,.7,.2,1), box-shadow .4s ease, background .4s ease;
  }
  .coc-info-card:hover{ transform:translateY(-6px); box-shadow:0 22px 44px rgba(59,31,41,.13); background:#fff; }
  .coc-info-card .ic{
    width:48px; height:48px; border-radius:50%; display:flex; align-items:center; justify-content:center;
    background:var(--rosegold); color:#fff; margin-bottom:14px;
  }
  .coc-info-card h4{ color:var(--choco); font-weight:700; font-size:.95rem; margin:0 0 6px; }
  .coc-info-card p{ color:#806369; font-size:.86rem; line-height:1.7; margin:0; }

  .coc-form-card{
    background:#fff; border-radius:24px; padding:44px; box-shadow:0 24px 60px rgba(59,31,41,.1);
  }
  .coc-field{ margin-bottom:22px; }
  .coc-field label{ display:block; color:var(--choco); font-weight:600; font-size:.86rem; margin-bottom:8px; }
  .coc-field input, .coc-field textarea{
    width:100%; padding:13px 16px; border:1.5px solid rgba(201,123,132,.22); border-radius:12px;
    outline:none; font-size:.92rem; color:var(--choco); background:var(--blush);
    transition:border-color .3s ease, box-shadow .3s ease, background .3s ease;
  }
  .coc-field input::placeholder, .coc-field textarea::placeholder{ color:#b89aa0; }
  .coc-field input:focus, .coc-field textarea:focus{
    border-color:var(--rosegold); background:#fff; box-shadow:0 0 0 4px rgba(201,123,132,.14);
  }
  .coc-field textarea{ resize:vertical; min-height:130px; }

.coc-submit{
    position:relative; width:100%; padding:16px; background:var(--rosegold); color:#fff; border:none;
    border-radius:50px; font-size:.96rem; font-weight:500; letter-spacing:.03em; cursor:pointer;
    display:flex; align-items:center; justify-content:center; gap:10px; overflow:hidden; isolation:isolate;
    box-shadow:0 14px 30px rgba(59,31,41,.22); transition:transform .35s ease, box-shadow .35s ease;
  }
  .coc-submit::before{
    content:""; position:absolute; inset:0; z-index:-1; transform:scaleX(0); transform-origin:left;
    background:var(--choco); transition:transform .45s cubic-bezier(.2,.7,.2,1);
  }
  .coc-submit:hover::before{ transform:scaleX(1); }
  .coc-submit:hover{ transform:translateY(-3px); box-shadow:0 18px 36px rgba(201,123,132,.32); }
  .coc-submit svg{ width:18px; height:18px; }
  @media (max-width: 860px){
    .coc-c-grid{ grid-template-columns:1fr; }
    .coc-form-card{ padding:30px 24px; }
  }
</style>

<div class="coc-contact">

  <section class="coc-c-hero">
  
    <div class="coc-wrap coc-reveal">
      <span class="coc-eyebrow">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0l2.6 7.9H22l-6.3 4.9 2.4 8L12 16l-6.1 4.8 2.4-8L2 7.9h7.4z"/></svg>
        We'd love to hear from you
      </span>
      <h1>Get In <em>Touch</em></h1>
      <p class="sub">Have a question or a custom order in mind? Send us a message and we'll get back to you within 24 hours.</p>
    </div>
  </section>
  <svg class="coc-scallop" viewBox="0 0 1200 34" preserveAspectRatio="none"><path d="M0,0 H1200 V14 C1150,30 1110,2 1060,16 C1010,30 970,2 920,16 C870,30 830,2 780,16 C730,30 690,2 640,16 C590,30 550,2 500,16 C450,30 410,2 360,16 C310,30 270,2 220,16 C170,30 130,2 80,16 C40,28 10,10 0,14 Z" fill="#FFF9F7"/></svg>

  <section class="coc-c-body">
    <div class="coc-wrap">

      <% if (typeof success !== 'undefined' && success) { %>
      <div class="coc-success coc-reveal is-in">
        <span class="ic">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" width="16" height="16"><polyline points="20 6 9 17 4 12"/></svg>
        </span>
        Your message has been sent! We'll get back to you within 24 hours.
      </div>
      <% } %>

      <div class="coc-c-grid">

        <!-- Info cards -->
        <div>
          <div class="coc-info-card coc-reveal">
            <div class="ic">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><path d="M21 10c0 6-9 12-9 12s-9-6-9-12a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <h4>Visit Us</h4>
            <p>Sweet Street, Trade Centre<br>Kottayam, Kerala, India</p>
          </div>

          <div class="coc-info-card coc-reveal">
            <div class="ic">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.69 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.33 1.85.56 2.81.69A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <h4>Call Us</h4>
            <p>+91 123 456 7890<br>Mon–Sat, 9am–7pm</p>
          </div>

          <div class="coc-info-card coc-reveal">
            <div class="ic">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" width="22" height="22"><path d="M4 4h16v16H4z"/><path d="M22 6l-10 7L2 6"/></svg>
            </div>
            <h4>Email Us</h4>
            <p>cakeoclock@gmail.com<br>We reply within 24 hrs</p>
          </div>
        </div>

        <!-- Form -->
        <div class="coc-form-card coc-reveal">
          <form action="/contact-us" method="POST">
            <div class="coc-field">
              <label>Your Name</label>
              <input type="text" name="name" placeholder="John Doe" required>
            </div>
            <div class="coc-field">
              <label>Email Address</label>
              <input type="email" name="email" placeholder="john@example.com" required>
            </div>
            <div class="coc-field">
              <label>Subject</label>
              <input type="text" name="subject" placeholder="Custom cake enquiry..." required>
            </div>
            <div class="coc-field">
              <label>Message</label>
              <textarea name="message" rows="5" placeholder="Tell us about your cake dream..." required></textarea>
            </div>
            <button type="submit" class="coc-submit">
              Send Message
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            </button>
          </form>
        </div>

      </div>
    </div>
  </section>

</div>

<script>
  (function(){
    var els = document.querySelectorAll('.coc-contact .coc-reveal');
    if(!('IntersectionObserver' in window)){ els.forEach(function(e){ e.classList.add('is-in'); }); return; }
    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(entry){
        if(entry.isIntersecting){ entry.target.classList.add('is-in'); io.unobserve(entry.target); }
      });
    }, { threshold: 0.15 });
    els.forEach(function(e){ io.observe(e); });
  })();
</script>

<%- include('../partials/user/footer') %>
