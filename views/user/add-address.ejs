<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Add New Address – Cake O'Clock</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Lato:wght@400;600;700&display=swap" rel="stylesheet">
  <%- include("../partials/user/dashboardStyles") %>
</head>
<body>

<%- include("../partials/user/h2") %>

<div class="page-wrap">

  <aside class="dash-sidebar">
    <%- include("../partials/user/sider") %>
  </aside>

  <main class="dash-main" id="dashMain">

    <div class="form-header">
<div class="form-header-icon"><i class="fas fa-map-marker-alt" style="color:var(--rose)"></i></div>      <div>
        <h1>Add New Address</h1>
        <p>Fill in your delivery details below</p>
      </div>
    </div>

    <div class="form-card">
      <form action="/add-address?from=<%= locals.from || '' %>" method="POST" class="form-grid">

        <div class="field-group">
          <label>Full Name</label>
          <input type="text" id="name" name="name" class="field-input" placeholder="Enter your name" maxlength="30">
          <span class="error-text" id="nameError"></span>
        </div>

        <div class="field-group">
          <label>Mobile Number</label>
          <input type="tel" id="phone" name="phone" class="field-input" placeholder="10-digit number">
          <span class="error-text" id="phoneError"></span>
        </div>

        <div class="field-group">
          <label>Pincode</label>
          <input type="text" id="pincode" name="pincode" class="field-input" placeholder="6-digit pincode">
          <span class="error-text" id="pincodeError"></span>
        </div>

        <div class="field-group">
          <label>Locality / Street</label>
          <input type="text" id="street" name="street" class="field-input" placeholder="Area, street, sector">
          <span class="error-text" id="streetError"></span>
        </div>

      <div class="field-group full-col">
  <label>Full Address</label>
  <textarea id="address" name="address" class="field-input" placeholder="House no., Building, Floor, etc."></textarea>
  <span class="error-text" id="addressError"></span>
</div>

        <div class="field-group">
          <label>City / District / Town</label>
          <input type="text" id="city" name="city" class="field-input" placeholder="Your city">
          <span class="error-text" id="cityError"></span>
        </div>

        <div class="field-group">
          <label>State</label>
          <input type="text" id="state" name="state" class="field-input" placeholder="Your state">
          <span class="error-text" id="stateError"></span>
        </div>

        <div class="field-group">
          <label>Landmark <span style="color:var(--muted);font-weight:400">(Optional)</span></label>
          <input type="text" name="landmark" class="field-input" placeholder="Near school, temple, etc.">
        </div>

        <div class="field-group">
          <label>Alternate Phone <span style="color:var(--muted);font-weight:400">(Optional)</span></label>
          <input type="tel" name="altPhone" class="field-input" placeholder="Alternate number">
        </div>

        <div class="full-col">
          <span class="type-label">Address Type</span>
          <div class="type-options">
            <div class="type-option">
  <input type="radio" name="type" value="HOME" id="type-home" checked>
  <label for="type-home"><span><i class="fa-solid fa-house" style="color:var(--rose)"></i></span> Home</label>
</div>
<div class="type-option">
  <input type="radio" name="type" value="WORK" id="type-work">
  <label for="type-work"><span><i class="fa-solid fa-briefcase" style="color:var(--rose)"></i></span> Work</label>
</div>
<div class="type-option">
  <input type="radio" name="type" value="FAMILY" id="type-family">
  <label for="type-family"><span><i class="fa-solid fa-people-roof" style="color:var(--rose)"></i></span> Family</label>
</div>
<div class="type-option">
  <input type="radio" name="type" value="FRIEND" id="type-friend">
  <label for="type-friend"><span><i class="fa-solid fa-handshake" style="color:var(--rose)"></i></span> Friend</label>
</div>
          </div>
        </div>

        <div class="form-actions full-col">
          <a href="/address" class="btn-cancel spa-link">Cancel</a>
          <button type="submit" class="btn-save">
            <i class="fas fa-save"></i> Save Address
          </button>
        </div>

      </form>
    </div>

    <script>
const fields = {
        name:    { id:"name",    error:"nameError",    regex:/^[A-Za-z ]{3,30}$/, msg:"Name must be 3-30 letters" },
        phone:   { id:"phone",   error:"phoneError",   regex:/^[6-9][0-9]{9}$/, msg:"Invalid phone number" },
        pincode: { id:"pincode", error:"pincodeError", regex:/^[1-9][0-9]{5}$/, msg:"Enter a valid 6-digit pincode" },
        street:  { id:"street",  error:"streetError",  regex:/^.{3,}$/,          msg:"Required" },
        address: { id:"address", error:"addressError", regex:/^.{10,}$/,        msg:"Enter a complete address (min 10 characters)" },
        city:    { id:"city",    error:"cityError",    regex:/^[A-Za-z ]{2,}$/,  msg:"Invalid city" },
        state:   { id:"state",   error:"stateError",   regex:/^[A-Za-z ]{2,}$/,  msg:"Invalid state" }
      };
      function validate(field) {
        const input = document.getElementById(field.id);
        const error = document.getElementById(field.error);
        const value = input.value.trim();

        // Reject pincodes where every digit is identical (e.g. 000000, 111111)
        if (field.id === "pincode" && /^(\d)\1{5}$/.test(value)) {
          input.classList.add("error"); input.classList.remove("success");
          error.textContent = "Pincode cannot be all the same digit"; return false;
        }

        if (!field.regex.test(value)) {
          input.classList.add("error"); input.classList.remove("success");
          error.textContent = field.msg; return false;
        } else {
          input.classList.remove("error"); input.classList.add("success");
          error.textContent = ""; return true;
        }
      }
      Object.values(fields).forEach(f => document.getElementById(f.id).addEventListener("input", () => validate(f)));
      document.querySelector('#dashMain form').addEventListener('submit', function(e) {
        let isValid = true;
        Object.values(fields).forEach(f => { if (!validate(f)) isValid = false; });
        if (!isValid) { e.preventDefault(); }
        else { document.querySelector('.btn-save').classList.add('saving'); }
      });
    </script>

  </main>
</div>

</body>
</html>
