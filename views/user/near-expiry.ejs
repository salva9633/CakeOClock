<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Near Expiry Cake Deals</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Bootstrap -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
    rel="stylesheet">

  <style>
    body {
      margin: 0;
      background: linear-gradient(to right, #fde2d9, #f9c5b5);
      font-family: "Segoe UI", sans-serif;
    }

    .page-title {
      margin-top: 100px;
      margin-bottom: 30px;
      font-weight: bold;
      text-align: center;
    }

    /* PRODUCT CARD (same as products page) */
    .product-card {
      border-radius: 14px;
      border: none;
      transition: 0.3s ease;
      height: 100%;
      position: relative;
    }

    .product-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 12px 30px rgba(0,0,0,0.15);
    }

    .product-img {
      height: 200px;
      object-fit: cover;
      border-radius: 14px 14px 0 0;
    }

    .desc {
      font-size: 0.85rem;
      color: #6c757d;
      height: 42px;
      overflow: hidden;
    }

    .price {
      font-weight: bold;
      color: #c0392b;
      font-size: 1.1rem;
    }

    /* EXPIRY BADGE */
    .expiry-badge {
      position: absolute;
      top: 12px;
      left: 12px;
      background: #dc3545;
      color: white;
      font-size: 0.75rem;
      padding: 4px 10px;
      border-radius: 12px;
      font-weight: 600;
    }

    /* DISCOUNT BADGE */
    .discount-badge {
      position: absolute;
      top: 12px;
      right: 12px;
      background: #198754;
      color: white;
      font-size: 0.75rem;
      padding: 4px 10px;
      border-radius: 12px;
      font-weight: 600;
    }

    .old-price {
      text-decoration: line-through;
      color: #6c757d;
      font-size: 0.85rem;
      margin-left: 6px;
    }

    .expiry-text {
      font-size: 0.8rem;
      color: #b02a37;
      font-weight: 600;
    }
  </style>
</head>

<body>

<%- include("../partials/user/h2") %>

<div class="container">


  <% if (deals.length === 0) { %>
    <p class="text-center text-muted">
      No near-expiry cake offers available right now.
    </p>
  <% } %>

  <div class="row g-4">

    <% deals.forEach(deal => { %>

      <div class="col-12 col-sm-6 col-md-4 col-lg-3">
        <div class="card product-card">

          <!-- BADGES -->
          <span class="expiry-badge">
            Expires Soon
          </span>

          <span class="discount-badge">
            <%= deal.discountPercent %>% OFF
          </span>

          <!-- IMAGE -->
          <% if (deal.product.productImages && deal.product.productImages.length > 0) { %>
            <img
              src="<%= deal.product.productImages[0] %>"
              class="product-img"
              alt="<%= deal.product.productName %>">
          <% } else { %>
            <img
              src="https://via.placeholder.com/300x200?text=No+Image"
              class="product-img">
          <% } %>

          <div class="card-body d-flex flex-column">

            <h6 class="fw-semibold">
              <%= deal.product.productName %>
            </h6>

            <p class="desc">
              <%= deal.product.description %>
            </p>

            <!-- VARIANT / EXPIRY INFO -->
            <p class="expiry-text mb-1">
              Weight: <%= deal.variant.weight %>g<br>
              Expires on:
              <%= new Date(deal.expiryAt).toDateString() %>
            </p>

            <div class="mt-auto">

              <!-- PRICE -->
              <p class="mb-1">
                <span class="price">
                  ₹ <%= deal.offerPrice %>
                </span>
               <span class="old-price">
  ₹ <%= deal.variant.regularPrice %>
</span>
              </p>

              <small class="text-muted">
                Limited stock: <%= deal.stock %>
              </small>

              <div class="d-flex gap-2 mt-2">
                <a
                  href="/product/<%= deal.product._id %>"
                  class="btn btn-outline-dark btn-sm w-100">
                  View
                </a>
                <a
                  href="/product/<%= deal.product._id %>"
                  class="btn btn-dark btn-sm w-100">
                  Buy
                </a>
              </div>

            </div>
          </div>

        </div>
      </div>

    <% }) %>

  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
