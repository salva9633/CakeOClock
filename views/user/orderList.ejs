<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>My Orders – Cake O'Clock</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=Lato:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
    :root { --rose:#AF5454; --cream:#fdf6f0; }
    body { font-family:'Lato',sans-serif; background:var(--cream); }
    h2 { font-family:'Playfair Display',serif; }
    .order-card { background:#fff; border-radius:14px; padding:20px; margin-bottom:16px; box-shadow:0 2px 10px rgba(0,0,0,.05); transition:.2s; }
    .order-card:hover { box-shadow:0 4px 18px rgba(175,84,84,.12); }
    .order-id { font-weight:700; color:var(--rose); font-size:.95rem; }
    .status-badge { font-size:.75rem; border-radius:20px; padding:3px 12px; font-weight:700; }
    .status-Pending    { background:#fff3cd; color:#856404; }
    .status-Processing { background:#cff4fc; color:#0a58ca; }
    .status-Shipped    { background:#d0efff; color:#0a3d62; }
    .status-Delivered  { background:#d4edda; color:#155724; }
    .status-Cancelled  { background:#f8d7da; color:#721c24; }
    .status-Returned   { background:#e2d9f3; color:#432874; }
    .item-img { width:50px; height:50px; object-fit:cover; border-radius:8px; }
    .search-input { border:2px solid #e8dada; border-radius:10px; padding:10px 16px; width:100%; max-width:360px; font-size:.9rem; }
    .search-input:focus { outline:none; border-color:var(--rose); }
    .btn-rose { background:var(--rose); color:#fff; border:none; border-radius:8px; padding:8px 16px; font-weight:600; font-size:.85rem; cursor:pointer; }
    .btn-rose:hover { background:#8c3a3a; color:#fff; }
    .empty-state { text-align:center; padding:60px 20px; color:#aaa; }
    .page-link { color:var(--rose); }
    .page-item.active .page-link { background:var(--rose); border-color:var(--rose); color:#fff; }
  </style>
</head>
<body>

<%- include("../partials/user/h2") %>

<div class="container py-4">
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
    <h2 class="mb-0">My Orders</h2>
    <form method="GET" action="/orders" class="d-flex gap-2">
      <input type="text" name="search" class="search-input" placeholder="Search by Order ID…" value="<%= search %>">
      <button type="submit" class="btn-rose">Search</button>
      <% if (search) { %><a href="/orders" class="btn btn-outline-secondary btn-sm align-self-center">Clear</a><% } %>
    </form>
  </div>

  <% if (!orders || orders.length === 0) { %>
    <div class="empty-state">
      <p class="fs-5 fw-bold">No orders found</p>
      <a href="/products" class="btn-rose mt-2 d-inline-block" style="border-radius:8px;padding:10px 24px;text-decoration:none">Start Shopping</a>
    </div>
  <% } else { %>
    <% orders.forEach(order => { %>
      <div class="order-card">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">
          <div>
            <div class="order-id"><%= order.orderId %></div>
            <div class="text-muted" style="font-size:.8rem">
              <%= new Date(order.createdAt).toLocaleDateString('en-IN', {day:'numeric',month:'long',year:'numeric'}) %>
            </div>
          </div>
          <span class="status-badge status-<%= order.status %>"><%= order.status %></span>
        </div>

        <div class="d-flex gap-2 flex-wrap mb-2">
          <% order.items.slice(0,2).forEach(item => { %>
            <div class="d-flex align-items-center gap-2">
              <img src="<%= item.productImage || '/img/placeholder.png' %>" class="item-img" alt="">
              <div>
                <div style="font-size:.88rem;font-weight:600"><%= item.productName %></div>
                <div class="text-muted" style="font-size:.78rem"><%= item.weight %>g × <%= item.quantity %></div>
              </div>
            </div>
          <% }) %>
          <% if (order.items.length > 2) { %>
            <div class="d-flex align-items-center text-muted" style="font-size:.82rem">+<%= order.items.length - 2 %> more</div>
          <% } %>
        </div>

        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
          <div class="fw-bold" style="color:var(--rose)">₹<%= order.finalTotal.toLocaleString('en-IN') %></div>
          <div class="d-flex gap-2 flex-wrap">
            <a href="/orders/<%= order._id %>" class="btn btn-sm btn-outline-secondary" style="border-radius:8px">View Details</a>
            <% if (['Pending','Processing'].includes(order.status)) { %>
              <button class="btn btn-sm btn-outline-danger" style="border-radius:8px"
                onclick="cancelOrder('<%= order._id %>', '<%= order.orderId %>')">Cancel</button>
            <% } %>
            <% if (order.status === 'Delivered') { %>
              <button class="btn btn-sm" style="background:#e2d9f3;color:#432874;border-radius:8px"
                onclick="returnOrder('<%= order._id %>')">Return</button>
            <% } %>
            <a href="/orders/<%= order._id %>/invoice" class="btn btn-sm" style="background:#f0f0f0;border-radius:8px">📄 Invoice</a>
          </div>
        </div>
      </div>
    <% }) %>

    <% if (totalPages > 1) { %>
      <nav class="mt-4">
        <ul class="pagination justify-content-center">
          <% for(let p=1; p<=totalPages; p++) { %>
            <li class="page-item <%= currentPage===p ? 'active' : '' %>">
              <a class="page-link" href="/orders?page=<%= p %><%= search ? '&search='+search : '' %>"><%= p %></a>
            </li>
          <% } %>
        </ul>
      </nav>
    <% } %>
  <% } %>
</div>

<%- include("../partials/user/footer") %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
async function cancelOrder(id, orderId) {
  const { value: reason, isConfirmed } = await Swal.fire({
    title: 'Cancel Order?',
    text: `Cancel order ${orderId}?`,
    icon: 'warning',
    input: 'text',
    inputPlaceholder: 'Reason (optional)',
    showCancelButton: true,
    confirmButtonColor: '#AF5454',
    cancelButtonColor: '#9a7070',
    confirmButtonText: 'Yes, Cancel Order',
    cancelButtonText: 'Keep Order'
  });
  if (!isConfirmed) return;
  const res  = await fetch(`/orders/${id}/cancel`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ reason: reason || '' })
  });
  const data = await res.json();
  if (data.success) {
    Swal.fire({ icon: 'success', title: 'Cancelled', text: data.message, confirmButtonColor: '#AF5454' })
      .then(() => location.reload());
  } else {
    Swal.fire({ icon: 'error', title: 'Failed', text: data.message, confirmButtonColor: '#AF5454' });
  }
}

async function returnOrder(id) {
  const { value: reason, isConfirmed } = await Swal.fire({
    title: 'Return Order',
    text: 'Please tell us why you want to return this order.',
    icon: 'question',
    input: 'textarea',
    inputPlaceholder: 'Enter reason for return (required)',
    showCancelButton: true,
    confirmButtonColor: '#AF5454',
    cancelButtonColor: '#9a7070',
    confirmButtonText: 'Submit Return',
    preConfirm: (val) => {
      if (!val || val.trim().length < 5) {
        Swal.showValidationMessage('Please enter a valid reason (min 5 characters)');
        return false;
      }
    }
  });
  if (!isConfirmed) return;
  const res  = await fetch(`/orders/${id}/return`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ reason })
  });
  const data = await res.json();
  if (data.success) {
    Swal.fire({ icon: 'success', title: 'Return Requested', text: data.message, confirmButtonColor: '#AF5454' })
      .then(() => location.reload());
  } else {
    Swal.fire({ icon: 'error', title: 'Failed', text: data.message, confirmButtonColor: '#AF5454' });
  }
}
</script>
</body>
</html>

