<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>My Wallet – Cake O'Clock</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<%- include("../partials/user/h2") %>
<%- include("../../views/partials/user/dashboardStyles") %>

<div class="page-wrap">

  <aside class="dash-sidebar">
    <%- include("../../views/partials/user/sider") %>
  </aside>

  <!-- Page CSS, markup and page JS all live inside #dashMain so a normal
       SPA swap brings everything this page needs along with it. -->
  <main class="dash-main" id="dashMain">
    <style>
      /* extra tokens on top of dashboardStyle's shared :root (safe to add,
         multiple :root blocks merge — these just aren't defined yet) */
      :root {
        --rose-mid: #c97070;
        --r-sm: 10px; --r-md: 14px; --r-lg: 18px; --r-xl: 24px;
        --gap-sm: 12px; --gap-md: 20px; --gap-lg: 28px;
        --shadow-md: 0 6px 20px rgba(139,74,90,.10);
        --shadow-lg: 0 12px 36px rgba(139,74,90,.16);
      }

      .page-topbar { margin-bottom: var(--gap-lg); }

      .wallet-grid { display: grid; grid-template-columns: 320px 1fr; gap: var(--gap-lg); align-items: start; }
      .wallet-col { display: flex; flex-direction: column; gap: var(--gap-md); }

      /* ── Balance card: calmer, one focal point instead of competing motion ── */
      .wallet-balance-card {
        background: linear-gradient(135deg, var(--rose) 0%, var(--rose-dk) 100%);
        border-radius: var(--r-xl); padding: 26px 28px; color: #fff;
        position: relative; overflow: hidden;
        box-shadow: 0 10px 30px rgba(139,74,90,.26);
      }
      .wallet-icon-wrap {
        width: 44px; height: 44px; background: rgba(255,255,255,.16); border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.25rem; margin-bottom: 14px; position: relative; z-index: 1;
      }
      .wallet-balance-card .label { font-size:.74rem; opacity:.75; letter-spacing:.07em; text-transform:uppercase; margin-bottom:6px; position:relative; z-index:1; }
      .wallet-balance-card .amount { font-family: var(--font-display); font-size: 2.2rem; font-weight: 700; line-height: 1; position: relative; z-index: 1; margin-bottom: 4px; }
      .wallet-balance-card .sub { font-size:.74rem; opacity:.65; position:relative; z-index:1; }

      /* ── Stats: one quiet strip instead of three separate bordered cards ── */
      .stats-row {
        display: grid; grid-template-columns: repeat(3,1fr);
        /* background: var(--cream); border: 1.5px solid var(--border); border-radius: var(--r-lg); */
      }
      .stat-card { padding: 16px 8px; text-align: center; }
      .stat-card + .stat-card { border-left: 1.5px solid var(--border); }
      .stat-card .stat-val { font-family: var(--font-display); font-size: 1.4rem; font-weight: 700; color: var(--rose); }
      .stat-card .stat-label { font-size: .7rem; color: var(--muted); margin-top: 3px; }

      .side-card {
        background: var(--cream); border: 1.5px solid var(--border); border-radius: var(--r-lg);
        padding: 20px;
      }
      .side-card-title { font-size: .88rem; font-weight: 700; color: var(--text); margin-bottom: 14px; display: flex; align-items: center; gap: 8px; }
      .info-list { font-size: .78rem; color: var(--muted); padding-left: 16px; margin: 0; line-height: 1.9; }

      #topupAmount {
        width: 100%; border: 1.5px solid var(--border); border-radius: var(--r-sm);
        padding: 12px 14px; font-size: .9rem; font-family: var(--font-body);
        color: var(--text); background: #fff; outline: none; margin-bottom: 12px;
        transition: border-color .2s, box-shadow .2s;
      }
      #topupAmount:focus { border-color: var(--rose); box-shadow: 0 0 0 4px rgba(139,74,90,.09); }

      .quick-btns { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 16px; }
      .quick-btn {
        flex: 1; min-width: 68px; padding: 8px 10px;
        border: 1.5px solid var(--border); border-radius: var(--r-sm);
        background: #fff; color: var(--rose); font-size: .8rem; font-weight: 700;
        cursor: pointer; transition: background .18s, color .18s, border-color .18s; font-family: var(--font-body);
      }
      .quick-btn:hover { background: var(--rose); color: #fff; border-color: var(--rose); }

      #addMoneyBtn {
        width: 100%; background: linear-gradient(135deg, var(--rose), var(--rose-dk));
        color: #fff; border: none; border-radius: var(--r-sm); padding: 13px;
        font-size: .9rem; font-weight: 700; cursor: pointer; letter-spacing: .02em;
        font-family: var(--font-body); transition: box-shadow .18s;
        box-shadow: 0 6px 18px rgba(139,74,90,.26);
      }
      #addMoneyBtn:hover { box-shadow: 0 8px 22px rgba(139,74,90,.32); }
      #addMoneyBtn:disabled { opacity: .7; cursor: not-allowed; }
      #topupMsg { font-size: .8rem; margin-top: 10px; display: none; padding: 9px 13px; border-radius: var(--r-sm); }

      .transactions-card {
        background: var(--cream); border-radius: var(--r-xl); padding: 28px;
        box-shadow: var(--shadow-md); border: 1.5px solid var(--border);
      }
      .transactions-title {
        font-family: var(--font-display); font-size: 1.1rem; color: var(--text);
        margin-bottom: 20px; padding-bottom: 14px; border-bottom: 2px solid var(--border);
        display: flex; align-items: center; gap: 8px;
      }
      .txn-count { font-size: .75rem; color: var(--muted); font-family: var(--font-body); font-weight: 400; margin-left: auto; }

      .txn-item {
        display: flex; align-items: center; gap: 16px; padding: 18px 8px;
        border-bottom: 1px solid var(--border);
      }
      .txn-item:last-child { border-bottom: none; padding-bottom: 6px; }
      .txn-item:first-child { padding-top: 6px; }

      .txn-icon {
        width: 42px; height: 42px; border-radius: var(--r-md);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.05rem; flex-shrink: 0;
      }
      .txn-icon.credit { background: #e6f4ea; }
      .txn-icon.debit  { background: #fdecea; }
      .txn-info { flex: 1; min-width: 0; }
      .txn-desc { font-size: .88rem; font-weight: 600; color: var(--text); }
      .txn-meta { font-size: .74rem; color: var(--muted); margin-top: 3px; }
      .txn-order { font-size: .71rem; color: var(--rose); margin-top: 3px; }
      .txn-amount { text-align: right; flex-shrink: 0; }
      .txn-amount .val { font-size: 1rem; font-weight: 700; }
      .txn-amount .val.credit { color: #2a8c4a; }
      .txn-amount .val.debit  { color: #c0392b; }
      .txn-amount .balance { font-size: .71rem; color: var(--muted); margin-top: 3px; }
      .txn-badge { display: inline-block; font-size: .6rem; font-weight: 800; letter-spacing: .06em; text-transform: uppercase; padding: 2px 7px; border-radius: 5px; margin-top: 5px; }
      .txn-badge.credit { background: #e6f4ea; color: #2a8c4a; }
      .txn-badge.debit  { background: #fdecea; color: #c0392b; }

      .empty-state { text-align: center; padding: 52px 24px; color: var(--muted); }
      .empty-state .icon { font-size: 3.2rem; margin-bottom: 14px; display: block; }
      .empty-state h3 { font-family: var(--font-display); font-size: 1.3rem; color: var(--rose); margin-bottom: 8px; }
      .empty-state p { font-size: .88rem; margin-bottom: 16px; }
      .empty-state a { color: var(--rose); font-weight: 600; text-decoration: none; }
      .empty-state a:hover { text-decoration: underline; }

      .pagination-wrap { display: flex; justify-content: center; gap: 6px; margin-top: 26px; flex-wrap: wrap; }
      .pg-btn {
        min-width: 34px; height: 34px; border-radius: 50%;
        border: 1.5px solid var(--border); background: #fff; color: var(--rose);
        font-size: .83rem; font-weight: 700; font-family: var(--font-body);
        display: flex; align-items: center; justify-content: center; text-decoration: none;
        transition: background .18s, border-color .18s;
      }
      .pg-btn:hover:not(.disabled):not(.active) { background: var(--rose-lt); border-color: var(--rose-mid); }
      .pg-btn.active { background: linear-gradient(135deg, var(--rose), var(--rose-dk)); border-color: var(--rose); color: #fff; }
      .pg-btn.disabled { opacity: .35; pointer-events: none; }

      @media (max-width: 700px) {
        .wallet-grid { grid-template-columns: 1fr; }
      }
    </style>

    <div class="page-topbar">
      <h2>My Wallet</h2>
    </div>

    <%
      // Show only the 6 most recent transactions on this view.
      // If your controller paginates with a larger page size, set the
      // wallet route's query limit to 6 so `totalPages` lines up with
      // what's rendered here.
      const visibleTransactions = (transactions || []).slice(0, 6);
    %>

    <div class="wallet-grid">
      <!-- Left column -->
      <div class="wallet-col">
        <div class="wallet-balance-card">
          <div class="wallet-icon-wrap"><i class="fas fa-wallet"></i></div>
          <div class="label">Available Balance</div>
          <div class="amount">₹<%= (walletBalance || 0).toLocaleString('en-IN') %></div>
          <div class="sub">Cake O'Clock Wallet</div>
        </div>

        <div class="stats-row">
          <div class="stat-card">
            <div class="stat-val"><%= transactions.filter(t => t.type === 'credit').length %></div>
            <div class="stat-label">Credits</div>
          </div>
          <div class="stat-card">
            <div class="stat-val"><%= transactions.filter(t => t.type === 'debit').length %></div>
            <div class="stat-label">Debits</div>
          </div>
          <div class="stat-card">
            <div class="stat-val"><%= totalTransactions %></div>
            <div class="stat-label">Total</div>
          </div>
        </div>

        <div class="side-card">
          <div class="side-card-title">
            <i class="fas fa-credit-card" style="color:var(--rose)"></i> Add Money to Wallet
          </div>
          <input type="number" id="topupAmount" placeholder="Enter amount (₹)" min="1">
          <div class="quick-btns">
            <button onclick="setAmount(500)"  class="quick-btn">+₹500</button>
            <button onclick="setAmount(1000)" class="quick-btn">+₹1000</button>
            <button onclick="setAmount(1500)" class="quick-btn">+₹1500</button>
            <button onclick="setAmount(2000)" class="quick-btn">+₹2000</button>
          </div>
          <button onclick="addMoneyToWallet()" id="addMoneyBtn">
            <i class="fas fa-plus-circle"></i> Add Money via Razorpay
          </button>
          <div id="topupMsg"></div>
        </div>

        <div class="side-card">
          <div class="side-card-title">
            <i class="fas fa-info-circle" style="color:var(--rose)"></i> How wallet works
          </div>
          <ul class="info-list">
            <li>Refunds for cancellations are instant</li>
            <li>Return refunds added after admin approval</li>
            <li>Use wallet balance at checkout</li>
            <li>Add money anytime via Razorpay</li>
          </ul>
        </div>
      </div>

      <!-- Right column: Transactions -->
      <div>
        <div class="transactions-card">
          <div class="transactions-title">
            <i class="fas fa-receipt" style="color:var(--rose)"></i>
            Transaction History
            <span class="txn-count"><%= totalTransactions %> transaction<%= totalTransactions !== 1 ? 's' : '' %></span>
          </div>

          <% if (visibleTransactions.length > 0) { %>
            <% visibleTransactions.forEach(txn => { %>
              <div class="txn-item">
                <div class="txn-icon <%= txn.type %>">
                  <i class="fas fa-<%= txn.type === 'credit' ? 'arrow-down' : 'arrow-up' %>"></i>
                </div>
                <div class="txn-info">
                  <div class="txn-desc"><%= txn.description %></div>
                  <div class="txn-meta">
                    <%= new Date(txn.createdAt).toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) %>
                  </div>
                  <% if (txn.orderId) { %>
                    <div class="txn-order"><i class="fas fa-hashtag" style="font-size:.65rem"></i> <%= txn.orderId.orderId || txn.orderId %></div>
                  <% } %>
                  <span class="txn-badge <%= txn.type %>"><%= txn.type %></span>
                </div>
                <div class="txn-amount">
                  <div class="val <%= txn.type %>">
                    <%= txn.type === 'credit' ? '+' : '-' %>₹<%= (txn.amount || 0).toLocaleString('en-IN') %>
                  </div>
                  <div class="balance">Bal: ₹<%= (txn.balanceAfter || 0).toLocaleString('en-IN') %></div>
                </div>
              </div>
            <% }) %>

            <% if (totalPages > 1) { %>
              <div class="pagination-wrap">
                <a class="pg-btn spa-link <%= currentPage === 1 ? 'disabled' : '' %>" href="/wallet?page=<%= currentPage - 1 %>">‹</a>
                <% for (let i = 1; i <= totalPages; i++) { %>
                  <a class="pg-btn spa-link <%= currentPage === i ? 'active' : '' %>" href="/wallet?page=<%= i %>"><%= i %></a>
                <% } %>
                <a class="pg-btn spa-link <%= currentPage === totalPages ? 'disabled' : '' %>" href="/wallet?page=<%= currentPage + 1 %>">›</a>
              </div>
            <% } %>

          <% } else { %>
            <div class="empty-state">
              <span class="icon"><i class="fas fa-wallet" style="color:var(--rose)"></i></span>
              <h3>No transactions yet</h3>
              <p>Your wallet transactions will appear here after orders, cancellations, or returns.</p>
              <a href="/products">Start shopping →</a>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
    <script>
      const RAZORPAY_KEY = "<%= razorpayKeyId %>";

      function refreshWallet() {
        (window.spaRefresh || (() => location.reload()))();
      }

      function setAmount(val) {
        const input = document.getElementById('topupAmount');
        input.value = val;
        input.style.borderColor = 'var(--rose)';
        input.style.boxShadow   = '0 0 0 4px rgba(139,74,90,.12)';
        setTimeout(() => { input.style.borderColor = ''; input.style.boxShadow = ''; }, 600);
      }

      async function addMoneyToWallet() {
        const amount = parseFloat(document.getElementById('topupAmount').value);
        const btn    = document.getElementById('addMoneyBtn');
        if (!amount || amount < 1) { showMsg('Please enter a valid amount (min ₹1)', 'error'); return; }
        btn.disabled = true; btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing…';
        try {
          const res  = await fetch('/wallet/create-order', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ amount })
          });
          const data = await res.json();
          if (!data.success) {
            showMsg(data.message || 'Failed to initiate payment', 'error');
            btn.disabled = false; btn.innerHTML = '<i class="fas fa-plus-circle"></i> Add Money via Razorpay'; return;
          }
          const options = {
            key: RAZORPAY_KEY, amount: data.amount, currency: data.currency,
            order_id: data.orderId, name: "Cake O'Clock", description: "Wallet Top-up",
            theme: { color: "#8B4A5A" },
            handler: async function(response) {
              const verifyRes = await fetch('/wallet/verify-payment', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ razorpay_order_id: response.razorpay_order_id, razorpay_payment_id: response.razorpay_payment_id, razorpay_signature: response.razorpay_signature, amount })
              });
              const result = await verifyRes.json();
              if (result.success) {
                showMsg('✅ ₹' + amount.toLocaleString('en-IN') + ' added to your wallet!', 'success');
                document.querySelector('.wallet-balance-card .amount').textContent = '₹' + result.newBalance.toLocaleString('en-IN');
                document.getElementById('topupAmount').value = '';
                setTimeout(refreshWallet, 1500);
              } else { showMsg(result.message || 'Verification failed', 'error'); }
              btn.disabled = false; btn.innerHTML = '<i class="fas fa-plus-circle"></i> Add Money via Razorpay';
            },
            modal: { ondismiss: function() { btn.disabled = false; btn.innerHTML = '<i class="fas fa-plus-circle"></i> Add Money via Razorpay'; } }
          };
          const rzp = new Razorpay(options);
          rzp.on('payment.failed', function(r) { showMsg('Payment failed: ' + r.error.description, 'error'); btn.disabled = false; btn.innerHTML = '<i class="fas fa-plus-circle"></i> Add Money via Razorpay'; });
          rzp.open();
        } catch (err) { showMsg('Something went wrong. Please try again.', 'error'); btn.disabled = false; btn.innerHTML = '<i class="fas fa-plus-circle"></i> Add Money via Razorpay'; }
      }

      function showMsg(text, type) {
        const el = document.getElementById('topupMsg');
        el.textContent      = text;
        el.style.display    = 'block';
        el.style.background = type === 'success' ? '#e6f4ea' : '#fdecea';
        el.style.color      = type === 'success' ? '#1e7e34' : '#c0392b';
      }
    </script>
  </main>
</div>

<%- include("../partials/user/footer") %>
</body>
</html>
