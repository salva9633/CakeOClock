<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>My Wallet – Cake O'Clock</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --rose: #AF5454; --rose-dk: #8c3a3a; --rose-lt: #f9eded;
      --cream: #fdf6f0; --muted: #8a7070; --border: #ecdada; --text: #2d1f1f;
    }
    * { box-sizing: border-box; }
    body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--text); }
    h1,h2,h3,h4,h5 { font-family: 'Playfair Display', serif; }

    .page-strip {
      background: linear-gradient(135deg, #fff5f5 0%, #fdf6f0 100%);
      border-bottom: 1px solid var(--border);
      padding: 18px 0 14px;
    }
    .breadcrumb-item a { color: var(--rose); text-decoration: none; font-size: .85rem; }
    .breadcrumb-item.active { color: var(--muted); font-size: .85rem; }

    .wallet-balance-card {
      background: linear-gradient(135deg, var(--rose) 0%, var(--rose-dk) 100%);
      border-radius: 20px;
      padding: 32px;
      color: #fff;
      margin-bottom: 24px;
      position: relative;
      overflow: hidden;
    }
    .wallet-balance-card::before {
      content: '👛';
      position: absolute;
      right: 24px; top: 24px;
      font-size: 3rem;
      opacity: 0.2;
    }
    .wallet-balance-card .label {
      font-size: .85rem;
      opacity: .8;
      letter-spacing: .05em;
      text-transform: uppercase;
      margin-bottom: 8px;
    }
    .wallet-balance-card .amount {
      font-size: 2.8rem;
      font-weight: 700;
      font-family: 'Playfair Display', serif;
      line-height: 1;
    }
    .wallet-balance-card .sub {
      font-size: .8rem;
      opacity: .7;
      margin-top: 8px;
    }

    .stats-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; margin-bottom: 24px; }
    .stat-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 16px;
      text-align: center;
    }
    .stat-card .stat-val { font-size: 1.4rem; font-weight: 700; color: var(--rose); }
    .stat-card .stat-label { font-size: .75rem; color: var(--muted); margin-top: 4px; }

    .transactions-card {
      background: #fff;
      border-radius: 18px;
      padding: 24px;
      box-shadow: 0 2px 14px rgba(175,84,84,.07);
      border: 1px solid #f5eded;
    }
    .transactions-title {
      font-size: 1.1rem;
      color: var(--text);
      margin-bottom: 20px;
      padding-bottom: 14px;
      border-bottom: 2px solid var(--rose-lt);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .txn-item {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 0;
      border-bottom: 1px solid #fdf0f0;
      transition: background .15s;
    }
    .txn-item:last-child { border-bottom: none; }
    .txn-item:hover { background: #fffafa; border-radius: 8px; padding-left: 8px; }

    .txn-icon {
      width: 42px; height: 42px;
      border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.2rem;
      flex-shrink: 0;
    }
    .txn-icon.credit { background: #e6f4ea; }
    .txn-icon.debit  { background: #fdecea; }

    .txn-info { flex: 1; min-width: 0; }
    .txn-desc { font-size: .88rem; font-weight: 500; color: var(--text); }
    .txn-meta { font-size: .75rem; color: var(--muted); margin-top: 2px; }
    .txn-order { font-size: .72rem; color: var(--rose); margin-top: 2px; }

    .txn-amount { text-align: right; flex-shrink: 0; }
    .txn-amount .val { font-size: 1rem; font-weight: 700; }
    .txn-amount .val.credit { color: #2a8c4a; }
    .txn-amount .val.debit  { color: #c0392b; }
    .txn-amount .balance { font-size: .72rem; color: var(--muted); margin-top: 2px; }

    .empty-state {
      text-align: center;
      padding: 48px 24px;
      color: var(--muted);
    }
    .empty-state .icon { font-size: 3rem; margin-bottom: 12px; }

    .pagination .page-link { color: var(--rose); border-color: var(--border); }
    .pagination .page-item.active .page-link { background: var(--rose); border-color: var(--rose); color: #fff; }
  </style>
</head>
<body>

<%- include("../partials/user/h2") %>

<div class="page-strip">
  <div class="container">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-1" style="--bs-breadcrumb-divider:'›'">
        <li class="breadcrumb-item"><a href="/">Home</a></li>
        <li class="breadcrumb-item"><a href="/profile">Profile</a></li>
        <li class="breadcrumb-item active">Wallet</li>
      </ol>
    </nav>
    <h2 style="font-size:1.65rem;margin:0;color:var(--text)">My Wallet</h2>
  </div>
</div>

<div class="container py-4">
  <div class="row g-4">

    <!-- LEFT: Balance + Stats -->
    <div class="col-lg-4">

      <div class="wallet-balance-card">
        <div class="label">Available Balance</div>
        <div class="amount">₹<%= (walletBalance || 0).toLocaleString('en-IN') %></div>
        <div class="sub">Cake O'Clock Wallet</div>
      </div>

      <div class="stats-row">
        <div class="stat-card">
          <div class="stat-val">
            <%= transactions.filter(t => t.type === 'credit').length %>
          </div>
          <div class="stat-label">Credits</div>
        </div>
        <div class="stat-card">
          <div class="stat-val">
            <%= transactions.filter(t => t.type === 'debit').length %>
          </div>
          <div class="stat-label">Debits</div>
        </div>
        <div class="stat-card">
          <div class="stat-val"><%= totalTransactions %></div>
          <div class="stat-label">Total</div>
        </div>
      </div>

      <div class="stat-card" style="text-align:left;margin-bottom:12px">
        <div style="font-size:.78rem;color:var(--muted);margin-bottom:6px">ℹ️ How wallet works</div>
        <ul style="font-size:.78rem;color:var(--muted);padding-left:16px;margin:0;line-height:1.8">
          <li>Refunds for cancellations are instant</li>
          <li>Return refunds added after admin approval</li>
          <li>Use wallet balance at checkout</li>
        </ul>
      </div>

    <!-- Add Money Card -->
      <div class="stat-card" style="text-align:left;margin-bottom:12px;padding:20px">
        <div style="font-size:.95rem;font-weight:600;color:var(--text);margin-bottom:14px">
          💳 Add Money to Wallet
        </div>

        <div style="display:flex;gap:8px;margin-bottom:10px">
          <input type="number" id="topupAmount" placeholder="Enter amount (₹)"
            min="1" style="flex:1;border:1.5px solid var(--border);border-radius:10px;
            padding:10px 14px;font-size:.9rem;font-family:'DM Sans',sans-serif;
            color:var(--text);background:#fdfafa;outline:none;">
        </div>

        <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px">
          <button onclick="setAmount(500)"  class="quick-btn">+₹500</button>
          <button onclick="setAmount(1000)" class="quick-btn">+₹1000</button>
          <button onclick="setAmount(1500)" class="quick-btn">+₹1500</button>
          <button onclick="setAmount(2000)" class="quick-btn">+₹2000</button>
        </div>

        <button onclick="addMoneyToWallet()" id="addMoneyBtn"
          style="width:100%;background:linear-gradient(135deg,var(--rose),var(--rose-dk));
          color:#fff;border:none;border-radius:10px;padding:12px;font-size:.92rem;
          font-weight:700;cursor:pointer;transition:all .2s;letter-spacing:.02em">
          Add Money via Razorpay
        </button>

        <div id="topupMsg" style="font-size:.8rem;margin-top:8px;display:none;
          padding:7px 12px;border-radius:8px"></div>
      </div>

      <div class="stat-card" style="text-align:left;margin-bottom:12px">
        <div style="font-size:.78rem;color:var(--muted);margin-bottom:6px">ℹ️ How wallet works</div>
        <ul style="font-size:.78rem;color:var(--muted);padding-left:16px;margin:0;line-height:1.8">
          <li>Refunds for cancellations are instant</li>
          <li>Return refunds added after admin approval</li>
          <li>Use wallet balance at checkout</li>
          <li>Add money anytime via Razorpay</li>
        </ul>
      </div>

    </div>

    <!-- RIGHT: Transactions -->
    <div class="col-lg-8">
      <div class="transactions-card">
        <div class="transactions-title">
          📋 Transaction History
          <span style="font-size:.75rem;color:var(--muted);font-family:'DM Sans',sans-serif;font-weight:400;margin-left:auto">
            <%= totalTransactions %> transaction<%= totalTransactions !== 1 ? 's' : '' %>
          </span>
        </div>

        <% if (transactions && transactions.length > 0) { %>
          <% transactions.forEach(txn => { %>
            <div class="txn-item">
              <div class="txn-icon <%= txn.type %>">
                <%= txn.type === 'credit' ? '⬆️' : '⬇️' %>
              </div>
              <div class="txn-info">
                <div class="txn-desc"><%= txn.description %></div>
                <div class="txn-meta">
                  <%= new Date(txn.createdAt).toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric', hour:'2-digit', minute:'2-digit' }) %>
                </div>
                <% if (txn.orderId) { %>
                  <div class="txn-order">
                    Order: #<%= txn.orderId.orderId || txn.orderId %>
                  </div>
                <% } %>
              </div>
            <div class="txn-amount">
                <div class="val <%= txn.type %>">
                  <%= txn.type === 'credit' ? '+' : '-' %>₹<%= (txn.amount || 0).toLocaleString('en-IN') %>
                </div>
                <div class="balance">Bal: ₹<%= (txn.balanceAfter || 0).toLocaleString('en-IN') %></div>
              </div>
            </div>
          <% }) %>

          <!-- Pagination -->
          <% if (totalPages > 1) { %>
            <nav class="mt-4">
              <ul class="pagination justify-content-center">
                <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                  <a class="page-link" href="/wallet?page=<%= currentPage - 1 %>">‹</a>
                </li>
                <% for (let i = 1; i <= totalPages; i++) { %>
                  <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                    <a class="page-link" href="/wallet?page=<%= i %>"><%= i %></a>
                  </li>
                <% } %>
                <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                  <a class="page-link" href="/wallet?page=<%= currentPage + 1 %>">›</a>
                </li>
              </ul>
            </nav>
          <% } %>

        <% } else { %>
          <div class="empty-state">
            <div class="icon">👛</div>
            <h5>No transactions yet</h5>
            <p>Your wallet transactions will appear here after orders, cancellations, or returns.</p>
            <a href="/products" style="color:var(--rose)">Start shopping →</a>
          </div>
        <% } %>

      </div>
    </div>

  </div>
</div>

<%- include("../partials/user/footer") %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
  const RAZORPAY_KEY = "<%= razorpayKeyId %>";

  function setAmount(val) {
    document.getElementById('topupAmount').value = val;
  }

  async function addMoneyToWallet() {
    const amount = parseFloat(document.getElementById('topupAmount').value);
    const btn    = document.getElementById('addMoneyBtn');
    const msg    = document.getElementById('topupMsg');

    if (!amount || amount < 1) {
      showMsg('Please enter a valid amount (min ₹1)', 'error');
      return;
    }

    btn.disabled    = true;
    btn.textContent = 'Processing…';

    try {
      // Step 1: create Razorpay order
      const res  = await fetch('/wallet/create-order', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ amount })
      });
      const data = await res.json();

      if (!data.success) {
        showMsg(data.message || 'Failed to initiate payment', 'error');
        btn.disabled    = false;
        btn.textContent = 'Add Money via Razorpay';
        return;
      }

      // Step 2: open Razorpay popup
      const options = {
        key:      RAZORPAY_KEY,
        amount:   data.amount,
        currency: data.currency,
        order_id: data.orderId,
        name:     "Cake O'Clock",
        description: "Wallet Top-up",
        theme:    { color: "#AF5454" },

        handler: async function(response) {
          // Step 3: verify payment
          const verifyRes = await fetch('/wallet/verify-payment', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({
              razorpay_order_id:   response.razorpay_order_id,
              razorpay_payment_id: response.razorpay_payment_id,
              razorpay_signature:  response.razorpay_signature,
              amount
            })
          });

          const result = await verifyRes.json();

          if (result.success) {
            showMsg('✅ ₹' + amount.toLocaleString('en-IN') + ' added to your wallet!', 'success');
            // update balance on page
            document.querySelector('.wallet-balance-card .amount').textContent =
              '₹' + result.newBalance.toLocaleString('en-IN');
            document.getElementById('topupAmount').value = '';
            setTimeout(() => location.reload(), 1500);
          } else {
            showMsg(result.message || 'Verification failed', 'error');
          }

          btn.disabled    = false;
          btn.textContent = 'Add Money via Razorpay';
        },

        modal: {
          ondismiss: function() {
            btn.disabled    = false;
            btn.textContent = 'Add Money via Razorpay';
          }
        }
      };

      const rzp = new Razorpay(options);
      rzp.on('payment.failed', function(response) {
        showMsg('Payment failed: ' + response.error.description, 'error');
        btn.disabled    = false;
        btn.textContent = 'Add Money via Razorpay';
      });
      rzp.open();

    } catch (err) {
      console.error(err);
      showMsg('Something went wrong. Please try again.', 'error');
      btn.disabled    = false;
      btn.textContent = 'Add Money via Razorpay';
    }
  }

  function showMsg(text, type) {
    const el      = document.getElementById('topupMsg');
    el.textContent = text;
    el.style.display     = 'block';
    el.style.background  = type === 'success' ? '#e6f4ea' : '#fdecea';
    el.style.color       = type === 'success' ? '#1e7e34' : '#c0392b';
  }
</script>

<style>
  .quick-btn {
    flex: 1;
    min-width: 70px;
    padding: 7px 10px;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    background: #fff;
    color: var(--rose);
    font-size: .82rem;
    font-weight: 600;
    cursor: pointer;
    transition: all .18s;
  }
  .quick-btn:hover {
    background: var(--rose);
    color: #fff;
    border-color: var(--rose);
  }
</style>
</body>
</html>