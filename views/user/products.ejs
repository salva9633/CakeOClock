<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Shop</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      margin: 0;
      background: linear-gradient(to right, #fde2d9, #f9c5b5);
      overflow: hidden; /* IMPORTANT */
      font-family: "Segoe UI", sans-serif;
    }

    /* MAIN LAYOUT */
    .shop-container {
      display: flex;
    }

    /* SIDEBAR */
    .sidebar {
      position: fixed;
      top: 80px; /* navbar height */
      left: 0;
      width: 260px;
      height: calc(100vh - 80px);
      background: #fbe1d7;
      padding: 20px;
      overflow-y: auto;
      border-right: 1px solid #e3b7a8;
    }

    .sidebar h5 {
      font-weight: 600;
      margin-bottom: 12px;
      color: #7a3e2d;
    }

    .sidebar label {
      display: block;
      font-size: 0.9rem;
      margin-bottom: 8px;
      cursor: pointer;
      color: #5c2e22;
    }

    .sidebar input {
      margin-right: 8px;
    }

    .sidebar hr {
      border-color: #ddb1a3;
    }

    /* PRODUCTS AREA */
    .products {
      margin-left: 260px;
      padding: 60px;
      width: calc(100% - 260px);
      height: calc(100vh - 70px);
      overflow-y: auto;
    }

    /* PRODUCT CARD */
    .product-card {
      border-radius: 15px;
      border: none;
      transition: 0.3s ease;
      height: 100%;
      overflow: hidden;
    }

    .product-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 12px 30px rgba(0,0,0,0.15);
    }

    

    .desc {
      font-size: 0.85rem;
      color: #6c757d;
      height: 42px;
      overflow: hidden;
    }

    .price {
      font-weight: bold;
      color: #198754;
      font-size: 1.05rem;
    }

    /* Clickable product card */
    .product-card-link {
      cursor: pointer;
    }

    .product-card-link:hover h6 {
      color: #AF5454;
    }

    /* Improve hover feel */
    .product-card-link:hover .product-img {
      transform: scale(1.03);
    }
   .image-wrapper {
  position: relative;
  overflow: hidden;
  border-radius: 14px 14px 0 0;
}

.product-img {
  width: 100%;
  height: 220px;
  object-fit: cover;
  transition: transform 0.4s ease;
}
.offer-badge {
  position: absolute;
  top: 10px;
  left: 10px;
  background: #ff4d4f;
  color: white;
  padding: 5px 12px;
  font-size: 12px;
  border-radius: 20px;
  font-weight: 600;
  z-index: 10;
}
.product-card {
  border-radius: 16px;
  overflow: hidden;
}
    

    
  </style>
</head>

<body>

<!-- NAVBAR -->
<%- include("../partials/user/h2") %>

<div class="shop-container">

  <!-- SIDEBAR -->
  <aside class="sidebar">
<form method="GET" action="/products" id="filterForm">
    <h5>Categories</h5>
    <% categories.forEach(cat => { %>
      <label>
        <input type="radio" name="category" value="<%= cat._id %>">
        <%= cat.name %>
      </label>
    <% }) %>

    <hr>

    <h5>Price</h5>
     <label>
      <input type="radio" name="price" value="50-349"> ₹50 – ₹349
    </label>
    <label>
      <input type="radio" name="price" value="350-599"> ₹350 – ₹599
    </label>
    <label>
      <input type="radio" name="price" value="600-999"> ₹600 – ₹999
    </label>
    <label>
      <input type="radio" name="price" value="1000-99999"> ₹1000+
    </label>

    <hr>

    <h5>Brands</h5>
    <% brands.forEach(brand => { %>
      <label>
        <input type="radio" name="brand" value="<%= brand %>">
        <%= brand %>
      </label>
    <% }) %>

 <input type="hidden" name="search" id="hiddenSearch">
    <input type="hidden" name="sort" id="hiddenSort">

    <button class="btn btn-dark btn-sm w-100 mt-3">
      Apply Filters
    </button>

  </form>
</aside>

  <!-- PRODUCTS -->
  <main class="products">
    <div class="d-flex gap-3 align-items-center justify-content-between">

        <div>

<div class="d-flex gap-2 mb-4">
  <input
    type="text"
    id="searchInput"
    value="<%= search || '' %>"
    class="form-control form-control-sm"
    placeholder="Search cakes...">

  <button type="button" class="btn btn-dark btn-sm" onclick="applyAll()">Search</button>

  <% if (search) { %>
    <a href="/products" class="btn btn-outline-secondary btn-sm">Clear</a>
  <% } %>
</div>
        </div>
        <div>


        <!-- Sort Dropdown -->
        <select
        class="form-select w-auto"
        id="sortOptions"
        style="margin-bottom: 50px;"
        onchange="applyAll()"
        >
        <option value="">Sort By</option>
        <option value="priceLowHigh">Price: Low to High</option>
        <option value="priceHighLow">Price: High to Low</option>
        <option value="az">A - Z</option>
        <option value="za">Z - A</option>
        </select>

        </div>

        </div>

    <div class="row g-4">

      <% if (products.length === 0) { %>
        <p class="text-center text-muted">No products available</p>
      <% } %>

      <% products.forEach(product => { %>

        <div class="col-12 col-sm-6 col-md-4 col-lg-3">
          <a
            href="/product/<%= product._id %>"
            class="text-decoration-none text-dark"
          >
            <div class="card product-card product-card-link">

              <% if (product.productImages && product.productImages.length > 0) { %>
<div class="image-wrapper">

  <% if (product.startingPrice && product.regularPrice) { %>
    <span class="offer-badge">
      <%= Math.round((product.regularPrice - product.startingPrice) / product.regularPrice * 100) %>% OFF
    </span>
  <% } %>

  <img src="<%= product.productImages[0] %>" class="product-img">

</div>
<% } else { %>
                <img src="https://via.placeholder.com/300x200?text=No+Image" class="product-img">
              <% } %>

              <div class="card-body d-flex flex-column">
                <h6 class="fw-semibold mb-1"><%= product.productName %></h6>

                <p class="desc"><%= product.description %></p>

                <div class="mt-auto d-flex align-items-center gap-2">

  <% if (product.startingPrice) { %>

    <!-- NEW PRICE -->
    <span class="price text-danger fw-bold">
      ₹ <%= product.startingPrice %>
    </span>

    <!-- OLD PRICE -->
    <span class="text-muted text-decoration-line-through small">
      ₹ <%= product.regularPrice %>
    </span>



  <% } else { %>

    <span class="text-danger small">Out of stock</span>

  <% } %>

</div>


              </div>
            </div>
          </a>
        </div>


      <% }) %>

    </div>
    <nav class="mt-4">
    <ul class="pagination justify-content-center" style="margin-right: 260px;">
  
      <% for (let i = 1; i <= totalPages; i++) { %>
        <li class="page-item <%= currentPage === i ? 'active' : '' %>">
          <a
           class="page-link"
            href="?page=<%= i %>&search=<%= search || '' %>&sort=<%= sort || '' %>&category=<%= category || '' %>&price=<%= price || '' %>&brand=<%= brand || '' %>">
            <%= i %>
          </a>
        </li>
      <% } %>
  
    </ul>
  </nav>
  </main>


</div>
<script>
  const params = new URLSearchParams(window.location.search);
  
// debounce
function debounce(func, delay) {
  let timer;
  return function () {
    clearTimeout(timer);
    timer = setTimeout(() => {
      func();
    }, delay);
  };
}

const debouncedSearch = debounce(() => {
  applyAll();
}, 500);

// ✅ KEEP ONLY ONE applyAll
function applyAll() {
  document.getElementById("hiddenSearch").value =
    document.getElementById("searchInput").value.trim();
  document.getElementById("hiddenSort").value =
    document.getElementById("sortOptions").value;
  document.getElementById("filterForm").submit();
}

// event
let lastValue = "";

document.getElementById("searchInput").addEventListener("input", function () {
  const currentValue = this.value.trim();

  if (currentValue !== lastValue) {
    lastValue = currentValue;
    debouncedSearch();
  }
}); 

  // Restore sort
  if (params.get("sort"))
    document.getElementById("sortOptions").value = params.get("sort");

  // Restore category radio
  if (params.get("category")) {
    const el = document.querySelector(`input[name="category"][value="${params.get("category")}"]`);
    if (el) el.checked = true;
  }

  // Restore price radio
  if (params.get("price")) {
    const el = document.querySelector(`input[name="price"][value="${params.get("price")}"]`);
    if (el) el.checked = true;
  }

  // Restore brand radio
  if (params.get("brand")) {
    const el = document.querySelector(`input[name="brand"][value="${params.get("brand")}"]`);
    if (el) el.checked = true;
  }

  
  // Intercept Apply Filters button too
  document.getElementById("filterForm").addEventListener("submit", function (e) {
    e.preventDefault();
    applyAll();
  });
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
