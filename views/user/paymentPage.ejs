<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Payment – Cake O'Clock</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --rose: #AF5454;
      --rose-dk: #8c3a3a;
      --rose-lt: #f9eded;
      --rose-mid: #d4807f;
      --cream: #fdf6f0;
      --muted: #8a7070;
      --border: #ecdada;
      --text: #2d1f1f;
    }
    * { box-sizing: border-box; }
    body { font-family: 'DM Sans', sans-serif; background: var(--cream); color: var(--text); min-height: 100vh; }
    h1,h2,h3,h4,h5 { font-family: 'Playfair Display', serif; }

    .page-strip {
      background: linear-gradient(135deg, #fff5f5 0%, #fdf6f0 100%);
      border-bottom: 1px solid var(--border);
      padding: 18px 0 14px;
    }
    .breadcrumb-item a { color: var(--rose); text-decoration: none; font-size: .85rem; }
    .breadcrumb-item.active { color: var(--muted); font-size: .85rem; }
    .page-title { font-size: 1.65rem; color: var(--text); margin: 0; }

    .checkout-card {
      background: #fff;
      border-radius: 18px;
      padding: 26px 28px;
      margin-bottom: 18px;
      box-shadow: 0 2px 14px rgba(175,84,84,.07);
      border: 1px solid #f5eded;
    }
    .card-heading {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 20px; padding-bottom: 14px; border-bottom: 2px solid var(--rose-lt);
    }
    .card-heading h5 {
      font-size: 1.05rem; color: var(--rose); margin: 0;
      display: flex; align-items: center; gap: 8px;
    }
    .card-heading h5::before {
      content: ''; display: inline-block; width: 4px; height: 18px;
      background: var(--rose); border-radius: 4px;
    }

    /* Payment method cards */
    .payment-option {
      display: flex; align-items: center; gap: 16px;
      border: 2px solid var(--border);
      border-radius: 14px;
      padding: 16px 20px;
      margin-bottom: 12px;
      cursor: pointer;
      transition: all .22s ease;
      background: #fff;
      position: relative;
    }
    .payment-option:hover { border-color: var(--rose-mid); background: #fffafa; }
    .payment-option.active {
      border-color: var(--rose);
      background: var(--rose-lt);
      box-shadow: 0 2px 12px rgba(175,84,84,.12);
    }
    .payment-radio {
      width: 20px; height: 20px; border-radius: 50%;
      border: 2px solid var(--border); background: #fff;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0; transition: all .2s;
    }
    .payment-option.active .payment-radio { border-color: var(--rose); background: var(--rose); }
    .payment-option.active .payment-radio::after {
      content: ''; width: 7px; height: 7px; border-radius: 50%; background: #fff;
    }
    .payment-icon { font-size: 1.5rem; flex-shrink: 0; }
    .payment-label { font-weight: 600; font-size: .95rem; }
    .payment-sub { font-size: .8rem; color: var(--muted); margin-top: 2px; }
    .payment-badge {
      margin-left: auto;
      background: var(--rose); color: #fff;
      font-size: .7rem; font-weight: 700;
      border-radius: 6px; padding: 3px 10px;
    }

    /* Wallet balance notice */
    .wallet-low {
      background: #fff8e1; border: 1px solid #ffd54f;
      border-radius: 10px; padding: 10px 14px;
      font-size: .82rem; color: #7a6000;
      margin-top: -4px; margin-bottom: 12px;
      display: none;
    }

    /* Summary sidebar */
    .summary-card {
      background: #fff; border-radius: 18px; padding: 24px;
      box-shadow: 0 2px 14px rgba(175,84,84,.07);
      border: 1px solid #f5eded; position: sticky; top: 20px;
    }
    .summary-title {
      font-size: 1.15rem; color: var(--text);
      margin-bottom: 18px; padding-bottom: 14px;
      border-bottom: 2px solid var(--rose-lt);
    }
    .item-count { font-size: .78rem; color: var(--muted); font-weight: 400; }

    .order-item { display: flex; gap: 12px; padding: 12px 0; border-bottom: 1px solid #f8f0f0; }
    .order-item:last-of-type { border-bottom: none; }
    .item-img { width: 56px; height: 56px; object-fit: cover; border-radius: 10px; flex-shrink: 0; border: 1px solid var(--border); }
    .item-info { flex: 1; min-width: 0; }
    .item-name { font-weight: 600; font-size: .88rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .item-meta { font-size: .76rem; color: var(--muted); margin-top: 2px; }
    .item-price { text-align: right; flex-shrink: 0; }
    .item-price .final { font-weight: 700; font-size: .9rem; }

    .price-breakdown { margin-top: 16px; }
    .price-row { display: flex; justify-content: space-between; font-size: .88rem; padding: 5px 0; }
    .price-row .label { color: var(--muted); }
    .price-row .val { font-weight: 500; }
    .price-row.total-row { border-top: 2px solid var(--border); margin-top: 10px; padding-top: 14px; }
    .price-row.total-row .label { font-weight: 700; font-size: .98rem; color: var(--text); }
    .price-row.total-row .val { font-weight: 800; font-size: 1.15rem; color: var(--rose); }
    .free-badge { background: #e6f4ea; color: #1e7e34; font-size: .75rem; font-weight: 700; border-radius: 20px; padding: 2px 10px; }
    .discount-val { color: #2a8c4a; font-weight: 600; }

    .btn-place {
      background: linear-gradient(135deg, var(--rose) 0%, var(--rose-dk) 100%);
      color: #fff; font-weight: 700; font-size: 1rem;
      padding: 15px; border-radius: 14px; border: none;
      width: 100%; margin-top: 18px; transition: all .22s; letter-spacing: .02em;
    }
    .btn-place:hover { background: linear-gradient(135deg, var(--rose-dk) 0%, #6d2a2a 100%); transform: translateY(-1px); box-shadow: 0 6px 20px rgba(175,84,84,.35); }
    .btn-place:active { transform: translateY(0); }
    .btn-place:disabled { opacity: .65; transform: none; box-shadow: none; cursor: not-allowed; }

    .secure-note { text-align: center; font-size: .75rem; color: var(--muted); margin-top: 10px; display: flex; align-items: center; justify-content: center; gap: 5px; }
    .secure-note::before { content: '🔒'; }

    /* Loading spinner overlay */
    #paymentOverlay {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,0.45); z-index: 9999;
      align-items: center; justify-content: center; flex-direction: column; gap: 16px;
    }
    #paymentOverlay.show { display: flex; }
    .spinner {
      width: 48px; height: 48px; border: 5px solid #fff3;
      border-top-color: #fff; border-radius: 50%; animation: spin .8s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    #paymentOverlay p { color: #fff; font-size: 1rem; font-weight: 600; }

    .steps-bar { display: flex; align-items: center; margin-bottom: 28px; }
    .step { display: flex; align-items: center; gap: 8px; font-size: .82rem; font-weight: 600; color: var(--muted); }
    .step.done { color: var(--rose); }
    .step-dot { width: 28px; height: 28px; border-radius: 50%; border: 2px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: .75rem; font-weight: 700; background: #fff; flex-shrink: 0; }
    .step.done .step-dot { border-color: var(--rose); background: var(--rose); color: #fff; }
    .step-line { flex: 1; height: 2px; background: var(--border); margin: 0 8px; }
    .step.done + .step-line { background: var(--rose); }
  </style>
</head>
<body>

<%- include("../partials/user/h2") %>

<!-- Loading overlay shown during payment processing -->
<div id="paymentOverlay">
  <div class="spinner"></div>
  <p>Processing your payment…</p>
</div>

<div class="page-strip">
  <div class="container">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-1" style="--bs-breadcrumb-divider:'›'">
        <li class="breadcrumb-item"><a href="/">Home</a></li>
        <li class="breadcrumb-item"><a href="/cart">Cart</a></li>
        <li class="breadcrumb-item"><a href="/checkout">Checkout</a></li>
        <li class="breadcrumb-item active">Payment</li>
      </ol>
    </nav>
    <h2 class="page-title">Select Payment</h2>
  </div>
</div>

<div class="container py-4">

  <div class="steps-bar">
    <div class="step done"><div class="step-dot">✓</div><span class="d-none d-sm-inline">Cart</span></div>
    <div class="step-line"></div>
    <div class="step done"><div class="step-dot">✓</div><span class="d-none d-sm-inline">Address</span></div>
    <div class="step-line"></div>
    <div class="step done"><div class="step-dot">3</div><span class="d-none d-sm-inline">Payment</span></div>
    <div class="step-line"></div>
    <div class="step"><div class="step-dot">4</div><span class="d-none d-sm-inline">Done</span></div>
  </div>

  <div class="row g-4 align-items-start">

    <!-- ── LEFT: Payment Methods ── -->
    <div class="col-lg-7">
      <div class="checkout-card">
        <div class="card-heading">
          <h5>Select Payment Method</h5>
        </div>

        <!-- Razorpay -->
        <div class="payment-option active" id="opt-razorpay" onclick="selectPayment('Razorpay', this)">
          <div class="payment-radio"></div>
          <div class="payment-icon">💳</div>
          <div>
            <div class="payment-label">Razorpay</div>
            <div class="payment-sub">Credit / Debit card, UPI, Net Banking, Wallets</div>
          </div>
          <span class="payment-badge">Recommended</span>
        </div>

        <!-- Wallet -->
        <div class="payment-option" id="opt-wallet" onclick="selectPayment('Wallet', this)">
          <div class="payment-radio"></div>
          <div class="payment-icon">👛</div>
          <div>
            <div class="payment-label">Wallet</div>
Balance: ₹<%= walletBalance ? walletBalance.toFixed(2) : '0.00' %>
          </div>
        </div>

        <!-- Wallet low balance warning -->
        <div class="wallet-low" id="walletLowMsg">
          ⚠️ Insufficient wallet balance for this order.
        </div>

        <!-- Cash on Delivery -->
        <div class="payment-option" id="opt-cod" onclick="selectPayment('COD', this)">
          <div class="payment-radio"></div>
          <div class="payment-icon">🎂</div>
          <div>
            <div class="payment-label">Cash on Delivery</div>
            <div class="payment-sub">Pay when your cake arrives</div>
          </div>
        </div>

      </div>
    </div>

    <!-- ── RIGHT: Order Summary ── -->
    <div class="col-lg-5">
      <div class="summary-card">
        <div class="summary-title">
          Order Summary
          <span class="item-count d-block"><%= cartItems.length %> item<%= cartItems.length !== 1 ? 's' : '' %></span>
        </div>

        <% cartItems.forEach(item => {
          const subtotal = item.price * item.quantity;
        %>
          <div class="order-item">
            <img src="<%= item.variantId?.imageUrls?.[0] || item.productId?.productImages?.[0] || '/img/placeholder.png' %>"
                 class="item-img" alt="<%= item.productId?.productName %>">
            <div class="item-info">
              <div class="item-name"><%= item.productId?.productName %></div>
              <div class="item-meta">
                <% if (item.variantId?.weight) { %><%= item.variantId.weight %>g · <% } %>Qty: <%= item.quantity %>
              </div>
            </div>
            <div class="item-price">
              <div class="final">₹<%= subtotal.toLocaleString('en-IN') %></div>
            </div>
          </div>
        <% }) %>

        <div class="price-breakdown">
          <div class="price-row">
            <span class="label">Item Total</span>
            <span class="val">₹<%= totalAmount.toLocaleString('en-IN') %></span>
          </div>
          <% if (couponDiscount > 0) { %>
          <div class="price-row">
            <span class="label">Coupon (<%= couponCode %>)</span>
            <span class="val discount-val">−₹<%= couponDiscount.toLocaleString('en-IN') %></span>
          </div>
          <% } %>
          <div class="price-row">
            <span class="label">Delivery</span>
            <span class="val">
              <% if (deliveryCharge === 0) { %>
                <span class="free-badge">FREE</span>
              <% } else { %>
                ₹<%= deliveryCharge %>
              <% } %>
            </span>
          </div>
          <div class="price-row total-row">
            <span class="label">Total Payable</span>
            <span class="val">₹<%= finalTotal.toLocaleString('en-IN') %></span>
          </div>
        </div>

        <button class="btn-place" id="placeOrderBtn" onclick="handlePlaceOrder()">
          Place Order →
        </button>
        <div class="secure-note">Safe and secure checkout</div>
      </div>
    </div>

  </div>
</div>

<%- include("../partials/user/footer") %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<!-- Razorpay SDK -->
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>
  // ── Data from server ──────────────────────────────────────────────
  const RAZORPAY_KEY   = "<%= razorpayKeyId %>";
  const FINAL_TOTAL    = <%= finalTotal %>;
  const ADDRESS_ID     = "<%= addressId || '' %>";
  const COUPON_CODE    = "<%= couponCode || '' %>";
const WALLET_BALANCE = <%= walletBalance || 0 %>;
  let selectedPaymentMethod = "Razorpay";

  // ── Payment method selection ──────────────────────────────────────
  function selectPayment(method, el) {
    selectedPaymentMethod = method;
    document.querySelectorAll('.payment-option').forEach(o => o.classList.remove('active'));
    el.classList.add('active');

    // Show wallet warning if balance is too low
    const walletMsg = document.getElementById('walletLowMsg');
    if (method === 'Wallet' && WALLET_BALANCE < FINAL_TOTAL) {
      walletMsg.style.display = 'block';
      document.getElementById('placeOrderBtn').disabled = true;
    } else {
      walletMsg.style.display = 'none';
      document.getElementById('placeOrderBtn').disabled = false;
    }
  }

  // ── Main handler ──────────────────────────────────────────────────
  async function handlePlaceOrder() {
    if (selectedPaymentMethod === 'Razorpay') {
      await payWithRazorpay();
    } else {
      // COD or Wallet — submit to existing placeOrder route
      submitCODorWallet();
    }
  }

  // ── COD / Wallet: POST form to /checkout/place ────────────────────
  function submitCODorWallet() {
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = '/checkout/place';

    const fields = {
      addressId:     ADDRESS_ID,
      paymentMethod: selectedPaymentMethod,
      couponCode:    COUPON_CODE,
    };

    Object.entries(fields).forEach(([name, value]) => {
      const input = document.createElement('input');
      input.type = 'hidden';
      input.name = name;
      input.value = value;
      form.appendChild(input);
    });

    document.body.appendChild(form);
    form.submit();
  }

  // ── Razorpay Payment Flow ─────────────────────────────────────────
  async function payWithRazorpay() {
    const btn = document.getElementById('placeOrderBtn');
    btn.disabled = true;
    btn.textContent = 'Initiating payment…';

    try {
      // Step 1: Create order on server
      const res = await fetch('/checkout/create-razorpay-order', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ amount: FINAL_TOTAL }),
      });

      const data = await res.json();

      if (!data.success) {
        throw new Error(data.message || 'Order creation failed');
      }

      // Step 2: Open Razorpay checkout popup
      const options = {
        key:      RAZORPAY_KEY,
        amount:   data.amount,
        currency: data.currency,
        order_id: data.orderId,
        name:     "Cake O' Clock",
        description: "Order Payment",
        theme:    { color: "#AF5454" },

        // Step 3: On payment success
        handler: async function (response) {
          document.getElementById('paymentOverlay').classList.add('show');

          try {
            const verifyRes = await fetch('/checkout/verify-razorpay-payment', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                razorpay_order_id:   response.razorpay_order_id,
                razorpay_payment_id: response.razorpay_payment_id,
                razorpay_signature:  response.razorpay_signature,
                addressId:           ADDRESS_ID,
                couponCode:          COUPON_CODE,
              }),
            });

            const result = await verifyRes.json();

            if (result.success) {
              window.location.href = `/order-success/${result.orderId}`;
            } else {
              document.getElementById('paymentOverlay').classList.remove('show');
              Swal.fire({
                icon: 'error',
                title: 'Verification Failed',
                text: result.message || 'Payment could not be verified. Contact support.',
                confirmButtonColor: '#AF5454',
              });
              btn.disabled = false;
              btn.textContent = 'Place Order →';
            }
          } catch (err) {
            document.getElementById('paymentOverlay').classList.remove('show');
            Swal.fire({ icon: 'error', title: 'Error', text: 'Something went wrong. Please contact support.', confirmButtonColor: '#AF5454' });
            btn.disabled = false;
            btn.textContent = 'Place Order →';
          }
        },

        // Step 4: On modal dismiss
        modal: {
          ondismiss: function () {
            btn.disabled = false;
            btn.textContent = 'Place Order →';
          }
        },

        // Prefill user info
        prefill: {
          name:  "<%= user.name || '' %>",
          email: "<%= user.email || '' %>",
          contact: "<%= user.phone || '' %>",
        },
      };

      const rzp = new Razorpay(options);

      // Step 5: On payment failure
      rzp.on('payment.failed', async function (response) {
        await fetch('/checkout/razorpay-failure', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ error: response.error }),
        });

        Swal.fire({
          icon: 'error',
          title: 'Payment Failed',
          text: response.error.description || 'Your payment was not completed.',
          confirmButtonColor: '#AF5454',
        });

        btn.disabled = false;
        btn.textContent = 'Place Order →';
      });

      rzp.open();

    } catch (err) {
      console.error(err);
      Swal.fire({
        icon: 'error',
        title: 'Could not initiate payment',
        text: err.message || 'Please try again.',
        confirmButtonColor: '#AF5454',
      });
      btn.disabled = false;
      btn.textContent = 'Place Order →';
    }
  }
</script>
</body>
</html>
