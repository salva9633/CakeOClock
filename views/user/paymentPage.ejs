<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Payment – Cake O'Clock</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

  <style>
    /* ── Brand tokens (matches homepage) ── */
    :root {
      --rose:       #C97B8A;
      --rose-dk:    #A85F6E;
      --rose-lt:    #FAE8ED;
      --blush:      #FDF0F3;
      --petal:      #FBE4EC;
      --cream:      #FDF8F5;
      --warm-white: #FFFCFA;
      --caramel:    #D4A574;
      --brown:      #5C3A3A;
      --brown-lt:   #8A6060;
      --muted:      #B08A8A;
      --border:     #F5D8E0;
      --burgundy:   #8B4A5A;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--blush);
      color: var(--brown);
      min-height: 100vh;
    }
    h1,h2,h3,h4,h5 {
      font-family: 'Cormorant Garamond', serif;
    }

    /* ── Page strip ── */
    .page-strip {
      background: linear-gradient(135deg, #FFF0F4 0%, #FDF8F5 100%);
      border-bottom: 1px solid var(--border);
      padding: 18px 0 14px;
      animation: stripIn .5s ease both;
    }
    @keyframes stripIn {
      from { opacity: 0; transform: translateY(-8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .breadcrumb-item a {
      color: var(--rose-dk);
      text-decoration: none;
      font-size: .82rem;
      transition: color .2s;
    }
    .breadcrumb-item a:hover { color: var(--burgundy); }
    .breadcrumb-item.active { color: var(--muted); font-size: .82rem; }
    .page-title {
      font-size: 1.7rem;
      color: var(--brown);
      margin: 6px 0 0;
      font-style: italic;
    }

    /* ── Steps bar ── */
    .steps-bar {
      display: flex;
      align-items: center;
      margin-bottom: 32px;
      animation: fadeUp .5s .05s ease both;
    }
    .step {
      display: flex;
      align-items: center;
      gap: 8px;
      font-size: .8rem;
      font-weight: 600;
      color: var(--muted);
      transition: color .3s;
    }
    .step.done { color: var(--rose-dk); }
    .step-dot {
      width: 30px; height: 30px;
      border-radius: 50%;
      border: 2px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: .72rem;
      font-weight: 700;
      background: var(--warm-white);
      flex-shrink: 0;
      transition: all .3s;
    }
    .step.done .step-dot {
      border-color: var(--rose-dk);
      background: linear-gradient(135deg, var(--rose) 0%, var(--rose-dk) 100%);
      color: #fff;
      box-shadow: 0 4px 12px rgba(168,95,110,.3);
    }
    .step-line {
      flex: 1;
      height: 2px;
      background: var(--border);
      margin: 0 8px;
      border-radius: 2px;
      transition: background .4s;
    }
    .step.done + .step-line { background: var(--rose); }

    /* ── Main checkout card ── */
    .checkout-card {
      background: var(--warm-white);
      border-radius: 22px;
      padding: 28px 30px;
      margin-bottom: 18px;
      border: 1px solid var(--border);
      box-shadow: 0 4px 24px rgba(201,123,138,.08);
      animation: fadeUp .5s .1s ease both;
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .card-heading {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 22px;
      padding-bottom: 16px;
      border-bottom: 1.5px solid var(--border);
    }
    .card-heading-icon {
      width: 36px; height: 36px;
      border-radius: 10px;
      background: var(--rose-lt);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--rose-dk);
      font-size: 1rem;
    }
    .card-heading h5 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--brown);
      margin: 0;
    }

    /* ── Payment options ── */
    .payment-option {
      display: flex;
      align-items: center;
      gap: 16px;
      border: 1.5px solid var(--border);
      border-radius: 16px;
      padding: 16px 20px;
      margin-bottom: 12px;
      cursor: pointer;
      transition: all .25s cubic-bezier(.4,0,.2,1);
      background: var(--warm-white);
      position: relative;
      overflow: hidden;
    }
    .payment-option::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse at left center, rgba(201,123,138,.07), transparent 70%);
      opacity: 0;
      transition: opacity .3s;
    }
    .payment-option:hover { border-color: var(--rose); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(201,123,138,.12); }
    .payment-option:hover::before { opacity: 1; }
    .payment-option.active {
      border-color: var(--rose-dk);
      background: var(--rose-lt);
      box-shadow: 0 4px 18px rgba(168,95,110,.16);
    }
    .payment-option.active::before { opacity: 1; }

    /* Radio dot */
    .payment-radio {
      width: 20px; height: 20px;
      border-radius: 50%;
      border: 2px solid var(--border);
      background: #fff;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: all .2s;
    }
    .payment-option.active .payment-radio {
      border-color: var(--rose-dk);
      background: linear-gradient(135deg, var(--rose), var(--rose-dk));
    }
    .payment-option.active .payment-radio::after {
      content: '';
      width: 7px; height: 7px;
      border-radius: 50%;
      background: #fff;
    }

    /* Icon wrap */
    .payment-icon-wrap {
      width: 46px; height: 46px;
      border-radius: 14px;
      background: var(--rose-lt);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      transition: transform .25s, background .25s;
      color: var(--rose-dk);
      font-size: 1.25rem;
    }
    .payment-option:hover .payment-icon-wrap { transform: scale(1.1) rotate(-4deg); }
    .payment-option.active .payment-icon-wrap {
      background: #fff;
      box-shadow: 0 2px 10px rgba(168,95,110,.15);
    }

    .payment-label { font-weight: 600; font-size: .92rem; color: var(--brown); }
    .payment-sub   { font-size: .78rem; color: var(--muted); margin-top: 3px; }
    .payment-badge {
      margin-left: auto;
      background: linear-gradient(135deg, var(--rose) 0%, var(--rose-dk) 100%);
      color: #fff;
      font-size: .68rem;
      font-weight: 700;
      border-radius: 20px;
      padding: 4px 12px;
      white-space: nowrap;
      flex-shrink: 0;
    }

    /* Wallet low balance */
    .wallet-low {
      background: #fff8e1;
      border: 1px solid #ffd54f;
      border-radius: 10px;
      padding: 10px 14px;
      font-size: .82rem;
      color: #7a6000;
      margin-top: -6px;
      margin-bottom: 12px;
      display: none;
      animation: fadeUp .3s ease;
    }
    .wallet-low i { margin-right: 6px; }

    /* ── Summary card ── */
    .summary-card {
      background: var(--warm-white);
      border-radius: 22px;
      padding: 26px;
      border: 1px solid var(--border);
      box-shadow: 0 4px 24px rgba(201,123,138,.08);
      position: sticky;
      top: 20px;
      animation: fadeUp .5s .18s ease both;
    }
    .summary-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--brown);
      margin-bottom: 16px;
      padding-bottom: 14px;
      border-bottom: 1.5px solid var(--border);
    }
    .item-count { font-size: .76rem; color: var(--muted); font-weight: 400; font-family: 'DM Sans', sans-serif; display: block; margin-top: 3px; }

    .order-item {
      display: flex;
      gap: 12px;
      padding: 12px 0;
      border-bottom: 1px solid var(--rose-lt);
    }
    .order-item:last-of-type { border-bottom: none; }
    .item-img {
      width: 56px; height: 56px;
      object-fit: cover;
      border-radius: 12px;
      flex-shrink: 0;
      border: 1px solid var(--border);
    }
    .item-info { flex: 1; min-width: 0; }
    .item-name {
      font-weight: 600;
      font-size: .87rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      color: var(--brown);
    }
    .item-meta { font-size: .75rem; color: var(--muted); margin-top: 2px; }
    .item-price { text-align: right; flex-shrink: 0; }
    .item-price .final { font-weight: 700; font-size: .9rem; color: var(--brown); }

    .price-breakdown { margin-top: 14px; }
    .price-row { display: flex; justify-content: space-between; font-size: .86rem; padding: 5px 0; }
    .price-row .label { color: var(--muted); }
    .price-row .val { font-weight: 500; color: var(--brown); }
    .price-row.total-row {
      border-top: 1.5px solid var(--border);
      margin-top: 10px;
      padding-top: 14px;
    }
    .price-row.total-row .label { font-weight: 700; font-size: .95rem; color: var(--brown); }
    .price-row.total-row .val {
      font-weight: 800;
      font-size: 1.15rem;
      color: var(--rose-dk);
    }
    .free-badge {
      background: #e6f4ea;
      color: #1e7e34;
      font-size: .73rem;
      font-weight: 700;
      border-radius: 20px;
      padding: 2px 10px;
    }
    .discount-val { color: #2a8c4a; font-weight: 600; }

    /* ── Place Order button ── */
    .btn-place {
      background: linear-gradient(135deg, var(--rose) 0%, var(--rose-dk) 100%);
      color: #fff;
      font-family: 'DM Sans', sans-serif;
      font-weight: 700;
      font-size: .95rem;
      padding: 15px;
      border-radius: 50px;
      border: none;
      width: 100%;
      margin-top: 18px;
      cursor: pointer;
      letter-spacing: .04em;
      transition: all .25s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      box-shadow: 0 6px 22px rgba(168,95,110,.3);
      position: relative;
      overflow: hidden;
    }
    .btn-place::after {
      content: '';
      position: absolute;
      top: 50%; left: 50%;
      width: 0; height: 0;
      background: rgba(255,255,255,.18);
      border-radius: 50%;
      transform: translate(-50%,-50%);
      transition: width .55s ease, height .55s ease, opacity .55s;
    }
    .btn-place:active::after { width: 300px; height: 300px; opacity: 0; }
    .btn-place:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 12px 32px rgba(168,95,110,.42);
    }
    .btn-place:disabled {
      opacity: .6;
      transform: none;
      box-shadow: none;
      cursor: not-allowed;
    }

    .secure-note {
      text-align: center;
      font-size: .72rem;
      color: var(--muted);
      margin-top: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 5px;
    }
    .secure-note i { color: var(--rose); font-size: .75rem; }

    /* ── Loading overlay ── */
    #paymentOverlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(92,58,58,.5);
      backdrop-filter: blur(4px);
      z-index: 9999;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      gap: 18px;
    }
    #paymentOverlay.show { display: flex; }
    .spinner-wrap {
      width: 70px; height: 70px;
      border-radius: 20px;
      background: rgba(255,255,255,.12);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .spinner {
      width: 40px; height: 40px;
      border: 4px solid rgba(255,255,255,.25);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin .75s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    #paymentOverlay p {
      color: #fff;
      font-size: .95rem;
      font-weight: 600;
      letter-spacing: .04em;
    }

    /* ── Wallet balance chip ── */
    .wallet-balance-chip {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      background: var(--rose-lt);
      color: var(--rose-dk);
      font-size: .74rem;
      font-weight: 700;
      border-radius: 20px;
      padding: 2px 10px;
      margin-top: 4px;
    }
  </style>
</head>
<body>

<%- include("../partials/user/h2") %>

<!-- Loading overlay -->
<div id="paymentOverlay">
  <div class="spinner-wrap">
    <div class="spinner"></div>
  </div>
  <p>Processing your payment…</p>
</div>

<!-- Page strip -->
<div class="page-strip">
  <div class="container">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-1" style="--bs-breadcrumb-divider:'›'">
        <li class="breadcrumb-item"><a href="/"><i class="fa-solid fa-house fa-xs me-1"></i>Home</a></li>
        <li class="breadcrumb-item"><a href="/cart">Cart</a></li>
        <li class="breadcrumb-item"><a href="/checkout">Checkout</a></li>
        <li class="breadcrumb-item active">Payment</li>
      </ol>
    </nav>
    <h2 class="page-title">Select Payment</h2>
  </div>
</div>

<div class="container py-4">

  <!-- Steps bar -->
  <div class="steps-bar">
    <div class="step done">
      <div class="step-dot"><i class="fa-solid fa-check" style="font-size:.65rem"></i></div>
      <span class="d-none d-sm-inline">Cart</span>
    </div>
    <div class="step-line"></div>
    <div class="step done">
      <div class="step-dot"><i class="fa-solid fa-check" style="font-size:.65rem"></i></div>
      <span class="d-none d-sm-inline">Address</span>
    </div>
    <div class="step-line"></div>
    <div class="step done">
      <div class="step-dot">3</div>
      <span class="d-none d-sm-inline">Payment</span>
    </div>
    <div class="step-line"></div>
    <div class="step">
      <div class="step-dot">4</div>
      <span class="d-none d-sm-inline">Done</span>
    </div>
  </div>

  <div class="row g-4 align-items-start">

    <!-- LEFT: Payment Methods -->
    <div class="col-lg-7">
      <div class="checkout-card">
        <div class="card-heading">
          <div class="card-heading-icon">
            <i class="fa-solid fa-wallet"></i>
          </div>
          <h5>Select Payment Method</h5>
        </div>

        <!-- Razorpay -->
        <div class="payment-option active" id="opt-razorpay" onclick="selectPayment('Razorpay', this)">
          <div class="payment-radio"></div>
          <div class="payment-icon-wrap">
            <i class="fa-solid fa-credit-card"></i>
          </div>
          <div>
            <div class="payment-label">Razorpay</div>
            <div class="payment-sub">Credit / Debit card, UPI, Net Banking, Wallets</div>
          </div>
          <span class="payment-badge">Recommended</span>
        </div>

        <!-- Wallet -->
        <div class="payment-option" id="opt-wallet" onclick="selectPayment('Wallet', this)">
          <div class="payment-radio"></div>
          <div class="payment-icon-wrap">
            <i class="fa-solid fa-sack-dollar"></i>
          </div>
          <div>
            <div class="payment-label">Wallet</div>
            <div class="wallet-balance-chip">
              <i class="fa-solid fa-coins fa-xs"></i>
              Balance: ₹<%= walletBalance ? walletBalance.toFixed(2) : '0.00' %>
            </div>
          </div>
        </div>

        <!-- Wallet low balance warning -->
        <div class="wallet-low" id="walletLowMsg">
          <i class="fa-solid fa-triangle-exclamation"></i>
          Insufficient wallet balance for this order.
        </div>

        <!-- Cash on Delivery -->
        <div class="payment-option" id="opt-cod" onclick="selectPayment('COD', this)">
          <div class="payment-radio"></div>
          <div class="payment-icon-wrap">
            <i class="fa-solid fa-money-bill-wave"></i>
          </div>
          <div>
            <div class="payment-label">Cash on Delivery</div>
            <div class="payment-sub">Pay when your cake arrives</div>
          </div>
        </div>

      </div>
    </div>

    <!-- RIGHT: Order Summary -->
    <div class="col-lg-5">
      <div class="summary-card">
        <div class="summary-title">
          <i class="fa-solid fa-bag-shopping me-2" style="color:var(--rose);font-size:1rem;font-family:'Font Awesome 6 Free'"></i>
          Order Summary
          <span class="item-count"><%= cartItems.length %> item<%= cartItems.length !== 1 ? 's' : '' %></span>
        </div>

        <% cartItems.forEach(item => {
          const subtotal = item.price * item.quantity;
        %>
          <div class="order-item">
            <img src="<%= item.variantId?.imageUrls?.[0] || item.productId?.productImages?.[0] || '/img/placeholder.png' %>"
                 class="item-img" alt="<%= item.productId?.productName %>">
            <div class="item-info">
              <div class="item-name"><%= item.productId?.productName %></div>
              <div class="item-meta">
                <% if (item.variantId?.weight) { %><%= item.variantId.weight %>g · <% } %>Qty: <%= item.quantity %>
              </div>
            </div>
            <div class="item-price">
              <div class="final">₹<%= subtotal.toLocaleString('en-IN') %></div>
            </div>
          </div>
        <% }) %>

        <div class="price-breakdown">
          <div class="price-row">
            <span class="label">Item Total</span>
            <span class="val">₹<%= totalAmount.toLocaleString('en-IN') %></span>
          </div>
          <% if (couponDiscount > 0) { %>
          <div class="price-row">
            <span class="label">Coupon (<%= couponCode %>)</span>
            <span class="val discount-val">−₹<%= couponDiscount.toLocaleString('en-IN') %></span>
          </div>
          <% } %>
          <div class="price-row">
            <span class="label">Delivery</span>
            <span class="val">
              <% if (deliveryCharge === 0) { %>
                <span class="free-badge">FREE</span>
              <% } else { %>
                ₹<%= deliveryCharge %>
              <% } %>
            </span>
          </div>
          <div class="price-row total-row">
            <span class="label">Total Payable</span>
            <span class="val">₹<%= finalTotal.toLocaleString('en-IN') %></span>
          </div>
        </div>

        <button class="btn-place" id="placeOrderBtn" onclick="handlePlaceOrder()">
          <i class="fa-solid fa-lock fa-xs"></i>
          Place Order
          <i class="fa-solid fa-arrow-right fa-xs"></i>
        </button>
        <div class="secure-note">
          <i class="fa-solid fa-shield-halved"></i>
          Safe and secure checkout
        </div>
      </div>
    </div>

  </div>
</div>

<%- include("../partials/user/footer") %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<!-- ── ALL ORIGINAL LOGIC PRESERVED EXACTLY ── -->
<script>
  const RAZORPAY_KEY   = "<%= razorpayKeyId %>";
  const FINAL_TOTAL    = <%= finalTotal %>;
  const ADDRESS_ID     = "<%= addressId || '' %>";
  const COUPON_CODE    = "<%= couponCode || '' %>";
  const WALLET_BALANCE = <%= walletBalance || 0 %>;
  let selectedPaymentMethod = "Razorpay";

  function selectPayment(method, el) {
    selectedPaymentMethod = method;
    document.querySelectorAll('.payment-option').forEach(o => o.classList.remove('active'));
    el.classList.add('active');
    const walletMsg = document.getElementById('walletLowMsg');
    if (method === 'Wallet' && WALLET_BALANCE < FINAL_TOTAL) {
      walletMsg.style.display = 'block';
      document.getElementById('placeOrderBtn').disabled = true;
    } else {
      walletMsg.style.display = 'none';
      document.getElementById('placeOrderBtn').disabled = false;
    }
  }

  async function handlePlaceOrder() {
    if (selectedPaymentMethod === 'Razorpay') {
      await payWithRazorpay();
    } else {
      submitCODorWallet();
    }
  }

  function submitCODorWallet() {
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = '/checkout/place';
    const fields = { addressId: ADDRESS_ID, paymentMethod: selectedPaymentMethod, couponCode: COUPON_CODE };
    Object.entries(fields).forEach(([name, value]) => {
      const input = document.createElement('input');
      input.type = 'hidden'; input.name = name; input.value = value;
      form.appendChild(input);
    });
    document.body.appendChild(form);
    form.submit();
  }

  async function payWithRazorpay() {
    const btn = document.getElementById('placeOrderBtn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin fa-xs"></i> Initiating payment…';

    try {
      const res = await fetch('/checkout/create-razorpay-order', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ amount: FINAL_TOTAL }),
      });

      const data = await res.json();
      if (!data.success) throw new Error(data.message || 'Order creation failed');

      const options = {
        key:         RAZORPAY_KEY,
        amount:      data.amount,
        currency:    data.currency,
        order_id:    data.orderId,
        name:        "Cake O' Clock",
        description: "Order Payment",
        theme:       { color: "#C97B8A" },

        retry: { enabled: false },
        modal: {
          ondismiss: function () {
            if (!paymentDone) {
              btn.disabled = false;
              btn.innerHTML = '<i class="fa-solid fa-lock fa-xs"></i> Place Order <i class="fa-solid fa-arrow-right fa-xs"></i>';
            }
          },
          animation: false,
        },

        handler: async function (response) {
          document.getElementById('paymentOverlay').classList.add('show');
          try {
            const verifyRes = await fetch('/checkout/verify-razorpay-payment', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                razorpay_order_id:   response.razorpay_order_id,
                razorpay_payment_id: response.razorpay_payment_id,
                razorpay_signature:  response.razorpay_signature,
                addressId:           ADDRESS_ID,
                couponCode:          COUPON_CODE,
              }),
            });
            const result = await verifyRes.json();
            if (result.success) {
              window.location.href = `/order-success/${result.orderId}`;
            } else {
              const reason = encodeURIComponent(result.message || 'Payment could not be verified.');
              window.location.href = `/payment-failed?addressId=${ADDRESS_ID}&couponCode=${COUPON_CODE}&reason=${reason}`;
            }
          } catch (err) {
            const reason = encodeURIComponent('Something went wrong while verifying your payment.');
            window.location.href = `/payment-failed?addressId=${ADDRESS_ID}&couponCode=${COUPON_CODE}&reason=${reason}`;
          }
        },

        prefill: {
          name:    "<%= user.name || '' %>",
          email:   "<%= user.email || '' %>",
          contact: "<%= user.phone || '' %>",
        },
      };

      const rzp = new Razorpay(options);
      let paymentDone = false;

    rzp.on('payment.failed', async function (response) {
  paymentDone = true;
  const reason = encodeURIComponent(
    response.error?.description || 'Your payment could not be processed.'
  );
  rzp.close();

  // ── Save failed order to DB ──
  try {
    await fetch('/checkout/razorpay-failure', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        razorpay_order_id:   response.error?.metadata?.order_id   || data.orderId,
        razorpay_payment_id: response.error?.metadata?.payment_id || '',
        addressId:           ADDRESS_ID,
        couponCode:          COUPON_CODE,
        amount:              FINAL_TOTAL
      })
    });
  } catch (e) {
    console.error('Failed to record failed order:', e);
  }

  window.location.href = `/payment-failed?addressId=${ADDRESS_ID}&couponCode=${COUPON_CODE}&reason=${reason}`;
});
      rzp.open();

    } catch (err) {
      console.error(err);
      btn.disabled = false;
      btn.innerHTML = '<i class="fa-solid fa-lock fa-xs"></i> Place Order <i class="fa-solid fa-arrow-right fa-xs"></i>';
      const reason = encodeURIComponent(err.message || 'Could not initiate payment. Please try again.');
      window.location.href = `/payment-failed?addressId=${ADDRESS_ID}&couponCode=${COUPON_CODE}&reason=${reason}`;
    }
  }
</script>
</body>
</html>
