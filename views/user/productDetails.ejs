<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= product.productName %> | Cake O'Clock</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;0,900;1,600;1,700&family=DM+Sans:wght@300;400;500;600&family=Dancing+Script:wght@700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <style>
:root{
  --rose:    #B85C5C;
  --rose-dk: #A85F6E;
  --rlt:     #FEF2F2;
  --rmid:    #F8D7D7;
  --crm:     #FDF6EE;
  --crm2:    #F9EEE3;
  --mute:    #9A7060;
  --bdr:     #EDD5C0;
  --wh:      #FFFFFF;
  --tr:      all .3s cubic-bezier(.4,0,.2,1);
}
*{box-sizing:border-box;}
body{
  background:linear-gradient(160deg,#fdf0f0 0%,var(--crm) 50%,var(--crm2) 100%);
  font-family:'DM Sans',sans-serif;
  min-height:100vh;
}

/* TOAST */
#toast-container{
  position:fixed;bottom:30px;right:30px;
  z-index:9999;display:flex;flex-direction:column;gap:10px;
}
.toast-msg{
  background:#8B3A62;color:#fff;
  padding:14px 22px;border-radius:14px;
  font-size:.88rem;font-weight:500;
  box-shadow:0 8px 30px rgba(139,58,98,.35);
  display:flex;align-items:center;gap:10px;
  animation:slideUp .35s ease forwards;
  min-width:220px;border-left:4px solid #ffb6d5;
}
.toast-msg.error{ background:#A02850; }
.toast-msg.info{  background:#7A2F55; }
@keyframes slideUp{
  from{opacity:0;transform:translateY(20px);}
  to{  opacity:1;transform:translateY(0);}
}

/* BREADCRUMB */
.bc{font-size:.84rem;color:var(--mute);margin-bottom:28px;}
.bc a{color:var(--mute);text-decoration:none;transition:color .2s;}
.bc a:hover{color:var(--rose);}

/* PRODUCT WRAPPER */
.pw{
  background:rgba(255,255,255,.9);
  backdrop-filter:blur(14px);
  border-radius:28px;
  box-shadow:0 12px 50px rgba(184,92,92,.1);
  padding:48px;margin-bottom:50px;
  border:1px solid rgba(255,255,255,.8);
}

/* GALLERY */
.gallery{display:flex;gap:16px;}
.thumbs{display:flex;flex-direction:column;gap:10px;width:80px;}
.thumbs img{
  width:80px;height:80px;object-fit:cover;
  border-radius:12px;cursor:pointer;
  border:2.5px solid transparent;transition:var(--tr);
}
.thumbs img:hover,.thumbs img.active{
  border-color:var(--rose);transform:scale(1.05);
  box-shadow:0 4px 14px rgba(184,92,92,.25);
}
.main-img-col{flex-grow:1;}
.zoom-box{
  width:100%;height:500px;background:#fdf8f8;
  border-radius:22px;overflow:hidden;
  display:flex;align-items:center;justify-content:center;
  cursor:zoom-in;background-repeat:no-repeat;background-size:0 0;
}
.zoom-box.zooming{background-size:210%;}
.zoom-box.zooming .mimg{opacity:0;}
.mimg{width:100%;height:100%;object-fit:cover;transition:opacity .2s ease;}

/* PRODUCT DETAILS */
.product-title{
  font-family:'Playfair Display',serif;
  font-size:2.4rem;font-weight:700;line-height:1.2;margin-bottom:14px;
}
.meta-row{display:flex;align-items:center;gap:14px;flex-wrap:wrap;margin-bottom:16px;}
.rating-badge{
  background:#fff8e1;color:#d97706;
  padding:5px 13px;border-radius:20px;
  font-weight:700;font-size:.88rem;
  display:inline-flex;align-items:center;gap:4px;
}
.price-block{display:flex;align-items:baseline;gap:14px;margin:22px 0;flex-wrap:wrap;}
.price-main{font-family:'Playfair Display',serif;font-size:2.2rem;font-weight:900;color:var(--rose);}
.price-old{font-size:1.1rem;text-decoration:line-through;color:var(--mute);}
.disc-tag{
  background:var(--rlt);color:var(--rose);
  font-size:.8rem;font-weight:700;padding:3px 10px;
  border-radius:20px;border:1px solid var(--rmid);
}
.desc-text{color:#6b5757;line-height:1.8;font-size:.95rem;margin-bottom:26px;}

/* VARIANTS */
.var-label{font-weight:600;margin-bottom:10px;display:block;font-size:.9rem;}
.wt-btn{
  background:#fff;border:1.5px solid #e5e7eb;
  margin:0 8px 8px 0;border-radius:10px;padding:8px 22px;
  font-size:.88rem;font-weight:500;cursor:pointer;transition:var(--tr);
}
.wt-btn:hover{border-color:var(--rose);color:var(--rose);background:var(--rlt);}
.wt-btn.active{background:var(--rose);color:#fff;border-color:var(--rose);box-shadow:0 4px 16px rgba(184,92,92,.35);}

/* QTY */
.qty-wrap{
  display:flex;align-items:center;
  border:1.5px solid #e5e7eb;border-radius:12px;
  overflow:hidden;width:fit-content;margin-bottom:8px;
}
.qty-btn{
  width:38px;height:38px;background:#fafafa;
  border:none;font-size:1.1rem;cursor:pointer;transition:var(--tr);
}
.qty-btn:hover{background:var(--rmid);color:var(--rose);}
.qty-disp{
  width:44px;text-align:center;font-weight:600;font-size:.95rem;
  border:none;border-left:1.5px solid #e5e7eb;border-right:1.5px solid #e5e7eb;
  height:38px;line-height:38px;
}

/* ACTIONS */
.action-group{display:flex;gap:12px;margin-top:8px;}
.btn-cart{
  flex:1;max-width:220px;background:var(--rose);color:#fff;
  border:none;padding:14px 28px;border-radius:14px;
  font-weight:600;font-size:.97rem;transition:var(--tr);
  box-shadow:0 4px 20px rgba(184,92,92,.35);
  display:flex;align-items:center;justify-content:center;gap:8px;cursor:pointer;
}
.btn-cart:hover:not(:disabled){background:#A85F6E;transform:translateY(-2px);box-shadow:0 8px 28px rgba(184,92,92,.45);}
.btn-cart:disabled{background:#ccc;box-shadow:none;cursor:not-allowed;}
.btn-wish{
  width:50px;height:50px;border-radius:14px;
  border:1.5px solid #A85F6E;background:var(--rose);
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;transition:var(--tr);color:var(--mute);font-size:1.1rem;flex-shrink:0;
}
.btn-wish:hover{border-color:var(--rose);color:var(--rose);background:var(--rlt);}
.btn-wish.wishlisted{border-color:var(--rose);background:var(--rose);color:#fff;}

/* FEATURES */
.features{display:flex;gap:18px;flex-wrap:wrap;margin-top:28px;padding-top:26px;border-top:1px solid var(--bdr);}
.feat{display:flex;align-items:center;gap:10px;font-size:.83rem;color:var(--mute);}
.feat-ic{
  width:36px;height:36px;border-radius:50%;
  background:var(--crm2);color:var(--rose);
  display:flex;align-items:center;justify-content:center;font-size:.82rem;
}

/* SECTION TITLE */
.sec-title{
  font-family:'Playfair Display',serif;font-weight:900;font-size:1.75rem;
  position:relative;display:inline-block;margin-bottom:36px;
}
.sec-title::after{
  content:'';position:absolute;bottom:-10px;left:50%;transform:translateX(-50%);
  width:50px;height:3px;background:var(--rose);border-radius:2px;
}

/* REVIEWS */
.reviews-wrap{
  background:#fff;border-radius:24px;padding:40px;
  box-shadow:0 6px 30px rgba(184,92,92,.08);
  max-width:960px;margin:auto;
}
.review-item{padding-bottom:18px;border-bottom:1px solid #f5eded;}
.review-item:last-child{border-bottom:none;}
.review-avatar{
  width:46px;height:46px;border-radius:50%;
  background:var(--rmid);color:var(--rose-dk);
  display:flex;align-items:center;justify-content:center;
  font-weight:700;font-size:.95rem;flex-shrink:0;
}
.review-input{
  background:#fdf8f8;border:1.5px solid #ecdede;
  border-radius:14px;padding:14px;resize:none;
  transition:var(--tr);font-family:'DM Sans',sans-serif;
}
.review-input:focus{background:#fff;border-color:var(--rose);box-shadow:0 0 0 4px rgba(184,92,92,.1);outline:none;}
.star-rating{display:flex;gap:6px;margin-bottom:14px;}
.star-rating i{font-size:1.3rem;color:#ddd;cursor:pointer;transition:color .2s;}
.star-rating i.active{color:#f59e0b;}
.btn-post{
  background:var(--rose);color:#fff;border:none;
  border-radius:12px;padding:10px 28px;
  font-weight:600;font-size:.9rem;transition:var(--tr);cursor:pointer;
}
.btn-post:hover{background:var(--rose-dk);transform:translateY(-1px);}

/* REVIEW GUARD BOXES */
.review-guard-box{
  border-radius:14px;padding:18px 22px;text-align:center;margin-bottom:4px;
}
.review-guard-box i{ font-size:1.4rem;margin-bottom:8px;display:block; }
.review-guard-box p{ margin:0;font-size:.9rem; }

/* RELATED CARDS */
.rel-card{
  background:#fff;border-radius:18px;overflow:hidden;
  height:100%;box-shadow:0 6px 22px rgba(0,0,0,.06);
  transition:var(--tr);display:flex;flex-direction:column;
}
.rel-card:hover{transform:translateY(-10px);box-shadow:0 18px 44px rgba(184,92,92,.14);}
.rel-img{height:190px;overflow:hidden;background:#fdf8f8;}
.rel-img img{width:100%;height:100%;object-fit:cover;transition:transform .5s;}
.rel-card:hover .rel-img img{transform:scale(1.08);}
.rel-body{padding:18px;display:flex;flex-direction:column;flex-grow:1;}
.rel-title{font-size:.97rem;font-weight:600;color:#8B4A5A;margin-bottom:6px;line-height:1.3;}
.rel-stars{ display:flex;align-items:center;gap:3px;margin-bottom:8px; }
.rel-stars i{ font-size:.68rem;color:#f59e0b; }
.rel-stars i.empty{ color:#ddd; }
.rel-stars .rev-ct{ font-size:.7rem;color:#9a7060;margin-left:2px; }
.pr-row{display:flex;align-items:center;gap:8px;margin-bottom:12px;}
.pr-v{font-size:1.05rem;font-weight:700;color:var(--rose);}
.pr-o{font-size:.83rem;color:#9ca3af;text-decoration:line-through;}
.btn-view{
  border:1.5px solid var(--rose);color:var(--rose);
  background:transparent;border-radius:20px;
  padding:7px 0;font-size:.85rem;font-weight:600;
  transition:var(--tr);width:100%;margin-top:auto;cursor:pointer;
}
.btn-view:hover{background:var(--rose);color:#fff;}

/* RESPONSIVE */
@media(max-width:768px){
  .gallery{flex-direction:column-reverse;}
  .thumbs{flex-direction:row;width:100%;overflow-x:auto;}
  .thumbs img{width:60px;height:60px;}
  .zoom-box{height:320px;}
  .pw{padding:22px;}
  .product-title{font-size:1.7rem;}
}
/* ── Related Product Cards ── */
.rel-card {
  background: #fff;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 2px 12px rgba(0,0,0,0.08);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.rel-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.13);
}

/* Image wrapper */
.rel-img-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 4/3;
  overflow: hidden;
}
.rel-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Category badge (top-left, on image) */
.rel-badge {
  position: absolute;
  top: 12px;
  left: 12px;
  background: rgba(255,255,255,0.92);
  color: #7a3a52;
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  padding: 4px 10px;
  border-radius: 20px;
}

/* Wishlist heart (top-right) */
.rel-wish {
  position: absolute;
  top: 10px;
  right: 10px;
  background: #fff;
  border: none;
  border-radius: 50%;
  width: 34px;
  height: 34px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  box-shadow: 0 2px 6px rgba(0,0,0,0.12);
  color: #c0608a;
  font-size: 0.95rem;
  transition: color 0.2s;
}
.rel-wish:hover { color: #a0335f; }

/* Card body */
.rel-body {
  padding: 14px 16px 18px;
}

/* Category label text */
.rel-cat {
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: #c0608a;
  margin: 0 0 4px;
}

/* Product name */
.rel-title {
  font-size: 1rem;
  font-weight: 700;
  color: #1a1a1a;
  margin: 0 0 8px;
  line-height: 1.3;
}

/* Stars */
.rel-stars {
  display: flex;
  align-items: center;
  gap: 2px;
  margin-bottom: 10px;
  flex-wrap: wrap;
}
.rel-stars .fas.fa-star,
.rel-stars .fas.fa-star-half-alt {
  color: #f5a623;
  font-size: 0.85rem;
}
.rel-stars .far.fa-star.empty {
  color: #ddd;
  font-size: 0.85rem;
}
.rev-ct {
  font-size: 0.78rem;
  color: #888;
  margin-left: 4px;
}

/* Price row */
.pr-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 14px;
  flex-wrap: wrap;
}
.pr-v {
  font-size: 1.25rem;
  font-weight: 800;
  color: #1a1a1a;
  font-family: serif;
}
.pr-o {
  font-size: 0.9rem;
  color: #aaa;
  text-decoration: line-through;
}
.pr-disc {
  background: #fce4ec;
  color: #c0608a;
  font-size: 0.72rem;
  font-weight: 700;
  padding: 3px 9px;
  border-radius: 20px;
}

/* Add to Cart button */
.btn-cart {
  width: 100%;
  background: #7a3a52;
  color: #fff;
  border: none;
  border-radius: 10px;
  padding: 11px 0;
  font-size: 0.9rem;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  transition: background 0.2s;
}
.btn-cart:hover { background: #5e2a3d; }

/* ── Shop-style Related Product Cards (matches /products page card design) ── */
.p-card {
  background: #fff;
  border-radius: 18px;
  box-shadow: 0 3px 16px rgba(194,96,122,.08);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  border: 1px solid rgba(240,212,219,.6);
  transition: box-shadow .35s, transform .35s;
  text-decoration: none;
  color: inherit;
}
.p-card:hover { box-shadow: 0 14px 40px rgba(194,96,122,.2); transform: translateY(-6px); }

.card-img-zone { position: relative; overflow: hidden; height: 195px; background: #fce8ed; }
.card-img-zone img { width: 100%; height: 100%; object-fit: cover; transition: transform .5s ease; }
.p-card:hover .card-img-zone img { transform: scale(1.08); }
.card-img-zone.oos-img img { filter: grayscale(.4) brightness(.95); }

.img-badge-tl {
  position: absolute; top: 10px; left: 10px;
  font-size: .6rem; font-weight: 800; letter-spacing: .09em; text-transform: uppercase;
  padding: 4px 11px; border-radius: 20px; z-index: 4; pointer-events: none;
}
.img-badge-tl.oos { background: #e02d2d; color: #fff; border-radius: 6px; font-size: .72rem; padding: 6px 16px; letter-spacing: .08em; }

.offer-pill {
  position: absolute; top: 10px; left: 10px;
  background: #8b3a52; color: #fff;
  font-size: .6rem; font-weight: 800; letter-spacing: .06em;
  padding: 4px 9px; border-radius: 20px; z-index: 4; pointer-events: none;
}

.img-cat-strip {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 32px 11px 10px;
  background: linear-gradient(to top, rgba(43,10,20,.58) 0%, transparent 100%);
  pointer-events: none; z-index: 3;
}
.img-cat-label {
  display: inline-block; background: rgba(255,255,255,.90); color: #8B3A52;
  font-size: .59rem; font-weight: 800; letter-spacing: .1em; text-transform: uppercase;
  padding: 3px 10px; border-radius: 20px; backdrop-filter: blur(3px);
}

.shop-wish-btn {
  position: absolute; top: 9px; right: 9px; width: 32px; height: 32px;
  background: rgba(255,255,255,.92); border: none; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; box-shadow: 0 2px 9px rgba(0,0,0,.12); z-index: 4;
  transition: background .2s, transform .2s; color: #C2607A; font-size: .8rem;
}
.shop-wish-btn:hover { background: #C2607A; color: #fff; transform: scale(1.12); }

.card-body-inner { padding: 13px 14px 14px; display: flex; flex-direction: column; flex: 1; }
.card-name {
  font-family: 'Playfair Display', serif; font-size: .98rem; font-weight: 600;
  color: #2d1a20; line-height: 1.3; margin-bottom: 3px;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  transition: color .2s;
}
.p-card:hover .card-name { color: #C2607A; }

.card-meta-row { display: flex; align-items: center; gap: 8px; margin-bottom: 5px; flex-wrap: wrap; }
.meta-cat { font-size: .68rem; font-weight: 600; color: #9a6b75; letter-spacing: .03em; }

.card-stars { display: flex; align-items: center; gap: 1px; margin-bottom: 8px; }
.card-stars i { font-size: .68rem; color: #f59e0b; }
.card-stars i.empty { color: #e8d0d5; }
.card-stars .rev-info { font-size: .7rem; color: #b09090; margin-left: 5px; }

.pricing-row { display: flex; align-items: center; gap: 7px; margin-bottom: 5px; flex-wrap: wrap; }
.price-now { font-family: 'Playfair Display', serif; font-size: 1.1rem; font-weight: 900; color: #C2607A; }
.card-price-old { font-size: .75rem; color: #c0a0a8; text-decoration: line-through; }

.card-actions { display: flex; gap: 7px; margin-top: auto; padding-top: 9px; }
.shop-atc-btn {
  flex: 1; padding: 9px 10px; border: none; border-radius: 10px;
  font-family: 'DM Sans', sans-serif; font-size: .79rem; font-weight: 700; letter-spacing: .04em;
  cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 5px;
  transition: background .2s, transform .15s, box-shadow .2s;
  background: #8B3A52; color: #fff;
}
.shop-atc-btn:hover { background: #C2607A; transform: translateY(-1px); box-shadow: 0 4px 14px rgba(194,96,122,.35); }
.shop-atc-btn.disabled-oos { background: #ede0e4; color: #b09090; cursor: not-allowed; }
/* ── Related card entrance + hover polish ── */
@keyframes relCardIn {
  from { opacity: 0; transform: translateY(18px); }
  to   { opacity: 1; transform: translateY(0); }
}
.p-card {
  animation: relCardIn .5s ease both;
}
.p-card:nth-child(1) { animation-delay: .05s; }
.p-card:nth-child(2) { animation-delay: .12s; }
.p-card:nth-child(3) { animation-delay: .19s; }
.p-card:nth-child(4) { animation-delay: .26s; }

.card-img-zone::after {
  content: '';
  position: absolute; inset: 0;
  background: linear-gradient(180deg, rgba(0,0,0,0) 60%, rgba(0,0,0,.08) 100%);
  opacity: 0; transition: opacity .35s ease;
  pointer-events: none; z-index: 2;
}
.p-card:hover .card-img-zone::after { opacity: 1; }

/* ── Image hover "View Product" overlay ── */
.img-hover-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(180deg, rgba(43,10,20,0) 35%, rgba(43,10,20,.55) 100%);
  display: flex; align-items: flex-end; justify-content: center;
  padding-bottom: 16px;
  opacity: 0; transform: translateY(8px);
  transition: opacity .3s ease, transform .3s ease;
  z-index: 3; pointer-events: none;
}
.p-card:hover .img-hover-overlay {
  opacity: 1; transform: translateY(0);
}
.view-product-pill {
  display: inline-flex; align-items: center; gap: 7px;
  background: #fff; color: #8B3A52;
  font-family: 'DM Sans', sans-serif; font-size: .76rem; font-weight: 700; letter-spacing: .04em;
  padding: 9px 18px; border-radius: 30px;
  box-shadow: 0 4px 14px rgba(0,0,0,.25);
  transition: background .25s, color .25s, transform .25s;
}
.p-card:hover .view-product-pill {
  animation: pillPop .35s ease;
}
@keyframes pillPop {
  0%   { transform: scale(.85); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}
  </style>
</head>
<body>

<%- include("../../views/partials/user/h2") %>

<div id="toast-container"></div>

<div class="container py-5">

  <!-- Breadcrumb -->
  <div class="bc">
    <a href="/">Home</a>
    <span class="mx-2">/</span>
    <a href="/products">Shop</a>
    <span class="mx-2">/</span>
    <span><%= product.productName %></span>
  </div>

  <!-- PRODUCT WRAPPER -->
<!-- BLOCKED PRODUCT CHECK -->
  <% if (locals.blocked) { %>
  <div style="
    min-height:60vh; display:flex; align-items:center; justify-content:center;
    flex-direction:column; text-align:center; padding:60px 24px;
  ">
    <div style="font-size:3.5rem; margin-bottom:16px;">🚫</div>
    <h2 style="font-family:'Playfair Display',serif; color:#8b3a52;
               font-size:1.9rem; margin-bottom:10px;">Product Unavailable</h2>
    <p style="color:#7a5c5c; font-size:1rem; max-width:400px; line-height:1.6;">
      This product is currently unavailable and cannot be purchased at this time.
      Please check back later or explore similar products.
    </p>
    <a href="/products" style="
      margin-top:28px; padding:12px 36px; border-radius:12px;
      background:linear-gradient(135deg,#8b3a52,#d97f9a);
      color:#fff; font-weight:700; font-size:.92rem;
      text-decoration:none; box-shadow:0 4px 14px rgba(175,84,84,.3);">
      ← Back to Shop
    </a>
  </div>
  <% } else { %>

  <!-- PRODUCT WRAPPER -->
  <div class="pw">    <div class="row align-items-start gx-5">

      <!-- Gallery -->
      <div class="col-lg-7 mb-5 mb-lg-0">
        <div class="gallery">
          <div class="thumbs">
            <% product.productImages.forEach((img,i) => { %>
              <img src="<%= img %>" class="<%= i===0?'active':'' %>"
                onclick="changeMainImage('<%= img %>',this)" alt="Thumb">
            <% }) %>
          </div>
          <div class="main-img-col">
            <div class="zoom-box" id="zoomBox">
              <img id="mainProductImage" src="<%= product.productImages[0] %>" class="mimg" alt="<%= product.productName %>">
            </div>
          </div>
        </div>
      </div>

      <!-- Details -->
      <div class="col-lg-5">
<h1 class="product-title"><%= product.productName %></h1>

<div class="mb-3">
  <p style="margin-bottom:4px;color:#7a5c5c;font-size:.9rem;">
    <strong>Category:</strong>
<%= product.categoryId?.categoryName || product.categoryId?.name || "N/A" %>  </p>

  <p style="margin-bottom:0;color:#7a5c5c;font-size:.9rem;">
    <strong>Brand:</strong>
    <%= product.brand || "N/A" %>
  </p>
</div>

        <!-- Meta row: stars + stock -->
        <div class="meta-row">
          <span class="rating-badge">
            <%
              const avg = parseFloat(avgRating) || 0;
              for (let i = 1; i <= 5; i++) {
                const d = avg - (i - 1);
                if      (d >= 0.75) { %><i class="fas fa-star"          style="color:#f59e0b"></i><%
                } else if (d >= 0.25) { %><i class="fas fa-star-half-alt" style="color:#f59e0b"></i><%
                } else               { %><i class="far fa-star"          style="color:#e0c8a0"></i><% }
              }
            %>
            <strong style="margin-left:5px"><%= avgRating %></strong>
          </span>
          <span style="color:var(--mute);font-size:.88rem;">
            <%= totalReviews %> Review<%= totalReviews !== 1 ? 's' : '' %>
          </span>
          <span id="stock-status"
            class="fw-semibold <%= initialStock > 0 ? 'text-success' : 'text-danger' %>"
            style="font-size:.88rem;">
            <% if (initialStock > 0) { %>
              <i class="fas fa-check-circle me-1"></i> In Stock
            <% } else { %>
              <i class="fas fa-times-circle me-1"></i> Out of Stock
            <% } %>
          </span>
        </div>

        <!-- Price -->
        <div class="price-block">
  <span class="price-main">
    ₹<span id="current-price"><%= offerData.finalPrice %></span>
  </span>
  <span class="price-old" id="old-price">
    ₹<%= selectedVariant.regularPrice %>
  </span>

  <% if (offerData.bestOffer > 0) { %>
    <% if (offerData.activeOfferLabel === 'category') { %>
      <span class="disc-tag" id="discount-percent"
        title="Category Offer applied — bigger than product offer">
        <%= offerData.bestOffer %>% OFF 🏷️
      </span>
    <% } else { %>
      <span class="disc-tag" id="discount-percent"
        title="Product Offer">
        <%= offerData.bestOffer %>% OFF 🎁
      </span>
    <% } %>
  <% } else { %>
  <span class="disc-tag" id="discount-percent">
    Best Price
  </span>
<% } %>
</div>

        <p class="desc-text"><%= product.longDescription || product.description %></p>

        <!-- Variants -->
        <div class="mb-3">
          <label class="var-label">Choose Weight</label>
          <div class="d-flex flex-wrap">
            <% variants.forEach(v => { %>
              <button class="wt-btn <%= v._id.toString() === selectedVariant._id.toString() ? 'active' : '' %>"
                data-variant="<%= v._id %>">
                <%= v.weight %>g
              </button>
            <% }) %>
          </div>
        </div>

        <!-- Quantity -->
        <label class="var-label">Quantity</label>
        <div class="qty-wrap">
          <button class="qty-btn" onclick="changeQty(-1)">−</button>
          <div class="qty-disp" id="qty-display">1</div>
          <button class="qty-btn" onclick="changeQty(1)">+</button>
        </div>
        <p style="font-size:.74rem;color:#b09090;margin-bottom:22px;">Max 5 per order</p>

        <!-- Actions -->
        <div class="action-group">
          <button id="add-to-cart-btn" class="btn-cart" onclick="addToCart()"
            <%= initialStock === 0 ? 'disabled' : '' %>>
            <% if (initialStock > 0) { %>
              <i class="fas fa-shopping-bag"></i> Add to Cart
            <% } else { %>Out of Stock<% } %>
          </button>
      <button id="wishlist-btn" class="btn-wish <%= locals.isWishlisted ? 'wishlisted' : '' %>" onclick="toggleWishlist()" title="Wishlist">
            <i class="<%= locals.isWishlisted ? 'fas' : 'far' %> fa-heart" id="wishlist-icon"></i>
          </button>
        </div>

        <!-- Features -->
        <div class="features">
          <div class="feat"><div class="feat-ic"><i class="fas fa-truck"></i></div><span>Fast Delivery</span></div>
          <div class="feat"><div class="feat-ic"><i class="fas fa-shield-alt"></i></div><span>Secure Payment</span></div>
          <div class="feat"><div class="feat-ic"><i class="fas fa-undo"></i></div><span>Easy Returns</span></div>
          <div class="feat"><div class="feat-ic"><i class="fas fa-leaf"></i></div><span>Fresh Ingredients</span></div>
        </div>
      </div>
    </div>
  </div>

  <!-- ══════════════ REVIEWS ══════════════ -->
  <div class="row mt-2 justify-content-center">
    <div class="col-12 col-lg-10">
      <h3 class="sec-title d-block text-center">Customer Reviews</h3>
      <div class="reviews-wrap">

        <!-- Existing reviews list -->
        <div id="reviews-container">
          <% if (reviews.length === 0) { %>
            <div class="text-center py-5 text-muted" id="no-reviews-msg">
              <i class="fas fa-comment-slash fs-2 mb-3 d-block" style="color:#e0c8c8"></i>
              <p class="mb-0">No reviews yet. Be the first!</p>
            </div>
          <% } %>

          <% reviews.forEach(r => { %>
            <div class="d-flex align-items-start gap-3 mb-4 review-item">
              <div class="review-avatar"><%= r.userId.name[0].toUpperCase() %></div>
              <div class="w-100">
                <div class="d-flex justify-content-between align-items-center">
                  <h6 class="fw-bold mb-0"><%= r.userId.name %></h6>
                  <small class="text-muted"><%= new Date(r.createdAt).toDateString() %></small>
                </div>
                <div class="text-warning small my-1">
                  <%= "★".repeat(r.rating || 5) %><%= "☆".repeat(5 - (r.rating || 5)) %>
                </div>
                <p class="text-muted mb-0" style="font-size:.9rem"><%= r.comment %></p>
              </div>
            </div>
          <% }) %>
        </div>

        <!-- Show all reviews -->
        <% if (totalReviews > 3) { %>
          <div class="text-center mt-3" id="show-all-wrapper">
            <button onclick="loadAllReviews()" class="btn btn-sm px-4 rounded-pill"
              style="border:1.5px solid var(--rose);color:var(--rose);">
              Show all <%= totalReviews %> reviews
            </button>
          </div>
        <% } %>

        <!-- Write a Review -->
        <div class="mt-4 pt-4 border-top">
          <h6 class="fw-bold mb-3">Write a Review</h6>

          <% if (!isLoggedIn) { %>
            <!-- Not logged in -->
            <div class="review-guard-box" style="background:#fdf5f2;border:1.5px solid #edd5c0;">
              <i class="fas fa-lock" style="color:#B85C5C;"></i>
              <p style="color:#7d5050;">
                Please <a href="/login" style="color:#B85C5C;font-weight:700;">login</a> to write a review.
              </p>
            </div>

          <% } else if (!canReview) { %>
            <!-- Logged in but no delivered order -->
            <div class="review-guard-box" style="background:#fdf5f2;border:1.5px solid #edd5c0;">
              <i class="fas fa-shopping-bag" style="color:#B85C5C;"></i>
              <p style="color:#7d5050;">
                Only customers who have <strong>received a delivered order</strong>
                of this product can leave a review.
              </p>
            </div>

          <% } else { %>
            <!-- Eligible — show review form (can post multiple times) -->
            <div class="star-rating mb-3" id="star-rating">
              <i class="far fa-star" data-val="1"></i>
              <i class="far fa-star" data-val="2"></i>
              <i class="far fa-star" data-val="3"></i>
              <i class="far fa-star" data-val="4"></i>
              <i class="far fa-star" data-val="5"></i>
            </div>
            <textarea id="reviewText" class="form-control review-input" rows="3"
              placeholder="Share your experience with this cake…"></textarea>
            <button onclick="submitReview()" class="btn-post mt-3">
              <i class="fas fa-paper-plane me-2"></i>Post Review
            </button>
          <% } %>

        </div>
      </div>
    </div>
  </div>

<!-- ══════════════ RELATED PRODUCTS ══════════════ -->
<div class="mt-5 pt-4">
  <h3 class="sec-title d-block text-center">You May Also Like</h3>
  <div class="row g-4 mt-2">
    <% relatedProducts.forEach(p => { %>
     <%
        const rIsOos = (p.startingPrice === null);
        const rDisc  = p.discountPercent || 0;
      %>
      <div class="col-12 col-sm-6 col-md-4 col-lg-3">
        <a href="/product/<%= p._id %>" class="p-card">

          <div class="card-img-zone <%= rIsOos ? 'oos-img' : '' %>">
            <% if (rIsOos) { %>
              <span class="img-badge-tl oos">OUT OF STOCK</span>
            <% } else if (rDisc > 0) { %>
              <span class="offer-pill"><%= rDisc %>% OFF</span>
            <% } %>

          <% if (p.productImages && p.productImages.length > 0) { %>
              <img src="<%= p.productImages[0] %>" alt="<%= p.productName %>" loading="lazy">
            <% } else { %>
              <img src="https://placehold.co/400x280/fde2d9/C2607A?text=" alt="No image">
            <% } %>

            <!-- <div class="img-hover-overlay">
              <span class="view-product-pill">
                <i class="fas fa-eye"></i> View Product
              </span>
            </div> -->
            <% if (p.category) { %>
              <div class="img-cat-strip">
                <span class="img-cat-label"><%= p.category %></span>
              </div>
            <% } %>
          </div>

          <div class="card-body-inner">
            <div class="card-name"><%= p.productName %></div>

           <% if (p.category || p.brand) { %>
              <div class="card-meta-row">
                <% if (p.category) { %>
                  <span class="meta-cat"><i class="fas fa-tag" style="font-size:.55rem;margin-right:3px;"></i><%= p.category %></span>
                <% } %>
                <% if (p.brand) { %>
                  <span class="meta-cat">· <%= p.brand %></span>
                <% } %>
              </div>
            <% } %>

            <div class="card-stars">
              <%
                const rAvg = parseFloat(p.avgRating) || 0;
                for (let i = 1; i <= 5; i++) {
                  const d = rAvg - (i - 1);
              %>
                <% if (d >= 0.75) { %>
                  <i class="fas fa-star"></i>
                <% } else if (d >= 0.25) { %>
                  <i class="fas fa-star-half-alt"></i>
                <% } else { %>
                  <i class="far fa-star empty"></i>
                <% } %>
              <% } %>
              <span class="rev-info"><%= rAvg.toFixed(1) %> (<%= p.totalReviews || 0 %> reviews)</span>
            </div>

       

            <div class="pricing-row">
              <% if (!rIsOos) { %>
                <span class="price-now">₹<%= Math.round(p.startingPrice) %></span>
              <% if (rDisc > 0) { %>
                  <span class="card-price-old">₹<%= p.regularPrice %></span>
                <% } %>
              <% } else { %>
                <span style="font-size:.76rem;color:#b09090;">Currently unavailable</span>
              <% } %>
            </div>

          
          </div>

        </a>
      </div>
    <% }) %>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
/* TOAST */
function showToast(msg, type = 'success') {
  const icons = { success:'fa-check-circle', error:'fa-times-circle', info:'fa-info-circle' };
  const tc = document.getElementById('toast-container');
  const t  = document.createElement('div');
  t.className = `toast-msg ${type}`;
  t.innerHTML = `<i class="fas ${icons[type] || icons.success}"></i> ${msg}`;
  tc.appendChild(t);
  setTimeout(() => t.remove(), 3200);
}

/* QUANTITY */
const MAX_QTY = 5;
let qty = 1;

function changeQty(d) {
  const next = qty + d;
  if (next < 1) return;
  if (next > MAX_QTY) {
    Swal.fire({ icon:'warning', title:'Limit Reached',
      text:`You can only order up to ${MAX_QTY} of the same item per order.`,
      confirmButtonColor:'#B85C5C' });
    return;
  }
  qty = next;
  document.getElementById('qty-display').textContent = qty;
}

/* VARIANT SELECTOR */
let selectedVariantId = '<%= selectedVariant._id %>';

document.querySelectorAll('.wt-btn').forEach(btn => {
  btn.addEventListener('click', async () => {
    document.querySelectorAll('.wt-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    selectedVariantId = btn.getAttribute('data-variant');
    try {
      const res  = await fetch(`/variant/${selectedVariantId}`);
      const data = await res.json();
      if (data.success) {
        document.getElementById('current-price').textContent = data.salePrice;
        document.getElementById('old-price').textContent     = `₹${data.regularPrice}`;
        const disc = Math.round((data.regularPrice - data.salePrice) / data.regularPrice * 100);
        document.getElementById('discount-percent').textContent = `${disc}% OFF`;

        const sEl  = document.getElementById('stock-status');
        const cBtn = document.getElementById('add-to-cart-btn');
        if (data.stock === 0) {
          sEl.innerHTML  = '<i class="fas fa-times-circle me-1"></i> Out of Stock';
          sEl.className  = 'fw-semibold text-danger';
          cBtn.disabled  = true;
          cBtn.innerHTML = 'Out of Stock';
        } else {
          sEl.innerHTML  = '<i class="fas fa-check-circle me-1"></i> In Stock';
          sEl.className  = 'fw-semibold text-success';
          cBtn.disabled  = false;
          cBtn.innerHTML = '<i class="fas fa-shopping-bag"></i> Add to Cart';
        }
      }
    } catch(err) { console.error(err); }
  });
});

/* ADD TO CART */
async function addToCart() {
  if (qty < 1 || qty > MAX_QTY) { showToast('Invalid quantity.', 'error'); return; }
  const btn = document.getElementById('add-to-cart-btn');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Adding…';

  try {
    const res  = await fetch('/cart/add', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ productId: '<%= product._id %>', variantId: selectedVariantId, quantity: qty })
    });
    const data = await res.json();

   if (data.success) {
      showToast('Added to cart! 🛒', 'success');
      btn.style.background = '#8B3A62';
      btn.innerHTML = '<i class="fas fa-check"></i> Added!';
      setTimeout(() => {
        btn.disabled = false;
        btn.style.background = '';
        btn.innerHTML = '<i class="fas fa-shopping-bag"></i> Add to Cart';
      }, 1800);
      // update cart badge
      fetch('/cart/count').then(r => r.json()).then(d => updateNavBadge('cart-count', d.count));
    } else if (data.redirectUrl) {
      Swal.fire({
        icon:'warning', iconColor:'#e8a87c', title:'Login Required',
        html:'Please login to <b>add items to your Cart</b>.',
        showCancelButton:true, confirmButtonText:'🔐 Go to Login',
        cancelButtonText:'Cancel', confirmButtonColor:'#8B3A62', cancelButtonColor:'#e8c8c8'
      }).then(r => { if (r.isConfirmed) window.location.href = data.redirectUrl; });
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-shopping-bag"></i> Add to Cart';
    } else {
      showToast(data.message || 'Could not add to cart', 'error');
      btn.disabled = false;
      btn.innerHTML = '<i class="fas fa-shopping-bag"></i> Add to Cart';
    }
  } catch(err) {
    showToast('Something went wrong', 'error');
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-shopping-bag"></i> Add to Cart';
  }
}

let isWishlisted = <%= locals.isWishlisted ? 'true' : 'false' %>;

async function toggleWishlist() {
  try {
    const res  = await fetch('/wishlist/toggle', {
      method:'POST',
      headers:{ 'Content-Type':'application/json' },
      body: JSON.stringify({ productId: '<%= product._id %>' })
    });
   const data = await res.json();
    if (data.redirect) { window.location.href = '/login'; return; }
    if (data.success) {
      isWishlisted = data.wished;
      const icon = document.getElementById('wishlist-icon');
      const btn  = document.getElementById('wishlist-btn');
      if (isWishlisted) {
        icon.className = 'fas fa-heart'; btn.classList.add('wishlisted');
        showToast('add to Wishlist ❤️', 'info');
      } else {
        icon.className = 'far fa-heart'; btn.classList.remove('wishlisted');
        showToast('Removed from Wishlist');
      }
      // update wishlist badge
      fetch('/wishlist/count').then(r => r.json()).then(d => updateNavBadge('wishlist-count', d.count));
    } else {
      showToast(data.message || "Please login to save items to your Wishlist"
);
    }
  } catch { showToast('Something went wrong', 'error'); }
}

/* IMAGE ZOOM */
const zoomBox = document.getElementById('zoomBox');
const mainImg = document.getElementById('mainProductImage');

function setZoomImg(src) { zoomBox.style.backgroundImage = `url(${src})`; }
if (mainImg) setZoomImg(mainImg.src);

zoomBox.addEventListener('mouseenter', () => zoomBox.classList.add('zooming'));
zoomBox.addEventListener('mouseleave', () => {
  zoomBox.classList.remove('zooming');
  zoomBox.style.backgroundPosition = 'center';
});
zoomBox.addEventListener('mousemove', e => {
  const r = zoomBox.getBoundingClientRect();
  zoomBox.style.backgroundPosition =
    `${((e.clientX-r.left)/r.width)*100}% ${((e.clientY-r.top)/r.height)*100}%`;
});

function changeMainImage(src, el) {
  mainImg.src = src; setZoomImg(src);
  document.querySelectorAll('.thumbs img').forEach(i => i.classList.remove('active'));
  if (el) el.classList.add('active');
}

/* STAR RATING PICKER */
let selectedRating = 5;

document.querySelectorAll('#star-rating i').forEach(star => {
  star.addEventListener('click', () => {
    selectedRating = +star.getAttribute('data-val');
    document.querySelectorAll('#star-rating i').forEach((s,i) => {
      s.className = i < selectedRating ? 'fas fa-star active' : 'far fa-star';
    });
  });
  star.addEventListener('mouseenter', () => {
    const val = +star.getAttribute('data-val');
    document.querySelectorAll('#star-rating i').forEach((s,i) => {
      s.style.color = i < val ? '#f59e0b' : '#ddd';
    });
  });
  star.addEventListener('mouseleave', () => {
    document.querySelectorAll('#star-rating i').forEach(s => { s.style.color = ''; });
  });
});

/* LOAD ALL REVIEWS */
async function loadAllReviews() {
  try {
    const res  = await fetch(`/reviews/<%= product._id %>`);
    const data = await res.json();
    if (!data.success) return;

    const container = document.getElementById('reviews-container');
    const noMsg     = document.getElementById('no-reviews-msg');
    if (noMsg) noMsg.remove();

    container.innerHTML = data.reviews.map(r => `
      <div class="d-flex align-items-start gap-3 mb-4 review-item">
        <div class="review-avatar">${r.userId.name[0].toUpperCase()}</div>
        <div class="w-100">
          <div class="d-flex justify-content-between">
            <h6 class="fw-bold mb-0">${r.userId.name}</h6>
            <small class="text-muted">${new Date(r.createdAt).toDateString()}</small>
          </div>
          <div class="text-warning small my-1">
            ${'★'.repeat(r.rating||5)}${'☆'.repeat(5-(r.rating||5))}
          </div>
          <p class="text-muted mb-0" style="font-size:.9rem">${r.comment}</p>
        </div>
      </div>`).join('');

    document.getElementById('show-all-wrapper')?.remove();
  } catch(err) { console.error(err); }
}

/* SUBMIT REVIEW */
async function submitReview() {
  const comment = document.getElementById('reviewText')?.value?.trim();
  if (!comment)        { showToast('Please write something first', 'error'); return; }
  if (!selectedRating) { showToast('Please select a star rating',  'error'); return; }

  const postBtn = document.querySelector('.btn-post');
  if (postBtn) { postBtn.disabled = true; postBtn.textContent = 'Posting…'; }

  try {
    const res  = await fetch('/add-review', {
      method:'POST',
      headers:{ 'Content-Type':'application/json' },
      body: JSON.stringify({ productId:'<%= product._id %>', comment, rating:selectedRating })
    });
    const data = await res.json();

    if (data.success) {
      showToast('Review posted! 🎉', 'success');
      // Clear the form for another review
      document.getElementById('reviewText').value = '';
      selectedRating = 5;
      document.querySelectorAll('#star-rating i').forEach(s => { s.className = 'far fa-star'; });
      // Reload reviews list after short delay
      setTimeout(() => loadAllReviews(), 800);
    } else {
      Swal.fire({ icon:'info', title:'Cannot Post Review',
        text: data.message || 'Failed to post review.',
        confirmButtonColor:'#B85C5C' });
    }
  } catch { showToast('Something went wrong', 'error'); }
 finally {
    if (postBtn) { postBtn.disabled = false; postBtn.innerHTML = '<i class="fas fa-paper-plane me-2"></i>Post Review'; }
  }
}
</script>

<script>
function updateNavBadge(id, count) {
  const el = document.getElementById(id);
  if (!el) return;
  el.textContent = count;
  el.style.display = count > 0 ? 'inline-block' : 'none';
}

document.addEventListener('DOMContentLoaded', () => {
  fetch('/cart/count').then(r => r.json()).then(d => updateNavBadge('cart-count', d.count)).catch(()=>{});
  fetch('/wishlist/count').then(r => r.json()).then(d => updateNavBadge('wishlist-count', d.count)).catch(()=>{});
});
</script>

<% } %>
</body>
</html>
