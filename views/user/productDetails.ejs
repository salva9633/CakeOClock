<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title><%= product.productName %> | Cake O'Clock</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --rose:       #AF5454;
            --rose-dk:    #8E3E3E;
            --rose-lt:    #fef2f2;
            --rose-mid:   #f8d7d7;
            --cream:      #fdf8f5;
            --ink:        #2c1810;
            --muted:      #7a6a6a;
            --card:       #ffffff;
            --transition: all 0.3s cubic-bezier(.4,0,.2,1);
        }

        * { box-sizing: border-box; }

        body {
            background: linear-gradient(160deg, #fdf0f0 0%, #fff 55%, #fdf5f0 100%);
            font-family: 'DM Sans', sans-serif;
            color: var(--ink);
            min-height: 100vh;
        }

        /* ── TOAST ── */
        #toast-container {
            position: fixed;
            bottom: 30px;
            right: 30px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        .toast-msg {
            background: #2c1810;
            color: #fff;
            padding: 14px 22px;
            border-radius: 14px;
            font-size: .88rem;
            font-weight: 500;
            box-shadow: 0 8px 30px rgba(0,0,0,.18);
            display: flex;
            align-items: center;
            gap: 10px;
            animation: slideUp .35s ease forwards;
            min-width: 220px;
        }
        .toast-msg.success i { color: #4ade80; }
        .toast-msg.error   i { color: #f87171; }
        .toast-msg.info    i { color: #60a5fa; }
        @keyframes slideUp {
            from { opacity:0; transform:translateY(20px); }
            to   { opacity:1; transform:translateY(0); }
        }

        /* ── BREADCRUMB ── */
        .breadcrumb-nav {
            font-size: .85rem;
            color: var(--muted);
            margin-bottom: 24px;
        }
        .breadcrumb-nav a {
            color: var(--muted);
            text-decoration: none;
            transition: var(--transition);
        }
        .breadcrumb-nav a:hover { color: var(--rose); }

        /* ── PRODUCT WRAPPER ── */
        .product-wrapper {
            background: rgba(255,255,255,.85);
            backdrop-filter: blur(12px);
            border-radius: 28px;
            box-shadow: 0 12px 50px rgba(175,84,84,.09);
            padding: 44px;
            margin-bottom: 50px;
            border: 1px solid rgba(255,255,255,.7);
        }

        /* ── GALLERY ── */
        .gallery-container { display: flex; gap: 16px; }

        .thumbs-col {
            display: flex;
            flex-direction: column;
            gap: 10px;
            width: 78px;
        }
        .thumbs-col img {
            width: 78px;
            height: 78px;
            object-fit: cover;
            border-radius: 12px;
            cursor: pointer;
            border: 2.5px solid transparent;
            transition: var(--transition);
        }
        .thumbs-col img:hover,
        .thumbs-col img.active {
            border-color: var(--rose);
            transform: scale(1.05);
            box-shadow: 0 4px 14px rgba(175,84,84,.25);
        }

        .main-image-col { flex-grow: 1; }

        .img-zoom-container {
            width: 100%;
            height: 500px;
            background: #fdf8f8;
            border-radius: 22px;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: zoom-in;
            background-repeat: no-repeat;
            background-size: 0% 0%;
        }
        .img-zoom-container.zooming { background-size: 210%; }
        .img-zoom-container.zooming .main-img { opacity: 0; }
        .main-img { width:100%; height:100%; object-fit:cover; transition:opacity .2s ease; }

        @media(hover:none){
            .img-zoom-container.zooming { background-size: 0% 0%; }
            .img-zoom-container.zooming .main-img { opacity: 1; }
        }
        @media(max-width:768px){
            .gallery-container { flex-direction: column-reverse; }
            .thumbs-col { flex-direction:row; width:100%; overflow-x:auto; }
            .thumbs-col img { width:60px; height:60px; }
            .img-zoom-container { height:320px; }
            .product-wrapper { padding: 22px; }
        }

        /* ── PRODUCT DETAILS ── */
        .product-title {
            font-family: 'Playfair Display', serif;
            font-size: 2.4rem;
            font-weight: 700;
            color: var(--ink);
            line-height: 1.2;
            margin-bottom: 14px;
        }

        .product-meta {
            display: flex;
            align-items: center;
            gap: 14px;
            flex-wrap: wrap;
            margin-bottom: 22px;
        }

        .rating-badge {
            background: #fff8e1;
            color: #d97706;
            padding: 4px 12px;
            border-radius: 20px;
            font-weight: 700;
            font-size: .88rem;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

        .price-container {
            display: flex;
            align-items: baseline;
            gap: 14px;
            margin: 22px 0;
            flex-wrap: wrap;
        }
        .price {
            font-size: 2.1rem;
            font-weight: 700;
            color: var(--rose);
            font-family: 'Playfair Display', serif;
        }
        .old-price {
            font-size: 1.15rem;
            text-decoration: line-through;
            color: var(--muted);
        }
        .discount-tag {
            background: #fef2f2;
            color: var(--rose);
            font-size: .82rem;
            font-weight: 700;
            padding: 3px 10px;
            border-radius: 20px;
            border: 1px solid var(--rose-mid);
        }

        .description-text {
            color: #6b5757;
            line-height: 1.75;
            font-size: .95rem;
            margin-bottom: 24px;
        }

        /* ── VARIANTS ── */
        .variant-label {
            font-weight: 600;
            margin-bottom: 10px;
            display: block;
            font-size: .9rem;
            color: var(--ink);
        }
        .weight-btn {
            background: #fff;
            border: 1.5px solid #e5e7eb;
            color: var(--ink);
            margin: 0 8px 8px 0;
            border-radius: 10px;
            padding: 8px 22px;
            font-size: .88rem;
            font-weight: 500;
            cursor: pointer;
            transition: var(--transition);
        }
        .weight-btn:hover {
            border-color: var(--rose);
            color: var(--rose);
            background: var(--rose-lt);
        }
        .weight-btn.active {
            background: var(--rose);
            color: #fff;
            border-color: var(--rose);
            box-shadow: 0 4px 14px rgba(175,84,84,.35);
        }

        /* ── QTY SELECTOR ── */
        .qty-wrapper {
            display: flex;
            align-items: center;
            gap: 0;
            border: 1.5px solid #e5e7eb;
            border-radius: 12px;
            overflow: hidden;
            width: fit-content;
            margin-bottom: 24px;
        }
        .qty-btn {
            width: 38px;
            height: 38px;
            background: #fafafa;
            border: none;
            font-size: 1.1rem;
            color: var(--ink);
            cursor: pointer;
            transition: var(--transition);
        }
        .qty-btn:hover { background: var(--rose-mid); color: var(--rose); }
        .qty-display {
            width: 44px;
            text-align: center;
            font-weight: 600;
            font-size: .95rem;
            border: none;
            border-left: 1.5px solid #e5e7eb;
            border-right: 1.5px solid #e5e7eb;
            height: 38px;
            line-height: 38px;
        }

        /* ── ACTION BUTTONS ── */
        .action-group { display: flex; gap: 12px; margin-top: 8px; }

        .btn-cart {
            flex: 1;
            max-width: 220px;
            background: linear-gradient(135deg, var(--rose), #d97373);
            color: #fff;
            border: none;
            padding: 13px 28px;
            border-radius: 14px;
            font-weight: 600;
            font-size: .97rem;
            transition: var(--transition);
            box-shadow: 0 4px 18px rgba(175,84,84,.3);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            cursor: pointer;
        }
        .btn-cart:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(175,84,84,.4);
        }
        .btn-cart:disabled {
            background: #ccc;
            box-shadow: none;
            cursor: not-allowed;
        }

        .btn-wishlist {
            width: 50px;
            height: 50px;
            border-radius: 14px;
            border: 1.5px solid #e5e7eb;
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: var(--transition);
            color: var(--muted);
            font-size: 1.1rem;
            flex-shrink: 0;
        }
        .btn-wishlist:hover {
            border-color: var(--rose);
            color: var(--rose);
            background: var(--rose-lt);
        }
        .btn-wishlist.wishlisted {
            border-color: var(--rose);
            background: var(--rose);
            color: #fff;
        }
        .btn-wishlist.wishlisted i { font-weight: 900; }

        /* ── FEATURES ── */
        .feature-list {
            display: flex;
            gap: 18px;
            flex-wrap: wrap;
            margin-top: 28px;
            padding-top: 24px;
            border-top: 1px solid #f0e8e8;
        }
        .feature-item {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: .83rem;
            color: #7a6a6a;
        }
        .feature-icon {
            width: 34px;
            height: 34px;
            background: var(--rose-lt);
            color: var(--rose);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: .8rem;
        }

        /* ── SECTION TITLE ── */
        .section-title {
            font-family: 'Playfair Display', serif;
            font-weight: 700;
            font-size: 1.75rem;
            position: relative;
            display: inline-block;
            margin-bottom: 36px;
        }
        .section-title::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 50%;
            transform: translateX(-50%);
            width: 50px;
            height: 3px;
            background: var(--rose);
            border-radius: 2px;
        }

        /* ── REVIEW SECTION ── */
        .review-section {
            background: #fff;
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 6px 30px rgba(175,84,84,.07);
            max-width: 950px;
            margin: auto;
        }
        .review-item {
            padding-bottom: 18px;
            border-bottom: 1px solid #f5eded;
        }
        .review-item:last-child { border-bottom: none; }
        .review-avatar {
            width: 46px;
            height: 46px;
            border-radius: 50%;
            background: var(--rose-mid);
            color: var(--rose-dk);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: .95rem;
            flex-shrink: 0;
        }
        .review-input {
            background: #fdf8f8;
            border: 1.5px solid #ecdede;
            border-radius: 14px;
            padding: 14px;
            resize: none;
            transition: var(--transition);
            font-family: 'DM Sans', sans-serif;
        }
        .review-input:focus {
            background: #fff;
            border-color: var(--rose);
            box-shadow: 0 0 0 4px rgba(175,84,84,.1);
            outline: none;
        }

        /* ── STAR RATING INPUT ── */
        .star-rating { display: flex; gap: 6px; margin-bottom: 14px; }
        .star-rating i {
            font-size: 1.3rem;
            color: #ddd;
            cursor: pointer;
            transition: color .2s;
        }
        .star-rating i.active { color: #f59e0b; }

        /* ── RELATED CARDS ── */
        .related-card-v2 {
            background: #fff;
            border-radius: 18px;
            overflow: hidden;
            height: 100%;
            box-shadow: 0 6px 22px rgba(0,0,0,.06);
            transition: var(--transition);
            display: flex;
            flex-direction: column;
        }
        .related-card-v2:hover {
            transform: translateY(-10px);
            box-shadow: 0 18px 40px rgba(175,84,84,.13);
        }
        .related-img-v2 {
            height: 190px;
            overflow: hidden;
            background: #fdf8f8;
        }
        .related-img-v2 img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform .5s ease;
        }
        .related-card-v2:hover .related-img-v2 img { transform: scale(1.08); }
        .related-body-v2 {
            padding: 18px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }
        .related-title-v2 {
            font-size: .97rem;
            font-weight: 600;
            color: var(--ink);
            margin-bottom: 8px;
            line-height: 1.3;
        }
        .price-row { display:flex; align-items:center; gap:8px; margin-bottom:12px; }
        .price-v2  { font-size:1.05rem; font-weight:700; color:var(--rose); }
        .old-price-v2 { font-size:.83rem; color:#9ca3af; text-decoration:line-through; }

        .btn-view {
            border: 1.5px solid var(--rose);
            color: var(--rose);
            background: transparent;
            border-radius: 20px;
            padding: 7px 0;
            font-size: .85rem;
            font-weight: 600;
            transition: var(--transition);
            width: 100%;
            margin-top: auto;
        }
        .btn-view:hover { background: var(--rose); color: #fff; }

        /* ── SUBMIT REVIEW BTN ── */
        .btn-post {
            background: var(--rose);
            color: #fff;
            border: none;
            border-radius: 12px;
            padding: 10px 28px;
            font-weight: 600;
            font-size: .9rem;
            transition: var(--transition);
            cursor: pointer;
        }
        .btn-post:hover { background: var(--rose-dk); transform: translateY(-1px); }
    </style>
</head>

<body>

<%- include("../../views/partials/user/h2") %>

<!-- Toast Container -->
<div id="toast-container"></div>

<div class="container py-5">

    <!-- Breadcrumb -->
    <div class="breadcrumb-nav">
        <a href="/">Home</a> <span class="mx-2">/</span>
        <a href="/products">Shop</a> <span class="mx-2">/</span>
        <span><%= product.productName %></span>
    </div>

    <!-- Product Wrapper -->
    <div class="product-wrapper">
        <div class="row align-items-start gx-5">

            <!-- LEFT: GALLERY -->
            <div class="col-lg-7 mb-5 mb-lg-0">
                <div class="gallery-container">
                    <div class="thumbs-col">
                        <% product.productImages.forEach((img, index) => { %>
                            <img src="<%= img %>"
                                 class="<%= index === 0 ? 'active' : '' %>"
                                 onclick="changeMainImage('<%= img %>', this)"
                                 alt="Thumbnail">
                        <% }) %>
                    </div>
                    <div class="main-image-col">
                        <div class="img-zoom-container" id="zoomBox">
                            <img id="mainProductImage"
                                 src="<%= product.productImages[0] %>"
                                 class="main-img"
                                 alt="<%= product.productName %>">
                        </div>
                    </div>
                </div>
            </div>

            <!-- RIGHT: DETAILS -->
            <div class="col-lg-5">

                <h1 class="product-title"><%= product.productName %></h1>

                <div class="product-meta">
                    <span class="rating-badge">
                        <i class="fas fa-star"></i> <%= avgRating %>
                    </span>
                    <span class="text-muted" style="font-size:.88rem;">
                        <%= totalReviews %> Reviews
                    </span>
                    <span id="stock-status"
                          class="fw-semibold <%= initialStock > 0 ? 'text-success' : 'text-danger' %>"
                          style="font-size:.88rem;">
                        <% if (initialStock > 0) { %>
                            <i class="fas fa-check-circle me-1"></i> In Stock
                        <% } else { %>
                            <i class="fas fa-times-circle me-1"></i> Out of Stock
                        <% } %>
                    </span>
                </div>

                <!-- Price -->
                <div class="price-container">
                    <span class="price">₹<span id="current-price"><%= selectedVariant.salePrice %></span></span>
                    <span class="old-price" id="old-price">₹<%= selectedVariant.regularPrice %></span>
                    <span class="discount-tag" id="discount-percent">
                        <%= Math.round((selectedVariant.regularPrice - selectedVariant.salePrice) / selectedVariant.regularPrice * 100) %>% OFF
                    </span>
                </div>

                <p class="description-text">
                    <%= product.longDescription || product.description %>
                </p>

                <!-- Variants -->
                <div class="mb-3">
                    <label class="variant-label">Choose Weight</label>
                    <div class="d-flex flex-wrap">
                        <% variants.forEach(v => { %>
                            <button class="weight-btn <%= v._id.toString() === selectedVariant._id.toString() ? 'active' : '' %>"
                                    data-variant="<%= v._id %>">
                                <%= v.weight %>g
                            </button>
                        <% }) %>
                    </div>
                </div>

                <!-- Quantity -->
                <label class="variant-label">Quantity</label>
                <div class="qty-wrapper mb-3">
                    <button class="qty-btn" onclick="changeQty(-1)">−</button>
                    <div class="qty-display" id="qty-display">1</div>
                    <button class="qty-btn" onclick="changeQty(1)">+</button>
                </div>

                <!-- Action Buttons -->
                <div class="action-group">

                    <!-- ADD TO CART -->
                    <button id="add-to-cart-btn"
                            class="btn-cart"
                            onclick="addToCart()"
                            <%= initialStock === 0 ? 'disabled' : '' %>>
                        <% if (initialStock > 0) { %>
                            <i class="fas fa-shopping-bag"></i> Add to Cart
                        <% } else { %>
                            Out of Stock
                        <% } %>
                    </button>

                    <!-- WISHLIST -->
                    <button id="wishlist-btn"
                            class="btn-wishlist"
                            onclick="toggleWishlist()"
                            title="Add to Wishlist">
                        <i class="far fa-heart" id="wishlist-icon"></i>
                    </button>

                </div>

                <!-- Features -->
                <div class="feature-list">
                    <div class="feature-item">
                        <div class="feature-icon"><i class="fas fa-truck"></i></div>
                        <span>Fast Delivery</span>
                    </div>
                    <div class="feature-item">
                        <div class="feature-icon"><i class="fas fa-shield-alt"></i></div>
                        <span>Secure Payment</span>
                    </div>
                    <div class="feature-item">
                        <div class="feature-icon"><i class="fas fa-undo"></i></div>
                        <span>Easy Returns</span>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- ── REVIEWS ── -->
    <div class="row mt-2 justify-content-center">
        <div class="col-12 col-lg-10">
            <h3 class="section-title d-block text-center">Customer Reviews</h3>

            <div class="review-section">

                <div id="reviews-container">
                    <% if (reviews.length === 0) { %>
                        <div class="text-center py-5 text-muted" id="no-reviews-msg">
                            <i class="fas fa-comment-slash fs-2 mb-3 d-block" style="color:#e0c8c8;"></i>
                            <p class="mb-0">No reviews yet. Be the first!</p>
                        </div>
                    <% } %>

                    <% reviews.forEach(r => { %>
                        <div class="d-flex align-items-start gap-3 mb-4 review-item">
                            <div class="review-avatar">
                                <%= r.userId.name[0].toUpperCase() %>
                            </div>
                            <div class="w-100">
                                <div class="d-flex justify-content-between align-items-center">
                                    <h6 class="fw-bold mb-0"><%= r.userId.name %></h6>
                                    <small class="text-muted"><%= new Date(r.createdAt).toDateString() %></small>
                                </div>
                                <div class="text-warning small my-1">
                                    <%= "★".repeat(r.rating || 5) %><%= "☆".repeat(5 - (r.rating || 5)) %>
                                </div>
                                <p class="text-muted mb-0" style="font-size:.9rem;"><%= r.comment %></p>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <% if (totalReviews > 3) { %>
                    <div class="text-center mt-3" id="show-all-wrapper">
                        <button onclick="loadAllReviews()"
                                class="btn btn-sm px-4 rounded-pill"
                                style="border:1.5px solid var(--rose,#AF5454);color:var(--rose,#AF5454);">
                            Show all <%= totalReviews %> reviews
                        </button>
                    </div>
                <% } %>

                <!-- Write Review -->
                <div class="mt-4 pt-4 border-top">
                    <h6 class="fw-bold mb-3">Write a Review</h6>
                    <div class="star-rating mb-3" id="star-rating">
                        <i class="far fa-star" data-val="1"></i>
                        <i class="far fa-star" data-val="2"></i>
                        <i class="far fa-star" data-val="3"></i>
                        <i class="far fa-star" data-val="4"></i>
                        <i class="far fa-star" data-val="5"></i>
                    </div>
                    <textarea id="reviewText" class="form-control review-input" rows="3"
                              placeholder="Share your experience…"></textarea>
                    <button onclick="submitReview()" class="btn-post mt-3">
                        <i class="fas fa-paper-plane me-2"></i>Post Review
                    </button>
                </div>

            </div>
        </div>
    </div>

    <!-- ── RELATED PRODUCTS ── -->
    <div class="mt-5 pt-4">
        <h3 class="section-title d-block text-center">You May Also Like</h3>
        <div class="row g-4 mt-2">
            <% relatedProducts.forEach(p => { %>
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <a href="/product/<%= p._id %>" class="text-decoration-none">
                        <div class="related-card-v2">
                            <div class="related-img-v2">
                                <% if (p.productImages && p.productImages.length > 0) { %>
                                    <img src="<%= p.productImages[0] %>" alt="<%= p.productName %>">
                                <% } else { %>
                                    <img src="https://via.placeholder.com/400x300?text=No+Image" alt="No image">
                                <% } %>
                            </div>
                            <div class="related-body-v2">
                                <h6 class="related-title-v2"><%= p.productName %></h6>
                                <% if (p.startingPrice !== null) { %>
                                    <div class="price-row">
                                        <span class="price-v2">₹ <%= p.startingPrice %></span>
                                        <% if (p.regularPrice && p.regularPrice > p.startingPrice) { %>
                                            <span class="old-price-v2">₹ <%= p.regularPrice %></span>
                                        <% } %>
                                    </div>
                                <% } %>
                                <button class="btn-view">View Details</button>
                            </div>
                        </div>
                    </a>
                </div>
            <% }) %>
        </div>
    </div>

</div><!-- /container -->

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>

/* ════════════════════════════════
   TOAST HELPER
════════════════════════════════ */
function showToast(msg, type = 'success') {
    const icons = { success: 'fa-check-circle', error: 'fa-times-circle', info: 'fa-info-circle' };
    const tc = document.getElementById('toast-container');
    const t = document.createElement('div');
    t.className = `toast-msg ${type}`;
    t.innerHTML = `<i class="fas ${icons[type]}"></i> ${msg}`;
    tc.appendChild(t);
    setTimeout(() => t.remove(), 3200);
}

/* ════════════════════════════════
   QUANTITY
════════════════════════════════ */
let qty = 1;
function changeQty(delta) {
    qty = Math.max(1, qty + delta);
    document.getElementById('qty-display').textContent = qty;
}

/* ════════════════════════════════
   VARIANT SELECTION
════════════════════════════════ */
let selectedVariantId = '<%= selectedVariant._id %>';

document.querySelectorAll('.weight-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
        document.querySelectorAll('.weight-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        selectedVariantId = btn.getAttribute('data-variant');

        try {
            const res  = await fetch(`/variant/${selectedVariantId}`);
            const data = await res.json();

            if (data.success) {
                document.getElementById('current-price').textContent = data.salePrice;
                document.getElementById('old-price').textContent = `₹${data.regularPrice}`;
                const disc = Math.round((data.regularPrice - data.salePrice) / data.regularPrice * 100);
                document.getElementById('discount-percent').textContent = `${disc}% OFF`;

                const stockEl = document.getElementById('stock-status');
                const cartBtn = document.getElementById('add-to-cart-btn');

                if (data.stock === 0) {
                    stockEl.innerHTML = `<i class="fas fa-times-circle me-1"></i> Out of Stock`;
                    stockEl.className = 'fw-semibold text-danger';
                    cartBtn.disabled  = true;
                    cartBtn.innerHTML = 'Out of Stock';
                } else {
                    stockEl.innerHTML = `<i class="fas fa-check-circle me-1"></i> In Stock`;
                    stockEl.className = 'fw-semibold text-success';
                    cartBtn.disabled  = false;
                    cartBtn.innerHTML = `<i class="fas fa-shopping-bag"></i> Add to Cart`;
                }
            }
        } catch (err) { console.error('Variant fetch error:', err); }
    });
});

/* ════════════════════════════════
   ADD TO CART  →  POST /cart/add
════════════════════════════════ */
async function addToCart() {
    const btn = document.getElementById('add-to-cart-btn');
    btn.disabled = true;
    btn.innerHTML = `<i class="fas fa-spinner fa-spin"></i> Adding…`;

    try {
        const res  = await fetch('/cart/add', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({
                productId: '<%= product._id %>',
                variantId: selectedVariantId,
                quantity:  qty
            })
        });
        const data = await res.json();

     if (data.success) {
            showToast('Added to cart! 🛒', 'success');
            btn.innerHTML = `<i class="fas fa-check"></i> Added!`;
            setTimeout(() => {
                btn.disabled  = false;
                btn.innerHTML = `<i class="fas fa-shopping-bag"></i> Add to Cart`;
            }, 1800);
        } else if (data.redirectUrl) {
            // Not logged in — show SweetAlert then redirect
            if (typeof Swal !== 'undefined') {
                Swal.fire({
                    icon: 'warning',
                    title: 'Login Required',
                    text: 'Please login to add items to your Cart.',
                    showCancelButton: true,
                    confirmButtonColor: '#8c3535',
                    cancelButtonColor: '#e8c8c8',
                    confirmButtonText: '🔑 Go to Login',
                    cancelButtonText: 'Cancel'
                }).then(result => {
                    if (result.isConfirmed) window.location.href = data.redirectUrl;
                });
            } else {
                window.location.href = data.redirectUrl;
            }
            btn.disabled  = false;
            btn.innerHTML = `<i class="fas fa-shopping-bag"></i> Add to Cart`;
        } else {
            showToast(data.message || 'Could not add to cart', 'error');
            btn.disabled  = false;
            btn.innerHTML = `<i class="fas fa-shopping-bag"></i> Add to Cart`;
        }
    } catch (err) {
        showToast('Something went wrong', 'error');
        btn.disabled  = false;
        btn.innerHTML = `<i class="fas fa-shopping-bag"></i> Add to Cart`;
    }
}

/* ════════════════════════════════
   WISHLIST  →  POST /wishlist/toggle
════════════════════════════════ */
let isWishlisted = false;

async function toggleWishlist() {
    try {
        const res  = await fetch('/wishlist/toggle', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({ productId: '<%= product._id %>' })
        });
        const data = await res.json();

        if (data.redirect) { window.location.href = '/login'; return; }

        if (data.success) {
            isWishlisted = data.wishlisted;
            const icon = document.getElementById('wishlist-icon');
            const btn  = document.getElementById('wishlist-btn');

            if (isWishlisted) {
                icon.className = 'fas fa-heart';
                btn.classList.add('wishlisted');
                showToast('Saved to Wishlist ❤️', 'info');
            } else {
                icon.className = 'far fa-heart';
                btn.classList.remove('wishlisted');
                showToast('add  cake to Wishlist',);
            }
        } else {
            showToast(data.message || 'Could not update wishlist', 'error');
        }
    } catch (err) {
        showToast('Something went wrong', 'error');
    }
}

/* ════════════════════════════════
   IMAGE ZOOM & GALLERY
════════════════════════════════ */
const zoomContainer = document.getElementById('zoomBox');
const mainImg       = document.getElementById('mainProductImage');

function setZoomImage(src) {
    zoomContainer.style.backgroundImage = `url(${src})`;
}
if (mainImg) setZoomImage(mainImg.src);

zoomContainer.addEventListener('mouseenter', () => zoomContainer.classList.add('zooming'));
zoomContainer.addEventListener('mouseleave', () => {
    zoomContainer.classList.remove('zooming');
    zoomContainer.style.backgroundPosition = 'center';
});
zoomContainer.addEventListener('mousemove', e => {
    const r = zoomContainer.getBoundingClientRect();
    zoomContainer.style.backgroundPosition =
        `${((e.clientX - r.left) / r.width) * 100}% ${((e.clientY - r.top) / r.height) * 100}%`;
});

function changeMainImage(src, el) {
    mainImg.src = src;
    setZoomImage(src);
    document.querySelectorAll('.thumbs-col img').forEach(i => i.classList.remove('active'));
    if (el) el.classList.add('active');
}

/* ════════════════════════════════
   STAR RATING (UI only)
════════════════════════════════ */
let selectedRating = 5;
document.querySelectorAll('#star-rating i').forEach(star => {
    star.addEventListener('click', () => {
        selectedRating = +star.getAttribute('data-val');
        document.querySelectorAll('#star-rating i').forEach((s, i) => {
            s.className = i < selectedRating ? 'fas fa-star active' : 'far fa-star';
        });
    });
    star.addEventListener('mouseenter', () => {
        const val = +star.getAttribute('data-val');
        document.querySelectorAll('#star-rating i').forEach((s, i) => {
            s.style.color = i < val ? '#f59e0b' : '#ddd';
        });
    });
    star.addEventListener('mouseleave', () => {
        document.querySelectorAll('#star-rating i').forEach((s, i) => {
            s.style.color = '';
        });
    });
});

/* ════════════════════════════════
   REVIEWS
════════════════════════════════ */
async function loadAllReviews() {
    try {
        const res  = await fetch(`/reviews/<%= product._id %>`);
        const data = await res.json();
        if (!data.success) return;

        const container = document.getElementById('reviews-container');
        const noMsg     = document.getElementById('no-reviews-msg');
        if (noMsg) noMsg.remove();

        container.innerHTML = data.reviews.map(r => `
            <div class="d-flex align-items-start gap-3 mb-4 review-item">
                <div class="review-avatar">${r.userId.name[0].toUpperCase()}</div>
                <div class="w-100">
                    <div class="d-flex justify-content-between">
                        <h6 class="fw-bold mb-0">${r.userId.name}</h6>
                        <small class="text-muted">${new Date(r.createdAt).toDateString()}</small>
                    </div>
                    <div class="text-warning small my-1">${'★'.repeat(r.rating||5)}${'☆'.repeat(5-(r.rating||5))}</div>
                    <p class="text-muted mb-0" style="font-size:.9rem;">${r.comment}</p>
                </div>
            </div>
        `).join('');

        document.getElementById('show-all-wrapper')?.remove();
    } catch (err) { console.error(err); }
}

async function submitReview() {
    const comment = document.getElementById('reviewText').value.trim();
    if (!comment) { showToast('Please write something first', 'error'); return; }

    try {
        const res  = await fetch('/add-review', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({
                productId: '<%= product._id %>',
                comment,
                rating: selectedRating
            })
        });
        const data = await res.json();
        if (data.success) { showToast('Review posted! 🎉', 'success'); setTimeout(() => location.reload(), 1200); }
        else showToast(data.message || 'Failed to post review', 'error');
    } catch (err) { showToast('Something went wrong', 'error'); }
}
</script>

</body>
</html>
