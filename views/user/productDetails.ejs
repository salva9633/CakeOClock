<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>
        <%= product.productName %> | Gourmet Details
    </title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Fonts -->
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@600;700&display=swap"
        rel="stylesheet">

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --primary-color: #AF5454;
            --primary-dark: #8E3E3E;
            --primary-light: #fef2f2;
            --text-dark: #2c1810;
            --text-muted: #6b7280;
            --bg-gradient-start: #fdfbfb;
            --bg-gradient-end: #f5e6e8;
            --card-bg: #ffffff;
            --transition: all 0.3s ease;
        }

        body {
            background: linear-gradient(135deg, var(--bg-gradient-end) 0%, #fff 50%, var(--bg-gradient-end) 100%);
            font-family: 'Inter', sans-serif;
            color: var(--text-dark);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* BREADCRUMB */
        .breadcrumb-nav {
            font-size: 0.9rem;
            margin-bottom: 20px;
            color: var(--text-muted);
        }

        .breadcrumb-nav a {
            color: var(--text-muted);
            text-decoration: none;
            transition: var(--transition);
        }

        .breadcrumb-nav a:hover {
            color: var(--primary-color);
        }

        /* PRODUCT LAYOUT */
        .product-wrapper {
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(10px);
            border-radius: 24px;
            box-shadow: 0 10px 40px rgba(175, 84, 84, 0.08);
            /* slight reddish shadow */
            padding: 40px;
            margin-top: 20px;
            margin-bottom: 40px;
            border: 1px solid rgba(255, 255, 255, 0.5);
        }

        /* IMAGE GALLERY */
        .gallery-container {
            display: flex;
            gap: 15px;
        }

        .thumbs-col {
            display: flex;
            flex-direction: column;
            gap: 10px;
            width: 80px;
        }

        .thumbs-col img {
            width: 80px;
            height: 80px;
            object-fit: cover;
            border-radius: 12px;
            cursor: pointer;
            border: 2px solid transparent;
            transition: var(--transition);
            background: #fff;
        }

        .thumbs-col img:hover,
        .thumbs-col img.active {
            border-color: var(--primary-color);
            transform: scale(1.05);
        }

        .main-image-col {
            flex-grow: 1;
            position: relative;
        }

        .img-zoom-container {
            width: 100%;
            height: 500px;
            background: #fff;
            border-radius: 24px;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            background-repeat: no-repeat;
            background-size: 0% 0%;
            /* Hidden initially to prevent duplication behind transparent image */
            cursor: zoom-in;
        }

        .img-zoom-container.zooming {
            background-size: 200%;
            /* Show zoomed image only on hover with 200% zoom */
        }

        .main-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: opacity 0.2s ease;
            display: block;
        }

        .img-zoom-container.zooming .main-img {
            opacity: 0;
        }


        /* Disable zoom effect on touch devices to prevent stuck state */
        @media (hover: none) {
            .img-zoom-container.zooming {
                background-size: 0% 0%;
            }

            .img-zoom-container.zooming .main-img {
                opacity: 1;
            }
        }

        @media (max-width: 768px) {
            .gallery-container {
                flex-direction: column-reverse;
            }

            .thumbs-col {
                flex-direction: row;
                width: 100%;
                overflow-x: auto;
            }

            .thumbs-col img {
                width: 60px;
                height: 60px;
            }

            .img-zoom-container {
                height: 350px;
            }
        }

        /* DETAILS SECTION */
        .product-title {
            font-family: 'Playfair Display', serif;
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 10px;
            color: #2c1810;
        }

        .product-meta {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 20px;
            font-size: 0.95rem;
        }

        .rating-badge {
            background: #fff8e1;
            color: #f59e0b;
            padding: 4px 10px;
            border-radius: 20px;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

        .price-container {
            margin: 25px 0;
            display: flex;
            align-items: baseline;
            gap: 15px;
        }

        .price {
            font-size: 2.2rem;
            font-weight: 700;
            color: var(--primary-color);
        }

        .old-price {
            font-size: 1.2rem;
            text-decoration: line-through;
            color: var(--text-muted);
            font-weight: 400;
        }

        .description-text {
            color: #555;
            line-height: 1.7;
            margin-bottom: 25px;
        }

        /* VARIANTS */
        .variant-label {
            font-weight: 600;
            margin-bottom: 10px;
            display: block;
            color: var(--text-dark);
        }

        .weight-btn {
            background: #fff;
            border: 1px solid #e5e7eb;
            color: var(--text-dark);
            margin-right: 10px;
            margin-bottom: 10px;
            border-radius: 8px;
            padding: 8px 20px;
            font-size: 0.9rem;
            font-weight: 500;
            cursor: pointer;
            transition: var(--transition);
            min-width: 80px;
        }

        .weight-btn:hover {
            border-color: var(--primary-color);
            color: var(--primary-color);
            background: var(--primary-light);
        }

        .weight-btn.active {
            background: var(--primary-color);
            color: white;
            border-color: var(--primary-color);
            box-shadow: 0 4px 12px rgba(175, 84, 84, 0.4);
        }

        /* ACTION BUTTONS */
        .action-group {
            display: flex;
            gap: 15px;
            margin-top: 30px;
        }

        .btn-buy {
            background: linear-gradient(135deg, #AF5454, #d97373);
            color: white;
            border: none;
            padding: 12px 35px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 1rem;
            transition: var(--transition);
            box-shadow: 0 4px 15px rgba(175, 84, 84, 0.3);
            flex: 1;
            max-width: 200px;
        }

        .btn-buy:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(175, 84, 84, 0.4);
        }

        .btn-wishlist {
            background: white;
            border: 2px solid #e5e7eb;
            color: var(--text-dark);
            padding: 12px 15px;
            border-radius: 12px;
            font-weight: 600;
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .btn-wishlist:hover {
            border-color: var(--primary-color);
            color: var(--primary-color);
            background: var(--primary-light);
        }

        /* RELATED PRODUCTS */
        .section-title {
            font-family: 'Playfair Display', serif;
            font-weight: 700;
            font-size: 1.8rem;
            margin-bottom: 30px;
            position: relative;
            display: inline-block;
        }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: -10px;
            left: 0;
            width: 60px;
            height: 3px;
            background: var(--primary-color);
            border-radius: 2px;
        }

        .related-card {
            background: #fff;
            border: none;
            border-radius: 16px;
            overflow: hidden;
            transition: var(--transition);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
            height: 100%;
        }

        .related-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);
        }

        .related-img-wrapper {
            height: 220px;
            overflow: hidden;
            position: relative;
            background: #f9fafb;
        }

        .related-img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            /* changed to contain for clean look, or cover if preferred */
            transition: transform 0.5s ease;
            padding: 20px;
        }

        .related-card:hover .related-img-wrapper img {
            transform: scale(1.1);
        }

        .related-body {
            padding: 20px;
        }

        .related-title {
            font-weight: 600;
            font-size: 1.1rem;
            margin-bottom: 8px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            color: var(--text-dark);
        }

        .related-price {
            color: var(--primary-color);
            font-weight: 700;
            font-size: 1.1rem;
        }

        .old-price-sm {
            text-decoration: line-through;
            color: #9ca3af;
            font-size: 0.9rem;
            margin-left: 8px;
        }

        /* REVIEWS SECTION */
        .review-section {
            background: #fff;
            border-radius: 24px;
            padding: 40px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
            margin-top: 50px;
        }

        .review-input {
            background: #f9fafb;
            border: 1px solid #e5e7eb;
            border-radius: 12px;
            padding: 15px;
            resize: none;
            transition: var(--transition);
        }

        .review-input:focus {
            background: #fff;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 4px rgba(175, 84, 84, 0.1);
            outline: none;
        }

        /* FEATURES */
        .feature-list {
            display: flex;
            gap: 20px;
            margin-top: 30px;
            padding-top: 30px;
            border-top: 1px solid #eaeaea;
        }

        .feature-item {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 0.85rem;
            color: #555;
        }

        .feature-icon {
            width: 36px;
            height: 36px;
            background: var(--primary-light);
            color: var(--primary-color);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* ================================
        RELATED PRODUCT – SPLIT CARD
        ================================ */

        .related-card-v2 {
        background: #fff;
        border-radius: 18px;
        overflow: hidden;
        height: 100%;
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.06);
        transition: all 0.35s ease;
        display: flex;
        flex-direction: column;
        }

        .related-card-v2:hover {
        transform: translateY(-10px);
        box-shadow: 0 18px 35px rgba(0, 0, 0, 0.12);
        }

        /* IMAGE (TOP HALF) */
        .related-img-v2 {
        height: 180px;
        width: 100%;
        background: #f9fafb;
        overflow: hidden;
        }

        .related-img-v2 img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
        }

        .related-card-v2:hover .related-img-v2 img {
        transform: scale(1.08);
        }

        /* BODY (BOTTOM HALF) */
        .related-body-v2 {
        padding: 18px;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
        }

        .related-title-v2 {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-dark);
        margin-bottom: 10px;
        line-height: 1.3;
        }

        /* PRICE ROW */
        .price-row {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 12px;
        }

        .price-v2 {
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--primary-color);
        }

        .old-price-v2 {
        font-size: 0.85rem;
        color: #9ca3af;
        text-decoration: line-through;
        }

        /* CTA Button polish */
        .related-body-v2 .btn {
        transition: all 0.3s ease;
        }

        .related-body-v2 .btn:hover {
        background: var(--primary-color);
        color: #fff;
        border-color: var(--primary-color);
        }

    </style>
</head>

<body>

    <%- include("../../views/partials/user/h2") %>

        <div class="container py-5">

            <!-- Breadcrumb -->
            <div class="breadcrumb-nav">
                <a href="/">Home</a> <span class="mx-2">/</span>
                <a href="/products">Shop</a> <span class="mx-2">/</span>
                <span class="text-dark">
                    <%= product.productName %>
                </span>
            </div>

            <div class="product-wrapper">
                <div class="row align-items-start gx-5">

                    <!-- LEFT: IMAGES -->
                    <div class="col-lg-7 mb-5 mb-lg-0">
                        <div class="gallery-container">
                            <!-- Thumbnails -->
                            <div class="thumbs-col">
                                <% product.productImages.forEach((img, index)=> { %>
                                    <img src="<%= img %>" class="<%= index === 0 ? 'active' : '' %>"
                                        onclick="changeMainImage('<%= img %>', this)" alt="Thumbnail">
                                    <% }) %>
                            </div>

                            <!-- Main Image -->
                            <div class="main-image-col">
                                <div class="img-zoom-container">
                                    <img id="mainProductImage" src="<%= product.productImages[0] %>" class="main-img"
                                        alt="<%= product.productName %>">
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- RIGHT: DETAILS -->
                    <div class="col-lg-5">
                        <h1 class="product-title">
                            <%= product.productName %>
                        </h1>

                        <div class="product-meta">
                            <span class="rating-badge">
                                <i class="fas fa-star"></i> 4.8
                            </span>
                            <span class="text-muted">
                                <%= product.reviewCount || 24 %> Reviews
                            </span>
                            <span class="text-success fw-medium"><i class="fas fa-check-circle me-1"></i> In
                                Stock</span>
                        </div>

                        <div class="price-container">
                            <span class="price">₹ <span id="current-price">
                                    <%= selectedVariant.salePrice %>
                                </span></span>
                            <span class="old-price" id="old-price">₹ <%= selectedVariant.regularPrice %></span>
                        </div>

                        <div class="description-text">
                            <%= product.longDescription || product.description %>
                        </div>

                        <!-- Variants -->
                        <div class="mb-4">
                            <label class="variant-label">Choose Weight</label>
                            <div class="d-flex flex-wrap">
                                <% variants.forEach(v=> { %>
                                    <button
                                        class="weight-btn <%= v._id.toString() === selectedVariant._id.toString() ? 'active' : '' %>"
                                        data-variant="<%= v._id %>">
                                        <%= v.weight %>g
                                    </button>
                                    <% }) %>
                            </div>
                        </div>

                        <!-- Actions -->
                        <div class="action-group">
                            <button class="btn btn-buy">
                                <i class="fas fa-shopping-bag me-2"></i> Add to Cart
                            </button>
                            <button class="btn btn-wishlist" title="Add to Wishlist">
                                <i class="far fa-heart"></i>
                            </button>
                        </div>

                        <!-- Feature Bullets (Static for aesthetics) -->
                        <div class="feature-list">
                            <div class="feature-item">
                                <div class="feature-icon"><i class="fas fa-truck"></i></div>
                                <span>Fast Delivery</span>
                            </div>
                            <div class="feature-item">
                                <div class="feature-icon"><i class="fas fa-shield-alt"></i></div>
                                <span>Secure Payment</span>
                            </div>
                        </div>

                    </div>
                </div>
            </div>


            <!-- REVIEWS SECTION -->
            <div class="row mt-5">
                <div class="col-lg-8">
                    <h3 class="section-title">Customer Reviews</h3>
                    <div class="review-section">
                        <div class="d-flex align-items-start gap-3 mb-4">
                            <div class="bg-light rounded-circle d-flex align-items-center justify-content-center text-secondary"
                                style="width: 50px; height: 50px; font-weight: bold;">
                                VR
                            </div>
                            <div>
                                <h6 class="fw-bold mb-1">Vinay R.</h6>
                                <div class="text-warning small mb-2"><i class="fas fa-star"></i><i
                                        class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i
                                        class="fas fa-star"></i></div>
                                <p class="text-muted mb-0">
                                    “The <%= product.productName %> is absolutely delicious! Soft, moist, and full of
                                        flavor. Packaging was excellent as well.”
                                </p>
                            </div>
                        </div>

                        <!-- Review Form -->
                        <div class="mt-4 pt-4 border-top">
                            <h6 class="fw-bold mb-3">Write a Review</h6>
                            <textarea class="form-control review-input" rows="3"
                                placeholder="Share your thoughts about this product..."></textarea>
                            <button class="btn btn-dark mt-3 px-4 rounded-3" style="background: var(--text-dark);">Post
                                Review</button>
                        </div>
                    </div>
                </div>
            </div>


            <!-- RELATED PRODUCTS -->
            <div class="mt-5 pt-4">
            <h3 class="section-title">You May Also Like</h3>

            <div class="row g-4 mt-2">
                <% relatedProducts.forEach(product => { %>
                <div class="col-12 col-sm-6 col-lg-3">

                    <a href="/product/<%= product._id %>" class="text-decoration-none">
                    <div class="related-card-v2">

                        <!-- IMAGE (TOP HALF) -->
                        <div class="related-img-v2">
                        <% if (product.productImages && product.productImages.length > 0) { %>
                            <img src="<%= product.productImages[0] %>" alt="<%= product.productName %>">
                        <% } else { %>
                            <img src="https://via.placeholder.com/400x300?text=No+Image" alt="No image">
                        <% } %>
                        </div>

                        <!-- DETAILS (BOTTOM HALF) -->
                        <div class="related-body-v2">
                        <h6 class="related-title-v2"><%= product.productName %></h6>

                        <% if (product.startingPrice !== null) { %>
                            <div class="price-row">
                            <span class="price-v2">₹ <%= product.startingPrice %></span>

                            <% if (product.regularPrice && product.regularPrice > product.startingPrice) { %>
                                <span class="old-price-v2">₹ <%= product.regularPrice %></span>
                            <% } %>
                            </div>
                        <% } %>

                        <button class="btn btn-outline-dark btn-sm w-100 rounded-pill mt-auto">
                            View Details
                        </button>
                        </div>

                    </div>
                    </a>

                </div>
                <% }) %>
            </div>
            </div>


        </div> <!-- End Container -->

        <br><br><br>

        <!-- Scripts -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

        <script>
            // --- VARIANT SELECTION LOGIC ---
            const weightButtons = document.querySelectorAll(".weight-btn");
            const priceEl = document.getElementById("current-price"); // Changed selector to ID for specificity
            const oldPriceEl = document.querySelector(".old-price");

            weightButtons.forEach(btn => {
                btn.addEventListener("click", async (e) => {
                    e.preventDefault();

                    // UI Update
                    weightButtons.forEach(b => b.classList.remove("active"));
                    btn.classList.add("active");

                    const variantId = btn.getAttribute("data-variant");

                    try {
                        // It's safer to wrap in try/catch
                        const res = await fetch(`/variant/${variantId}`);
                        const data = await res.json();

                        if (data.success) {
                            priceEl.innerText = `${data.salePrice}`;
                            oldPriceEl.innerText = `₹ ${data.regularPrice}`;

                            // Optional: Animate price change
                            priceEl.parentElement.style.opacity = '0.5';
                            setTimeout(() => priceEl.parentElement.style.opacity = '1', 200);
                        }
                    } catch (err) {
                        console.error("Error fetching variant:", err);
                    }
                });
            });

            // --- IMAGE ZOOM & GALLERY ---
            const zoomContainer = document.querySelector(".img-zoom-container");
            const mainImg = document.getElementById("mainProductImage");

            function setZoomImage(src) {
                zoomContainer.style.backgroundImage = `url(${src})`;
            }

            // Set initial zoom background
            if (mainImg) {
                setZoomImage(mainImg.src);
            }

            if (zoomContainer) {
                zoomContainer.addEventListener("mouseenter", () => {
                    zoomContainer.classList.add("zooming");
                });

                zoomContainer.addEventListener("mouseleave", () => {
                    zoomContainer.classList.remove("zooming");
                    zoomContainer.style.backgroundPosition = "center";
                });

                zoomContainer.addEventListener("mousemove", (e) => {
                    const rect = zoomContainer.getBoundingClientRect();
                    const x = ((e.clientX - rect.left) / rect.width) * 100;
                    const y = ((e.clientY - rect.top) / rect.height) * 100;
                    zoomContainer.style.backgroundPosition = `${x}% ${y}%`;
                });
            }

            // Unified function for changing image
            function changeMainImage(src, thumbElement) {
                // 1. Update Main Image
                mainImg.src = src;
                // 2. Update Zoom Background
                setZoomImage(src);

                // 3. Update Active State on Thumbnails (if thumbElement is passed)
                if (thumbElement) {
                    document.querySelectorAll('.thumbs-col img').forEach(img => img.classList.remove('active'));
                    thumbElement.classList.add('active');
                } else {
                    // Fallback if called without element (old calls potentially)
                    // Try to find the image with matching src and activate it
                    document.querySelectorAll('.thumbs-col img').forEach(img => {
                        if (img.getAttribute('src') === src) img.classList.add('active');
                        else img.classList.remove('active');
                    });
                }
            }
        </script>
</body>

</html>