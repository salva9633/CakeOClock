<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Checkout – Cake O'Clock</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

  <style>
    /* ── Brand tokens (matches homepage + payment page) ── */
    :root {
      --rose:       #C97B8A;
      --rose-dk:    #A85F6E;
      --rose-lt:    #FAE8ED;
      --blush:      #FDF0F3;
      --petal:      #FBE4EC;
      --cream:      #FDF8F5;
      --warm-white: #FFFCFA;
      --caramel:    #D4A574;
      --brown:      #5C3A3A;
      --brown-lt:   #8A6060;
      --muted:      #B08A8A;
      --border:     #F5D8E0;
      --burgundy:   #8B4A5A;
      --green:      #2a8c4a;
      --green-lt:   #e6f4ea;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--blush);
      color: var(--brown);
      min-height: 100vh;
    }
    h1,h2,h3,h4,h5 { font-family: 'Cormorant Garamond', serif; }

    /* ── Page strip ── */
    .page-strip {
      background: linear-gradient(135deg, #FFF0F4 0%, #FDF8F5 100%);
      border-bottom: 1px solid var(--border);
      padding: 18px 0 14px;
      animation: stripIn .5s ease both;
    }
    @keyframes stripIn {
      from { opacity: 0; transform: translateY(-8px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .breadcrumb-item a { color: var(--rose-dk); text-decoration: none; font-size: .82rem; transition: color .2s; }
    .breadcrumb-item a:hover { color: var(--burgundy); }
    .breadcrumb-item.active { color: var(--muted); font-size: .82rem; }
    .page-title { font-size: 1.7rem; color: var(--brown); margin: 6px 0 0; font-style: italic; }

    /* ── Steps bar ── */
    .steps-bar { display: flex; align-items: center; margin-bottom: 32px; animation: fadeUp .5s .05s ease both; }
    .step { display: flex; align-items: center; gap: 8px; font-size: .8rem; font-weight: 600; color: var(--muted); transition: color .3s; }
    .step.done { color: var(--rose-dk); }
    .step-dot {
      width: 30px; height: 30px; border-radius: 50%;
      border: 2px solid var(--border);
      display: flex; align-items: center; justify-content: center;
      font-size: .72rem; font-weight: 700;
      background: var(--warm-white); flex-shrink: 0; transition: all .3s;
    }
    .step.done .step-dot {
      border-color: var(--rose-dk);
      background: linear-gradient(135deg, var(--rose), var(--rose-dk));
      color: #fff;
      box-shadow: 0 4px 12px rgba(168,95,110,.3);
    }
    .step-line { flex: 1; height: 2px; background: var(--border); margin: 0 8px; border-radius: 2px; transition: background .4s; }
    .step.done + .step-line { background: var(--rose); }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── Cards ── */
    .checkout-card {
      background: var(--warm-white);
      border-radius: 22px;
      padding: 26px 28px;
      margin-bottom: 18px;
      border: 1px solid var(--border);
      box-shadow: 0 4px 24px rgba(201,123,138,.08);
      animation: fadeUp .5s .1s ease both;
    }
    .coupon-card {
      background: var(--warm-white);
      border-radius: 22px;
      padding: 24px 28px;
      margin-bottom: 18px;
      border: 1px solid var(--border);
      box-shadow: 0 4px 24px rgba(201,123,138,.08);
      animation: fadeUp .5s .08s ease both;
    }

    .card-heading {
      display: flex; align-items: center; gap: 12px;
      margin-bottom: 22px; padding-bottom: 16px;
      border-bottom: 1.5px solid var(--border);
    }
    .card-heading-icon {
      width: 36px; height: 36px; border-radius: 10px;
      background: var(--rose-lt);
      display: flex; align-items: center; justify-content: center;
      color: var(--rose-dk); font-size: 1rem;
    }
    .card-heading h5 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem; font-weight: 700; color: var(--brown); margin: 0;
    }

    .coupon-card-title {
      display: flex; align-items: center; gap: 10px;
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem; font-weight: 700; color: var(--brown);
      margin-bottom: 16px; padding-bottom: 14px;
      border-bottom: 1.5px solid var(--border);
    }
    .coupon-card-title-icon {
      width: 34px; height: 34px; border-radius: 10px;
      background: var(--rose-lt);
      display: flex; align-items: center; justify-content: center;
      color: var(--rose-dk); font-size: .95rem;
    }

    /* ── Coupon input row ── */
    .coupon-apply-row { display: flex; gap: 10px; margin-bottom: 10px; }
    .coupon-input {
      flex: 1; border: 1.5px solid var(--border); border-radius: 12px;
      padding: 11px 16px; font-size: .88rem; font-family: 'DM Sans', sans-serif;
      color: var(--brown); background: var(--blush); outline: none;
      transition: border-color .2s, background .2s;
    }
    .coupon-input:focus { border-color: var(--rose); background: var(--warm-white); }
    .coupon-input::placeholder { color: var(--muted); }
    .btn-apply {
      background: linear-gradient(135deg, var(--rose), var(--rose-dk));
      color: #fff; border: none; border-radius: 12px;
      padding: 11px 22px; font-weight: 700; font-size: .85rem;
      cursor: pointer; transition: all .2s; white-space: nowrap;
      box-shadow: 0 4px 14px rgba(168,95,110,.25);
    }
    .btn-apply:hover { transform: translateY(-1px); box-shadow: 0 6px 18px rgba(168,95,110,.35); }
    .btn-apply:disabled { opacity: .6; cursor: not-allowed; transform: none; box-shadow: none; }

    /* Applied coupon strip */
    .applied-strip {
      display: none; align-items: center; justify-content: space-between;
      background: var(--green-lt); border: 1.5px solid #b2dfca;
      border-radius: 12px; padding: 11px 16px; margin-bottom: 10px; gap: 10px;
    }
    .applied-strip.visible { display: flex; animation: fadeUp .3s ease; }
    .applied-strip-left { display: flex; align-items: center; gap: 8px; font-size: .87rem; color: var(--green); font-weight: 600; }
    .applied-strip-left i { font-size: .9rem; }
    .btn-remove-coupon {
      background: transparent; border: 1.5px solid #c0392b; color: #c0392b;
      border-radius: 8px; padding: 4px 12px; font-size: .76rem; font-weight: 700;
      cursor: pointer; transition: all .18s; white-space: nowrap;
    }
    .btn-remove-coupon:hover { background: #fdecea; }

    .coupon-msg { font-size: .8rem; margin-top: 6px; padding: 8px 13px; border-radius: 10px; display: none; }
    .coupon-msg.success { background: var(--green-lt); color: var(--green); display: block; }
    .coupon-msg.error   { background: #fdecea; color: #c0392b; display: block; }

    .coupon-list-header {
      font-size: .72rem; font-weight: 700; color: var(--muted);
      letter-spacing: .08em; text-transform: uppercase;
      margin-bottom: 10px; margin-top: 18px;
      display: flex; align-items: center; gap: 6px;
    }
    .coupon-list-header::after { content: ''; flex: 1; height: 1px; background: var(--border); }

    .coupon-item {
      display: flex; align-items: center; justify-content: space-between;
      border: 1.5px dashed var(--border); border-radius: 14px;
      padding: 13px 16px; margin-bottom: 8px; background: var(--blush);
      cursor: pointer; transition: all .22s; gap: 12px;
    }
    .coupon-item:hover { border-color: var(--rose); background: var(--rose-lt); transform: translateY(-1px); box-shadow: 0 4px 14px rgba(201,123,138,.12); }
    .coupon-item.applied { border-color: var(--green); background: var(--green-lt); border-style: solid; }

    .coupon-left { display: flex; align-items: center; gap: 12px; min-width: 0; }
    .coupon-icon {
      width: 38px; height: 38px; background: var(--rose-lt); border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      color: var(--rose-dk); font-size: 1rem; flex-shrink: 0;
      transition: transform .2s;
    }
    .coupon-item:hover .coupon-icon { transform: rotate(-8deg) scale(1.1); }
    .coupon-item.applied .coupon-icon { background: var(--green-lt); color: var(--green); }
    .coupon-code { font-weight: 800; font-size: .88rem; color: var(--rose-dk); letter-spacing: .05em; }
    .coupon-item.applied .coupon-code { color: var(--green); }
    .coupon-desc { font-size: .76rem; color: var(--muted); margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

    .btn-use-coupon {
      background: transparent; border: 1.5px solid var(--rose); color: var(--rose-dk);
      border-radius: 8px; padding: 5px 14px; font-size: .77rem; font-weight: 700;
      cursor: pointer; transition: all .2s; white-space: nowrap; flex-shrink: 0;
    }
    .btn-use-coupon:hover { background: var(--rose); color: #fff; }
    .coupon-item.applied .btn-use-coupon { background: var(--green); color: #fff; border-color: var(--green); cursor: default; }
    .no-coupons-text { color: var(--muted); font-size: .86rem; }

    /* ── Address items ── */
    .addr-list { display: flex; flex-direction: column; gap: 12px; }
    .addr-item {
      position: relative; border: 1.5px solid var(--border); border-radius: 16px;
      padding: 16px 18px 16px 54px; cursor: pointer;
      transition: all .25s cubic-bezier(.4,0,.2,1); background: var(--warm-white);
    }
    .addr-item:hover { border-color: var(--rose); background: var(--rose-lt); transform: translateY(-1px); box-shadow: 0 6px 20px rgba(201,123,138,.1); }
    .addr-item.active { border-color: var(--rose-dk); background: var(--rose-lt); box-shadow: 0 4px 16px rgba(168,95,110,.15); }

    .addr-radio {
      position: absolute; left: 18px; top: 50%; transform: translateY(-50%);
      width: 20px; height: 20px; border-radius: 50%;
      border: 2px solid var(--border); background: #fff;
      transition: all .2s; display: flex; align-items: center; justify-content: center;
    }
    .addr-item.active .addr-radio { border-color: var(--rose-dk); background: linear-gradient(135deg, var(--rose), var(--rose-dk)); }
    .addr-item.active .addr-radio::after { content: ''; width: 7px; height: 7px; border-radius: 50%; background: #fff; }

    .addr-type-badge {
      display: inline-flex; align-items: center; gap: 4px;
      font-size: .65rem; font-weight: 700; letter-spacing: .05em; text-transform: uppercase;
      background: linear-gradient(135deg, var(--rose), var(--rose-dk));
      color: #fff; border-radius: 6px; padding: 2px 9px; margin-bottom: 5px;
    }
    .default-badge {
      display: inline-flex; align-items: center; gap: 4px;
      font-size: .62rem; font-weight: 600; background: #f0f0f0; color: #666;
      border-radius: 5px; padding: 2px 8px; margin-left: 6px; vertical-align: middle;
    }
    .addr-name { font-weight: 600; font-size: .92rem; color: var(--brown); }
    .addr-phone { font-size: .8rem; color: var(--muted); margin-top: 1px; display: flex; align-items: center; gap: 4px; }
    .addr-line { font-size: .82rem; color: var(--muted); margin-top: 5px; line-height: 1.5; }
    .addr-edit-link {
      font-size: .76rem; color: var(--rose-dk); text-decoration: none;
      display: inline-flex; align-items: center; gap: 4px;
      margin-top: 7px; font-weight: 600; transition: color .2s;
    }
    .addr-edit-link:hover { color: var(--burgundy); }

    .btn-add-addr {
      display: flex; align-items: center; justify-content: center; gap: 10px;
      border: 1.5px dashed var(--rose); color: var(--rose-dk); background: transparent;
      border-radius: 16px; padding: 13px; width: 100%;
      font-weight: 600; font-size: .88rem; cursor: pointer;
      transition: all .22s; margin-top: 14px;
    }
    .btn-add-addr:hover { background: var(--rose-lt); border-color: var(--rose-dk); transform: translateY(-1px); }
    .plus-icon {
      width: 24px; height: 24px;
      background: linear-gradient(135deg, var(--rose), var(--rose-dk));
      color: #fff; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: .9rem; flex-shrink: 0;
    }

    /* ── Summary card ── */
    .summary-card {
      background: var(--warm-white); border-radius: 22px; padding: 24px;
      border: 1px solid var(--border); box-shadow: 0 4px 24px rgba(201,123,138,.08);
      position: sticky; top: 20px; animation: fadeUp .5s .18s ease both;
    }
    .summary-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem; font-weight: 700; color: var(--brown);
      margin-bottom: 16px; padding-bottom: 14px; border-bottom: 1.5px solid var(--border);
    }
    .item-count { font-size: .76rem; color: var(--muted); font-weight: 400; font-family: 'DM Sans', sans-serif; display: block; margin-top: 3px; }

    .order-item { display: flex; gap: 12px; padding: 11px 0; border-bottom: 1px solid var(--rose-lt); }
    .order-item:last-of-type { border-bottom: none; }
    .item-img { width: 54px; height: 54px; object-fit: cover; border-radius: 12px; flex-shrink: 0; border: 1px solid var(--border); }
    .item-info { flex: 1; min-width: 0; }
    .item-name { font-weight: 600; font-size: .86rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--brown); }
    .item-meta { font-size: .74rem; color: var(--muted); margin-top: 2px; }
    .item-price { text-align: right; flex-shrink: 0; }
    .item-price .final { font-weight: 700; font-size: .88rem; color: var(--brown); }
    .item-price .was { font-size: .73rem; color: #bbb; text-decoration: line-through; }
    .item-price .saving { font-size: .71rem; color: var(--green); display: block; }

    .price-breakdown { margin-top: 14px; }
    .price-row { display: flex; justify-content: space-between; align-items: center; font-size: .86rem; padding: 5px 0; }
    .price-row .label { color: var(--muted); }
    .price-row .val { font-weight: 500; color: var(--brown); }
    .price-row.total-row { border-top: 1.5px solid var(--border); margin-top: 10px; padding-top: 14px; }
    .price-row.total-row .label { font-weight: 700; font-size: .95rem; color: var(--brown); }
    .price-row.total-row .val { font-weight: 800; font-size: 1.15rem; color: var(--rose-dk); }
    .free-badge { background: var(--green-lt); color: var(--green); font-size: .73rem; font-weight: 700; border-radius: 20px; padding: 2px 10px; }
    .discount-val { color: var(--green); font-weight: 600; }
    .coupon-breakdown-row { display: none; }
    .coupon-breakdown-row.visible { display: flex; }

    /* ── Place order button ── */
    .btn-place {
      background: linear-gradient(135deg, var(--rose) 0%, var(--rose-dk) 100%);
      color: #fff; font-family: 'DM Sans', sans-serif;
      font-weight: 700; font-size: .95rem;
      padding: 15px; border-radius: 50px; border: none;
      width: 100%; margin-top: 18px; cursor: pointer;
      letter-spacing: .04em; transition: all .25s;
      display: flex; align-items: center; justify-content: center; gap: 8px;
      box-shadow: 0 6px 22px rgba(168,95,110,.3);
      position: relative; overflow: hidden;
    }
    .btn-place::after {
      content: ''; position: absolute; top: 50%; left: 50%;
      width: 0; height: 0; background: rgba(255,255,255,.18); border-radius: 50%;
      transform: translate(-50%,-50%);
      transition: width .55s ease, height .55s ease, opacity .55s;
    }
    .btn-place:active::after { width: 300px; height: 300px; opacity: 0; }
    .btn-place:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(168,95,110,.42); }
    .btn-place:disabled { opacity: .6; transform: none; box-shadow: none; cursor: not-allowed; }

    .secure-note {
      text-align: center; font-size: .72rem; color: var(--muted);
      margin-top: 10px; display: flex; align-items: center; justify-content: center; gap: 5px;
    }
    .secure-note i { color: var(--rose); font-size: .75rem; }

    .empty-addr { text-align: center; padding: 24px; color: var(--muted); font-size: .88rem; }

    /* ── Spinner ── */
    .spinner {
      display: inline-block; width: 13px; height: 13px;
      border: 2px solid rgba(255,255,255,.4); border-top-color: #fff;
      border-radius: 50%; animation: spin .6s linear infinite; vertical-align: middle; margin-right: 4px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
  </style>
</head>
<body>

<%- include("../partials/user/h2") %>

<!-- Page strip -->
<div class="page-strip">
  <div class="container">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-1" style="--bs-breadcrumb-divider:'›'">
        <li class="breadcrumb-item"><a href="/"><i class="fa-solid fa-house fa-xs me-1"></i>Home</a></li>
        <li class="breadcrumb-item"><a href="/cart">Cart</a></li>
        <li class="breadcrumb-item active">Checkout</li>
      </ol>
    </nav>
    <h2 class="page-title">Checkout</h2>
  </div>
</div>

<div class="container py-4">

  <!-- Steps bar -->
  <div class="steps-bar">
    <div class="step done">
      <div class="step-dot"><i class="fa-solid fa-check" style="font-size:.6rem"></i></div>
      <span class="d-none d-sm-inline">Cart</span>
    </div>
    <div class="step-line"></div>
    <div class="step done">
      <div class="step-dot">2</div>
      <span class="d-none d-sm-inline">Address</span>
    </div>
    <div class="step-line"></div>
    <div class="step done">
      <div class="step-dot">3</div>
      <span class="d-none d-sm-inline">Payment</span>
    </div>
    <div class="step-line"></div>
    <div class="step">
      <div class="step-dot">4</div>
      <span class="d-none d-sm-inline">Done</span>
    </div>
  </div>

  <div class="row g-4 align-items-start">

    <!-- LEFT COLUMN -->
    <div class="col-lg-7">

      <!-- Coupon Section -->
      <div class="coupon-card">
        <div class="coupon-card-title">
          <div class="coupon-card-title-icon">
            <i class="fa-solid fa-ticket"></i>
          </div>
          Available Coupons
        </div>

        <!-- Applied coupon strip -->
        <div class="applied-strip" id="appliedStrip">
          <div class="applied-strip-left">
            <i class="fa-solid fa-circle-check"></i>
            <span id="appliedStripText">Coupon applied</span>
          </div>
          <button class="btn-remove-coupon" onclick="removeCoupon()">
            <i class="fa-solid fa-xmark fa-xs"></i> Remove
          </button>
        </div>

        <!-- Manual entry row -->
        <div id="couponInputRow">
          <div class="coupon-apply-row">
            <input type="text" class="coupon-input" id="couponCodeInput"
                   placeholder="Enter coupon code"
                   oninput="this.value = this.value.toUpperCase()">
            <button class="btn-apply" id="btnApply" onclick="applyCouponCode()">
              <i class="fa-solid fa-tag fa-xs me-1"></i>Apply
            </button>
          </div>
        </div>

        <div class="coupon-msg" id="couponMsg"></div>

        <!-- Available coupons list -->
        <% if (typeof coupons !== 'undefined' && coupons && coupons.length > 0) { %>
          <div class="coupon-list-header">
            <i class="fa-solid fa-gift fa-xs"></i> Available for you
          </div>
          <% coupons.forEach(coupon => { %>
            <div class="coupon-item" id="couponItem_<%= coupon.code %>"
                 onclick="useCoupon('<%= coupon.code %>')">
              <div class="coupon-left">
                <div class="coupon-icon">
                  <i class="fa-solid fa-percent"></i>
                </div>
                <div>
                  <div class="coupon-code"><%= coupon.code %></div>
                  <div class="coupon-desc">
                    <% if (coupon.discountType === 'percentage') { %>
                      <%= coupon.discountValue %>% off<% if (coupon.maxDiscount) { %> · up to ₹<%= coupon.maxDiscount %><% } %>
                    <% } else { %>
                      ₹<%= coupon.discountValue %> off
                    <% } %>
                    <% if (coupon.minPurchase) { %> · Min ₹<%= coupon.minPurchase %><% } %>
                  </div>
                </div>
              </div>
              <button class="btn-use-coupon" id="btnUseCoupon_<%= coupon.code %>"
                      onclick="event.stopPropagation(); useCoupon('<%= coupon.code %>')">
                Use
              </button>
            </div>
          <% }) %>
        <% } else { %>
          <p class="no-coupons-text mt-3 mb-0">
            <i class="fa-regular fa-face-sad-tear me-1"></i>No coupons available right now.
          </p>
        <% } %>
      </div>

      <!-- Delivery Address -->
      <div class="checkout-card">
        <div class="card-heading">
          <div class="card-heading-icon">
            <i class="fa-solid fa-location-dot"></i>
          </div>
          <h5>Delivery Address</h5>
        </div>

        <% if (addresses && addresses.length > 0) { %>
          <div class="addr-list">
            <% addresses.forEach(addr => {
              const isSelected = selectedAddress && String(selectedAddress._id) === String(addr._id);
            %>
              <div class="addr-item <%= isSelected ? 'active' : '' %>"
                   onclick="selectAddr('<%= addr._id %>', this)">
                <div class="addr-radio"></div>
                <div>
                  <div class="mb-1">
                    <span class="addr-type-badge">
                      <i class="fa-solid fa-<%= (addr.type || 'home').toLowerCase() === 'work' ? 'briefcase' : 'house' %> fa-xs"></i>
                      <%= addr.type || 'Home' %>
                    </span>
                    <% if (addr.isDefault) { %>
                      <span class="default-badge">
                        <i class="fa-solid fa-star fa-xs"></i> Default
                      </span>
                    <% } %>
                  </div>
                  <div class="addr-name"><%= addr.name %></div>
                  <div class="addr-phone">
                    <i class="fa-solid fa-phone fa-xs"></i>
                    <%= addr.phone %>
                  </div>
                  <div class="addr-line">
                    <i class="fa-solid fa-map-pin fa-xs" style="color:var(--rose);margin-right:4px"></i>
                    <%= addr.street %><% if(addr.address){ %>, <%= addr.address %><% } %>
                    <% if(addr.landmark){ %><br>&nbsp;&nbsp;&nbsp;&nbsp;<%= addr.landmark %><% } %><br>
                    &nbsp;&nbsp;&nbsp;&nbsp;<%= addr.city %>, <%= addr.state %> – <%= addr.pincode %>
                  </div>
                  <a href="/address/edit/<%= addr._id %>?redirect=/checkout"
                     class="addr-edit-link" onclick="event.stopPropagation()">
                    <i class="fa-solid fa-pen-to-square fa-xs"></i> Edit address
                  </a>
                </div>
              </div>
            <% }) %>
          </div>
        <% } else { %>
          <div class="empty-addr">
            <i class="fa-solid fa-location-crosshairs" style="font-size:2.5rem;color:var(--rose);margin-bottom:12px;display:block"></i>
            <p class="mb-0">No saved addresses yet.</p>
          </div>
        <% } %>

        <button class="btn-add-addr" onclick="location.href='/add-address?from=checkout'">
          <span class="plus-icon"><i class="fa-solid fa-plus" style="font-size:.8rem"></i></span>
          Add a new delivery address
        </button>
      </div>

    </div>

    <!-- RIGHT COLUMN: Order Summary -->
    <div class="col-lg-5">
      <div class="summary-card">
        <div class="summary-title">
          <i class="fa-solid fa-bag-shopping me-2" style="color:var(--rose);font-size:.95rem;font-family:'Font Awesome 6 Free'"></i>
          Order Summary
          <span class="item-count"><%= items.length %> item<%= items.length !== 1 ? 's' : '' %> in your bag</span>
        </div>

        <% items.forEach(item => {
          const finalPrice = item.price;
          const regPrice   = item.variantId?.regularPrice;
          const saving     = regPrice > finalPrice ? (regPrice - finalPrice) * item.quantity : 0;
          const subtotal   = finalPrice * item.quantity;
        %>
          <div class="order-item">
            <img src="<%= item.variantId?.imageUrls?.[0] || item.productId?.productImages?.[0] || '/img/placeholder.png' %>"
                 class="item-img" alt="<%= item.productId?.productName %>">
            <div class="item-info">
              <div class="item-name"><%= item.productId?.productName %></div>
              <div class="item-meta">
                <% if (item.variantId?.weight) { %><%= item.variantId.weight %>g · <% } %>Qty: <%= item.quantity %>
              </div>
            </div>
            <div class="item-price">
              <% if (regPrice > finalPrice) { %>
                <div class="was">₹<%= (regPrice * item.quantity).toLocaleString('en-IN') %></div>
              <% } %>
              <div class="final">₹<%= subtotal.toLocaleString('en-IN') %></div>
              <% if (saving > 0) { %>
                <span class="saving">Save ₹<%= saving.toLocaleString('en-IN') %></span>
              <% } %>
            </div>
          </div>
        <% }) %>

        <!-- Price breakdown -->
        <div class="price-breakdown">
          <div class="price-row">
            <span class="label">Item Total</span>
            <span class="val" id="displayItemTotal">₹<%= itemTotal.toLocaleString('en-IN') %></span>
          </div>
          <% if (discount > 0) { %>
          <div class="price-row">
            <span class="label">
              <i class="fa-solid fa-tag fa-xs me-1" style="color:var(--green)"></i>Offer Discount
            </span>
            <span class="val discount-val">−₹<%= discount.toLocaleString('en-IN') %></span>
          </div>
          <% } %>

          <div class="price-row coupon-breakdown-row" id="couponBreakdownRow">
            <span class="label">
              <i class="fa-solid fa-percent fa-xs me-1" style="color:var(--green)"></i>Coupon Discount
              <span id="couponBreakdownCode" style="font-size:.75rem;color:var(--rose-dk);font-weight:700;margin-left:4px;"></span>
            </span>
            <span class="val discount-val" id="couponBreakdownAmt"></span>
          </div>

          <% if (tax > 0) { %>
          <div class="price-row">
            <span class="label">GST (<%= Math.round(TAX_RATE * 100) %>%)</span>
            <span class="val">₹<%= tax.toLocaleString('en-IN') %></span>
          </div>
          <% } %>

          <div class="price-row">
            <span class="label">
              <i class="fa-solid fa-truck-fast fa-xs me-1" style="color:var(--muted)"></i>Delivery
            </span>
            <span class="val" id="displayShipping">
              <% if (shippingCharge === 0) { %>
                <span class="free-badge">FREE</span>
              <% } else { %>
                ₹<%= shippingCharge %>
              <% } %>
            </span>
          </div>

          <div class="price-row total-row">
            <span class="label">Total Payable</span>
            <span class="val" id="finalTotalDisplay">₹<%= finalTotal.toLocaleString('en-IN') %></span>
          </div>
        </div>

        <!-- Hidden fields — ALL ORIGINAL, UNTOUCHED -->
        <input type="hidden" id="selectedAddrId"  value="<%= selectedAddress?._id || '' %>">
        <input type="hidden" id="appliedCoupon"   value="">
        <input type="hidden" id="baseItemTotal"   value="<%= itemTotal %>">
        <input type="hidden" id="baseShipping"    value="<%= shippingCharge %>">
        <input type="hidden" id="baseTotal"       value="<%= finalTotal %>">

        <button class="btn-place" onclick="proceedToPayment()">
          <i class="fa-solid fa-lock fa-xs"></i>
          Proceed to Payment
          <i class="fa-solid fa-arrow-right fa-xs"></i>
        </button>
        <div class="secure-note">
          <i class="fa-solid fa-shield-halved"></i>
          Safe and secure checkout
        </div>
      </div>
    </div>

  </div>
</div>

<%- include("../partials/user/footer") %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<!-- ── ALL ORIGINAL LOGIC PRESERVED EXACTLY ── -->
<script>
  let couponApplied = false;

  function selectAddr(id, el) {
    document.getElementById('selectedAddrId').value = id;
    document.querySelectorAll('.addr-item').forEach(c => c.classList.remove('active'));
    el.classList.add('active');
  }

  function useCoupon(code) {
    if (couponApplied) {
      showCouponMsg('Remove the current coupon before applying another.', 'error');
      return;
    }
    document.getElementById('couponCodeInput').value = code;
    applyCouponCode();
  }

  async function applyCouponCode() {
    if (couponApplied) {
      showCouponMsg('Remove the current coupon before applying another.', 'error');
      return;
    }

    const code = document.getElementById('couponCodeInput').value.trim().toUpperCase();
    const btn  = document.getElementById('btnApply');

    if (!code) {
      showCouponMsg('Please enter a coupon code.', 'error');
      return;
    }

    btn.disabled  = true;
    btn.innerHTML = '<span class="spinner"></span> Applying…';

    try {
      const res  = await fetch('/checkout/apply-coupon', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify({ code })
      });
      const data = await res.json();

      if (!data.success) {
        showCouponMsg(data.message, 'error');
        return;
      }

      couponApplied = true;
      document.getElementById('appliedCoupon').value = data.couponCode;

      document.getElementById('couponBreakdownRow').classList.add('visible');
      document.getElementById('couponBreakdownCode').textContent = `(${data.couponCode})`;
      document.getElementById('couponBreakdownAmt').textContent  = `−₹${data.discountAmt.toLocaleString('en-IN')}`;
      document.getElementById('finalTotalDisplay').textContent   = `₹${data.newTotal.toLocaleString('en-IN')}`;

      document.getElementById('appliedStripText').textContent =
        `${data.couponCode} — You save ₹${data.discountAmt.toLocaleString('en-IN')}`;
      document.getElementById('appliedStrip').classList.add('visible');
      document.getElementById('couponInputRow').style.display = 'none';

      document.querySelectorAll('.coupon-item').forEach(i => {
        i.classList.remove('applied');
        const b = i.querySelector('.btn-use-coupon');
        if (b) b.textContent = 'Use';
      });
      const card = document.getElementById('couponItem_' + data.couponCode);
      if (card) {
        card.classList.add('applied');
        card.querySelector('.btn-use-coupon').textContent = 'Applied ✓';
      }

      showCouponMsg(`🎉 ${data.message}`, 'success');

    } catch (err) {
      showCouponMsg('Something went wrong. Please try again.', 'error');
    } finally {
      btn.disabled  = false;
      btn.innerHTML = '<i class="fa-solid fa-tag fa-xs me-1"></i>Apply';
    }
  }

  async function removeCoupon() {
    try {
      const res  = await fetch('/checkout/remove-coupon', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' }
      });
      const data = await res.json();

      if (!data.success) return;

      couponApplied = false;
      document.getElementById('appliedCoupon').value = '';

      document.getElementById('couponBreakdownRow').classList.remove('visible');
      document.getElementById('couponBreakdownCode').textContent = '';
      document.getElementById('couponBreakdownAmt').textContent  = '';
      document.getElementById('finalTotalDisplay').textContent   =
        `₹${data.newTotal.toLocaleString('en-IN')}`;

      document.getElementById('appliedStrip').classList.remove('visible');
      document.getElementById('couponInputRow').style.display = '';
      document.getElementById('couponCodeInput').value = '';

      document.querySelectorAll('.coupon-item').forEach(i => {
        i.classList.remove('applied');
        const b = i.querySelector('.btn-use-coupon');
        if (b) b.textContent = 'Use';
      });

      hideCouponMsg();

    } catch (err) {
      console.error('removeCoupon error', err);
    }
  }

  function showCouponMsg(text, type) {
    const el     = document.getElementById('couponMsg');
    el.className = 'coupon-msg ' + type;
    el.textContent = text;
  }
  function hideCouponMsg() {
    const el     = document.getElementById('couponMsg');
    el.className = 'coupon-msg';
    el.textContent = '';
  }

  function proceedToPayment() {
    const addressId  = document.getElementById('selectedAddrId').value;
    const couponCode = document.getElementById('appliedCoupon').value;

    if (!addressId) {
      Swal.fire({
        icon: 'warning',
        title: 'Select an Address',
        text: 'Please select or add a delivery address.',
        confirmButtonColor: '#C97B8A'
      });
      return;
    }

    window.location.href =
      `/payment-page?addressId=${addressId}&couponCode=${encodeURIComponent(couponCode)}`;
  }

  const urlParams   = new URLSearchParams(window.location.search);
  const couponError = urlParams.get('couponError');
  if (couponError) {
    Swal.fire({
      icon: 'error',
      title: 'Coupon Invalid',
      text: decodeURIComponent(couponError),
      confirmButtonColor: '#C97B8A'
    });
  }

  const orderError = urlParams.get('error');
  if (orderError) {
    Swal.fire({
      icon: 'warning',
      title: 'COD Not Available',
      text: decodeURIComponent(orderError),
      confirmButtonColor: '#C97B8A',
      confirmButtonText: 'OK'
    });
  }
</script>
</body>
</html>
