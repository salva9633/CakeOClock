<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>User Profile – Cake O'Clock</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Nunito:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/cake.css">
  <style>
    :root {
      --burgundy:    #8B4A5A;
      --burgundy-dk: #6e3547;
      --blush:       #f7e0e8;
      --blush-mid:   #f0c4d4;
      --blush-pale:  #fdf5f8;
      --blush-field: #fce8f0;
      --white:       #ffffff;
      --text:        #2d1520;
      --muted:       #a07085;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: linear-gradient(135deg, #f9e8ef 0%, #fdf5f8 100%);
      font-family: 'Nunito', sans-serif;
      min-height: 100vh;
    }

    /* ── Shell ── */
    .dash-wrap {
      display: flex;
      width: 97%;
      min-height: 85vh;
      margin: 20px auto;
      background: var(--white);
      border-radius: 24px;
      box-shadow: 0 20px 60px rgba(139,74,90,.12);
      overflow: hidden;
    }

    /* ── Sidebar ── */
    .dash-sidebar {
      width: 260px;
      min-width: 260px;
      background: linear-gradient(180deg, #fff5f7 0%, #ffeef3 100%);
      border-right: 1.5px solid var(--blush-mid);
      padding: 28px 22px;
      flex-shrink: 0;
    }

    /* ── Main ── */
    .dash-main {
      flex: 1;
      padding: 48px 60px;
      overflow-y: auto;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .profile-wrapper {
      width: 100%;
      max-width: 660px;
    }

    /* ── Avatar section ── */
    .profile-header {
      display: flex;
      flex-direction: column;
      align-items: center;
      margin-bottom: 44px;
    }

    .avatar-ring {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      padding: 4px;
      background: linear-gradient(135deg, var(--burgundy), #d4889a);
      margin-bottom: 18px;
      box-shadow: 0 8px 28px rgba(139,74,90,.22);
    }
    .avatar-inner {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      overflow: hidden;
      background: var(--blush);
      border: 3px solid #fff;
    }
    .avatar-inner img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .profile-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.9rem;
      font-weight: 700;
      color: var(--burgundy);
      margin-bottom: 6px;
    }
    .profile-joined {
      font-size: .84rem;
      color: var(--muted);
    }
    .profile-joined strong { color: var(--burgundy); font-weight: 700; }

    /* ── Section title ── */
    .section-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--burgundy);
      margin-bottom: 24px;
      padding-bottom: 10px;
      border-bottom: 2px solid var(--blush-mid);
      width: 100%;
    }

    /* ── Info grid ── */
    .info-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-bottom: 32px;
      width: 100%;
    }

    .form-group { display: flex; flex-direction: column; gap: 8px; }

    .info-label {
      font-size: .72rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: .08em;
      color: var(--muted);
    }

    .info-input {
      background: var(--blush-field);
      border: 1.5px solid transparent;
      border-radius: 12px;
      padding: 14px 18px;
      font-size: .95rem;
      font-family: 'Nunito', sans-serif;
      font-weight: 600;
      color: var(--text);
      transition: border-color .2s;
      outline: none;
      width: 100%;
    }
    .info-input:focus { border-color: var(--blush-mid); }

    /* ── Edit button ── */
    .btn-edit {
      width: 100%;
      background: linear-gradient(135deg, var(--burgundy) 0%, var(--burgundy-dk) 100%);
      color: #fff;
      border: none;
      border-radius: 14px;
      padding: 16px;
      font-size: 1rem;
      font-weight: 700;
      font-family: 'Nunito', sans-serif;
      cursor: pointer;
      letter-spacing: .4px;
      box-shadow: 0 6px 20px rgba(139,74,90,.28);
      transition: transform .18s, box-shadow .18s;
      display: block;
      text-align: center;
      text-decoration: none;
    }
    .btn-edit:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 28px rgba(139,74,90,.36);
      color: #fff;
    }

    .google-note {
      margin-top: 16px;
      text-align: center;
      font-size: .82rem;
      color: var(--muted);
      background: var(--blush-field);
      border-radius: 10px;
      padding: 10px 16px;
    }
    .google-note i { color: var(--burgundy); margin-right: 5px; }

    /* ── Responsive ── */
    @media (max-width: 860px) {
      .dash-wrap { flex-direction: column; width: 100%; border-radius: 0; margin: 0; }
      .dash-sidebar { width: 100%; min-width: unset; border-right: none; border-bottom: 1.5px solid var(--blush-mid); }
      .dash-main { padding: 28px 20px; }
      .info-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<%- include("../../views/partials/user/h2") %>

<div class="dash-wrap">

  <!-- Sidebar -->
  <aside class="dash-sidebar">
    <%- include("../../views/partials/user/sider") %>
  </aside>

  <!-- Main -->
  <main class="dash-main">
    <div class="profile-wrapper">

      <!-- Avatar & name -->
      <div class="profile-header">
        <div class="avatar-ring">
          <div class="avatar-inner">
            <% if (user.authType === "google" && user.googleImage) { %>
              <img src="<%= user.googleImage %>" alt="Profile">
            <% } else if (user.profileImage) { %>
              <img src="<%= user.profileImage %>" alt="Profile">
            <% } else { %>
              <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRa4dLHtaXEf7QlVZYYQSnAbAi_8RuuLEzps2qyfORSMg&s" alt="Default">
            <% } %>
          </div>
        </div>
        <h1 class="profile-name"><%= user.name %></h1>
        <p class="profile-joined">Joined On: <strong><%= new Date(user.createdAt).toDateString() %></strong></p>
      </div>

      <!-- Fields -->
      <div class="section-title">User Profile</div>

      <div class="info-grid">
        <div class="form-group">
          <label class="info-label">Username</label>
          <input class="info-input" value="<%= user.name %>" readonly>
        </div>
        <div class="form-group">
          <label class="info-label">Gender</label>
          <input class="info-input" value="<%= user.gender || 'N/A' %>" readonly>
        </div>
        <div class="form-group">
          <label class="info-label">Email</label>
          <input class="info-input" value="<%= user.email %>" readonly>
        </div>
        <div class="form-group">
          <label class="info-label">Phone</label>
          <input class="info-input" value="<%= user.phone || 'N/A' %>" readonly>
        </div>
      </div>

      <a href="/editProfile" class="btn-edit">Edit Profile</a>

      <% if (user.authType === "google") { %>
        <p class="google-note">
          <i class="fab fa-google"></i>
          You signed in with Google. Email cannot be changed.
        </p>
      <% } %>

    </div>
  </main>

</div>

</body>
</html>
