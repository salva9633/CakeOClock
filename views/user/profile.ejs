<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>User Profile – Cake O'Clock</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Lato:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/cake.css">
  <%- include("../../views/partials/user/dashboardStyles") %>
</head>
<body>

<%- include("../../views/partials/user/h2") %>

<div class="page-wrap">

  <!-- ── SIDEBAR (never swapped by AJAX) ── -->
  <aside class="dash-sidebar">
    <%- include("../../views/partials/user/sider") %>
  </aside>

  <!-- ── MAIN (this is what gets swapped on navigation) ── -->
  <main class="dash-main" id="dashMain">

    <!-- HERO CARD -->
    <div class="hero-card">
      <div class="avatar-ring">
        <div class="avatar-inner">
          <% if (user.authType === "google" && user.googleImage) { %>
            <img src="<%= user.googleImage %>" alt="Profile">
          <% } else if (user.profileImage) { %>
            <img src="<%= user.profileImage %>" alt="Profile">
          <% } else { %>
            <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRa4dLHtaXEf7QlVZYYQSnAbAi_8RuuLEzps2qyfORSMg&s" alt="Default">
          <% } %>
        </div>
      </div>
      <div class="hero-info">
        <h1 class="hero-name"><%= user.name %></h1>
        <p class="hero-email"><%= user.email %></p>
        <span class="hero-badge">
          <i class="fas fa-calendar-alt"></i>
          Joined <%= new Date(user.createdAt).toDateString() %>
        </span>
      </div>
    </div>

    <!-- STATS ROW -->
    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-shopping-bag"></i></div>
        <div>
          <div class="stat-label">Total Orders</div>
          <div class="stat-value"><%= user.totalOrders || '0' %></div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-wallet"></i></div>
        <div>
          <div class="stat-label">Wallet Balance</div>
          <div class="stat-value">₹<%= user.walletBalance || '0' %></div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-heart"></i></div>
        <div>
          <div class="stat-label">Wishlist Items</div>
          <div class="stat-value"><%= user.wishlistCount || '0' %></div>
        </div>
      </div>
    </div>

    <!-- DETAILS CARD -->
    <div class="details-card">
      <div class="card-title">
        <i class="fas fa-user-circle"></i>
        Personal Information
      </div>

      <div class="field-grid">
        <div class="field-group">
          <span class="field-label">Full Name</span>
          <div class="field-value"><%= user.name %></div>
        </div>
        <div class="field-group">
          <span class="field-label">Gender</span>
          <div class="field-value"><%= user.gender || 'Not specified' %></div>
        </div>
        <div class="field-group">
          <span class="field-label">Email Address</span>
          <div class="field-value"><%= user.email %></div>
        </div>
        <div class="field-group">
          <span class="field-label">Phone Number</span>
          <div class="field-value"><%= user.phone || 'Not added' %></div>
        </div>
      </div>

      <!-- Referral Code -->
      <div class="field-label" style="margin-bottom:10px;">Referral Code</div>
      <div class="referral-row">
        <div class="referral-box" id="refCode">
          <%= user.referralCode || 'N/A' %>
        </div>
        <button class="copy-btn" onclick="copyRef()">
          <i class="fas fa-copy"></i> Copy
        </button>
      </div>

      <!-- Actions -->
      <div class="action-row">
        <a href="/editProfile" class="btn-primary-rose">
          <i class="fas fa-pen"></i> Edit Profile
        </a>
        <a href="/changePassword" class="btn-outline-rose spa-link">
          <i class="fas fa-lock"></i> Change Password
        </a>
      </div>

      <% if (user.authType === "google") { %>
        <p class="google-note">
          <i class="fab fa-google"></i>
          You signed in with Google. Email cannot be changed.
        </p>
      <% } %>
    </div>

  </main>
</div>

<script>
function copyRef() {
  const code = document.getElementById('refCode').textContent.trim();
  if (code === 'N/A') return;
  navigator.clipboard.writeText(code).then(() => {
    const btn = document.querySelector('.copy-btn');
    btn.innerHTML = '<i class="fas fa-check"></i> Copied!';
    btn.style.background = '#4caf50';
    setTimeout(() => {
      btn.innerHTML = '<i class="fas fa-copy"></i> Copy';
      btn.style.background = '';
    }, 2000);
  });
}
</script>

</body>
</html>
