<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>User Profile – Cake O'Clock</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Lato:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/cake.css">
  <style>
    :root {
      --rose:    #8B4A5A;
      --rose-dk: #6e3547;
      --rose-lt: #fdf0f5;
      --blush:   #f3d7d3;
      --cream:   #fff8f9;
      --muted:   #a07085;
      --border:  #f0c4d4;
      --text:    #2d1520;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: linear-gradient(135deg, #f9e8ef 0%, #fdf5f8 50%, #f3e8f5 100%);
      font-family: 'Lato', sans-serif;
      min-height: 100vh;
    }

    /* ── PAGE WRAP ── */
    .page-wrap {
      max-width: 1180px;
      margin: 0 auto;
      padding: 32px 24px 60px;
      display: flex;
      gap: 28px;
      align-items: flex-start;
    }

    /* ══════════════════════════════
       SIDEBAR
    ══════════════════════════════ */
    .dash-sidebar {
      width: 250px;
      min-width: 250px;
      flex-shrink: 0;
      animation: slideLeft .5s ease both;
    }

    @keyframes slideLeft {
      from { opacity: 0; transform: translateX(-24px); }
      to   { opacity: 1; transform: translateX(0); }
    }

    /* ══════════════════════════════
       MAIN CONTENT
    ══════════════════════════════ */
    .dash-main {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 24px;
      animation: slideUp .55s ease .1s both;
    }

    @keyframes slideUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── HERO CARD ── */
    .hero-card {
      background: linear-gradient(135deg, var(--rose) 0%, #c27090 50%, #d4889a 100%);
      border-radius: 24px;
      padding: 40px 48px;
      display: flex;
      align-items: center;
      gap: 36px;
      box-shadow: 0 16px 48px rgba(139,74,90,.22);
      position: relative;
      overflow: hidden;
    }

    .hero-card::before {
      content: '';
      position: absolute;
      top: -60px; right: -60px;
      width: 220px; height: 220px;
      border-radius: 50%;
      background: rgba(255,255,255,.08);
    }

    .hero-card::after {
      content: '';
      position: absolute;
      bottom: -40px; left: 30%;
      width: 160px; height: 160px;
      border-radius: 50%;
      background: rgba(255,255,255,.06);
    }

    /* Avatar */
    .avatar-ring {
      width: 110px; height: 110px;
      border-radius: 50%;
      padding: 3px;
      background: rgba(255,255,255,.35);
      flex-shrink: 0;
      box-shadow: 0 8px 28px rgba(0,0,0,.18);
      position: relative;
      z-index: 2;
    }

    .avatar-inner {
      width: 100%; height: 100%;
      border-radius: 50%;
      overflow: hidden;
      background: var(--blush);
      border: 3px solid rgba(255,255,255,.8);
    }

    .avatar-inner img {
      width: 100%; height: 100%;
      object-fit: cover;
    }

    .hero-info { position: relative; z-index: 2; }

    .hero-name {
      font-family: 'Playfair Display', serif;
      font-size: 2rem;
      font-weight: 700;
      color: #fff;
      line-height: 1.1;
      margin-bottom: 6px;
    }

    .hero-email {
      font-size: .88rem;
      color: rgba(255,255,255,.78);
      margin-bottom: 14px;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(255,255,255,.18);
      border: 1px solid rgba(255,255,255,.28);
      color: #fff;
      font-size: .72rem;
      font-weight: 700;
      letter-spacing: .06em;
      padding: 5px 14px;
      border-radius: 50px;
      backdrop-filter: blur(6px);
    }

    /* ── INFO CARDS ROW ── */
    .stats-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }

    .stat-card {
      background: #fff;
      border-radius: 18px;
      padding: 22px 24px;
      display: flex;
      align-items: center;
      gap: 16px;
      box-shadow: 0 4px 20px rgba(139,74,90,.08);
      border: 1px solid var(--border);
      transition: transform .25s, box-shadow .25s;
      animation: fadeCard .5s ease both;
    }

    .stat-card:nth-child(1) { animation-delay: .15s; }
    .stat-card:nth-child(2) { animation-delay: .22s; }
    .stat-card:nth-child(3) { animation-delay: .29s; }

    @keyframes fadeCard {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .stat-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 10px 32px rgba(139,74,90,.14);
    }

    .stat-icon {
      width: 48px; height: 48px;
      border-radius: 14px;
      background: var(--rose-lt);
      display: flex; align-items: center; justify-content: center;
      color: var(--rose);
      font-size: 1.2rem;
      flex-shrink: 0;
    }

    .stat-label {
      font-size: .72rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .08em;
      color: var(--muted);
      margin-bottom: 4px;
    }

    .stat-value {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      font-weight: 700;
      color: var(--text);
    }

    /* ── DETAILS CARD ── */
    .details-card {
      background: #fff;
      border-radius: 22px;
      padding: 32px 36px;
      box-shadow: 0 4px 20px rgba(139,74,90,.08);
      border: 1px solid var(--border);
      animation: fadeCard .5s ease .35s both;
    }

    .card-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--rose);
      margin-bottom: 24px;
      padding-bottom: 12px;
      border-bottom: 2px solid var(--border);
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .card-title i { font-size: 1rem; }

    /* ── FIELD GRID ── */
    .field-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
      margin-bottom: 24px;
    }

    .field-group { display: flex; flex-direction: column; gap: 7px; }

    .field-label {
      font-size: .7rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: .1em;
      color: var(--muted);
    }

    .field-value {
      background: var(--rose-lt);
      border: 1.5px solid var(--border);
      border-radius: 12px;
      padding: 13px 18px;
      font-size: .93rem;
      font-weight: 600;
      color: var(--text);
      font-family: 'Lato', sans-serif;
      transition: border-color .2s;
    }

    .field-value:focus-within { border-color: var(--rose); }

    /* Referral row */
    .referral-row {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 28px;
    }

    .referral-box {
      flex: 1;
      background: linear-gradient(135deg, var(--rose-lt) 0%, #fce8f0 100%);
      border: 1.5px dashed var(--border);
      border-radius: 12px;
      padding: 13px 18px;
      font-size: .93rem;
      font-weight: 700;
      color: var(--rose);
      letter-spacing: .06em;
      font-family: 'Lato', sans-serif;
    }

    .copy-btn {
      padding: 13px 20px;
      background: var(--rose);
      color: #fff;
      border: none;
      border-radius: 12px;
      font-size: .82rem;
      font-weight: 700;
      cursor: pointer;
      font-family: 'Lato', sans-serif;
      transition: background .2s, transform .15s;
      display: flex;
      align-items: center;
      gap: 6px;
      white-space: nowrap;
    }

    .copy-btn:hover { background: var(--rose-dk); transform: translateY(-1px); }

    /* ── ACTIONS ── */
    .action-row {
      display: flex;
      gap: 12px;
    }

    .btn-primary-rose {
      flex: 1;
      background: linear-gradient(135deg, var(--rose) 0%, var(--rose-dk) 100%);
      color: #fff;
      border: none;
      border-radius: 14px;
      padding: 15px 24px;
      font-size: .92rem;
      font-weight: 700;
      font-family: 'Lato', sans-serif;
      cursor: pointer;
      box-shadow: 0 6px 20px rgba(139,74,90,.28);
      transition: transform .18s, box-shadow .18s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      text-decoration: none;
    }

    .btn-primary-rose:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 28px rgba(139,74,90,.36);
      color: #fff;
    }

    .btn-outline-rose {
      flex: 1;
      background: transparent;
      color: var(--rose);
      border: 1.5px solid var(--border);
      border-radius: 14px;
      padding: 15px 24px;
      font-size: .92rem;
      font-weight: 700;
      font-family: 'Lato', sans-serif;
      cursor: pointer;
      transition: all .18s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      text-decoration: none;
    }

    .btn-outline-rose:hover {
      background: var(--rose-lt);
      border-color: var(--rose);
      color: var(--rose);
      transform: translateY(-2px);
    }

    .google-note {
      margin-top: 16px;
      text-align: center;
      font-size: .82rem;
      color: var(--muted);
      background: var(--rose-lt);
      border-radius: 10px;
      padding: 10px 16px;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      .page-wrap { flex-direction: column; padding: 16px; }
      .dash-sidebar { width: 100%; min-width: unset; }
      .stats-row { grid-template-columns: 1fr 1fr; }
      .hero-card { flex-direction: column; text-align: center; padding: 32px 24px; }
      .details-card { padding: 24px 20px; }
      .field-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 540px) {
      .stats-row { grid-template-columns: 1fr; }
      .action-row { flex-direction: column; }
    }
  </style>
</head>
<body>

<%- include("../../views/partials/user/h2") %>

<div class="page-wrap">

  <!-- ── SIDEBAR ── -->
  <aside class="dash-sidebar">
    <%- include("../../views/partials/user/sider") %>
  </aside>

  <!-- ── MAIN ── -->
  <main class="dash-main">

    <!-- HERO CARD -->
    <div class="hero-card">
      <div class="avatar-ring">
        <div class="avatar-inner">
          <% if (user.authType === "google" && user.googleImage) { %>
            <img src="<%= user.googleImage %>" alt="Profile">
          <% } else if (user.profileImage) { %>
            <img src="<%= user.profileImage %>" alt="Profile">
          <% } else { %>
            <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRa4dLHtaXEf7QlVZYYQSnAbAi_8RuuLEzps2qyfORSMg&s" alt="Default">
          <% } %>
        </div>
      </div>
      <div class="hero-info">
        <h1 class="hero-name"><%= user.name %></h1>
        <p class="hero-email"><%= user.email %></p>
        <span class="hero-badge">
          <i class="fas fa-calendar-alt"></i>
          Joined <%= new Date(user.createdAt).toDateString() %>
        </span>
      </div>
    </div>

    <!-- STATS ROW -->
    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-shopping-bag"></i></div>
        <div>
          <div class="stat-label">Total Orders</div>
          <div class="stat-value"><%= user.totalOrders || '0' %></div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-wallet"></i></div>
        <div>
          <div class="stat-label">Wallet Balance</div>
          <div class="stat-value">₹<%= user.walletBalance || '0' %></div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon"><i class="fas fa-heart"></i></div>
        <div>
          <div class="stat-label">Wishlist Items</div>
          <div class="stat-value"><%= user.wishlistCount || '0' %></div>
        </div>
      </div>
    </div>

    <!-- DETAILS CARD -->
    <div class="details-card">
      <div class="card-title">
        <i class="fas fa-user-circle"></i>
        Personal Information
      </div>

      <div class="field-grid">
        <div class="field-group">
          <span class="field-label">Full Name</span>
          <div class="field-value"><%= user.name %></div>
        </div>
        <div class="field-group">
          <span class="field-label">Gender</span>
          <div class="field-value"><%= user.gender || 'Not specified' %></div>
        </div>
        <div class="field-group">
          <span class="field-label">Email Address</span>
          <div class="field-value"><%= user.email %></div>
        </div>
        <div class="field-group">
          <span class="field-label">Phone Number</span>
          <div class="field-value"><%= user.phone || 'Not added' %></div>
        </div>
      </div>

      <!-- Referral Code -->
      <div class="field-label" style="margin-bottom:10px;">Referral Code</div>
      <div class="referral-row">
        <div class="referral-box" id="refCode">
          <%= user.referralCode || 'N/A' %>
        </div>
        <button class="copy-btn" onclick="copyRef()">
          <i class="fas fa-copy"></i> Copy
        </button>
      </div>

      <!-- Actions -->
      <div class="action-row">
        <a href="/editProfile" class="btn-primary-rose">
          <i class="fas fa-pen"></i> Edit Profile
        </a>
        <a href="/changePassword" class="btn-outline-rose">
          <i class="fas fa-lock"></i> Change Password
        </a>
      </div>

      <% if (user.authType === "google") { %>
        <p class="google-note">
          <i class="fab fa-google"></i>
          You signed in with Google. Email cannot be changed.
        </p>
      <% } %>
    </div>

  </main>
</div>

<script>
function copyRef() {
  const code = document.getElementById('refCode').textContent.trim();
  if (code === 'N/A') return;
  navigator.clipboard.writeText(code).then(() => {
    const btn = document.querySelector('.copy-btn');
    btn.innerHTML = '<i class="fas fa-check"></i> Copied!';
    btn.style.background = '#4caf50';
    setTimeout(() => {
      btn.innerHTML = '<i class="fas fa-copy"></i> Copy';
      btn.style.background = '';
    }, 2000);
  });
}
</script>

</body>
</html>