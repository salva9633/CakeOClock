<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Message Detail – Cake O'Clock</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Lato:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="/css/cake.css">
  <style>
    :root {
      --rose:    #8B4A5A;
      --rose-dk: #6e3547;
      --rose-lt: #fdf0f5;
      --blush:   #f3d7d3;
      --cream:   #fff8f9;
      --muted:   #a07085;
      --border:  #f0c4d4;
      --text:    #2d1520;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: linear-gradient(135deg, #f9e8ef 0%, #fdf5f8 50%, #f3e8f5 100%);
      font-family: 'Lato', sans-serif;
      min-height: 100vh;
    }

    .page-wrap {
      max-width: 1180px;
      margin: 0 auto;
      padding: 32px 24px 60px;
      display: flex;
      gap: 28px;
      align-items: flex-start;
    }

    .dash-sidebar {
      width: 250px;
      min-width: 250px;
      flex-shrink: 0;
      animation: slideLeft .5s ease both;
    }

    @keyframes slideLeft {
      from { opacity: 0; transform: translateX(-24px); }
      to   { opacity: 1; transform: translateX(0); }
    }

    .dash-main {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 20px;
      animation: slideUp .55s ease .1s both;
    }

    @keyframes slideUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── TOP NAV ── */
    .top-nav {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .back-btn {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 9px 16px;
      background: #fff;
      border: 1.5px solid var(--border);
      border-radius: 10px;
      color: var(--muted);
      font-size: .82rem;
      font-weight: 700;
      text-decoration: none;
      font-family: 'Lato', sans-serif;
      transition: all .2s;
    }

    .back-btn:hover {
      border-color: var(--rose);
      color: var(--rose);
      background: var(--rose-lt);
    }

    .page-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem;
      font-weight: 700;
      color: var(--text);
    }

    /* ── MESSAGE CARD ── */
    .msg-card {
      background: #fff;
      border-radius: 22px;
      overflow: hidden;
      box-shadow: 0 4px 20px rgba(139,74,90,.08);
      border: 1px solid var(--border);
      animation: fadeCard .5s ease .1s both;
    }

    @keyframes fadeCard {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .msg-card-header {
      background: linear-gradient(135deg, var(--rose) 0%, #c27090 100%);
      padding: 28px 32px;
      position: relative;
      overflow: hidden;
    }

    .msg-card-header::before {
      content: '';
      position: absolute;
      top: -40px; right: -40px;
      width: 160px; height: 160px;
      border-radius: 50%;
      background: rgba(255,255,255,.08);
    }

    .msg-subject {
      font-family: 'Playfair Display', serif;
      font-size: 1.3rem;
      font-weight: 700;
      color: #fff;
      margin-bottom: 10px;
      position: relative; z-index: 2;
    }

    .msg-meta {
      display: flex;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
      position: relative; z-index: 2;
    }

    .msg-meta-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: .78rem;
      color: rgba(255,255,255,.75);
    }

    .msg-meta-item i { color: rgba(255,255,255,.5); }

    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      font-size: .7rem;
      font-weight: 700;
      padding: 5px 14px;
      border-radius: 20px;
      letter-spacing: .04em;
      margin-left: auto;
      position: relative; z-index: 2;
    }

    .badge-replied {
      background: rgba(230,244,234,.9);
      color: #2e7d32;
    }

    .badge-pending {
      background: rgba(252,232,237,.9);
      color: #c0394f;
    }

    .msg-body {
      padding: 28px 32px;
      border-bottom: 1px solid #fdf0f2;
    }

    .msg-body-label {
      font-size: .68rem;
      font-weight: 800;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 7px;
    }

    .msg-body-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    .msg-body p {
      font-size: .92rem;
      color: #555;
      line-height: 1.9;
      white-space: pre-wrap;
    }

    /* ── REPLY CARD ── */
    .reply-card {
      background: #fff;
      border-radius: 22px;
      overflow: hidden;
      box-shadow: 0 4px 20px rgba(139,74,90,.08);
      border: 1px solid var(--border);
      animation: fadeCard .5s ease .2s both;
    }

    .reply-header {
      background: linear-gradient(135deg, #f0faf2, #e8f5ea);
      border-bottom: 1px solid #b7dfbf;
      padding: 18px 28px;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .reply-icon {
      width: 36px; height: 36px;
      border-radius: 10px;
      background: #e6f4ea;
      border: 1.5px solid #b7dfbf;
      display: flex; align-items: center; justify-content: center;
      color: #2e7d32;
      font-size: .9rem;
    }

    .reply-from {
      font-size: .72rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: .1em;
      color: #2e7d32;
    }

    .reply-from span {
      display: block;
      font-size: .75rem;
      font-weight: 600;
      color: #5a9463;
      text-transform: none;
      letter-spacing: 0;
      margin-top: 1px;
    }

    .reply-time {
      margin-left: auto;
      font-size: .74rem;
      color: #aaa;
      font-weight: 600;
    }

    .reply-body {
      padding: 24px 28px;
    }

    .reply-body p {
      font-size: .92rem;
      color: #444;
      line-height: 1.9;
      white-space: pre-wrap;
    }

    /* ── PENDING CARD ── */
    .pending-card {
      background: #fff;
      border-radius: 22px;
      border: 2px dashed var(--border);
      padding: 36px 28px;
      text-align: center;
      box-shadow: 0 4px 20px rgba(139,74,90,.04);
      animation: fadeCard .5s ease .2s both;
    }

    .pending-icon {
      width: 64px; height: 64px;
      border-radius: 50%;
      background: var(--rose-lt);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.5rem;
      color: var(--muted);
      margin: 0 auto 16px;
    }

    .pending-card h3 {
      font-family: 'Playfair Display', serif;
      font-size: 1rem;
      color: var(--text);
      margin-bottom: 8px;
    }

    .pending-card p {
      font-size: .84rem;
      color: #bbb;
    }

    /* ── BACK FOOTER ── */
    .footer-nav {
      animation: fadeCard .5s ease .3s both;
    }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 12px 22px;
      background: #fff;
      border: 1.5px solid var(--border);
      border-radius: 12px;
      color: var(--muted);
      font-size: .84rem;
      font-weight: 700;
      text-decoration: none;
      transition: all .2s;
    }

    .back-link:hover {
      border-color: var(--rose);
      color: var(--rose);
      background: var(--rose-lt);
      transform: translateX(-3px);
    }

    @media (max-width: 900px) {
      .page-wrap { flex-direction: column; padding: 16px; }
      .dash-sidebar { width: 100%; min-width: unset; }
      .msg-card-header, .msg-body, .reply-header, .reply-body { padding: 20px; }
      .msg-meta { gap: 10px; }
    }
  </style>
</head>
<body>

<%- include("../../views/partials/user/h2") %>

<div class="page-wrap">

  <!-- SIDEBAR -->
  <aside class="dash-sidebar">
    <%- include("../../views/partials/user/sider") %>
  </aside>

  <!-- MAIN -->
  <main class="dash-main">

    <!-- TOP NAV -->
    <div class="top-nav">
      <a href="/my-messages" class="back-btn">
        <i class="fas fa-arrow-left"></i> Back to Messages
      </a>
      <h1 class="page-title">Message Detail</h1>
    </div>

    <!-- MESSAGE CARD -->
    <div class="msg-card">
      <div class="msg-card-header">
        <div class="msg-subject"><%= msg.subject %></div>
        <div class="msg-meta">
          <div class="msg-meta-item">
            <i class="fas fa-user"></i>
            <strong style="color:#fff;"><%= msg.name %></strong>
          </div>
          <div class="msg-meta-item">
            <i class="fas fa-envelope"></i>
            <%= msg.email %>
          </div>
          <div class="msg-meta-item">
            <i class="fas fa-clock"></i>
            <%= new Date(msg.createdAt).toLocaleString('en-IN',{day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
          </div>
          <% if (msg.status === 'replied') { %>
            <span class="status-badge badge-replied">
              <i class="fas fa-check-circle"></i> Replied
            </span>
          <% } else { %>
            <span class="status-badge badge-pending">
              <i class="fas fa-clock"></i> Pending
            </span>
          <% } %>
        </div>
      </div>
      <div class="msg-body">
        <div class="msg-body-label"><i class="fas fa-comment-dots"></i> Your Message</div>
        <p><%= msg.message %></p>
      </div>
    </div>

    <!-- REPLY or PENDING -->
    <% if (msg.adminReply && msg.adminReply.text) { %>
    <div class="reply-card">
      <div class="reply-header">
        <div class="reply-icon">
          <i class="fas fa-reply"></i>
        </div>
        <div class="reply-from">
          Reply from Cake O'Clock
          <span>Our team got back to you</span>
        </div>
        <div class="reply-time">
          <i class="fas fa-clock" style="margin-right:4px;"></i>
          <%= new Date(msg.adminReply.repliedAt).toLocaleString('en-IN',{day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
        </div>
      </div>
      <div class="reply-body">
        <p><%= msg.adminReply.text %></p>
      </div>
    </div>
    <% } else { %>
    <div class="pending-card">
      <div class="pending-icon">
        <i class="fas fa-hourglass-half"></i>
      </div>
      <h3>Reply on the way</h3>
      <p>Our team hasn't replied yet. We typically respond within 24 hours.</p>
    </div>
    <% } %>

    <!-- FOOTER NAV -->
    <div class="footer-nav">
      <a href="/my-messages" class="back-link">
        <i class="fas fa-arrow-left"></i> Back to all messages
      </a>
    </div>

  </main>
</div>

</body>
</html>
