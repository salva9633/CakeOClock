<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Change Password – Cake O'Clock</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/css/cake.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --rose: #AF5454; --rose-dk: #8c3a3a; --rose-mid: #c97070;
      --rose-lt: #fdf0f0; --rose-pale: #fff5f2;
      --brown: #3d1f1f; --brown-lt: #7a5050;
      --cream: #fdf8f6; --muted: #8a7070; --border: #ecdada;
      --font-display: 'Playfair Display', serif;
      --font-body: 'DM Sans', sans-serif;
      --r-sm: 10px; --r-md: 14px; --r-lg: 18px; --r-xl: 24px;
      --shadow-md: 0 6px 24px rgba(175,84,84,.12);
      --shadow-lg: 0 14px 44px rgba(175,84,84,.18);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: var(--font-body); background: linear-gradient(135deg, #f5e0dd 0%, #fdf3ef 100%); color: var(--brown); }

    .dash-wrap {
      display: flex; width: 97%; min-height: 85vh;
      margin: 20px auto; background: #fff;
      border-radius: var(--r-xl); box-shadow: var(--shadow-md); overflow: hidden;
      animation: wrapIn .5s cubic-bezier(.22,.9,.36,1) both;
    }
    @keyframes wrapIn {
      from { opacity: 0; transform: translateY(30px) scale(.98); }
      to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    .dash-sidebar {
      width: 260px; min-width: 260px;
      background: linear-gradient(180deg, var(--rose-pale) 0%, #fff0ec 100%);
      border-right: 1px solid var(--border); padding: 28px 22px;
    }
    .dash-main { flex: 1; padding: 36px 44px; overflow-y: auto; display: flex; flex-direction: column; align-items: center; }

    /* ── Topbar ── */
    .page-topbar {
      width: 100%; max-width: 500px;
      margin-bottom: 32px; animation: slideDown .45s .1s ease both;
    }
    @keyframes slideDown { from { opacity: 0; transform: translateY(-16px); } to { opacity: 1; transform: translateY(0); } }
    .page-topbar h2 {
      font-family: var(--font-display); font-size: 1.9rem; font-weight: 700;
      color: var(--brown); position: relative; display: inline-block;
    }
    .page-topbar h2::after {
      content: ''; position: absolute; bottom: -4px; left: 0;
      height: 3px; width: 0;
      background: linear-gradient(90deg, var(--rose), var(--rose-dk));
      border-radius: 2px; animation: drawLine .55s .55s ease forwards;
    }
    @keyframes drawLine { to { width: 100%; } }

    /* ── Form container ── */
    .pw-container {
      width: 100%; max-width: 500px;
      animation: slideUp .5s .2s ease both;
    }
    @keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

    /* ── Alert banners ── */
    .alert-banner {
      border-radius: var(--r-sm); padding: 12px 16px; margin-bottom: 20px;
      font-size: .88rem; font-weight: 500; display: flex; align-items: center; gap: 10px;
    }
    .alert-error { background: #fdecea; color: #c0392b; border: 1px solid #f5c6c6; }
    .alert-success { background: #e6f4ea; color: #1e7e34; border: 1px solid #b8dfc0; }

    /* ── Google card ── */
    .google-card {
      text-align: center; padding: 36px 32px;
      background: var(--cream); border-radius: var(--r-lg);
      border: 1.5px dashed var(--border); margin-bottom: 20px;
      animation: slideUp .5s .25s ease both;
    }
    .google-card-icon {
      width: 64px; height: 64px; margin: 0 auto 16px;
      background: linear-gradient(135deg, #fff0f0, #fde8e8);
      border-radius: 50%; display: flex; align-items: center; justify-content: center;
      font-size: 1.8rem;
    }
    .google-card h3 { font-family: var(--font-display); font-size: 1.25rem; color: var(--brown); margin-bottom: 10px; }
    .google-card p { color: var(--muted); line-height: 1.6; font-size: .9rem; margin-bottom: 20px; }
    .btn-google {
      display: inline-flex; align-items: center; gap: 8px;
      background: #db4437; color: #fff; padding: 12px 22px;
      border-radius: 50px; text-decoration: none; font-weight: 700; font-size: .87rem;
      font-family: var(--font-body); transition: transform .18s, box-shadow .18s;
      box-shadow: 0 4px 16px rgba(219,68,55,.28);
    }
    .btn-google:hover { transform: translateY(-2px); box-shadow: 0 8px 22px rgba(219,68,55,.38); color: #fff; }

    /* ── Password form card ── */
    .pw-form-card {
      background: var(--cream); border: 1.5px solid var(--border);
      border-radius: var(--r-lg); padding: 32px 36px;
    }
    .form-group { margin-bottom: 20px; }
    .form-label {
      font-size: .72rem; font-weight: 800; letter-spacing: .1em;
      text-transform: uppercase; color: var(--brown-lt); display: block; margin-bottom: 7px;
      transition: color .2s;
    }
    .form-group:focus-within .form-label { color: var(--rose); }

    .input-wrap { position: relative; }
    .form-input {
      width: 100%; background: #fff; border: 1.5px solid var(--border);
      border-radius: var(--r-sm); padding: 13px 44px 13px 16px;
      font-family: var(--font-body); font-size: .92rem; color: var(--brown); outline: none;
      transition: border-color .2s, box-shadow .2s, transform .15s;
    }
    .form-input::placeholder { color: var(--muted); opacity: .7; }
    .form-input:focus {
      background: #fff; border-color: var(--rose-mid);
      box-shadow: 0 0 0 4px rgba(175,84,84,.09); transform: translateY(-1px);
    }
    .form-input.error-field { border-color: #e05555 !important; }
    .toggle-pw {
      position: absolute; right: 14px; top: 50%; transform: translateY(-50%);
      color: var(--muted); cursor: pointer; font-size: .9rem;
      transition: color .2s;
    }
    .toggle-pw:hover { color: var(--rose); }
    .field-error { font-size: .74rem; color: #e05555; margin-top: 5px; display: none; }

    .btn-submit {
      width: 100%; padding: 14px;
      background: linear-gradient(135deg, var(--rose) 0%, var(--rose-dk) 100%);
      color: #fff; border: none; border-radius: 50px;
      font-family: var(--font-body); font-size: .92rem; font-weight: 700; cursor: pointer;
      transition: transform .18s, box-shadow .18s;
      box-shadow: 0 6px 20px rgba(175,84,84,.28);
      display: flex; align-items: center; justify-content: center; gap: 8px;
      position: relative; overflow: hidden; margin-top: 8px;
    }
    .btn-submit::after {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(105deg, transparent 40%, rgba(255,255,255,.22) 50%, transparent 60%);
      transform: translateX(-100%); transition: transform .4s;
    }
    .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(175,84,84,.36); }
    .btn-submit:hover::after { transform: translateX(160%); }
    .btn-submit:active { transform: scale(.97); }

    @media (max-width: 860px) {
      .dash-wrap { flex-direction: column; width: 100%; border-radius: 0; margin: 0; }
      .dash-sidebar { width: 100%; border-right: none; border-bottom: 1px solid var(--border); }
      .dash-main { padding: 20px 16px; }
    }
  </style>
</head>
<body>

<%- include("../../views/partials/user/h2") %>

<div class="dash-wrap">
  <aside class="dash-sidebar">
    <%- include("../../views/partials/user/sider") %>
  </aside>

  <main class="dash-main">
    <div class="page-topbar">
      <h2>Change Password</h2>
    </div>

    <div class="pw-container">

      <% if (error) { %>
        <div class="alert-banner alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
      <% } %>
      <% if (success) { %>
        <div class="alert-banner alert-success"><i class="fas fa-check-circle"></i> <%= success %></div>
      <% } %>

      <%
        const isGoogleUser = user && user.authType === "google";
        const hasPassword = user && user.password;
      %>

      <% if (isGoogleUser || (!isGoogleUser && !hasPassword)) { %>
        <div class="google-card">
          <div class="google-card-icon"><i class="fab fa-google" style="color:#db4437"></i></div>
          <h3>Google Account Login</h3>
          <p>
            This account was created using <strong>Google Sign-In</strong>.<br>
            Passwords for Google accounts are managed directly through Google.
          </p>
          <a href="https://myaccount.google.com/security" target="_blank" class="btn-google">
            <i class="fab fa-google"></i> Manage Google Password
          </a>
        </div>
      <% } %>

      <% if (!isGoogleUser && hasPassword) { %>
        <div class="pw-form-card">
          <form action="/changePassword" method="POST" onsubmit="return validatePasswordForm()">

            <div class="form-group">
              <label class="form-label">Current Password</label>
              <div class="input-wrap">
                <input type="password" name="currentPassword" id="currentPassword"
                  class="form-input" placeholder="Enter current password" required onblur="checkCurrentPassword()">
                <span class="toggle-pw" onclick="toggleVis('currentPassword', this)">
                  <i class="fas fa-eye"></i>
                </span>
              </div>
              <div class="field-error" id="currentPassError">Current password is incorrect</div>
            </div>

            <div class="form-group">
              <label class="form-label">New Password</label>
              <div class="input-wrap">
                <input type="password" name="newPassword" id="newPassword"
                  class="form-input" placeholder="Min 8 characters" required>
                <span class="toggle-pw" onclick="toggleVis('newPassword', this)">
                  <i class="fas fa-eye"></i>
                </span>
              </div>
              <div class="field-error" id="newPassError"></div>
            </div>

            <div class="form-group">
              <label class="form-label">Confirm New Password</label>
              <div class="input-wrap">
                <input type="password" name="confirmPassword" id="confirmPassword"
                  class="form-input" placeholder="Repeat new password" required>
                <span class="toggle-pw" onclick="toggleVis('confirmPassword', this)">
                  <i class="fas fa-eye"></i>
                </span>
              </div>
              <div class="field-error" id="confirmPassError"></div>
            </div>

            <button type="submit" class="btn-submit">
              <i class="fas fa-lock"></i> Update Password
            </button>
          </form>
        </div>
      <% } %>
    </div>
  </main>
</div>

<script>
  function toggleVis(id, icon) {
    const input = document.getElementById(id);
    const isHidden = input.type === 'password';
    input.type = isHidden ? 'text' : 'password';
    icon.innerHTML = isHidden ? '<i class="fas fa-eye-slash"></i>' : '<i class="fas fa-eye"></i>';
  }

  function validatePasswordForm() {
    const current = document.querySelector('[name="currentPassword"]').value.trim();
    const newPass = document.querySelector('[name="newPassword"]').value.trim();
    const confirm = document.querySelector('[name="confirmPassword"]').value.trim();
    let valid = true;

    if (newPass.length < 8) {
      showFieldError('newPassError', 'Password must be at least 8 characters');
      valid = false;
    } else { clearFieldError('newPassError'); }

    if (newPass !== confirm) {
      showFieldError('confirmPassError', 'Passwords do not match');
      valid = false;
    } else { clearFieldError('confirmPassError'); }

    return valid;
  }

  function showFieldError(id, msg) {
    const el = document.getElementById(id);
    el.textContent = msg; el.style.display = 'block';
  }
  function clearFieldError(id) {
    const el = document.getElementById(id);
    el.style.display = 'none';
  }

  async function checkCurrentPassword() {
    const currentPassword = document.getElementById("currentPassword").value.trim();
    const errorEl = document.getElementById("currentPassError");
    if (!currentPassword) { errorEl.style.display = "none"; return; }
    const res  = await fetch("/checkCurrentPassword", {
      method: "POST", headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ currentPassword })
    });
    const data = await res.json();
    errorEl.style.display = data.valid ? "none" : "block";
  }
</script>
</body>
</html>
