<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>My Messages – Cake O'Clock</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<%- include("../../views/partials/user/h2") %>
<%- include("../../views/partials/user/dashboardStyles") %>

<div class="page-wrap">

  <aside class="dash-sidebar">
    <%- include("../../views/partials/user/sider") %>
  </aside>

  <!-- Page CSS, markup and page JS all live inside #dashMain so a normal
       SPA swap brings everything this page needs along with it. -->
  <main class="dash-main" id="dashMain">
    <style>
      /* extra tokens on top of dashboardStyle's shared :root */
      :root {
        --r-sm: 10px; --r-md: 14px; --r-lg: 18px; --r-xl: 24px;
        --gap-sm: 12px; --gap-md: 20px; --gap-lg: 28px;
      }

      .page-topbar {
        margin-bottom: var(--gap-lg);
        display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;
      }
      .page-topbar-stats { display: flex; gap: 10px; }
    .pt-stat {
  background: linear-gradient(135deg, var(--rose-lt), #fdf2f5);
  border: 1.5px solid var(--border); border-radius: var(--r-md);
  padding: 8px 16px; text-align: center; min-width: 68px;
}
      .pt-stat .pt-num { font-family: var(--font-display); font-size: 1.15rem; font-weight: 700; color: var(--rose); line-height: 1; }
      .pt-stat .pt-label { font-size: .64rem; color: var(--muted); letter-spacing: .06em; text-transform: uppercase; margin-top: 3px; }

      .new-msg-btn {
        display: inline-flex; align-items: center; gap: 7px; padding: 10px 18px;
        background: linear-gradient(135deg, var(--rose), var(--rose-dk));
        color: #fff; border-radius: var(--r-sm); font-size: .82rem; font-weight: 700;
        text-decoration: none; font-family: var(--font-body);
        box-shadow: 0 6px 18px rgba(139,74,90,.24); transition: box-shadow .18s;
      }
      .new-msg-btn:hover { box-shadow: 0 8px 22px rgba(139,74,90,.3); color: #fff; }

      .messages-card {
        background: var(--cream); border-radius: var(--r-xl);
        box-shadow: var(--shadow-md, 0 6px 20px rgba(139,74,90,.1)); border: 1.5px solid var(--border);
        overflow: hidden;
      }
    .card-header {
  padding: 18px 24px; border-bottom: 1.5px solid var(--border);
  display: flex; align-items: center; justify-content: space-between; gap: 12px;
  background: linear-gradient(135deg, var(--rose-lt), #fdf2f5);
}
      .card-header-title {
        font-family: var(--font-display); font-size: 1.05rem; font-weight: 700; color: var(--rose);
        display: flex; align-items: center; gap: 9px;
      }

      .empty-state { text-align: center; padding: 60px 24px; }
      .empty-icon {
        width: 72px; height: 72px; border-radius: 50%;
        background: var(--rose-lt); display: flex; align-items: center; justify-content: center;
        font-size: 1.8rem; color: var(--muted); margin: 0 auto 18px;
      }
      .empty-state h3 { font-family: var(--font-display); font-size: 1.1rem; color: var(--text); margin-bottom: 8px; }
      .empty-state p { font-size: .85rem; color: var(--muted); margin-bottom: 20px; }

      .msg-table { width: 100%; border-collapse: collapse; }
.msg-table thead tr { background: linear-gradient(135deg, var(--rose-lt), #fdf2f5); }
      .msg-table th {
        padding: 13px 20px; text-align: left; font-size: .68rem; font-weight: 800;
        letter-spacing: .1em; text-transform: uppercase; color: var(--muted);
      }
      .msg-table tbody tr { border-top: 1px solid var(--border); cursor: pointer; transition: background .15s; }
      .msg-table tbody tr:hover { background: var(--rose-lt); }
      .msg-table td { padding: 16px 20px; vertical-align: middle; }

      .subject-cell strong { display: block; font-size: .88rem; font-weight: 700; color: var(--text); margin-bottom: 3px; }
      .subject-cell .ticket-no { font-size: .68rem; font-weight: 700; color: var(--rose); letter-spacing: .04em; margin-right: 6px; }
      .subject-cell span.preview { font-size: .75rem; color: var(--muted); }

      .badge { display: inline-flex; align-items: center; gap: 5px; font-size: .7rem; font-weight: 700; padding: 5px 12px; border-radius: 20px; letter-spacing: .04em; }
      .badge-open        { background: #fce8ed; color: #c0394f; }
      .badge-in_progress { background: #e8f0fe; color: #3367d6; }
      .badge-resolved    { background: #fff8e1; color: #b9840a; }
      .badge-closed      { background: #eee; color: #888; }

      .date-cell { font-size: .8rem; color: var(--muted); font-weight: 600; }

      .view-btn {
        display: inline-flex; align-items: center; gap: 6px; padding: 7px 16px;
        background: #fff; color: var(--rose); border-radius: var(--r-sm); font-size: .78rem; font-weight: 700;
        text-decoration: none; border: 1.5px solid var(--border); transition: all .2s; font-family: var(--font-body);
      }
      .view-btn:hover { background: var(--rose); color: #fff; border-color: var(--rose); }
@media (max-width: 600px) {
        .msg-table th:nth-child(3), .msg-table td:nth-child(3) { display: none; }
      }

      .pagination-wrap {
        display: flex; justify-content: center; align-items: center; gap: 6px;
        margin-top: 24px; flex-wrap: wrap;
      }
      .pg-btn {
        min-width: 36px; height: 36px; border-radius: 50%;
        border: 1.5px solid var(--border); background: #fff; color: var(--rose);
        font-size: .85rem; font-weight: 700; font-family: var(--font-body);
        display: flex; align-items: center; justify-content: center;
        transition: background .18s, border-color .18s, color .18s, box-shadow .18s;
        cursor: pointer; padding: 0 4px;
      }
      .pg-btn:hover:not(.disabled) { background: var(--rose-lt); border-color: var(--rose); }
      .pg-btn.active {
        background: linear-gradient(135deg, var(--rose), var(--rose-dk));
        border-color: var(--rose); color: #fff; box-shadow: 0 3px 10px rgba(139,74,90,.30);
      }
      .pg-btn.disabled { opacity: .35; pointer-events: none; cursor: default; }
      .pg-info { font-size: .8rem; color: var(--muted); font-family: var(--font-body); white-space: nowrap; margin-left: 6px; }
    </style>

    <%
      const badgeMap = {
        open:        { cls: 'badge-open',        icon: 'fa-circle-exclamation', label: 'Open' },
        in_progress: { cls: 'badge-in_progress', icon: 'fa-comments',           label: 'In Progress' },
        resolved:    { cls: 'badge-resolved',    icon: 'fa-check-circle',       label: 'Resolved' },
        closed:      { cls: 'badge-closed',      icon: 'fa-lock',               label: 'Closed' },
      };
      const activeCount = messages.filter(m => m.status === 'open' || m.status === 'in_progress').length;
      const resolvedCount = messages.filter(m => m.status === 'resolved').length;
    %>

    <div class="page-topbar">
      <h2>My Messages</h2>
      <div class="page-topbar-stats">
        <div class="pt-stat"><div class="pt-num"><%= messages.length %></div><div class="pt-label">Total</div></div>
        <div class="pt-stat"><div class="pt-num"><%= activeCount %></div><div class="pt-label">Active</div></div>
        <div class="pt-stat"><div class="pt-num"><%= resolvedCount %></div><div class="pt-label">Resolved</div></div>
      </div>
    </div>

    <div class="messages-card">
      <div class="card-header">
        <div class="card-header-title"><i class="fas fa-inbox"></i> Your Tickets</div>
        <a href="/contact-us" class="new-msg-btn spa-link"><i class="fas fa-plus"></i> New Ticket</a>
      </div>
      <% if (messages.length === 0) { %>
        <div class="empty-state">
          <div class="empty-icon"><i class="fas fa-inbox"></i></div>
          <h3>No tickets yet</h3>
          <p>Have a question or a custom cake order in mind?</p>
          <a href="/contact-us" class="new-msg-btn spa-link">
            <i class="fas fa-paper-plane"></i> Send your first message
          </a>
        </div>
      <% } else { %>
        <table class="msg-table">
          <thead>
            <tr>
              <th>Subject</th>
              <th>Status</th>
              <th>Last Activity</th>
              <th style="text-align:center;">Action</th>
            </tr>
          </thead>
          <tbody>
            <% messages.forEach(msg => {
              const firstMsg = msg.messages && msg.messages.length ? msg.messages[0].text : '';
              const b = badgeMap[msg.status] || badgeMap.open;
            %>
<tr class="spa-link msg-row" data-href="/my-messages/<%= msg._id %>" onclick="window.location='/my-messages/<%= msg._id %>'">              <td class="subject-cell">
<strong style="display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
  <span class="ticket-no">#<%= msg.ticketNumber %></span>
  <%= msg.subject %>
  <% if (msg.unreadUserCount > 0) { %>
  <span style="
    background:#8B3A52;
    color:#fff;
    font-size:10px;
    font-weight:800;
    min-width:20px;
    height:20px;
    border-radius:99px;
    display:inline-flex;
    align-items:center;
    justify-content:center;
    padding:0 6px;
    line-height:1;
    flex-shrink:0;
    box-shadow:0 2px 6px rgba(139,58,82,.35);
  "><%= msg.unreadUserCount %></span>
  <% } %>
</strong>                <span class="preview"><%= firstMsg.length > 60 ? firstMsg.substring(0,60)+'…' : firstMsg %></span>
              </td>
              <td>
                <span class="badge <%= b.cls %>">
                  <i class="fas <%= b.icon %>"></i> <%= b.label %>
                </span>
              </td>
              <td class="date-cell">
                <%= new Date(msg.lastActivityAt || msg.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %>
              </td>
              <td style="text-align:center;" onclick="event.stopPropagation()">
                <a href="/my-messages/<%= msg._id %>" class="view-btn spa-link">
                  <i class="fas fa-eye"></i> View
                </a>
              </td>
            </tr>
            <% }) %>
          </tbody>
</table>
      <% } %>
    </div>

    <% if (totalPages > 1) { %>
      <div class="pagination-wrap">
        <a class="pg-btn <%= currentPage === 1 ? 'disabled' : '' %>"
           href="/my-messages?page=<%= currentPage - 1 %>">‹</a>

        <% for (let p = 1; p <= totalPages; p++) { %>
          <a class="pg-btn <%= currentPage === p ? 'active' : '' %>"
             href="/my-messages?page=<%= p %>"><%= p %></a>
        <% } %>

        <a class="pg-btn <%= currentPage === totalPages ? 'disabled' : '' %>"
           href="/my-messages?page=<%= currentPage + 1 %>">›</a>

        <span class="pg-info">Page <%= currentPage %> of <%= totalPages %></span>
      </div>
    <% } %>
  </main>
</div>

<%- include("../../views/partials/user/footer") %>
</body>
</html>
