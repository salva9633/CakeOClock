<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Profile – Cake O'Clock</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Lato:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <style>
    :root {
      --rose:    #8B4A5A;
      --rose-dk: #6e3547;
      --rose-lt: #fdf0f5;
      --blush:   #f3d7d3;
      --cream:   #fff8f9;
      --muted:   #a07085;
      --border:  #f0c4d4;
      --text:    #2d1520;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: linear-gradient(135deg, #f9e8ef 0%, #fdf5f8 50%, #f3e8f5 100%);
      font-family: 'Lato', sans-serif;
      min-height: 100vh;
    }

    /* ── PAGE WRAP ── */
    .page-wrap {
      max-width: 1180px;
      margin: 0 auto;
      padding: 32px 24px 60px;
      display: flex;
      gap: 28px;
      align-items: flex-start;
    }

    /* ── SIDEBAR ── */
    .dash-sidebar {
      width: 250px;
      min-width: 250px;
      flex-shrink: 0;
      animation: slideLeft .5s ease both;
    }

    @keyframes slideLeft {
      from { opacity: 0; transform: translateX(-24px); }
      to   { opacity: 1; transform: translateX(0); }
    }

    /* ── MAIN ── */
    .dash-main {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 24px;
      animation: slideUp .55s ease .1s both;
    }

    @keyframes slideUp {
      from { opacity: 0; transform: translateY(24px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── HERO CARD ── */
    .hero-card {
      background: linear-gradient(135deg, var(--rose) 0%, #c27090 50%, #d4889a 100%);
      border-radius: 24px;
      padding: 36px 48px;
      display: flex;
      align-items: center;
      gap: 36px;
      box-shadow: 0 16px 48px rgba(139,74,90,.22);
      position: relative;
      overflow: hidden;
    }

    .hero-card::before {
      content: '';
      position: absolute;
      top: -60px; right: -60px;
      width: 220px; height: 220px;
      border-radius: 50%;
      background: rgba(255,255,255,.08);
    }

    .hero-card::after {
      content: '';
      position: absolute;
      bottom: -40px; left: 30%;
      width: 160px; height: 160px;
      border-radius: 50%;
      background: rgba(255,255,255,.06);
    }

    /* Avatar in hero */
    .avatar-ring {
      width: 100px; height: 100px;
      border-radius: 50%;
      padding: 3px;
      background: rgba(255,255,255,.35);
      flex-shrink: 0;
      box-shadow: 0 8px 28px rgba(0,0,0,.18);
      position: relative;
      z-index: 2;
      cursor: pointer;
    }

    .avatar-inner {
      width: 100%; height: 100%;
      border-radius: 50%;
      overflow: hidden;
      background: var(--blush);
      border: 3px solid rgba(255,255,255,.8);
      position: relative;
    }

    .avatar-inner img {
      width: 100%; height: 100%;
      object-fit: cover;
      display: block;
    }

    /* Camera overlay on avatar */
    .avatar-overlay {
      position: absolute;
      inset: 0;
      border-radius: 50%;
      background: rgba(0,0,0,.38);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity .2s;
      color: #fff;
      font-size: .6rem;
      font-weight: 700;
      gap: 3px;
    }

    .avatar-ring:hover .avatar-overlay { opacity: 1; }

    .avatar-overlay i { font-size: 1.1rem; }

    .hero-info { position: relative; z-index: 2; }

    .hero-name {
      font-family: 'Playfair Display', serif;
      font-size: 1.8rem;
      font-weight: 700;
      color: #fff;
      line-height: 1.1;
      margin-bottom: 6px;
    }

    .hero-sub {
      font-size: .86rem;
      color: rgba(255,255,255,.75);
      margin-bottom: 14px;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(255,255,255,.18);
      border: 1px solid rgba(255,255,255,.28);
      color: #fff;
      font-size: .72rem;
      font-weight: 700;
      letter-spacing: .06em;
      padding: 5px 14px;
      border-radius: 50px;
      backdrop-filter: blur(6px);
    }

    /* ── FORM CARD ── */
    .form-card {
      background: #fff;
      border-radius: 22px;
      padding: 36px 40px;
      box-shadow: 0 4px 20px rgba(139,74,90,.08);
      border: 1px solid var(--border);
      animation: fadeCard .5s ease .25s both;
    }

    @keyframes fadeCard {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .card-title {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--rose);
      margin-bottom: 28px;
      padding-bottom: 14px;
      border-bottom: 2px solid var(--border);
      display: flex;
      align-items: center;
      gap: 10px;
    }

    /* ── FIELD GRID ── */
    .field-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-bottom: 28px;
    }

    .field-group {
      display: flex;
      flex-direction: column;
      gap: 7px;
    }

    .field-label {
      font-size: .7rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: .1em;
      color: var(--muted);
    }

    .field-input {
      background: var(--rose-lt);
      border: 1.5px solid var(--border);
      border-radius: 12px;
      padding: 13px 16px;
      font-size: .93rem;
      font-weight: 600;
      color: var(--text);
      font-family: 'Lato', sans-serif;
      outline: none;
      transition: border-color .2s, box-shadow .2s;
      width: 100%;
    }

    .field-input:focus {
      border-color: var(--rose);
      box-shadow: 0 0 0 3px rgba(139,74,90,.1);
    }

    .field-input[readonly] {
      opacity: .65;
      cursor: not-allowed;
    }

    .field-input.error {
      border-color: #c0392b;
      box-shadow: 0 0 0 3px rgba(192,57,43,.08);
    }

    /* Hidden file input */
    #profileImage { display: none; }

    /* Image error */
    .img-error-wrap {
      text-align: center;
      min-height: 18px;
      margin-top: -4px;
    }

    /* Error text */
    .error-text {
      color: #c0392b;
      font-size: .72rem;
      font-weight: 600;
      margin-top: 3px;
      display: none;
    }

    /* Google note */
    .google-note {
      margin-top: 20px;
      text-align: center;
      font-size: .82rem;
      color: var(--muted);
      background: var(--rose-lt);
      border-radius: 10px;
      padding: 10px 16px;
      border: 1px solid var(--border);
    }

    /* ── ACTION ROW ── */
    .action-row {
      display: flex;
      gap: 12px;
      margin-top: 4px;
    }

    .btn-primary-rose {
      flex: 1;
      background: linear-gradient(135deg, var(--rose) 0%, var(--rose-dk) 100%);
      color: #fff;
      border: none;
      border-radius: 14px;
      padding: 15px 24px;
      font-size: .92rem;
      font-weight: 700;
      font-family: 'Lato', sans-serif;
      cursor: pointer;
      box-shadow: 0 6px 20px rgba(139,74,90,.28);
      transition: transform .18s, box-shadow .18s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    .btn-primary-rose:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 28px rgba(139,74,90,.36);
    }

    .btn-outline-rose {
      flex: 1;
      background: transparent;
      color: var(--rose);
      border: 1.5px solid var(--border);
      border-radius: 14px;
      padding: 15px 24px;
      font-size: .92rem;
      font-weight: 700;
      font-family: 'Lato', sans-serif;
      cursor: pointer;
      transition: all .18s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      text-decoration: none;
    }

    .btn-outline-rose:hover {
      background: var(--rose-lt);
      border-color: var(--rose);
      transform: translateY(-2px);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 900px) {
      .page-wrap { flex-direction: column; padding: 16px; }
      .dash-sidebar { width: 100%; min-width: unset; }
      .hero-card { flex-direction: column; text-align: center; padding: 28px 20px; }
      .form-card { padding: 24px 20px; }
      .field-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 540px) {
      .action-row { flex-direction: column; }
    }
  </style>
</head>
<body>

<%- include("../../views/partials/user/h2") %>

<div class="page-wrap">

  <!-- ── SIDEBAR ── -->
  <aside class="dash-sidebar">
    <%- include("../../views/partials/user/sider") %>
  </aside>

  <!-- ── MAIN ── -->
  <main class="dash-main">

    <!-- HERO CARD — avatar clickable to change photo -->
    <div class="hero-card">
      <label for="profileImage" style="display:contents; cursor:pointer;">
        <div class="avatar-ring">
          <div class="avatar-inner">
            <img
              src="<%= user.authType === 'google' && user.googleImage
                      ? user.googleImage
                      : user.profileImage
                        ? user.profileImage
                        : 'https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcRa4dLHtaXEf7QlVZYYQSnAbAi_8RuuLEzps2qyfORSMg&s' %>"
              alt="Profile"
              id="avatarPreview"
            >
            <div class="avatar-overlay">
              <i class="fas fa-camera"></i>
              <span>Change</span>
            </div>
          </div>
        </div>
      </label>
      <div class="hero-info">
        <h1 class="hero-name"><%= user.name %></h1>
        <p class="hero-sub"><%= user.email %></p>
        <span class="hero-badge">
          <i class="fas fa-pen"></i>
          Editing Profile
        </span>
      </div>
      <div class="img-error-wrap" style="position:absolute;bottom:14px;left:50%;transform:translateX(-50%);white-space:nowrap;">
        <span class="error-text" id="imageError" style="color:#ffe0e0;"></span>
      </div>
    </div>

    <!-- FORM CARD -->
    <div class="form-card">
      <div class="card-title">
        <i class="fas fa-user-edit"></i>
        Personal Information
      </div>

      <form
        action="/editProfile"
        method="POST"
        enctype="multipart/form-data"
        id="editForm"
      >
        <!-- Hidden file input — triggered by avatar label above -->
        <input
          type="file"
          id="profileImage"
          name="profileImage"
          accept="image/*"
          onchange="previewImage(event)"
        >

        <div class="field-grid">

          <div class="field-group">
            <span class="field-label">Full Name</span>
            <input
              class="field-input"
              type="text"
              name="name"
              id="name"
              value="<%= user.name %>"
              placeholder="Your full name"
              maxlength="30"
            >
            <span class="error-text" id="nameError"></span>
          </div>

          <div class="field-group">
            <span class="field-label">Gender</span>
            <select class="field-input" name="gender" id="gender">
              <option value="">Select gender</option>
              <option value="male"   <%= user.gender === 'male'   ? 'selected' : '' %>>Male</option>
              <option value="female" <%= user.gender === 'female' ? 'selected' : '' %>>Female</option>
              <option value="other"  <%= user.gender === 'other'  ? 'selected' : '' %>>Other</option>
            </select>
            <span class="error-text" id="genderError"></span>
          </div>

          <div class="field-group">
            <span class="field-label">Email Address</span>
            <input
              class="field-input"
              type="email"
              name="email"
              id="email"
              value="<%= user.email %>"
              placeholder="your@email.com"
              <%= (user.authType === 'google' || !user.password) ? 'readonly' : '' %>
            >
            <span class="error-text" id="emailError"></span>
          </div>

          <div class="field-group">
            <span class="field-label">Phone Number</span>
            <input
              class="field-input"
              type="text"
              name="phone"
              id="phone"
              value="<%= user.phone || '' %>"
              placeholder="10-digit mobile number"
            >
            <span class="error-text" id="phoneError"></span>
          </div>

        </div>

        <!-- Actions -->
        <div class="action-row">
          <button type="submit" class="btn-primary-rose">
            <i class="fas fa-check"></i> Save Changes
          </button>
          <a href="/profile" class="btn-outline-rose">
            <i class="fas fa-arrow-left"></i> Back to Profile
          </a>
        </div>

        <% if (user.authType === 'google') { %>
          <p class="google-note">
            <i class="fab fa-google"></i>
            You signed in with Google. Email cannot be changed.
          </p>
        <% } %>

      </form>
    </div>

  </main>
</div>

<script>
/* ── IMAGE PREVIEW (unchanged logic) ── */
function previewImage(event) {
  const file       = event.target.files[0];
  const imageError = document.getElementById('imageError');

  imageError.innerText      = '';
  imageError.style.display  = 'none';

  if (!file) return;

  const allowedTypes = ['image/jpeg', 'image/png', 'image/jpg', 'image/webp'];
  const maxSize      = 2 * 1024 * 1024;

  if (!allowedTypes.includes(file.type)) {
    imageError.innerText     = 'Only JPG, PNG, JPEG, WEBP images are allowed';
    imageError.style.display = 'block';
    event.target.value       = '';
    return;
  }

  if (file.size > maxSize) {
    imageError.innerText     = 'Image size must be less than 2MB';
    imageError.style.display = 'block';
    event.target.value       = '';
    return;
  }

  const reader   = new FileReader();
  reader.onload  = e => { document.getElementById('avatarPreview').src = e.target.result; };
  reader.readAsDataURL(file);
}

/* ── FORM VALIDATION (unchanged logic) ── */
document.getElementById('editForm').addEventListener('submit', function (e) {
  let isValid = true;
  clearErrors();

  const name       = document.getElementById('name');
  const email      = document.getElementById('email');
  const phone      = document.getElementById('phone');
  const gender     = document.getElementById('gender');
  const imageInput = document.getElementById('profileImage');
  const imageError = document.getElementById('imageError');

  /* Name */
  const namePattern = /^[A-Za-z ]+$/;
  const trimmedNameVal = name.value.trim();
  if (trimmedNameVal === '') {
    showError(name, 'nameError', 'Name is required'); isValid = false;
  } else if (trimmedNameVal.length < 3) {
    showError(name, 'nameError', 'Name must be at least 3 characters'); isValid = false;
  } else if (trimmedNameVal.length > 30) {
    showError(name, 'nameError', 'Name cannot exceed 30 characters'); isValid = false;
  } else if (!namePattern.test(trimmedNameVal)) {
    showError(name, 'nameError', 'Name can contain only letters'); isValid = false;
  }

  /* Email */
  if (!email.hasAttribute('readonly')) {
    const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailPattern.test(email.value.trim())) {
      showError(email, 'emailError', 'Enter a valid email address'); isValid = false;
    }
  }

  /* Phone */
  if (phone.value.trim() !== '') {
    if (!/^[6-9]\d{9}$/.test(phone.value.trim())) {
      showError(phone, 'phoneError', 'Enter a valid 10-digit phone number'); isValid = false;
    }
  }

  /* Gender */
  if (gender.value === '') {
    showError(gender, 'genderError', 'Please select gender'); isValid = false;
  }

  /* Image (submit safety) */
  if (imageInput.files.length > 0) {
    const file         = imageInput.files[0];
    const allowedTypes = ['image/jpeg', 'image/png', 'image/jpg', 'image/webp'];
    const maxSize      = 2 * 1024 * 1024;
    if (!allowedTypes.includes(file.type)) {
      imageError.innerText     = 'Invalid image format';
      imageError.style.display = 'block';
      isValid = false;
    } else if (file.size > maxSize) {
      imageError.innerText     = 'Image size must be less than 2MB';
      imageError.style.display = 'block';
      isValid = false;
    }
  }

  if (!isValid) e.preventDefault();
});

function showError(input, errorId, message) {
  input.classList.add('error');
  const err      = document.getElementById(errorId);
  err.innerText  = message;
  err.style.display = 'block';
}

function clearErrors() {
  document.querySelectorAll('.error-text').forEach(e => {
    e.innerText = ''; e.style.display = 'none';
  });
  document.querySelectorAll('.field-input').forEach(el => el.classList.remove('error'));
}
</script>

</body>
</html>
