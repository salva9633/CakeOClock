<%- include('../partials/user/header') %>
<%- include('../partials/user/navbar') %>

<!-- ============================================================
     CAKE O'CLOCK — ABOUT US
     Tokens:
     --blush:#FDF1F4  --cream:#FFF9F7  --rosegold:#C97B84
     --choco:#3B1F29  --beige:#F6E8E3  --gold:#D9A857
     Display: 'Playfair Display'   Body: 'Poppins'
     Signature element: the "piped border" — a scalloped buttercream
     edge (SVG) separates every major section, echoing the way a
     cake decorator finishes a layer.
============================================================= -->

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
  :root{
    --blush:#FDF1F4;
    --cream:#FFF9F7;
    --rosegold:#C97B84;
    --choco:#3B1F29;
    --beige:#F6E8E3;
    --gold:#D9A857;
  }

  .coc-about{ background:var(--cream); color:var(--choco); overflow:hidden; }
  .coc-about *{ box-sizing:border-box; }
  .coc-about h1,.coc-about h2,.coc-about h3,.coc-about .font-display{
    font-family:'Playfair Display',serif; font-weight:600; letter-spacing:-0.01em;
  }
  .coc-about, .coc-about p, .coc-about span, .coc-about a, .coc-about button{
    font-family:'Poppins',sans-serif;
  }
  .coc-wrap{ max-width:1180px; margin:0 auto; padding:0 28px; }

  /* ---------- scroll reveal ---------- */
  .coc-reveal{ opacity:0; transform:translateY(28px); transition:opacity .9s cubic-bezier(.2,.7,.2,1), transform .9s cubic-bezier(.2,.7,.2,1); }
  .coc-reveal.is-in{ opacity:1; transform:translateY(0); }

  /* ---------- piped scallop divider (signature) ---------- */
  .coc-scallop{ display:block; width:100%; height:34px; margin-top:-1px; }

  /* ============ HERO ============ */
  .coc-hero{
    position:relative; padding:120px 0 90px; background:
      radial-gradient(60% 50% at 85% 10%, rgba(201,123,132,.18), transparent 60%),
      radial-gradient(50% 45% at 5% 90%, rgba(217,168,87,.16), transparent 60%),
      var(--blush);
  }
  .coc-hero-grid{ display:grid; grid-template-columns:1.05fr .95fr; gap:60px; align-items:center; }
  .coc-eyebrow{
    display:inline-flex; align-items:center; gap:8px; font-size:.74rem; letter-spacing:.22em;
    font-weight:600; color:var(--rosegold); text-transform:uppercase; margin-bottom:18px;
  }
  .coc-eyebrow svg{ width:14px; height:14px; }
  .coc-hero h1{ font-size:clamp(2.4rem,4.6vw,3.6rem); line-height:1.08; color:var(--choco); margin:0 0 22px; }
  .coc-hero h1 em{ font-style:italic; color:var(--rosegold); }
  .coc-hero p.sub{ font-size:1.05rem; line-height:1.8; color:#7a5a62; max-width:480px; margin-bottom:34px; }

  .coc-btn{
    position:relative; display:inline-flex; align-items:center; gap:10px;
    background:var(--choco); color:#fff; padding:16px 36px; border-radius:50px;
    text-decoration:none; font-weight:500; font-size:.95rem; letter-spacing:.02em;
    overflow:hidden; isolation:isolate; transition:transform .35s ease, box-shadow .35s ease;
    box-shadow:0 12px 30px rgba(59,31,41,.22);
  }
  .coc-btn::before{
    content:""; position:absolute; inset:0; z-index:-1; transform:scaleX(0); transform-origin:left;
    background:var(--rosegold); transition:transform .45s cubic-bezier(.2,.7,.2,1);
  }
  .coc-btn:hover::before{ transform:scaleX(1); }
  .coc-btn:hover{ transform:translateY(-3px); box-shadow:0 18px 36px rgba(201,123,132,.35); }

  .coc-hero-art{ position:relative; }
  .coc-hero-frame{
    position:relative; border-radius:30px; overflow:hidden; transform:rotate(2.5deg);
    box-shadow:0 30px 80px rgba(59,31,41,.22); border:6px solid #fff;
  }
  .coc-hero-frame img{ width:100%; display:block; aspect-ratio:4/4.6; object-fit:cover; }
  .coc-glow{ position:absolute; width:340px; height:340px; border-radius:50%; filter:blur(60px); background:rgba(201,123,132,.35); top:-40px; right:10%; z-index:-1; }
  .coc-badge{
    position:absolute; left:-26px; bottom:36px; background:rgba(255,255,255,.75); backdrop-filter:blur(10px);
    border:1px solid rgba(255,255,255,.6); border-radius:18px; padding:14px 20px; box-shadow:0 14px 34px rgba(59,31,41,.15);
    font-size:.8rem; font-weight:600; color:var(--choco); display:flex; align-items:center; gap:8px;
    animation:coc-float 5s ease-in-out infinite;
  }
  .coc-float-icon{
    position:absolute; font-size:1.8rem; filter:drop-shadow(0 6px 10px rgba(0,0,0,.12));
    animation:coc-float 6s ease-in-out infinite;
  }
  .coc-float-icon.f1{ top:6%; left:-8%; animation-delay:.2s; }
  .coc-float-icon.f2{ bottom:8%; right:-6%; font-size:2.1rem; animation-delay:1.4s; }
  .coc-float-icon.f3{ top:46%; right:-10%; font-size:1.5rem; animation-delay:.8s; }
  @keyframes coc-float{ 0%,100%{ transform:translateY(0);} 50%{ transform:translateY(-14px);} }

  @media (prefers-reduced-motion: reduce){
    .coc-badge, .coc-float-icon{ animation:none; }
    .coc-reveal{ transition:none; opacity:1; transform:none; }
  }

  /* ============ STORY ============ */
  .coc-story{ padding:110px 0; background:var(--cream); }
  .coc-story-grid{ display:grid; grid-template-columns:.85fr 1.15fr; gap:70px; align-items:center; }
  .coc-story-img{ border-radius:26px; overflow:hidden; box-shadow:0 24px 60px rgba(59,31,41,.14); }
  .coc-story-img img{ width:100%; display:block; aspect-ratio:3/3.4; object-fit:cover; }
  .coc-story h2{ font-size:clamp(1.9rem,3vw,2.6rem); margin:0 0 18px; color:var(--choco); }
  .coc-story p.lead{ color:#7a5a62; line-height:1.85; margin-bottom:40px; max-width:520px; }

  .coc-timeline{ position:relative; padding-left:30px; }
  .coc-timeline::before{ content:""; position:absolute; left:6px; top:6px; bottom:6px; width:2px; background:var(--rosegold); }
  .coc-tl-item{ position:relative; padding-bottom:34px; }
  .coc-tl-item:last-child{ padding-bottom:0; }
  .coc-tl-item::before{
    content:""; position:absolute; left:-30px; top:4px; width:13px; height:13px; border-radius:50%;
    background:var(--rosegold); border:3px solid var(--cream); box-shadow:0 0 0 2px var(--rosegold);
  }
  .coc-tl-year{ font-family:'Playfair Display',serif; font-weight:700; color:var(--rosegold); font-size:1.05rem; margin-bottom:4px; }
  .coc-tl-text{ color:#5c4047; font-size:.96rem; }

  /* ============ WHY CHOOSE US ============ */
  .coc-why{ padding:100px 0; background:var(--beige); position:relative; }
  .coc-section-head{ text-align:center; max-width:560px; margin:0 auto 56px; }
  .coc-section-head .coc-eyebrow{ justify-content:center; }
  .coc-section-head h2{ font-size:clamp(1.9rem,3vw,2.5rem); }

  .coc-cards4{ display:grid; grid-template-columns:repeat(4,1fr); gap:24px; }
  .coc-card{
    background:rgba(255,255,255,.55); backdrop-filter:blur(14px); border:1px solid rgba(255,255,255,.7);
    border-radius:25px; padding:34px 26px; text-align:center; box-shadow:0 14px 34px rgba(59,31,41,.08);
    transition:transform .4s cubic-bezier(.2,.7,.2,1), box-shadow .4s ease, background .4s ease;
  }
  .coc-card:hover{ transform:translateY(-10px); box-shadow:0 26px 50px rgba(59,31,41,.16); background:rgba(255,255,255,.85); }
  .coc-card .ic{
    width:62px; height:62px; margin:0 auto 18px; border-radius:50%; display:flex; align-items:center; justify-content:center;
    font-size:1.6rem; background:var(--rosegold); color:#fff;
  }
  .coc-card h3{ font-size:1rem; margin:0 0 8px; color:var(--choco); }
  .coc-card p{ font-size:.86rem; color:#806369; line-height:1.7; margin:0; }

  /* ============ STATS ============ */
  .coc-stats{ padding:90px 0; background:var(--choco); color:#fff; position:relative; }
  .coc-stats::before{
    content:""; position:absolute; inset:0; background:radial-gradient(50% 80% at 50% 0%, rgba(201,123,132,.18), transparent 70%);
  }
  .coc-stats-grid{ position:relative; display:grid; grid-template-columns:repeat(4,1fr); gap:20px; text-align:center; }
  .coc-stat-num{ font-family:'Playfair Display',serif; font-weight:700; font-size:clamp(2.1rem,3.6vw,2.8rem); color:var(--gold); }
  .coc-stat-label{ font-size:.84rem; letter-spacing:.04em; color:rgba(255,255,255,.7); margin-top:6px; }

  /* ============ BAKERS ============ */
  .coc-bakers{ padding:100px 0; background:var(--cream); }
  .coc-baker-grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:32px; }
  .coc-baker{ text-align:center; }
  .coc-baker .photo{
    width:140px; height:140px; border-radius:50%; margin:0 auto 18px; overflow:hidden;
    border:5px solid #fff; box-shadow:0 16px 34px rgba(59,31,41,.16);
  }
  .coc-baker .photo img{ width:100%; height:100%; object-fit:cover; }
  .coc-baker h3{ font-size:1.1rem; margin:0 0 2px; color:var(--choco); }
  .coc-baker .role{ font-size:.8rem; color:var(--rosegold); font-weight:600; letter-spacing:.05em; text-transform:uppercase; margin-bottom:12px; }
  .coc-baker .quote{ font-style:italic; color:#806369; font-size:.92rem; max-width:240px; margin:0 auto; line-height:1.7; }

  /* ============ TESTIMONIALS ============ */
  .coc-testi{ padding:100px 0; background:var(--beige); }
  .coc-testi-track{ display:grid; grid-template-columns:repeat(3,1fr); gap:24px; }
  .coc-testi-card{
    background:#fff; border-radius:22px; padding:30px; box-shadow:0 14px 34px rgba(59,31,41,.08);
  }
  .coc-stars{ color:var(--gold); font-size:.9rem; margin-bottom:14px; letter-spacing:2px; }
  .coc-testi-card p{ color:#5c4047; font-size:.92rem; line-height:1.8; margin-bottom:20px; }
  .coc-testi-person{ display:flex; align-items:center; gap:12px; }
  .coc-testi-person img{ width:42px; height:42px; border-radius:50%; object-fit:cover; }
  .coc-testi-person .name{ font-weight:600; font-size:.88rem; color:var(--choco); }
  .coc-testi-person .loc{ font-size:.76rem; color:#a4878d; }

  /* ============ GALLERY ============ */
  .coc-gallery{ padding:100px 0; background:var(--cream); }
  .coc-masonry{ column-count:3; column-gap:18px; }
  .coc-masonry .g-item{ break-inside:avoid; margin-bottom:18px; border-radius:18px; overflow:hidden; box-shadow:0 10px 26px rgba(59,31,41,.1); }
  .coc-masonry .g-item img{ width:100%; display:block; transition:transform .6s ease; }
  .coc-masonry .g-item:hover img{ transform:scale(1.08); }

  /* ============ FINAL CTA ============ */
  .coc-final{ position:relative; background:var(--choco); padding:110px 0; text-align:center; overflow:hidden; }
  .coc-final::before{ content:""; position:absolute; inset:0; background:radial-gradient(55% 70% at 50% 100%, rgba(217,168,87,.18), transparent 70%); }
  .coc-final h2{ position:relative; color:#fff; font-size:clamp(2rem,4vw,3rem); margin:0 0 18px; }
  .coc-final p{ position:relative; color:rgba(255,255,255,.65); margin-bottom:36px; }
  .coc-final .coc-btn{ position:relative; background:var(--rosegold); }
  .coc-final .coc-btn::before{ background:#fff; }
  .coc-final .coc-btn:hover{ color:var(--choco); }
  .coc-final-icon{ position:absolute; font-size:2.2rem; opacity:.5; animation:coc-float 7s ease-in-out infinite; }
  .coc-final-icon.fi1{ top:14%; left:8%; }
  .coc-final-icon.fi2{ bottom:16%; right:10%; animation-delay:1.6s; }

  @media (max-width: 900px){
    .coc-hero-grid, .coc-story-grid{ grid-template-columns:1fr; }
    .coc-hero-art{ order:-1; max-width:380px; margin:0 auto; }
    .coc-cards4{ grid-template-columns:repeat(2,1fr); }
    .coc-stats-grid{ grid-template-columns:repeat(2,1fr); row-gap:30px; }
    .coc-baker-grid, .coc-testi-track{ grid-template-columns:1fr; }
    .coc-masonry{ column-count:2; }
    .coc-badge{ left:6px; }
  }
</style>

