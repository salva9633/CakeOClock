<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Edit Address – Cake O'Clock</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Lato:wght@400;600;700&display=swap" rel="stylesheet">
  <%- include("../partials/user/dashboardStyles") %>
</head>
<body>

<%- include("../partials/user/h2") %>

<div class="page-wrap">

  <aside class="dash-sidebar">
    <%- include("../partials/user/sider") %>
  </aside>

  <main class="dash-main" id="dashMain">

    <div class="form-header">
<div class="form-header-icon"><i class="fa-solid fa-pen-to-square" style="color:var(--rose)"></i></div>      <div>
        <h1>Edit Address</h1>
        <p>Update your delivery details below</p>
      </div>
    </div>

    <div class="form-card">
      <form action="/address/edit/<%= address._id %>?redirect=<%= locals.redirect || '/address' %>" method="POST" class="form-grid">

        <div class="field-group">
          <label>Full Name</label>
          <input type="text" id="name" name="name" class="field-input"
                 placeholder="Enter your name" value="<%= address.name %>">
          <span class="error-text" id="nameError"></span>
        </div>

        <div class="field-group">
          <label>Mobile Number</label>
          <input type="tel" id="phone" name="phone" class="field-input"
                 placeholder="10-digit number" value="<%= address.phone %>">
          <span class="error-text" id="phoneError"></span>
        </div>

        <div class="field-group">
          <label>Pincode</label>
          <input type="text" id="pincode" name="pincode" class="field-input"
                 placeholder="6-digit pincode" value="<%= address.pincode %>">
          <span class="error-text" id="pincodeError"></span>
        </div>

        <div class="field-group">
          <label>Locality / Street</label>
          <input type="text" id="street" name="street" class="field-input"
                 placeholder="Area, street, sector" value="<%= address.street %>">
          <span class="error-text" id="streetError"></span>
        </div>

       <div class="field-group full-col">
  <label>Full Address</label>
  <textarea id="address" name="address" class="field-input"
            placeholder="House no., Building, Floor, etc."><%= address.address || '' %></textarea>
  <span class="error-text" id="addressError"></span>
</div>

        <div class="field-group">
          <label>City / District / Town</label>
          <input type="text" id="city" name="city" class="field-input"
                 placeholder="Your city" value="<%= address.city %>">
          <span class="error-text" id="cityError"></span>
        </div>

        <div class="field-group">
          <label>State</label>
          <input type="text" id="state" name="state" class="field-input"
                 placeholder="Your state" value="<%= address.state %>">
          <span class="error-text" id="stateError"></span>
        </div>

        <div class="field-group">
          <label>Landmark <span style="color:var(--muted);font-weight:400">(Optional)</span></label>
          <input type="text" name="landmark" class="field-input"
                 placeholder="Near school, temple, etc." value="<%= address.landmark || '' %>">
        </div>

        <div class="field-group">
          <label>Alternate Phone <span style="color:var(--muted);font-weight:400">(Optional)</span></label>
          <input type="tel" name="altPhone" class="field-input"
                 placeholder="Alternate number" value="<%= address.altPhone || '' %>">
        </div>

        <div class="full-col">
          <span class="type-label">Address Type</span>
          <div class="type-options">
           <% [
  ['HOME','<i class="fa-solid fa-house" style="color:var(--rose)"></i>','Home'],
  ['WORK','<i class="fa-solid fa-briefcase" style="color:var(--rose)"></i>','Work'],
  ['FAMILY','<i class="fa-solid fa-people-roof" style="color:var(--rose)"></i>','Family'],
  ['FRIEND','<i class="fa-solid fa-handshake" style="color:var(--rose)"></i>','Friend']
].forEach(([val,icon,lbl]) => { %>
<div class="type-option">
  <input type="radio" name="type" value="<%= val %>"
         id="type-<%= val %>" <%= address.type === val ? 'checked' : '' %>>
  <label for="type-<%= val %>"><span><%- icon %></span> <%= lbl %></label>
</div>
<% }) %>
          </div>
        </div>

        <div class="form-actions full-col">
          <a href="<%= locals.redirect || '/address' %>" class="btn-cancel spa-link">
            <i class="fas fa-arrow-left" style="margin-right:6px;font-size:.8rem"></i> Cancel
          </a>
          <button type="submit" class="btn-save">
            <i class="fas fa-check" style="margin-right:6px"></i> Update Address
          </button>
        </div>

      </form>
    </div>

    <script>
const fields = {
        name:    { id:'name',    error:'nameError',    regex:/^[A-Za-z ]{3,}$/,  msg:'Min 3 letters'           },
        phone:   { id:'phone',   error:'phoneError',   regex:/^[6-9][0-9]{9}$/,  msg:'Invalid phone number'    },
        pincode: { id:'pincode', error:'pincodeError', regex:/^[1-9][0-9]{5}$/,  msg:'Enter a valid 6-digit pincode' },
        street:  { id:'street',  error:'streetError',  regex:/^.{3,}$/,           msg:'Required'                },
        address: { id:'address', error:'addressError', regex:/^.{10,}$/,         msg:'Enter a complete address (min 10 characters)' },
        city:    { id:'city',    error:'cityError',    regex:/^[A-Za-z ]{2,}$/,  msg:'Invalid city'            },
        state:   { id:'state',   error:'stateError',   regex:/^[A-Za-z ]{2,}$/,  msg:'Invalid state'           }
      };

      function validate(field) {
        const input = document.getElementById(field.id);
        const error = document.getElementById(field.error);
        const value = input.value.trim();

        if (field.id === 'pincode' && /^(\d)\1{5}$/.test(value)) {
          input.classList.add('error'); input.classList.remove('success');
          error.textContent = 'Pincode cannot be all the same digit';
          return false;
        }

        const ok = field.regex.test(value);
        input.classList.toggle('error',   !ok);
        input.classList.toggle('success',  ok);
        error.textContent = ok ? '' : field.msg;
        return ok;
      }

      Object.values(fields).forEach(f =>
        document.getElementById(f.id).addEventListener('input', () => validate(f))
      );

      Object.values(fields).forEach(f => validate(f));

      document.querySelector('#dashMain form').addEventListener('submit', function (e) {
        const ok = Object.values(fields).map(validate).every(Boolean);
        if (!ok) {
          e.preventDefault();
        } else {
          document.querySelector('.btn-save').classList.add('saving');
        }
      });
    </script>

  </main>
</div>

</body>
</html>
