<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Edit Address – Cake O'Clock</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/css/cake.css">
  <style>
    body { background: linear-gradient(135deg, #f5e0dd 0%, #fdf3ef 100%); }

    .address-shell {
      max-width: 860px;
      margin: 36px auto 60px;
      background: #fff;
      border-radius: var(--r-xl);
      box-shadow: var(--shadow-lg);
      overflow: hidden;
      animation: fadeUp .45s ease both;
    }

    .address-header {
      background: linear-gradient(135deg, var(--caramel) 0%, #a37a45 100%);
      padding: 32px 44px;
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .address-header-icon {
      width: 52px; height: 52px;
      background: rgba(255,255,255,.2);
      border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.4rem;
    }
    .address-header h1 {
      font-family: var(--font-display);
      font-size: 1.8rem;
      font-weight: 700;
      color: #fff;
      margin: 0;
    }
    .address-header p { font-size: .82rem; color: rgba(255,255,255,.8); margin: 3px 0 0; }

    .address-body { padding: 44px; }

    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; }
    .full-col { grid-column: 1 / -1; }

    .field-group { display: flex; flex-direction: column; gap: 7px; }
    .field-group label {
      font-size: .72rem; font-weight: 700; letter-spacing: .10em;
      text-transform: uppercase; color: var(--brown-lt);
    }
    .field-input {
      width: 100%; background: var(--rose-lt);
      border: 1.5px solid transparent; border-radius: var(--r-sm);
      padding: 13px 16px; font-family: var(--font-body);
      font-size: .92rem; color: var(--brown); outline: none;
      transition: border-color .2s, background .2s, box-shadow .2s;
    }
    .field-input::placeholder { color: var(--muted); opacity: .7; }
    .field-input:focus {
      background: #fff; border-color: var(--rose-mid);
      box-shadow: 0 0 0 4px rgba(175,84,84,.09);
    }
    .field-input.error { border-color: #e05555 !important; }
    .field-input.success { border-color: #4caf50 !important; }
    textarea.field-input { resize: none; min-height: 100px; }
    .error-text { font-size: .74rem; color: #e05555; }

    .type-section { margin-top: 8px; }
    .type-label {
      font-size: .72rem; font-weight: 700; letter-spacing: .10em;
      text-transform: uppercase; color: var(--brown-lt); margin-bottom: 12px; display: block;
    }
    .type-options { display: flex; gap: 10px; flex-wrap: wrap; }
    .type-option { position: relative; }
    .type-option input[type="radio"] { display: none; }
    .type-option label {
      display: flex; align-items: center; gap: 7px;
      padding: 9px 18px; border: 1.5px solid var(--border);
      border-radius: 50px; font-size: .83rem; font-weight: 600;
      color: var(--muted); cursor: pointer; transition: all .2s;
    }
    .type-option label:hover { border-color: var(--rose-mid); color: var(--rose); }
    .type-option input:checked + label { border-color: var(--rose); background: var(--rose-lt); color: var(--rose); }
    .type-option label span { font-size: 1rem; }

    .form-actions {
      display: flex; justify-content: flex-end; gap: 12px;
      margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--border);
    }
    .btn-cancel {
      padding: 12px 26px; background: #f5f0f0; color: var(--muted);
      border: none; border-radius: 50px; font-family: var(--font-body);
      font-size: .88rem; font-weight: 600; cursor: pointer; transition: background .2s;
      text-decoration: none; display: inline-flex; align-items: center;
    }
    .btn-cancel:hover { background: #ede8e8; }
    .btn-save {
      padding: 12px 32px;
      background: linear-gradient(135deg, var(--rose) 0%, var(--rose-dk) 100%);
      color: #fff; border: none; border-radius: 50px;
      font-family: var(--font-body); font-size: .88rem; font-weight: 700;
      cursor: pointer; transition: transform .18s, box-shadow .18s;
      box-shadow: 0 6px 20px rgba(175,84,84,.28);
    }
    .btn-save:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(175,84,84,.36); }

    @media (max-width: 640px) {
      .address-shell { margin: 0; border-radius: 0; }
      .address-header { padding: 24px 20px; }
      .address-body { padding: 24px 20px; }
      .form-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<%- include("../../views/partials/user/h2") %>

<div class="address-shell">
  <div class="address-header">
    <div class="address-header-icon">✏️</div>
    <div>
      <h1>Edit Address</h1>
      <p>Update your delivery details</p>
    </div>
  </div>

  <div class="address-body">
    <form action="/address/edit/<%= address._id %>?redirect=<%= locals.redirect || '/address' %>" method="POST" class="form-grid">

      <div class="field-group">
        <label>Full Name</label>
        <input type="text" id="name" name="name" class="field-input" value="<%= address.name %>">
        <span class="error-text" id="nameError"></span>
      </div>
      <div class="field-group">
        <label>Mobile Number</label>
        <input type="tel" id="phone" name="phone" class="field-input" value="<%= address.phone %>">
        <span class="error-text" id="phoneError"></span>
      </div>
      <div class="field-group">
        <label>Pincode</label>
        <input type="text" id="pincode" name="pincode" class="field-input" value="<%= address.pincode %>">
        <span class="error-text" id="pincodeError"></span>
      </div>
      <div class="field-group">
        <label>Locality / Street</label>
        <input type="text" id="street" name="street" class="field-input" value="<%= address.street %>">
        <span class="error-text" id="streetError"></span>
      </div>
      <div class="field-group full-col">
        <label>Full Address</label>
        <textarea name="address" class="field-input"><%= address.address || "" %></textarea>
      </div>
      <div class="field-group">
        <label>City / District</label>
        <input type="text" id="city" name="city" class="field-input" value="<%= address.city %>">
        <span class="error-text" id="cityError"></span>
      </div>
      <div class="field-group">
        <label>State</label>
        <input type="text" id="state" name="state" class="field-input" value="<%= address.state %>">
        <span class="error-text" id="stateError"></span>
      </div>
      <div class="field-group">
        <label>Landmark <span style="color:var(--muted);font-weight:400">(Optional)</span></label>
        <input type="text" name="landmark" class="field-input" value="<%= address.landmark || '' %>">
      </div>
      <div class="field-group">
        <label>Alternate Phone <span style="color:var(--muted);font-weight:400">(Optional)</span></label>
        <input type="tel" name="altPhone" class="field-input" value="<%= address.altPhone || '' %>">
      </div>

      <div class="full-col type-section">
        <span class="type-label">Address Type</span>
        <div class="type-options">
          <% [['HOME','🏠','Home'],['WORK','💼','Work'],['FAMILY','👨‍👩‍👧','Family'],['FRIEND','🤝','Friend']].forEach(([val,icon,label]) => { %>
          <div class="type-option">
            <input type="radio" name="type" value="<%= val %>" id="type-<%= val %>" <%= address.type === val ? 'checked' : '' %>>
            <label for="type-<%= val %>"><span><%= icon %></span> <%= label %></label>
          </div>
          <% }) %>
        </div>
      </div>

      <div class="form-actions full-col">
        <a href="<%= locals.redirect || '/address' %>" class="btn-cancel">Cancel</a>
        <button type="submit" class="btn-save">Update Address</button>
      </div>
    </form>
  </div>
</div>

<script>
  const fields = {
    name:    { id:"name",    error:"nameError",    regex:/^[A-Za-z ]{3,}$/, msg:"Min 3 letters" },
    phone:   { id:"phone",   error:"phoneError",   regex:/^[6-9][0-9]{9}$/, msg:"Invalid phone" },
    pincode: { id:"pincode", error:"pincodeError", regex:/^[0-9]{6}$/, msg:"6-digit pincode required" },
    street:  { id:"street",  error:"streetError",  regex:/^.{3,}$/, msg:"Required" },
    city:    { id:"city",    error:"cityError",    regex:/^[A-Za-z ]{2,}$/, msg:"Invalid city" },
    state:   { id:"state",   error:"stateError",   regex:/^[A-Za-z ]{2,}$/, msg:"Invalid state" }
  };
  function validate(field) {
    const input = document.getElementById(field.id);
    const error = document.getElementById(field.error);
    if (!field.regex.test(input.value.trim())) {
      input.classList.add("error"); input.classList.remove("success");
      error.textContent = field.msg; return false;
    } else {
      input.classList.remove("error"); input.classList.add("success");
      error.textContent = ""; return true;
    }
  }
  Object.values(fields).forEach(f => {
    document.getElementById(f.id).addEventListener("input", () => validate(f));
  });
  window.onload = () => Object.values(fields).forEach(f => validate(f));
</script>
</body>
</html>
