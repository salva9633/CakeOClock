<%- include("../../views/partials/user/header") %>
<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
<style>
@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,700&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&family=Dancing+Script:wght@700&display=swap');

:root {
  --rose:       #C97B8A;
  --rose-dk:    #A85F6E;
  --rose-lt:    #FAE8ED;
  --blush:      #FDF0F3;
  --petal:      #FBE4EC;
  --lavender:   #F0E8F8;
  --mint:       #E8F6F0;
  --peach:      #FEF0E8;
  --cream:      #FDF8F5;
  --warm-white: #FFFCFA;
  --caramel:    #D4A574;
  --brown:      #5C3A3A;
  --brown-lt:   #8A6060;
  --muted:      #B08A8A;
  --border:     #F5D8E0;
  --burgundy:   #8B4A5A;
  --white:      #FFFFFF;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--blush);
  color: var(--brown);
  overflow-x: hidden;
}

a { text-decoration: none; color: inherit; }
img { display: block; }


/* ══════════════════════════════════════
   HERO — Soft Pink Split
══════════════════════════════════════ */
.hero {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 90vh;
  overflow: hidden;
  background: var(--blush);
}

.hero-left {
  background: linear-gradient(145deg, #FAE0E8 0%, #F5C8D8 40%, #FBDDE8 100%);
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 80px 72px;
  position: relative;
  overflow: hidden;
}
.hero-left::before {
  content: '';
  position: absolute;
  top: -100px; right: -100px;
  width: 380px; height: 380px;
  border-radius: 50%;
  background: rgba(255,255,255,.35);
}
.hero-left::after {
  content: '';
  position: absolute;
  bottom: -60px; left: -60px;
  width: 240px; height: 240px;
  border-radius: 50%;
  background: rgba(212,165,116,.12);
}

.hero-eyebrow {
  font-size: .72rem;
  font-weight: 700;
  letter-spacing: .20em;
  text-transform: uppercase;
  color: var(--rose-dk);
  margin-bottom: 20px;
  opacity: 0;
  animation: heroUp .6s ease .1s forwards;
}

.hero-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(2.8rem, 5.5vw, 5rem);
  font-weight: 700;
  color: var(--brown);
  line-height: 1.08;
  margin-bottom: 14px;
  opacity: 0;
  animation: heroUp .6s ease .2s forwards;
}
.hero-title em {
  font-style: italic;
  color: var(--rose-dk);
}

.hero-subtitle {
  font-size: .98rem;
  color: var(--brown-lt);
  line-height: 1.75;
  margin-bottom: 40px;
  max-width: 380px;
  opacity: 0;
  animation: heroUp .6s ease .3s forwards;
}

.hero-actions {
  display: flex;
  gap: 14px;
  align-items: center;
  flex-wrap: wrap;
  opacity: 0;
  animation: heroUp .6s ease .4s forwards;
}

.btn-hero-primary {
  padding: 15px 34px;
  background: linear-gradient(135deg, var(--rose-dk) 0%, #8B4A5A 100%);
  color: #fff;
  border: none;
  border-radius: 50px;
  font-family: 'DM Sans', sans-serif;
  font-size: .9rem;
  font-weight: 700;
  letter-spacing: .05em;
  cursor: pointer;
  box-shadow: 0 8px 28px rgba(168,95,110,.35);
  transition: transform .2s, box-shadow .2s;
  display: inline-flex;
  align-items: center;
  gap: 8px;
}
.btn-hero-primary:hover {
  transform: translateY(-3px);
  box-shadow: 0 14px 36px rgba(168,95,110,.45);
  color: #fff;
}

.btn-hero-ghost {
  padding: 13px 26px;
  border: 1.5px solid rgba(92,58,58,.25);
  color: var(--brown-lt);
  border-radius: 50px;
  font-size: .88rem;
  font-weight: 600;
  transition: border-color .2s, color .2s, background .2s;
  background: rgba(255,255,255,.5);
}
.btn-hero-ghost:hover {
  border-color: var(--rose-dk);
  color: var(--rose-dk);
  background: rgba(255,255,255,.8);
}

.hero-trust {
  margin-top: 52px;
  display: flex;
  gap: 32px;
  align-items: center;
  opacity: 0;
  animation: heroUp .6s ease .5s forwards;
}
.trust-item { text-align: center; }
.trust-number {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2rem;
  font-weight: 700;
  color: var(--rose-dk);
  line-height: 1;
}
.trust-label {
  font-size: .68rem;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--muted);
  margin-top: 4px;
}
.trust-divider {
  width: 1px;
  height: 36px;
  background: rgba(168,95,110,.2);
}

/* Hero Right — Mosaic */
.hero-right {
  display: grid;
  grid-template-rows: 1fr 1fr;
  grid-template-columns: 1fr 1fr;
  gap: 6px;
  position: relative;
  background: var(--petal);
}
.hero-img-cell { overflow: hidden; position: relative; }
.hero-img-cell img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform .6s ease;
}
.hero-img-cell:hover img { transform: scale(1.06); }
.hero-img-cell.tall { grid-row: 1 / 3; }

.hero-badge {
  position: absolute;
  bottom: 28px; right: 28px;
  background: var(--white);
  border-radius: 18px;
  padding: 14px 20px;
  box-shadow: 0 8px 32px rgba(168,95,110,.18);
  display: flex;
  align-items: center;
  gap: 12px;
  z-index: 10;
  animation: badgePop .5s cubic-bezier(.34,1.56,.64,1) .8s both;
  border: 1px solid var(--border);
}
.badge-icon { font-size: 1.5rem; }
.badge-text-top { font-size: .68rem; color: var(--muted); letter-spacing: .06em; text-transform: uppercase; }
.badge-text-bottom { font-size: .88rem; font-weight: 700; color: var(--brown); margin-top: 2px; }

@keyframes heroUp {
  from { opacity: 0; transform: translateY(24px); }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes badgePop {
  from { opacity: 0; transform: scale(.7); }
  to   { opacity: 1; transform: scale(1); }
}

/* ══════════════════════════════════════
   MARQUEE STRIP — Soft Rose
══════════════════════════════════════ */
.marquee-strip {
  background: linear-gradient(90deg, var(--rose-dk) 0%, #BE6E7E 50%, var(--rose-dk) 100%);
  padding: 14px 0;
  overflow: hidden;
  white-space: nowrap;
}
.marquee-inner {
  display: inline-flex;
  animation: marquee 24s linear infinite;
}
.marquee-item {
  display: inline-flex;
  align-items: center;
  gap: 14px;
  padding: 0 28px;
  font-size: .72rem;
  font-weight: 700;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: rgba(255,255,255,.92);
}
.marquee-dot {
  width: 4px; height: 4px;
  border-radius: 50%;
  background: rgba(255,255,255,.5);
  flex-shrink: 0;
}
@keyframes marquee {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}

/* ══════════════════════════════════════
   ABOUT — Warm Pastel
══════════════════════════════════════ */
.about-section {
  padding: 110px 0;
  background: var(--warm-white);
}
.about-inner {
  max-width: 1180px;
  margin: 0 auto;
  padding: 0 60px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}
.about-eyebrow {
  font-size: .72rem;
  font-weight: 700;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: var(--rose-dk);
  margin-bottom: 18px;
}
.about-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(2.2rem, 3.5vw, 3.5rem);
  font-weight: 700;
  color: var(--brown);
  line-height: 1.15;
  margin-bottom: 24px;
}
.about-title em { font-style: italic; color: var(--rose-dk); }
.about-body {
  font-size: .96rem;
  line-height: 1.85;
  color: var(--muted);
  margin-bottom: 32px;
}
.about-features {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}
.about-feat {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: .86rem;
  font-weight: 600;
  color: var(--brown);
  padding: 10px 14px;
  background: var(--rose-lt);
  border-radius: 10px;
}
.feat-icon { font-size: 1rem; }

.about-img-stack { position: relative; padding-bottom: 32px; }
.about-img-main {
  border-radius: 28px;
  overflow: hidden;
  aspect-ratio: 4/5;
  box-shadow: 0 20px 60px rgba(168,95,110,.18);
}
.about-img-main img { width: 100%; height: 100%; object-fit: cover; }
.about-img-float {
  position: absolute;
  bottom: 0; left: -36px;
  width: 180px;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 12px 36px rgba(0,0,0,.15);
  border: 4px solid var(--white);
}
.about-img-float img { width: 100%; height: 130px; object-fit: cover; }

/* ══════════════════════════════════════
   CATEGORIES — Cream Pastel
══════════════════════════════════════ */
.categories-section {
  padding: 110px 0;
  background: var(--cream);
  position: relative;
  overflow: hidden;
}
.categories-section::before {
  content: '';
  position: absolute;
  top: -100px; right: -100px;
  width: 400px; height: 400px;
  border-radius: 50%;
  background: rgba(240,232,248,.6);
  pointer-events: none;
}
.categories-section::after {
  content: '';
  position: absolute;
  bottom: -80px; left: -80px;
  width: 300px; height: 300px;
  border-radius: 50%;
  background: rgba(232,246,240,.6);
  pointer-events: none;
}

.section-header {
  text-align: center;
  margin-bottom: 64px;
  position: relative;
  z-index: 2;
}
.section-eyebrow {
  font-size: .7rem;
  font-weight: 700;
  letter-spacing: .20em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 14px;
}
.section-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(2rem, 4vw, 3.2rem);
  font-weight: 700;
  color: var(--brown);
}
.section-title em { font-style: italic; color: var(--rose-dk); }

.categories-grid {
  max-width: 960px;
  margin: 0 auto;
  padding: 0 40px;
  display: flex;
  justify-content: center;
  gap: 44px;
  flex-wrap: wrap;
  position: relative;
  z-index: 2;
}

.category-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
  cursor: pointer;
  opacity: 0;
  transform: translateY(28px);
  transition: opacity .5s ease, transform .5s ease;
}
.category-card.visible { opacity: 1; transform: translateY(0); }
.category-card:hover { transform: translateY(-10px) !important; }

.cat-ring {
  width: 136px; height: 136px;
  border-radius: 50%;
  padding: 4px;
  background: linear-gradient(135deg, #F5C0CC 0%, #E8A8B8 50%, #D4A574 100%);
  box-shadow: 0 8px 30px rgba(201,123,138,.25);
  transition: box-shadow .3s, transform .3s;
}
.category-card:hover .cat-ring {
  box-shadow: 0 18px 48px rgba(201,123,138,.40);
}
.cat-ring img {
  width: 100%; height: 100%;
  border-radius: 50%;
  object-fit: cover;
  border: 3px solid var(--white);
}
.cat-name {
  font-size: .7rem;
  font-weight: 800;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--brown-lt);
  transition: color .2s;
}
.category-card:hover .cat-name { color: var(--rose-dk); }

/* ══════════════════════════════════════
   PROMO CAROUSEL — Pastel Pink
══════════════════════════════════════ */
.promo-section {
  padding: 80px 60px;
  background: var(--blush);
}
.promo-carousel-wrap {
  max-width: 1180px;
  margin: 0 auto;
  position: relative;
}
#promoCarousel .carousel-inner { border-radius: 28px; overflow: hidden; }

.promo-slide {
  min-height: 380px;
  display: flex;
  align-items: center;
}
.promo-slide-1 {
  background: linear-gradient(135deg, #FCE4EF 0%, #F8CEDD 100%);
}
.promo-slide-2 {
  background: linear-gradient(135deg, #FCEEE4 0%, #F8D8C4 100%);
}

.promo-content { flex: 1; padding: 60px 64px; }

.promo-tag {
  display: inline-block;
  background: var(--rose-dk);
  color: #fff;
  font-size: .68rem;
  font-weight: 800;
  letter-spacing: .14em;
  text-transform: uppercase;
  padding: 6px 18px;
  border-radius: 50px;
  margin-bottom: 22px;
}
.promo-tag-peach {
  background: var(--caramel);
}

.promo-heading {
  font-family: 'Cormorant Garamond', serif;
  font-size: 3rem;
  font-weight: 700;
  color: var(--brown);
  line-height: 1.1;
  margin-bottom: 16px;
}
.promo-body {
  font-size: .92rem;
  color: var(--muted);
  line-height: 1.65;
  margin-bottom: 30px;
  max-width: 320px;
}
.btn-promo {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 30px;
  background: var(--rose-dk);
  color: #fff;
  border: none;
  border-radius: 50px;
  font-family: 'DM Sans', sans-serif;
  font-size: .9rem;
  font-weight: 700;
  cursor: pointer;
  transition: transform .18s, box-shadow .18s;
  box-shadow: 0 6px 20px rgba(168,95,110,.3);
  text-decoration: none;
}
.btn-promo:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 30px rgba(168,95,110,.42);
  color: #fff;
}
.btn-promo-caramel { background: var(--caramel); box-shadow: 0 6px 20px rgba(212,165,116,.35); }
.btn-promo-caramel:hover { box-shadow: 0 10px 30px rgba(212,165,116,.45); color: #fff; }

.promo-img-side {
  width: 420px;
  flex-shrink: 0;
  padding: 28px 36px 28px 0;
}
.promo-img-card {
  border-radius: 22px;
  overflow: hidden;
  box-shadow: 0 12px 44px rgba(168,95,110,.14);
  aspect-ratio: 4/3;
  background: var(--white);
  border: 1px solid rgba(245,216,224,.5);
}
.promo-img-card img,
.promo-img-card video {
  width: 100%; height: 100%;
  object-fit: cover;
}

/* Carousel controls */
.carousel-control-prev,
.carousel-control-next {
  width: 48px; height: 48px;
  background: var(--white) !important;
  border-radius: 50%;
  top: 50%; transform: translateY(-50%);
  box-shadow: 0 4px 18px rgba(168,95,110,.18);
  opacity: 1 !important;
  transition: transform .2s, box-shadow .2s;
  border: 1px solid var(--border) !important;
}
.carousel-control-prev { left: -24px; }
.carousel-control-next { right: -24px; }
.carousel-control-prev:hover,
.carousel-control-next:hover {
  transform: translateY(-50%) scale(1.1);
  box-shadow: 0 8px 26px rgba(168,95,110,.28);
}
.carousel-control-prev-icon,
.carousel-control-next-icon {
  filter: invert(0.35) sepia(1) saturate(3) hue-rotate(300deg);
  width: 16px; height: 16px;
}

/* ══════════════════════════════════════
   GALLERY — Pastel Lavender / Dusty Rose
══════════════════════════════════════ */
.gallery-section {
  background: linear-gradient(145deg, #F5E8F2 0%, #EDE0F0 35%, #F2E0E8 70%, #F0E8F5 100%);
  padding: 100px 60px;
  position: relative;
  overflow: hidden;
}
.gallery-section::before {
  content: '';
  position: absolute;
  top: -100px; left: -100px;
  width: 400px; height: 400px;
  border-radius: 50%;
  background: rgba(255,255,255,.25);
  pointer-events: none;
}
.gallery-section::after {
  content: '';
  position: absolute;
  bottom: -80px; right: -80px;
  width: 320px; height: 320px;
  border-radius: 50%;
  background: rgba(255,220,235,.2);
  pointer-events: none;
}

.gallery-header {
  text-align: center;
  margin-bottom: 52px;
  position: relative;
  z-index: 2;
}
.gallery-eyebrow {
  font-size: .68rem;
  font-weight: 700;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--rose-dk);
  opacity: .75;
  margin-bottom: 14px;
}
.gallery-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: clamp(2rem, 4vw, 3.2rem);
  font-weight: 700;
  color: var(--brown);
  line-height: 1.1;
}
.gallery-title em { font-style: italic; color: var(--rose-dk); }

.gallery-carousel-wrap {
  max-width: 1180px;
  margin: 0 auto;
  position: relative;
  z-index: 2;
}
#cakeGallery .carousel-inner { border-radius: 24px; overflow: hidden; }

.gallery-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
}
.gallery-item {
  border-radius: 20px;
  overflow: hidden;
  aspect-ratio: 3/4;
  position: relative;
  cursor: pointer;
  box-shadow: 0 6px 24px rgba(168,95,110,.12);
}
.gallery-item img {
  width: 100%; height: 100%;
  object-fit: cover;
  transition: transform .5s ease;
}
.gallery-item:hover img { transform: scale(1.08); }
.gallery-item-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(139,74,90,.35) 0%, transparent 55%);
  opacity: 0;
  transition: opacity .3s;
  border-radius: 20px;
}
.gallery-item:hover .gallery-item-overlay { opacity: 1; }

/* Gallery carousel controls */
#cakeGallery .carousel-control-prev,
#cakeGallery .carousel-control-next {
  background: rgba(255,255,255,.7) !important;
  backdrop-filter: blur(8px);
  border: 1px solid rgba(245,216,224,.8) !important;
  box-shadow: 0 4px 16px rgba(168,95,110,.15);
}

/* ══════════════════════════════════════
   FEATURES STRIP
══════════════════════════════════════ */
.features-strip {
  background: var(--warm-white);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  padding: 50px 60px;
}
.features-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32px;
}
.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 14px;
}
.feature-icon-wrap {
width: 80px;
  height: 80px;
    border-radius: 20px;
  background: var(--rose-lt);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.6rem;
  box-shadow: 0 4px 16px rgba(201,123,138,.15);
  transition: transform .2s, box-shadow .2s;
}
.feature-icon-wrap i{
  font-size:32px;
  color:#C97B8A;
}
.feature-item:hover .feature-icon-wrap {
  transform: translateY(-4px);
  box-shadow: 0 10px 28px rgba(201,123,138,.25);
}
.feature-label {
  font-size: .88rem;
  font-weight: 700;
  color: var(--brown);
}
.feature-desc {
  font-size: .78rem;
  color: var(--muted);
  line-height: 1.5;
  margin-top: -4px;
}

/* ══════════════════════════════════════
   SCROLL REVEAL
══════════════════════════════════════ */
.reveal {
  opacity: 0;
  transform: translateY(40px);
  transition: opacity .7s ease, transform .7s ease;
}
.reveal.visible { opacity: 1; transform: translateY(0); }

/* ══════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════ */
@media (max-width: 1024px) {
  .hero { grid-template-columns: 1fr; min-height: auto; }
  .hero-left { padding: 64px 36px; }
  .hero-right { height: 50vw; }
  .about-inner { grid-template-columns: 1fr; gap: 48px; padding: 0 28px; }
  .about-img-float { display: none; }
  .promo-slide { flex-direction: column; }
  .promo-img-side { width: 100%; padding: 0 32px 32px; }
  .features-inner { grid-template-columns: repeat(2, 1fr); }
  .gallery-section { padding: 70px 24px; }
  .promo-section { padding: 60px 24px; }
}
@media (max-width: 640px) {
  .hero-right { display: none; }
  .hero-left { min-height: 80vh; }
  .categories-grid { gap: 20px; }
  .cat-ring { width: 100px; height: 100px; }
  .gallery-grid { grid-template-columns: repeat(2, 1fr); gap: 8px; }
  .promo-content { padding: 32px 24px; }
  .promo-heading { font-size: 2rem; }
  .features-inner { grid-template-columns: repeat(2, 1fr); gap: 20px; }
  .about-section { padding: 70px 0; }
  .about-inner { padding: 0 20px; }
  .features-strip { padding: 40px 20px; }
}
</style>

<body>

<%- include("../../views/partials/user/navbar") %>



<!-- ══════════════════════════════════════
     HERO
══════════════════════════════════════ -->
<section class="hero">

  <div class="hero-left">
    <div class="hero-eyebrow">✦ Handcrafted with love · Est. 2020</div>
    <h1 class="hero-title">
      Every Moment<br>Deserves <em>Sweet</em><br>Perfection
    </h1>
    <p class="hero-subtitle">
