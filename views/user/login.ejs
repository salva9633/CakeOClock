<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Login - Cake O Clock</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

      body, html {
    height: 100%; width: 100%;
    font-family: 'Outfit', sans-serif;
    overflow: hidden;
}

        .background-wrapper {
            position: fixed;
            top: 0; left: 0;
            width: 100vw; height: 100vh;
            overflow: hidden;
            z-index: -2;
        }

        .background-image {
            width: 100%; height: 100%;
            object-fit: cover;
            object-position: center;
        }

        .blur-overlay {
            position: fixed;
            top: 0; left: 0;
            width: 100vw; height: 100vh;
            background: rgba(255, 200, 200, 0.25);
            backdrop-filter: blur(5px);
            -webkit-backdrop-filter: blur(5px);
            z-index: -1;
        }

        .login-container {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
            position: relative;
            z-index: 1;
        }

     .login-card {
    background: rgba(253, 240, 243, 0.25);
    backdrop-filter: blur(30px);
    -webkit-backdrop-filter: blur(30px);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 28px;
    padding: 28px 36px 24px;
    width: 100%;
    max-width: 400px;
    box-shadow: 0 24px 60px rgba(0,0,0,0.3),
                inset 0 1px 0 rgba(255,255,255,0.05);
    animation: cardIn 0.7s cubic-bezier(0.22,1,0.36,1) both;
}

        @keyframes cardIn {
            from { opacity: 0; transform: translateY(28px) scale(0.97); }
            to   { opacity: 1; transform: translateY(0) scale(1); }
        }

        .logo-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 12px;
    animation: fadeDown 0.6s 0.1s cubic-bezier(0.22,1,0.36,1) both;
}

.logo-icon {
    width: 130px;
    height: 130px;
    background: transparent;
    border-radius: 0;
    box-shadow: none;
    display: flex;
    align-items: center;
    justify-content: center;
}
.logo-icon img {
    width: 100%;
    height: auto;
    object-fit: contain;
}

        .logo-icon svg {
            width: 24px; height: 24px;
            fill: none;
            stroke: rgba(255,255,255,0.9);
            stroke-width: 1.8;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .brand-heading {
    text-align: center;
    margin-bottom: 4px;
    animation: fadeDown 0.6s 0.15s cubic-bezier(0.22,1,0.36,1) both;
}

.brand-heading h1 {
    font-family: 'Playfair Display', serif;
    font-size: 26px;
            font-weight: 700;
            color: #8B3A52;
            letter-spacing: -0.5px;
            line-height: 1;
        }

        .brand-heading h1 span { color: #d4748a; font-style: italic; }

        .brand-sub {
            font-size: 12px;
            color: rgba(139,58,82,0.7);
            letter-spacing: 0.5px;
            text-align: center;
            margin-bottom: 14px;
            animation: fadeDown 0.6s 0.18s cubic-bezier(0.22,1,0.36,1) both;
        }

        .divider {
             display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 14px;
            animation: fadeDown 0.6s 0.2s cubic-bezier(0.22,1,0.36,1) both;
        }

        .divider-line { flex: 1; height: 1px; background: rgba(255,255,255,0.1); }

        .divider-text {
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 2.5px;
            color: rgba(139,58,82,0.5);
        }

        .form-group {
             margin-bottom: 10px;
            animation: fadeDown 0.6s 0.25s cubic-bezier(0.22,1,0.36,1) both;
        }

        .form-group:nth-child(2) { animation-delay: 0.3s; }

        .form-label {
    display: block;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2px;
    color: rgba(139,58,82,0.8);
    margin-bottom: 6px;
            text-transform: uppercase;
        }

        .input-wrap {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-icon {
            position: absolute;
            left: 18px;
            width: 18px; height: 18px;
color: rgba(139,58,82,0.4);
            pointer-events: none;
            transition: color 0.3s;
        }

        .input-icon svg {
            width: 18px; height: 18px;
            fill: none;
            stroke: currentColor;
            stroke-width: 1.6;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .form-control {
            width: 100%;
  padding: 11px 18px 11px 44px;
               background: rgba(255,255,255,0.45);
    border: 1px solid rgba(139,58,82,0.2);
            border-radius: 50px;
            font-size: 14px;
            font-family: 'Outfit', sans-serif;
   color: #8B3A52;            outline: none;
            transition: all 0.3s ease;
        }

.form-control::placeholder { color: rgba(139,58,82,0.4); }
        .form-control:focus {
            background: rgba(255,255,255,0.1);
            border-color: rgba(212,116,138,0.55);
            box-shadow: 0 0 0 3px rgba(212,116,138,0.12);
        }

        .input-wrap:focus-within .input-icon { color: rgba(212,116,138,0.7); }

        .eye-toggle {
            position: absolute;
            right: 16px;
            background: none;
            border: none;
            cursor: pointer;
color: rgba(139,58,82,0.4);
            display: flex;
            align-items: center;
            padding: 4px;
            transition: color 0.2s;
        }

        .eye-toggle:hover { color: rgba(255,255,255,0.55); }

        .eye-toggle svg {
            width: 18px; height: 18px;
            fill: none;
            stroke: currentColor;
            stroke-width: 1.6;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .forgot-link {
            text-align: right;
            margin-top: -4px;
            margin-bottom: 4px;
        }

        .forgot-link a {
            font-size: 12px;
            color: rgba(212,116,138,0.8);
            text-decoration: none;
            transition: color 0.2s;
        }

        .forgot-link a:hover { color: #d4748a; }

        .btn-login {
    width: 100%;
    padding: 13px;
    background: linear-gradient(135deg, #b86878 0%, #7a2d3d 100%);
    border: none;
    border-radius: 50px;
    color: #fff;
    font-size: 15px;
    font-weight: 600;
    font-family: 'Outfit', sans-serif;
    cursor: pointer;
    margin-top: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: all 0.3s ease;
            box-shadow: 0 8px 28px rgba(100,30,45,0.5);
            letter-spacing: 0.3px;
            animation: fadeDown 0.6s 0.35s cubic-bezier(0.22,1,0.36,1) both;
        }

        .btn-login svg {
            width: 18px; height: 18px;
            fill: none;
            stroke: currentColor;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .btn-login:hover {
            background: linear-gradient(135deg, #ca8090 0%, #9b4a5a 100%);
            transform: translateY(-2px);
            box-shadow: 0 14px 36px rgba(139,58,74,0.5);
        }

        .btn-google {
            width: 100%;
            padding: 11px;
            background: rgba(255,255,255,0.5);
    border: 1.5px solid rgba(139,58,82,0.3);
            border-radius: 50px;
 color: #8B3A52;
             font-size: 14px;
            font-weight: 500;
            font-family: 'Outfit', sans-serif;
            cursor: pointer;
            margin-top: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: all 0.3s ease;
            text-decoration: none;
        }

        .btn-google:hover {
      background: rgba(139,58,82,0.1);
    color: #8B3A52;
            transform: translateY(-1px);
        }

        .btn-google img { width: 18px; height: 18px; }

        .divider-or {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 10px 0 0px;
        }

.divider-or .divider-line { flex: 1; height: 1px; background: rgba(139,58,82,0.2); }.divider-or span { font-size: 11px; color: rgba(139,58,82,0.5); letter-spacing: 1px; }

        .signup-link {
            text-align: center;
            margin-top: 10px;
            font-size: 13px;
color: rgba(139,58,82,0.6);
            animation: fadeDown 0.6s 0.4s cubic-bezier(0.22,1,0.36,1) both;
        }

        .signup-link a { color: #d4748a; text-decoration: none; font-weight: 600; }
        .signup-link a:hover { color: #e896aa; }

        .secure-note {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 7px;
            margin-top: 10px;
            font-size: 12px;
color: rgba(139,58,82,0.45);
        }

        .secure-note svg {
            width: 14px; height: 14px;
            fill: none;
            stroke: currentColor;
            stroke-width: 1.8;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

        .error-message {
            background: rgba(239,68,68,0.12);
            border: 1px solid rgba(239,68,68,0.3);
            color: #f87171;
            padding: 12px 18px;
            border-radius: 12px;
            font-size: 13px;
            margin-bottom: 20px;
            text-align: center;
            animation: shake 0.45s ease;
        }

        .error-text {
            color: #f87171;
            font-size: 0.75rem;
            margin-top: 6px;
            padding-left: 16px;
            display: none;
        }

        @keyframes shake {
            0%,100% { transform: translateX(0); }
            25%      { transform: translateX(-8px); }
            75%      { transform: translateX(8px); }
        }

        @keyframes fadeDown {
            from { opacity: 0; transform: translateY(-12px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        @media (max-width: 500px) {
            .login-card { padding: 40px 28px 36px; }
            .brand-heading h1 { font-size: 26px; }
        }
    </style>
</head>

<body>

<!-- Background -->
<div class="background-wrapper">
    <img src="https://res.cloudinary.com/dtfzp8rwt/image/upload/v1780680344/premium_photo-1680172800367-9d9437174856_eaulnr.avif" alt="Background" class="background-image">
</div>
<div class="blur-overlay"></div>

<div class="login-container">
    <div class="login-card">

       <div class="logo-wrap">
    <div class="logo-icon">
  <img     src="https://res.cloudinary.com/dtfzp8rwt/image/upload/v1780840131/WhatsApp_Image_2026-06-07_at_4.24.57_PM-removebg-preview_cmrltl.png"
 alt="Logo">
    </div>
</div>

        
        <p class="brand-sub">Welcome back! Please login to continue</p>

        <div class="divider">
            <div class="divider-line"></div>
            <span class="divider-text">SIGN IN TO CONTINUE</span>
            <div class="divider-line"></div>
        </div>

        <!-- Server error (EJS) — logic unchanged -->
        <% if (typeof error !== "undefined") { %>
            <div class="error-message"><%= error %></div>
        <% } %>

        <!-- ── FORM — action/method/fields unchanged ── -->
        <form id="loginForm" action="/login" method="POST">

            <div class="form-group">
                <label class="form-label">Email Address</label>
                <div class="input-wrap">
                    <span class="input-icon">
                        <svg viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/></svg>
                    </span>
                    <input type="email" id="email" name="email"
                        class="form-control"
                        placeholder="you@example.com"
                        required autocomplete="email">
                </div>
                <div id="emailError" class="error-text"></div>
            </div>

            <div class="form-group">
                <label class="form-label">Password</label>
                <div class="input-wrap">
                    <span class="input-icon">
                        <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    </span>
                    <input type="password" id="password" name="password"
                        class="form-control"
                        placeholder="Enter your password"
                        required autocomplete="current-password">
                    <button type="button" class="eye-toggle" id="eyeToggle">
                        <svg id="eyeIcon" viewBox="0 0 24 24">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                    </button>
                </div>
                <div id="passwordError" class="error-text"></div>
            </div>

            <!-- Forgot password — unchanged href -->
            <div class="forgot-link">
                <a href="/forgotPassword">Forgot password?</a>
            </div>

            <button type="submit" class="btn-login">
                <svg viewBox="0 0 24 24"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
                Login
            </button>
        </form>

        <!-- Google login — unchanged href -->
        <div class="divider-or">
            <div class="divider-line"></div>
            <span>OR</span>
            <div class="divider-line"></div>
        </div>

        <a href="/auth/google" class="btn-google">
            <img src="https://developers.google.com/identity/images/g-logo.png" alt="Google">
            Continue with Google
        </a>

        <div class="signup-link">
            Don't have an account? <a href="/signUp">Sign up</a>
        </div>

        <div class="secure-note">
            <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Secured with end-to-end encryption
        </div>

    </div>
</div>

<!-- ── SCRIPTS — validation logic completely unchanged ── -->
<script>
const form = document.getElementById("loginForm");

form.addEventListener("submit", function (e) {
    let valid = true;

    const email = document.getElementById("email");
    const password = document.getElementById("password");
    const emailError = document.getElementById("emailError");
    const passwordError = document.getElementById("passwordError");

    emailError.style.display = "none";
    passwordError.style.display = "none";

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    if (!email.value.trim()) {
        emailError.innerText = "Email is required";
        emailError.style.display = "block";
        valid = false;
    } else if (!emailRegex.test(email.value)) {
        emailError.innerText = "Invalid email format";
        emailError.style.display = "block";
        valid = false;
    }

    if (!password.value.trim()) {
        passwordError.innerText = "Password is required";
        passwordError.style.display = "block";
        valid = false;
    } else if (password.value.length < 6) {
        passwordError.innerText = "Password must be at least 6 characters";
        passwordError.style.display = "block";
        valid = false;
    }

    if (!valid) e.preventDefault();
});

// Eye toggle
const eyeToggle = document.getElementById('eyeToggle');
const passwordInput = document.getElementById('password');
const eyeIcon = document.getElementById('eyeIcon');

eyeToggle.addEventListener('click', () => {
    const isPassword = passwordInput.type === 'password';
    passwordInput.type = isPassword ? 'text' : 'password';
    eyeIcon.innerHTML = isPassword
        ? '<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>'
        : '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>';
});
</script>

</body>
</html>